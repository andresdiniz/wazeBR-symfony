APP_ENV=dev
APP_SECRET=change_me_to_a_random_32char_string

# -------------------------------------------------------------------------
# BANCO DE DADOS — MySQL local XAMPP
# Altere usuario/senha conforme sua instalação (root sem senha = padrao XAMPP)
# -------------------------------------------------------------------------
DATABASE_URL="mysql://root:@127.0.0.1:3306/wazebr?serverVersion=8.0&charset=utf8mb4"

# -------------------------------------------------------------------------
# MESSENGER — usa a própria conexao Doctrine (tabela messenger_messages)
# auto_setup=0 porque você cria a tabela via migration
# -------------------------------------------------------------------------
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# -------------------------------------------------------------------------
# MAILER
# -------------------------------------------------------------------------
MAILER_DSN=null://null

# -------------------------------------------------------------------------
# APLICAÇÃO
# -------------------------------------------------------------------------
APP_NAME=WazeBR
SENDER_EMAIL=noreply@wazebr.local
DEFAULT_URI=http://localhost
APP_SHARE_DIR=var/share

# -------------------------------------------------------------------------
# TOKEN API EXTERNA
# -------------------------------------------------------------------------
API_EXTERNA_TOKEN=mude_para_um_token_secreto_aqui

# -------------------------------------------------------------------------
# WAZE
# -------------------------------------------------------------------------
WAZE_API_URL=https://www.waze.com/row-rtserver/web/TGeoRSS
WAZE_API_KEY=
WAZE_BBOX=-44.1,-20.1,-43.8,-19.8

# -------------------------------------------------------------------------
# CEMADEN
# -------------------------------------------------------------------------
CEMADEN_API_URL=http://sjc.salvar.cemaden.gov.br/resources/graficos/interativo/getJson2.php
CEMADEN_API_KEY=
APP_ENV=dev
APP_DEBUG=true
