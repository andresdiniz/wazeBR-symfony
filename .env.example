###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_to_a_random_32char_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://wazebr:password@127.0.0.1:3306/wazebr?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost:1025
###< symfony/mailer ###

###> waze api ###
WAZE_API_URL=https://www.waze.com/row-rtserver/web/TGeoRSS
WAZE_API_KEY=your_waze_ccp_token
WAZE_BBOX=-20.0,-44.0,-19.5,-43.5
###< waze api ###

###> cemaden api ###
CEMADEN_API_URL=http://sjc.salvar.cemaden.gov.br/resources/graficos/interativo/getJson.php
CEMADEN_API_KEY=your_cemaden_api_key
###< cemaden api ###

###> app config ###
APP_NAME="WazePortalBR"
APP_SENDER_EMAIL=noreply@wazebr.local
APP_API_TOKEN=change_me_to_a_random_api_token
APP_EXPORT_PATH=%kernel.project_dir%/var/exports
###< app config ###
