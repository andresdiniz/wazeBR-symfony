<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Nova senha — WazeBR</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&display=swap" rel="stylesheet">
  <style>
    :root{--color-bg:#f7f6f2;--color-surface:#f9f8f5;--color-border:#d4d1ca;--color-text:#28251d;--color-text-muted:#7a7974;--color-primary:#01696f;--color-primary-hover:#0c4e54;--color-error:#a12c7b;--radius-md:.5rem;--radius-lg:.75rem;--space-2:.5rem;--space-3:.75rem;--space-4:1rem;--space-5:1.25rem;--space-8:2rem;--text-sm:clamp(.875rem,.8rem+.35vw,1rem);--font-body:'Inter',sans-serif;--shadow-lg:0 12px 32px oklch(.2 .01 80/.12);--transition:180ms cubic-bezier(.16,1,.3,1)}
    [data-theme="dark"]{--color-bg:#171614;--color-surface:#1c1b19;--color-border:#393836;--color-text:#cdccca;--color-primary:#4f98a3;--color-error:#d163a7}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{min-height:100dvh;font-family:var(--font-body);color:var(--color-text);background:var(--color-bg);display:flex;align-items:center;justify-content:center;padding:var(--space-8);-webkit-font-smoothing:antialiased}
    .card{width:100%;max-width:400px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);padding:var(--space-8)}
    h1{font-size:1.25rem;font-weight:700;margin-bottom:var(--space-4)}
    label{display:block;font-size:var(--text-sm);font-weight:500;margin-bottom:var(--space-2)}
    input{width:100%;padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-md);background:transparent;color:var(--color-text);font-size:var(--text-sm);font-family:inherit;transition:border-color var(--transition)}
    input:focus{outline:none;border-color:var(--color-primary);box-shadow:0 0 0 3px oklch(from var(--color-primary) l c h/.15)}
    .btn{display:block;width:100%;padding:var(--space-3);background:var(--color-primary);color:#fff;border:none;border-radius:var(--radius-md);font-size:var(--text-sm);font-weight:600;cursor:pointer;margin-top:var(--space-5)}
    .btn:hover{background:var(--color-primary-hover)}
    .error-msg{background:oklch(from var(--color-error) l c h/.08);color:var(--color-error);border:1px solid oklch(from var(--color-error) l c h/.2);border-radius:var(--radius-md);padding:var(--space-3);font-size:var(--text-sm);margin-bottom:var(--space-4)}
    .hint{font-size:var(--text-sm);color:var(--color-text-muted);margin-top:var(--space-2)}
  </style>
</head>
<body>
  <div class="card">
    <h1>Criar nova senha</h1>
    {% for msg in app.flashes('error') %}
      <div class="error-msg">{{ msg }}</div>
    {% endfor %}
    <form method="POST">
      <label for="password">Nova senha</label>
      <input type="password" id="password" name="password" required autofocus minlength="8" placeholder="Mínimo 8 caracteres">
      <p class="hint">Mínimo de 8 caracteres.</p>
      <button type="submit" class="btn">Salvar nova senha</button>
    </form>
  </div>
</body>
</html>
