{% extends 'base.html.twig' %}

{% block title %}Nível dos Rios — Ao Vivo{% endblock %}

{% block stylesheets %}
<style>
/* ── KPI status cards ── */
.hydro-kpis {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}
.hydro-kpi {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition);
}
.hydro-kpi:hover { box-shadow: var(--shadow-md); }
.hydro-kpi-icon  { font-size: 1.6rem; line-height: 1; margin-bottom: var(--space-2); }
.hydro-kpi-value {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 700;
  letter-spacing: -.03em;
  line-height: 1;
}
.hydro-kpi-label { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-1); }

.kpi-normal  .hydro-kpi-value { color: var(--color-success); }
.kpi-atencao .hydro-kpi-value { color: var(--color-gold); }
.kpi-alerta  .hydro-kpi-value { color: var(--color-warning); }
.kpi-transb  .hydro-kpi-value { color: var(--color-error); }

/* ── toolbar ── */
.hydro-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}
.hydro-toolbar-left h1 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -.02em; }
.hydro-toolbar-left small { font-size: var(--text-xs); color: var(--color-text-muted); }
.hydro-toolbar-right { display: flex; gap: var(--space-2); flex-wrap: wrap; }

/* ── live badge ── */
.live-badge {
  display: inline-flex; align-items: center; gap: var(--space-2);
  font-size: var(--text-xs); font-weight: 600;
  color: var(--color-success);
  background: oklch(from var(--color-success) l c h / .10);
  padding: 3px 10px; border-radius: var(--radius-full);
}
.live-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--color-success);
  animation: live-pulse 2s ease-in-out infinite;
}
@keyframes live-pulse {
  0%,100% { box-shadow: 0 0 0 0 oklch(from var(--color-success) l c h / .4); }
  50%      { box-shadow: 0 0 0 5px oklch(from var(--color-success) l c h / 0); }
}
@media(prefers-reduced-motion:reduce){ .live-dot { animation: none; } }

/* ── table rows por nível ── */
.row-atencao td         { background: oklch(from var(--color-gold)    l c h / .07); }
.row-alerta td          { background: oklch(from var(--color-warning)  l c h / .09); }
.row-transbordamento td { background: oklch(from var(--color-error)    l c h / .09); }
tr.row-atencao:hover td         { background: oklch(from var(--color-gold)   l c h / .14); }
tr.row-alerta:hover td          { background: oklch(from var(--color-warning) l c h / .16); }
tr.row-transbordamento:hover td { background: oklch(from var(--color-error)   l c h / .16); }

/* ── nível icon cell ── */
.level-icon { font-size: 1.25rem; line-height: 1; display: block; text-align: center; }

/* ── barra de progresso de nível ── */
.level-bar-wrap {
  margin-top: var(--space-1);
  height: 4px;
  background: var(--color-surface-offset);
  border-radius: var(--radius-full);
  overflow: hidden;
  width: 100%;
  min-width: 60px;
}
.level-bar {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width .5s ease;
}
.bar-normal  { background: var(--color-success); }
.bar-atencao { background: var(--color-gold); }
.bar-alerta  { background: var(--color-warning); }
.bar-transb  { background: var(--color-error); }

/* ── spinning refresh ── */
@keyframes spin { to { transform: rotate(360deg); } }
.spinning { animation: spin .7s linear infinite; }

/* ── empty ── */
.hydro-empty {
  padding: var(--space-16) var(--space-8);
  text-align: center;
  color: var(--color-text-muted);
}
.hydro-empty-icon { font-size: 3rem; margin-bottom: var(--space-4); }
.hydro-empty h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-2); }
</style>
{% endblock %}

{% block content %}

{# ── Toolbar ── #}
<div class="hydro-toolbar">
  <div class="hydro-toolbar-left">
    <h1>🌊 Nível dos Rios</h1>
    <small>
      <span class="live-badge"><span class="live-dot"></span> Ao vivo</span>
      &nbsp;atualiza a cada 60 s &nbsp;•&nbsp; última leitura: <span id="last-update">—</span>
    </small>
  </div>
  <div class="hydro-toolbar-right">
    <a href="{{ path('hydro_historico') }}" class="btn btn-ghost btn-sm">
      <i data-lucide="history" style="width:15px;height:15px"></i> Histórico
    </a>
    <button id="btn-refresh" class="btn btn-primary btn-sm">
      <i data-lucide="refresh-cw" id="refresh-icon" style="width:15px;height:15px"></i> Atualizar
    </button>
  </div>
</div>

{# ── KPI summary ── #}
{% set cnt_normal = 0 %}
{% set cnt_atencao = 0 %}
{% set cnt_alerta = 0 %}
{% set cnt_transb = 0 %}
{% for r in rows %}
  {% if r.alert_level == 'atencao' %}{% set cnt_atencao = cnt_atencao + 1 %}
  {% elseif r.alert_level == 'alerta' %}{% set cnt_alerta = cnt_alerta + 1 %}
  {% elseif r.alert_level == 'transbordamento' %}{% set cnt_transb = cnt_transb + 1 %}
  {% else %}{% set cnt_normal = cnt_normal + 1 %}
  {% endif %}
{% endfor %}

<div class="hydro-kpis" id="hydro-kpis">
  <div class="hydro-kpi kpi-normal">
    <div class="hydro-kpi-icon">✅</div>
    <div class="hydro-kpi-value" id="cnt-normal">{{ cnt_normal }}</div>
    <div class="hydro-kpi-label">Normal</div>
  </div>
  <div class="hydro-kpi kpi-atencao">
    <div class="hydro-kpi-icon">⚠️</div>
    <div class="hydro-kpi-value" id="cnt-atencao">{{ cnt_atencao }}</div>
    <div class="hydro-kpi-label">Atenção</div>
  </div>
  <div class="hydro-kpi kpi-alerta">
    <div class="hydro-kpi-icon">🚨</div>
    <div class="hydro-kpi-value" id="cnt-alerta">{{ cnt_alerta }}</div>
    <div class="hydro-kpi-label">Alerta</div>
  </div>
  <div class="hydro-kpi kpi-transb">
    <div class="hydro-kpi-icon">🌊</div>
    <div class="hydro-kpi-value" id="cnt-transb">{{ cnt_transb }}</div>
    <div class="hydro-kpi-label">Transbordamento</div>
  </div>
</div>

{# ── Tabela ── #}
<div class="card">
  <div class="card-header">
    <span class="card-title">Estações monitoradas</span>
    <span class="badge badge-gray" id="total-count">{{ rows|length }} estações</span>
  </div>
  <div class="table-wrap">
    <table id="hydro-table">
      <thead>
        <tr>
          <th style="width:44px"></th>
          <th>Estação</th>
          <th>Município / UF</th>
          <th style="text-align:right">Nível (m)</th>
          <th style="text-align:right">Atenção</th>
          <th style="text-align:right">Alerta</th>
          <th style="text-align:right">Transb.</th>
          <th>Medido em</th>
        </tr>
      </thead>
      <tbody id="hydro-tbody">
      {% for r in rows %}
        {% set rowCss = '' %}
        {% set icon   = '✅' %}
        {% set barCss = 'bar-normal' %}
        {% if r.alert_level == 'atencao' %}
          {% set rowCss = 'row-atencao' %}{% set icon = '⚠️' %}{% set barCss = 'bar-atencao' %}
        {% elseif r.alert_level == 'alerta' %}
          {% set rowCss = 'row-alerta' %}{% set icon = '🚨' %}{% set barCss = 'bar-alerta' %}
        {% elseif r.alert_level == 'transbordamento' %}
          {% set rowCss = 'row-transbordamento' %}{% set icon = '🌊' %}{% set barCss = 'bar-transb' %}
        {% endif %}
        {% set pct = 0 %}
        {% if r.cota_transbordamento is not null and r.water_level is not null and r.cota_transbordamento > 0 %}
          {% set pct_raw = ((r.water_level / r.cota_transbordamento) * 100)|round %}
          {% set pct = pct_raw > 100 ? 100 : pct_raw %}
        {% endif %}
        <tr class="{{ rowCss }}">
          <td><span class="level-icon" title="{{ r.alert_level|capitalize }}">{{ icon }}</span></td>
          <td>
            <div style="font-weight:600">{{ r.station_name }}</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ r.station_code }}</div>
          </td>
          <td style="white-space:nowrap">{{ r.municipality }} / {{ r.state }}</td>
          <td style="text-align:right">
            <div style="font-weight:700;font-variant-numeric:tabular-nums">
              {{ r.water_level is not null ? r.water_level|number_format(2,',','.') ~ ' m' : '—' }}
            </div>
            {% if pct > 0 %}
            <div class="level-bar-wrap">
              <div class="level-bar {{ barCss }}" style="width:{{ pct }}%"></div>
            </div>
            {% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {{ r.cota_atencao is not null ? r.cota_atencao|number_format(2,',','.') ~ ' m' : '—' }}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {{ r.cota_alerta is not null ? r.cota_alerta|number_format(2,',','.') ~ ' m' : '—' }}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {{ r.cota_transbordamento is not null ? r.cota_transbordamento|number_format(2,',','.') ~ ' m' : '—' }}
          </td>
          <td style="white-space:nowrap;font-size:var(--text-xs)">
            <time data-utc="{{ r.measured_at|date('Y-m-d H:i:s') }}" data-fmt="datetime">{{ r.measured_at|date('d/m H:i') }}</time>
          </td>
        </tr>
      {% else %}
        <tr id="empty-row">
          <td colspan="8">
            <div class="hydro-empty">
              <div class="hydro-empty-icon">💧</div>
              <h3>Sem dados hidrológicos</h3>
              <p>Nenhuma estação cadastrada ou aguardando primeira leitura.</p>
            </div>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
  const INTERVAL = 60_000;
  const tbody    = document.getElementById('hydro-tbody');
  const lastEl   = document.getElementById('last-update');
  const btnRef   = document.getElementById('btn-refresh');
  const refreshIcon = document.getElementById('refresh-icon');

  const meta = {
    normal:          { icon: '✅', rowCss: '',                    barCss: 'bar-normal',  kpi: 'cnt-normal'  },
    atencao:         { icon: '⚠️', rowCss: 'row-atencao',         barCss: 'bar-atencao', kpi: 'cnt-atencao' },
    alerta:          { icon: '🚨', rowCss: 'row-alerta',          barCss: 'bar-alerta',  kpi: 'cnt-alerta'  },
    transbordamento: { icon: '🌊', rowCss: 'row-transbordamento', barCss: 'bar-transb',  kpi: 'cnt-transb'  },
  };

  function fmt(v) {
    if (v === null || v === undefined) return '—';
    return parseFloat(v).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' m';
  }
  function fmtDt(s) {
    if (!s) return '—';
    return WazeTZ.format(s.replace(' ', 'T'));
  }

  function updateKPIs(rows) {
    const counts = { normal: 0, atencao: 0, alerta: 0, transbordamento: 0 };
    rows.forEach(r => { const k = r.alert_level ?? 'normal'; if (counts[k] !== undefined) counts[k]++; else counts.normal++; });
    document.getElementById('cnt-normal').textContent  = counts.normal;
    document.getElementById('cnt-atencao').textContent = counts.atencao;
    document.getElementById('cnt-alerta').textContent  = counts.alerta;
    document.getElementById('cnt-transb').textContent  = counts.transbordamento;
    document.getElementById('total-count').textContent = rows.length + ' estações';
  }

  function renderRows(rows) {
    if (!rows.length) {
      tbody.innerHTML = `<tr><td colspan="8"><div class="hydro-empty"><div class="hydro-empty-icon">💧</div><h3>Sem dados</h3><p>Aguardando primeira leitura.</p></div></td></tr>`;
      return;
    }
    updateKPIs(rows);
    tbody.innerHTML = rows.map(r => {
      const m   = meta[r.alert_level ?? 'normal'] ?? meta.normal;
      const pct = (r.cota_transbordamento && r.water_level)
        ? Math.min(Math.round((r.water_level / r.cota_transbordamento) * 100), 100) : 0;
      const bar = pct ? `<div class="level-bar-wrap"><div class="level-bar ${m.barCss}" style="width:${pct}%"></div></div>` : '';
      return `<tr class="${m.rowCss}">
        <td><span class="level-icon" title="${r.alert_level ?? 'normal'}">${m.icon}</span></td>
        <td>
          <div style="font-weight:600">${r.station_name}</div>
          <div style="font-size:var(--text-xs);color:var(--color-text-muted)">${r.station_code}</div>
        </td>
        <td style="white-space:nowrap">${r.municipality} / ${r.state}</td>
        <td style="text-align:right">
          <div style="font-weight:700;font-variant-numeric:tabular-nums">${fmt(r.water_level)}</div>${bar}
        </td>
        <td style="text-align:right;font-variant-numeric:tabular-nums">${fmt(r.cota_atencao)}</td>
        <td style="text-align:right;font-variant-numeric:tabular-nums">${fmt(r.cota_alerta)}</td>
        <td style="text-align:right;font-variant-numeric:tabular-nums">${fmt(r.cota_transbordamento)}</td>
        <td style="white-space:nowrap;font-size:var(--text-xs)">${fmtDt(r.measured_at)}</td>
      </tr>`;
    }).join('');
    lastEl.textContent = new Date().toLocaleTimeString('pt-BR');
  }

  function load() {
    btnRef.disabled = true;
    refreshIcon.classList.add('spinning');
    fetch('{{ path('hydro_live_data') }}')
      .then(r => r.json())
      .then(renderRows)
      .catch(() => {})
      .finally(() => { btnRef.disabled = false; refreshIcon.classList.remove('spinning'); });
  }

  btnRef.addEventListener('click', load);
  lastEl.textContent = new Date().toLocaleTimeString('pt-BR');
  setInterval(load, INTERVAL);
  lucide.createIcons();
})();
</script>
{% endblock %}
