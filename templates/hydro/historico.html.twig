{% extends 'base.html.twig' %}

{% block title %}Nível dos Rios — Histórico{% endblock %}

{% block content %}
<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">📋 Nível dos Rios — Histórico</h4>
        <small class="text-muted">{{ total }} registro(s) encontrado(s)</small>
    </div>
    <a href="{{ path('hydro_live') }}" class="btn btn-sm btn-outline-primary">🌊 Ao Vivo</a>
</div>

{# Filtros #}
<form method="get" class="card card-body shadow-sm mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
            <label class="form-label small mb-1">Estação</label>
            <select name="station" class="form-select form-select-sm">
                <option value="">Todas</option>
                {% for s in stations %}
                    <option value="{{ s.station_code }}" {% if station == s.station_code %}selected{% endif %}>
                        {{ s.station_name }} ({{ s.municipality }}/{{ s.state }})
                    </option>
                {% endfor %}
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small mb-1">Nível</label>
            <select name="level" class="form-select form-select-sm">
                <option value="">Todos</option>
                <option value="normal"          {% if level == 'normal'          %}selected{% endif %}>✅ Normal</option>
                <option value="atencao"         {% if level == 'atencao'         %}selected{% endif %}>⚠️ Atenção</option>
                <option value="alerta"          {% if level == 'alerta'          %}selected{% endif %}>🚨 Alerta</option>
                <option value="transbordamento" {% if level == 'transbordamento' %}selected{% endif %}>🌊 Transbordamento</option>
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small mb-1">De</label>
            <input type="date" name="date_from" class="form-control form-control-sm" value="{{ date_from }}">
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small mb-1">Até</label>
            <input type="date" name="date_to" class="form-control form-control-sm" value="{{ date_to }}">
        </div>
        <div class="col-6 col-md-2 d-flex gap-1">
            <button class="btn btn-sm btn-primary w-100">🔍 Filtrar</button>
            <a href="{{ path('hydro_historico') }}" class="btn btn-sm btn-outline-secondary">✕</a>
        </div>
    </div>
</form>

{# Tabela #}
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nível</th>
                        <th>Estação</th>
                        <th>Município / UF</th>
                        <th class="text-end">Rio (m)</th>
                        <th class="text-end">Atenção</th>
                        <th class="text-end">Alerta</th>
                        <th class="text-end">Transb.</th>
                        <th>Medido em</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in rows %}
                    {% set bg = '' %}
                    {% set icon = '✅' %}
                    {% if r.alert_level == 'atencao' %}{% set bg = 'table-warning' %}{% set icon = '⚠️' %}
                    {% elseif r.alert_level == 'alerta' %}{% set bg = 'table-danger' %}{% set icon = '🚨' %}
                    {% elseif r.alert_level == 'transbordamento' %}{% set bg = 'table-dark text-white' %}{% set icon = '🌊' %}
                    {% endif %}
                    <tr class="{{ bg }}">
                        <td class="fs-5 text-center" title="{{ r.alert_level|capitalize }}">{{ icon }}</td>
                        <td>
                            <div class="fw-semibold">{{ r.station_name }}</div>
                            <div class="text-muted small">{{ r.station_code }}</div>
                        </td>
                        <td>{{ r.municipality }} / {{ r.state }}</td>
                        <td class="text-end fw-bold">
                            {{ r.water_level is not null ? r.water_level|number_format(2, ',', '.') ~ ' m' : '—' }}
                        </td>
                        <td class="text-end">{{ r.cota_atencao          is not null ? r.cota_atencao|number_format(2, ',', '.') ~ ' m' : '—' }}</td>
                        <td class="text-end">{{ r.cota_alerta           is not null ? r.cota_alerta|number_format(2, ',', '.') ~ ' m' : '—' }}</td>
                        <td class="text-end">{{ r.cota_transbordamento  is not null ? r.cota_transbordamento|number_format(2, ',', '.') ~ ' m' : '—' }}</td>
                        <td class="small text-nowrap">{{ r.measured_at|date('d/m/Y H:i') }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="text-center text-muted py-4">Nenhum dado encontrado para os filtros selecionados.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# Paginação #}
{% if pages > 1 %}
<nav class="mt-3">
    <ul class="pagination pagination-sm justify-content-center">
        {% if page > 1 %}
            <li class="page-item">
                <a class="page-link" href="?{{ app.request.query.all|merge({page: page - 1})|url_encode }}">‹</a>
            </li>
        {% endif %}

        {% for p in 1..pages %}
            {% if p == page %}
                <li class="page-item active"><span class="page-link">{{ p }}</span></li>
            {% elseif p == 1 or p == pages or (p >= page - 2 and p <= page + 2) %}
                <li class="page-item">
                    <a class="page-link" href="?{{ app.request.query.all|merge({page: p})|url_encode }}">{{ p }}</a>
                </li>
            {% elseif p == page - 3 or p == page + 3 %}
                <li class="page-item disabled"><span class="page-link">…</span></li>
            {% endif %}
        {% endfor %}

        {% if page < pages %}
            <li class="page-item">
                <a class="page-link" href="?{{ app.request.query.all|merge({page: page + 1})|url_encode }}">›</a>
            </li>
        {% endif %}
    </ul>
    <p class="text-center text-muted small">Página {{ page }} de {{ pages }} — {{ total }} registros</p>
</nav>
{% endif %}
{% endblock %}
