{% extends 'base.html.twig' %}
{% block title %}Alertas{% endblock %}
{% block content %}
<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Alertas Waze</h1>
    <p class="page-subtitle">{{ total|number_format(0, ',', '.') }} alerta(s) encontrado(s)</p>
  </div>
</div>

{# Filtros #}
<div class="card" style="margin-bottom:var(--space-6)">
  <div class="card-body">
    <form method="get" style="display:flex;flex-wrap:wrap;gap:var(--space-4);align-items:flex-end">
      <div class="form-group" style="margin:0;flex:1;min-width:140px">
        <label class="form-label">Tipo</label>
        <select name="type" class="form-input form-select">
          <option value="">Todos</option>
          {% for t in types %}
            <option value="{{ t }}" {{ type == t ? 'selected' : '' }}>{{ t }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="form-group" style="margin:0;flex:1;min-width:140px">
        <label class="form-label">Subtipo</label>
        <input type="text" name="subtype" class="form-input" value="{{ subtype }}" placeholder="ex: HAZARD_ON_ROAD">
      </div>
      <div class="form-group" style="margin:0;flex:1;min-width:140px">
        <label class="form-label">Cidade</label>
        <input type="text" name="city" class="form-input" value="{{ city }}" placeholder="ex: Belo Horizonte">
      </div>
      <div class="form-group" style="margin:0;flex:1;min-width:130px">
        <label class="form-label">De (UTC)</label>
        <input type="date" name="dateFrom" class="form-input" value="{{ dateFrom }}"
               title="Filtro por data UTC — a conversão para seu fuso é feita na exibição">
      </div>
      <div class="form-group" style="margin:0;flex:1;min-width:130px">
        <label class="form-label">Até (UTC)</label>
        <input type="date" name="dateTo" class="form-input" value="{{ dateTo }}"
               title="Filtro por data UTC">
      </div>
      <button type="submit" class="btn btn-primary">Filtrar</button>
      <a href="{{ path('alert_index') }}" class="btn btn-ghost">Limpar</a>
    </form>
  </div>
</div>

{% if alerts is empty %}
  <div class="card"><div class="card-body" style="text-align:center;padding:var(--space-16);color:var(--color-text-muted)">Nenhum alerta encontrado.</div></div>
{% else %}

{# Mapa #}
<div class="card" style="margin-bottom:var(--space-6)">
  <div class="card-header"><span class="card-title">Mapa de alertas</span></div>
  <div id="alert-map" style="height:380px;border-radius:0 0 var(--radius-lg) var(--radius-lg)"></div>
</div>

{# Tabela #}
<div class="card">
  <div class="card-header">
    <span class="card-title">Lista de alertas</span>
    <span style="font-size:var(--text-xs);color:var(--color-text-muted)">Página {{ page }} de {{ pages }}</span>
  </div>
  <div style="overflow-x:auto">
    <table>
      <thead><tr>
        <th>Tipo</th>
        <th>Subtipo</th>
        <th>Via</th>
        <th>Cidade</th>
        <th style="text-align:center">Conf.</th>
        <th style="text-align:center">👍</th>
        <th>Publicado</th>
        <th></th>
      </tr></thead>
      <tbody>
      {% for a in alerts %}
        <tr>
          <td><span class="badge badge-{{ a.type == 'ACCIDENT' ? 'red' : (a.type == 'JAM' ? 'orange' : (a.type == 'HAZARD' ? 'yellow' : 'gray')) }}">{{ a.type }}</span></td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ a.subtype ?? '—' }}</td>
          <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ a.street ?? '—' }}</td>
          <td style="font-size:var(--text-xs)">{{ a.city ?? '—' }}</td>
          <td style="text-align:center;font-size:var(--text-xs)">
            {% if a.confidence is not null %}
              {% set c = a.confidence %}
              <span class="badge {{ c >= 7 ? 'badge-green' : (c >= 4 ? 'badge-orange' : 'badge-red') }}">{{ c }}</span>
            {% else %}—{% endif %}
          </td>
          <td style="text-align:center;font-size:var(--text-xs);color:var(--color-text-muted)">
            {{ a.nThumbsUp ?? '—' }}
          </td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted);white-space:nowrap">
            <time data-utc="{{ a.pubDate|date('c') }}" data-fmt="datetime">{{ a.pubDate|date('d/m H:i') }}</time>
          </td>
          <td>
            <a href="{{ path('alert_show', {id: a.id}) }}" class="btn btn-ghost btn-sm">
              <i data-lucide="eye" style="width:13px;height:13px"></i> Ver
            </a>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>

    {# Paginação #}
    {% if pages > 1 %}
    <div style="padding:var(--space-4) var(--space-5);border-top:1px solid var(--color-divider)">
      <div class="pagination">
        {% if page > 1 %}
          <a href="?{{ app.request.query.all|merge({page: page - 1})|url_encode }}">&#8249;</a>
        {% endif %}
        {% for p in max(1, page-2)..min(pages, page+2) %}
          {% if p == page %}
            <span class="current">{{ p }}</span>
          {% else %}
            <a href="?{{ app.request.query.all|merge({page: p})|url_encode }}">{{ p }}</a>
          {% endif %}
        {% endfor %}
        {% if page < pages %}
          <a href="?{{ app.request.query.all|merge({page: page + 1})|url_encode }}">&#8250;</a>
        {% endif %}
      </div>
    </div>
    {% endif %}

  {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  const TZ  = WazeTZ.TZ;
  const FMT = WazeTZ.FMT_FULL;

  const alerts = {{ alerts|map(a => {
    id:      a.id,
    lat:     a.latitude,
    lng:     a.longitude,
    type:    a.type,
    subtype: a.subtype,
    street:  a.street,
    city:    a.city,
    conf:    a.confidence,
    thumbs:  a.nThumbsUp,
    pubIso:  a.pubDate|date('c')
  })|json_encode|raw }};

  const TYPE_COLOR = {
    ACCIDENT:'#a12c7b', HAZARD:'#d19900', WEATHERHAZARD:'#006494',
    JAM:'#da7101', ROAD_CLOSED:'#7a7974', CONSTRUCTION:'#437a22',
    POLICE:'#01696f', MISC:'#7a39bb'
  };
  const TYPE_LABEL = {
    ACCIDENT:'Acidente', HAZARD:'Perigo', WEATHERHAZARD:'Risco climático',
    JAM:'Congestionamento', ROAD_CLOSED:'Via fechada', CONSTRUCTION:'Obra',
    POLICE:'Polícia/Radar', MISC:'Diverso'
  };

  const map = L.map('alert-map', {zoomControl:true});
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    {attribution:'© OpenStreetMap',maxZoom:19}).addTo(map);

  const markers = [];
  alerts.forEach(a => {
    const lat = parseFloat(a.lat);
    const lng = parseFloat(a.lng);
    if (!lat && !lng) return;
    const color = TYPE_COLOR[a.type] || '#7a7974';
    const icon = L.divIcon({
      html:`<div style="width:12px;height:12px;border-radius:50%;background:${color};border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.3);cursor:pointer"></div>`,
      className:'',iconSize:[12,12],iconAnchor:[6,6]
    });

    const subtypeClean = a.subtype ? a.subtype.replace(/_/g,' ') : '';
    const pubFormatted = a.pubIso ? FMT.format(new Date(a.pubIso)) : '—';
    const popup = `
      <div class="popup-inner">
        <div class="popup-type" style="color:${color}">${TYPE_LABEL[a.type]||a.type}</div>
        ${subtypeClean?`<div class="popup-sub">${subtypeClean}</div>`:''}
        <div class="popup-street">${a.street||'Via não identificada'}</div>
        ${a.city?`<div class="popup-city">${a.city}</div>`:''}
        <div class="popup-meta">
          ${a.conf!==null?`<span class="pm">★ Conf. ${a.conf}</span>`:''}
          ${a.thumbs?`<span class="pm">👍 ${a.thumbs}</span>`:''}
          <span class="pm">📅 ${pubFormatted}</span>
        </div>
        <a class="popup-link" href="/alertas/${a.id}">🔗 Ver detalhes completos</a>
      </div>`;

    const m = L.marker([lat, lng], {icon}).bindPopup(popup, {maxWidth:260});
    m.addTo(map);
    markers.push(m);
  });

  if (markers.length) {
    map.fitBounds(L.featureGroup(markers).getBounds().pad(0.15));
  } else {
    map.setView([-19.92, -43.94], 10);
  }
})();
</script>
{% endblock %}
