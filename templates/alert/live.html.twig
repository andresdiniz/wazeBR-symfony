{% extends 'base.html.twig' %}
{% block title %}Alertas ao Vivo{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
.live-shell{display:grid;grid-template-columns:340px 1fr;gap:var(--space-6);height:calc(100vh - var(--header-h) - 120px)}
.live-map{border-radius:var(--radius-lg);border:1px solid var(--color-border);overflow:hidden;height:100%}
.live-sidebar{display:flex;flex-direction:column;gap:var(--space-4);overflow-y:auto}
.region-card{
  background:var(--color-surface);border:1px solid var(--color-border);
  border-radius:var(--radius-lg);padding:var(--space-4);cursor:pointer;
  transition:box-shadow var(--transition),border-color var(--transition);
}
.region-card:hover,.region-card.active{
  box-shadow:var(--shadow-md);border-color:var(--color-primary);
}
.region-name{font-size:var(--text-sm);font-weight:600;color:var(--color-text);margin-bottom:var(--space-1)}
.region-count{font-size:var(--text-xl);font-weight:700;letter-spacing:-.03em;color:var(--color-text);font-variant-numeric:tabular-nums}
.region-types{display:flex;flex-wrap:wrap;gap:4px;margin-top:var(--space-2)}
.region-alerts{margin-top:var(--space-3);display:none}
.region-alerts.open{display:block}
.region-alert-item{font-size:var(--text-xs);padding:var(--space-2) 0;border-bottom:1px solid var(--color-divider)}
.region-alert-item:last-child{border-bottom:none}
.hours-toggle{display:flex;gap:var(--space-2);margin-bottom:var(--space-4)}
.pulse{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--color-error);animation:pulse 2s ease infinite}
@keyframes pulse{
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.4;transform:scale(1.4)}
}
.stat-row{display:flex;align-items:center;justify-content:space-between;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4)}
@media(max-width:900px){
  .live-shell{grid-template-columns:1fr;height:auto}
  .live-map{height:340px}
  .live-sidebar{max-height:50vh}
}
</style>
{% endblock %}

{% block content %}

<div class="page-header" style="margin-bottom:var(--space-5)">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-3)">
    <div>
      <h1 class="page-title">
        <span class="pulse"></span>&nbsp; Alertas ao vivo
      </h1>
      <p class="page-subtitle">{{ partner.name }} &mdash; últimas {{ hours }}h &mdash; <strong>{{ total }}</strong> ocorrências</p>
    </div>
    <div style="display:flex;gap:var(--space-3)">
      <a href="{{ path('alert_index') }}" class="btn btn-ghost">
        <i data-lucide="history" style="width:14px;height:14px"></i> Histórico
      </a>
      <button class="btn btn-ghost" id="refresh-btn">
        <i data-lucide="refresh-cw" style="width:14px;height:14px"></i> Atualizar
      </button>
    </div>
  </div>
</div>

{# Janela de tempo #}
<div class="hours-toggle">
  {% for h in [1, 3, 6, 12, 24] %}
    <a href="{{ path('alert_live', {hours: h}) }}"
       class="btn {{ hours == h ? 'btn-primary' : 'btn-ghost' }} btn-sm">
      {{ h }}h
    </a>
  {% endfor %}
</div>

{# Totalizador por tipo #}
{% set typeCounts = {} %}
{% for r in regions %}
  {% for type, cnt in r.types %}
    {% set typeCounts = typeCounts|merge({(type): (typeCounts[type]|default(0) + cnt)}) %}
  {% endfor %}
{% endfor %}

{% if typeCounts %}
<div style="display:flex;flex-wrap:wrap;gap:var(--space-3);margin-bottom:var(--space-5)">
  {% for type, cnt in typeCounts %}
  <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-3) var(--space-4);min-width:120px">
    <div style="font-size:var(--text-xs);font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--color-text-muted)">{{ typesMap[type] ?? type }}</div>
    <div style="font-size:var(--text-xl);font-weight:700;font-variant-numeric:tabular-nums">{{ cnt }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

{# Shell mapa + sidebar #}
{% if regions is empty %}
  <div class="empty">
    <i data-lucide="check-circle"></i>
    <h3>Nenhum alerta nas últimas {{ hours }}h</h3>
    <p>A cidade está sem ocorrências no período selecionado.</p>
  </div>
{% else %}
<div class="live-shell">

  {# Sidebar: lista de regiões #}
  <div class="live-sidebar">
    {% for r in regions %}
    <div class="region-card" data-lat="{{ r.lat }}" data-lng="{{ r.lng }}" data-city="{{ r.city }}" onclick="focusRegion(this)">
      <div class="region-row" style="display:flex;align-items:flex-start;justify-content:space-between">
        <div>
          <div class="region-name">{{ r.city }}</div>
          <div class="region-types">
            {% for type, cnt in r.types %}
              <span class="badge
                {% if type == 'ACCIDENT' %}badge-red
                {% elseif type in ['HAZARD','WEATHERHAZARD'] %}badge-yellow
                {% elseif type == 'JAM' %}badge-orange
                {% elseif type == 'ROAD_CLOSED' %}badge-gray
                {% else %}badge-blue{% endif %}">
                {{ typesMap[type] ?? type }} ({{ cnt }})
              </span>
            {% endfor %}
          </div>
        </div>
        <div class="region-count">{{ r.count }}</div>
      </div>
      {% if r.alerts %}
      <div class="region-alerts">
        {% for al in r.alerts %}
        <div class="region-alert-item">
          <span class="badge badge-gray" style="margin-right:4px">{{ typesMap[al.type] ?? al.type }}</span>
          {{ al.street ?? '—' }}
          {% if al.subtype %}<div style="color:var(--color-text-faint);margin-top:2px">{{ subtypesMap[al.type ~ '|' ~ al.subtype] ?? al.subtype }}</div>{% endif %}
        </div>
        {% endfor %}
        {% if r.count > r.alerts|length %}
          <div style="font-size:var(--text-xs);color:var(--color-text-faint);padding-top:var(--space-1)">+ {{ r.count - r.alerts|length }} mais ocorrências</div>
        {% endif %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  {# Mapa #}
  <div id="live-map" class="live-map"></div>

</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  const regions = {{ regions|json_encode|raw }};
  const allAlerts = {{ alerts|map(a => {
    lat: a.latitude,
    lng: a.longitude,
    type: a.type,
    subtype: a.subtype,
    street: a.street,
    city: a.city,
    conf: a.confidence,
    id: a.id
  })|json_encode|raw }};

  const TYPE_COLOR = {
    ACCIDENT:'#a12c7b', HAZARD:'#d19900', WEATHERHAZARD:'#006494',
    JAM:'#da7101', ROAD_CLOSED:'#7a7974', CONSTRUCTION:'#437a22',
    POLICE:'#01696f', MISC:'#7a39bb'
  };
  const TYPE_LABEL = {{ typesMap|json_encode|raw }};
  const SUBTYPE_LABEL = {{ subtypesMap|json_encode|raw }};

  const map = L.map('live-map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    {attribution:'© OpenStreetMap',maxZoom:19}).addTo(map);

  // pontos individuais
  const pts = [];
  allAlerts.forEach(a => {
    if (!a.lat || !a.lng) return;
    const color = TYPE_COLOR[a.type] || '#7a7974';
    const icon = L.divIcon({
      html:`<div style="width:10px;height:10px;border-radius:50%;background:${color};border:2px solid #fff;box-shadow:0 1px 3px rgba(0,0,0,.3)"></div>`,
      className:'',iconSize:[10,10],iconAnchor:[5,5]
    });
    const m = L.marker([a.lat,a.lng],{icon})
      .bindPopup(`<b>${TYPE_LABEL[a.type]||a.type}</b><br>${a.subtype ? (SUBTYPE_LABEL[a.type+'|'+a.subtype]||a.subtype) : ''}<br>${a.street||''}${a.city?' — '+a.city:''}`);
    m.addTo(map);
    pts.push(m);
  });

  if (pts.length) {
    map.fitBounds(L.featureGroup(pts).getBounds().pad(0.1));
  } else {
    map.setView([-19.92,-43.94],11);
  }

  // foco ao clicar na região
  window.focusRegion = function(el) {
    document.querySelectorAll('.region-card').forEach(c => {
      c.classList.remove('active');
      c.querySelector('.region-alerts')?.classList.remove('open');
    });
    el.classList.add('active');
    el.querySelector('.region-alerts')?.classList.add('open');
    const lat = parseFloat(el.dataset.lat);
    const lng = parseFloat(el.dataset.lng);
    if (lat && lng) map.flyTo([lat,lng], 14, {duration:0.8});
  };

  // atualização automática a cada 60s
  const hours = {{ hours }};
  document.getElementById('refresh-btn')?.addEventListener('click', () => location.reload());
  setTimeout(() => location.reload(), 60000);
})();
</script>
{% endblock %}
