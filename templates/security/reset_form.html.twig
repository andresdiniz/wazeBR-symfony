{% extends 'base.html.twig' %}
{% block title %}Nova senha — WazeBR{% endblock %}
{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <h1>Definir nova senha</h1>

        {% for type, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash flash--{{ type }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        <form method="post">
            <div class="form-group">
                <label for="password">Nova senha</label>
                <input type="password" id="password" name="password" required autofocus minlength="8" placeholder="Mínimo 8 caracteres">
            </div>
            <div class="form-group">
                <label for="confirm">Confirmar senha</label>
                <input type="password" id="confirm" name="confirm" required placeholder="Repita a senha">
            </div>
            <button type="submit" class="btn btn--primary btn--full">Salvar nova senha</button>
        </form>
    </div>
</div>
{% endblock %}
