{% extends 'base.html.twig' %}

{% block title %}Login — WazeBR{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">
            <svg viewBox="0 0 48 48" width="48" height="48" aria-label="WazeBR" fill="none">
                <circle cx="24" cy="24" r="22" stroke="var(--color-primary)" stroke-width="2.5"/>
                <path d="M14 30 Q24 14 34 30" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                <circle cx="18" cy="26" r="2" fill="var(--color-primary)"/>
                <circle cx="30" cy="26" r="2" fill="var(--color-primary)"/>
            </svg>
            <span>WazeBR</span>
        </div>

        <h1>Entrar na plataforma</h1>
        <p class="auth-sub">Monitoramento inteligente de tráfego</p>

        {% for type, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash flash--{{ type }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        {% if error %}
            <div class="flash flash--error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('security_login') }}" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ last_username }}" autofocus autocomplete="email" required placeholder="seu@email.com">
            </div>

            <div class="form-group">
                <label for="password">Senha</label>
                <input type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <div class="form-row">
                <label class="checkbox-label">
                    <input type="checkbox" name="_remember_me"> Lembrar de mim
                </label>
                <a href="{{ path('password_request') }}" class="link-muted">Esqueci minha senha</a>
            </div>

            <button type="submit" class="btn btn--primary btn--full">Entrar</button>
        </form>
    </div>
</div>
{% endblock %}
