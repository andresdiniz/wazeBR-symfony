{% extends 'base.html.twig' %}
{% block title %}Recuperar senha — WazeBR{% endblock %}
{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <h1>Recuperar senha</h1>
        <p class="auth-sub">Informe seu email e enviaremos um link de redefinição.</p>

        {% for type, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash flash--{{ type }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        <form method="post">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autofocus placeholder="seu@email.com">
            </div>
            <button type="submit" class="btn btn--primary btn--full">Enviar link</button>
        </form>
        <p class="auth-back"><a href="{{ path('security_login') }}">Voltar ao login</a></p>
    </div>
</div>
{% endblock %}
