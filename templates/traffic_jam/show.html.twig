{% extends 'base.html.twig' %}
{% block title %}Congestionamento #{{ jam.id }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
.show-grid{
  display:grid;
  grid-template-columns:1fr 380px;
  gap:var(--space-6);
  align-items:start;
}
.detail-card{
  background:var(--color-surface);
  border:1px solid var(--color-border);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-sm);
  overflow:hidden;
}
.detail-section-title{
  font-size:var(--text-xs);
  font-weight:700;
  letter-spacing:.07em;
  text-transform:uppercase;
  color:var(--color-text-muted);
  padding:var(--space-3) var(--space-5);
  background:var(--color-surface-offset);
  border-bottom:1px solid var(--color-divider);
}
.detail-rows{ padding:var(--space-2) 0; }
.detail-row{
  display:flex;
  align-items:flex-start;
  gap:var(--space-4);
  padding:var(--space-3) var(--space-5);
  border-bottom:1px solid var(--color-divider);
}
.detail-row:last-child{ border-bottom:none }
.detail-label{
  font-size:var(--text-xs);
  font-weight:600;
  color:var(--color-text-muted);
  text-transform:uppercase;
  letter-spacing:.04em;
  min-width:130px;
  padding-top:2px;
  flex-shrink:0;
}
.detail-value{
  font-size:var(--text-sm);
  color:var(--color-text);
  word-break:break-word;
}
.meta-pill{
  display:inline-flex;
  align-items:center;
  gap:var(--space-1);
  padding:var(--space-1) var(--space-3);
  border-radius:var(--radius-full);
  font-size:var(--text-xs);
  font-weight:600;
  background:var(--color-surface-offset);
  color:var(--color-text-muted);
}
#jam-map{
  height:340px;
  width:100%;
  border-radius:var(--radius-lg);
  border:1px solid var(--color-border);
  margin-bottom:var(--space-6);
}
.seg-bar{
  height:6px;
  border-radius:var(--radius-full);
  background:var(--color-orange);
  margin-top:var(--space-1);
}
@media(max-width:860px){ .show-grid{grid-template-columns:1fr} }
</style>
{% endblock %}

{% block content %}
<div style="display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-6);flex-wrap:wrap">
  <a href="{{ path('traffic_jam_index') }}" class="btn btn-ghost btn-sm">
    <i data-lucide="arrow-left" style="width:14px;height:14px"></i> Voltar
  </a>
  <div style="flex:1">
    <h1 class="page-title" style="margin:0">Congestionamento #{{ jam.id }}</h1>
    <div style="margin-top:var(--space-2);display:flex;gap:var(--space-3);flex-wrap:wrap">
      <span class="meta-pill">
        <i data-lucide="clock" style="width:11px;height:11px"></i>
        <time data-utc="{{ jam.pubDate|date('c') }}" data-fmt="datetime">{{ jam.pubDate|date('d/m/Y H:i:s') }}</time>
      </span>
      {% if jam.speedKMH is not null %}
        <span class="meta-pill">🚗 {{ jam.speedKMH }} km/h</span>
      {% endif %}
      {% if jam.length is not null %}
        <span class="meta-pill">📏 {{ (jam.length / 1000)|number_format(1, ',') }} km</span>
      {% endif %}
      {% if jam.delay is not null %}
        <span class="meta-pill">⏱ +{{ jam.delay }}s</span>
      {% endif %}
    </div>
  </div>
</div>

{# Mapa #}
<div id="jam-map"></div>

<div class="show-grid">
  <div style="display:flex;flex-direction:column;gap:var(--space-5)">

    <div class="detail-card">
      <div class="detail-section-title">Localização</div>
      <div class="detail-rows">
        <div class="detail-row"><span class="detail-label">Via</span><span class="detail-value">{{ jam.street ?? '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Cidade</span><span class="detail-value">{{ jam.city ?? '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">País</span><span class="detail-value">{{ jam.country ?? '—' }}</span></div>
      </div>
    </div>

    <div class="detail-card">
      <div class="detail-section-title">Tráfego</div>
      <div class="detail-rows">
        <div class="detail-row"><span class="detail-label">Velocidade</span><span class="detail-value">{{ jam.speedKMH is not null ? jam.speedKMH ~ ' km/h' : '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Velocidade (m/s)</span><span class="detail-value">{{ jam.speed is not null ? jam.speed|number_format(1,',') ~ ' m/s' : '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Comprimento</span><span class="detail-value">{{ jam.length is not null ? (jam.length / 1000)|number_format(1,',') ~ ' km (' ~ jam.length ~ ' m)' : '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Atraso</span><span class="detail-value">{{ jam.delay is not null ? jam.delay ~ 's' : '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Nível</span><span class="detail-value">{{ jam.level is not null ? jam.level ~ '/5' : '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Tipo de via</span><span class="detail-value">{{ jam.roadType is not null ? jam.roadType : '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Causa</span><span class="detail-value">{{ jam.causeType ?? '—' }}</span></div>
        <div class="detail-row"><span class="detail-label">Bloqueio</span><span class="detail-value">{{ jam.blocking ? 'Sim' : 'Não' }}</span></div>
      </div>
    </div>

  </div>

  <div style="display:flex;flex-direction:column;gap:var(--space-5)">

    <div class="detail-card">
      <div class="detail-section-title">Identificação</div>
      <div class="detail-rows">
        <div class="detail-row"><span class="detail-label">ID interno</span><span class="detail-value">#{{ jam.id }}</span></div>
        <div class="detail-row"><span class="detail-label">UUID Waze</span><span class="detail-value" style="font-family:monospace;font-size:var(--text-xs);word-break:break-all">{{ jam.wazeId ?? '—' }}</span></div>
      </div>
    </div>

    <div class="detail-card">
      <div class="detail-section-title">Timestamps</div>
      <div class="detail-rows">
        <div class="detail-row"><span class="detail-label">Publicado (Waze)</span><span class="detail-value"><time data-utc="{{ jam.pubDate|date('c') }}" data-fmt="datetime">{{ jam.pubDate|date('d/m/Y H:i:s') }}</time></span></div>
        <div class="detail-row"><span class="detail-label">pubMillis</span><span class="detail-value" style="font-family:monospace;font-size:var(--text-xs)">{{ jam.pubMillis }}</span></div>
        <div class="detail-row"><span class="detail-label">Coletado em</span><span class="detail-value"><time data-utc="{{ jam.createdAt|date('c') }}" data-fmt="datetime">{{ jam.createdAt|date('d/m/Y H:i:s') }}</time></span></div>
        {% if jam.updatedAt %}
          <div class="detail-row"><span class="detail-label">Atualizado em</span><span class="detail-value"><time data-utc="{{ jam.updatedAt|date('c') }}" data-fmt="datetime">{{ jam.updatedAt|date('d/m/Y H:i:s') }}</time></span></div>
        {% endif %}
      </div>
    </div>

  </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  const line = {{ jam.line|json_encode|raw }};
  if (!line || !line.length) return;

  const map = L.map('jam-map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    {attribution:'© OpenStreetMap',maxZoom:19}).addTo(map);

  const coords = line.map(function(p){ return [p.y, p.x]; });
  const poly = L.polyline(coords, {color:'#da7101', weight:5, opacity:0.85}).addTo(map);
  map.fitBounds(poly.getBounds().pad(0.15));
  setTimeout(function(){ map.invalidateSize(); }, 150);
})();
</script>
{% endblock %}
