{% extends 'base.html.twig' %}

{% block title %}Congestionamentos{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  .jam-layout { display: grid; grid-template-columns: 1fr 380px; gap: var(--space-6); align-items: start; }
  @media(max-width:1100px){ .jam-layout { grid-template-columns: 1fr; } }
  #hist-map { height: 520px; border-radius: var(--radius-lg); border: 1px solid var(--color-border); box-shadow: var(--shadow-md); }
  .level-bar { display:flex; align-items:center; gap:6px; }
  .level-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .level-0,.level-1 { background:#4caf50; }
  .level-2,.level-3 { background:#ff9800; }
  .level-4 { background:#f44336; }
  .level-5 { background:#7b1fa2; }
  .speed-chip { font-family:var(--font-mono); font-size:var(--text-xs); background:var(--color-surface-offset); padding:2px 6px; border-radius:var(--radius-sm); }
  .map-legend { display:flex; flex-wrap:wrap; gap:var(--space-3); padding:var(--space-3) var(--space-4); background:var(--color-surface); border:1px solid var(--color-border); border-radius:var(--radius-md); margin-bottom:var(--space-4); font-size:var(--text-xs); }
  .legend-item { display:flex; align-items:center; gap:6px; color:var(--color-text-muted); }
  .legend-line { width:24px; height:4px; border-radius:2px; }
  .tab-bar { display:flex; gap:var(--space-2); margin-bottom:var(--space-6); border-bottom:1px solid var(--color-border); }
  .tab { padding:var(--space-2) var(--space-4); font-size:var(--text-sm); font-weight:500; color:var(--color-text-muted); border-bottom:2px solid transparent; margin-bottom:-1px; cursor:pointer; }
  .tab.active { color:var(--color-primary); border-bottom-color:var(--color-primary); }
  .tab:hover:not(.active) { color:var(--color-text); }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
    <div>
      <h1 class="page-title">Congestionamentos</h1>
      <p class="page-subtitle">{{ total }} registro{{ total != 1 ? 's' }} encontrado{{ total != 1 ? 's' }}</p>
    </div>
    <div style="display:flex;gap:var(--space-2)">
      <a href="{{ path('jam_live') }}" class="btn btn-primary">
        <i data-lucide="radio" style="width:14px;height:14px"></i> Ao Vivo
      </a>
    </div>
  </div>
</div>

{# Filtros #}
<form method="get" class="filter-bar" style="margin-bottom:var(--space-6)">
  <select name="minLevel" class="form-select" style="width:auto">
    <option value="">Qualquer nível</option>
    {% for l in 0..5 %}
      <option value="{{ l }}" {{ minLevel == l ? 'selected' }}>Nível ≥ {{ l }}</option>
    {% endfor %}
  </select>
  {% if cities|length %}
  <select name="city" class="form-select" style="width:auto">
    <option value="">Todas as cidades</option>
    {% for c in cities %}<option value="{{ c }}" {{ city == c ? 'selected' }}>{{ c }}</option>{% endfor %}
  </select>
  {% endif %}
  <input type="date" name="dateFrom" class="form-input" style="width:auto" value="{{ dateFrom }}" placeholder="De">
  <input type="date" name="dateTo" class="form-input" style="width:auto" value="{{ dateTo }}" placeholder="Até">
  <button type="submit" class="btn btn-primary btn-sm"><i data-lucide="search" style="width:13px;height:13px"></i> Filtrar</button>
  <a href="{{ path('jam_index') }}" class="btn btn-ghost btn-sm">Limpar</a>
</form>

<div class="map-legend">
  <div class="legend-item"><div class="legend-line" style="background:#4caf50"></div> Livre (0-1)</div>
  <div class="legend-item"><div class="legend-line" style="background:#ff9800"></div> Moderado (2-3)</div>
  <div class="legend-item"><div class="legend-line" style="background:#f44336"></div> Congestionado (4)</div>
  <div class="legend-item"><div class="legend-line" style="background:#7b1fa2"></div> Parado (5)</div>
</div>

<div class="jam-layout">
  {# Mapa #}
  <div>
    <div class="card" style="overflow:visible;margin-bottom:var(--space-6)">
      <div class="card-header">
        <span class="card-title"><i data-lucide="map" style="width:14px;height:14px;display:inline"></i> Mapa do Histórico</span>
        <span style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ total }} jam{{ total != 1 ? 's' }} filtrado{{ total != 1 ? 's' }}</span>
      </div>
      <div id="hist-map"></div>
    </div>
  </div>

  {# Lista #}
  <div>
    <div class="card">
      <div class="card-header"><span class="card-title">Lista</span></div>
      {% if jams is empty %}
        <div class="empty" style="padding:var(--space-10)">
          <i data-lucide="traffic-cone" style="width:36px;height:36px;color:var(--color-text-faint);margin-bottom:var(--space-3)"></i>
          <h3>Nenhum congestionamento</h3>
          <p>Ajuste os filtros para ver resultados.</p>
        </div>
      {% else %}
      <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>Via</th>
              <th>Nível</th>
              <th>Vel.</th>
              <th>Ext.</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for jam in jams %}
            <tr style="cursor:pointer" data-jam-id="{{ jam.id }}" onclick="focusJam({{ jam.id }})">
              <td>
                <div style="font-weight:500;max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ jam.street ?: '—' }}</div>
                <div style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ jam.city ?: '—' }}</div>
              </td>
              <td>
                <div class="level-bar">
                  <div class="level-dot level-{{ jam.level }}"></div>
                  <span>{{ jam.level }}</span>
                </div>
              </td>
              <td><span class="speed-chip">{{ jam.speedKmh ? jam.speedKmh|number_format(0) ~ ' km/h' : '—' }}</span></td>
              <td style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ jam.length ? jam.length ~ ' m' : '—' }}</td>
              <td><a href="{{ path('jam_show', {id: jam.id}) }}" class="btn btn-ghost btn-sm" onclick="event.stopPropagation()">Ver</a></td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
    </div>

    {# Paginação #}
    {% if pages > 1 %}
    <div class="pagination">
      {% if page > 1 %}<a href="?page={{ page - 1 }}&{{ app.request.queryString|replace({'page='~page: ''}) }}">‹</a>{% endif %}
      {% for p in max(1, page-2)..min(pages, page+2) %}
        {% if p == page %}<span class="current">{{ p }}</span>
        {% else %}<a href="?page={{ p }}&{{ app.request.queryString|replace({'page='~page: ''}) }}">{{ p }}</a>{% endif %}
      {% endfor %}
      {% if page < pages %}<a href="?page={{ page + 1 }}&{{ app.request.queryString|replace({'page='~page: ''}) }}">›</a>{% endif %}
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const JAM_DATA = [
  {% for jam in jams %}
  {% if jam.line %}
  {
    id: {{ jam.id }},
    street: {{ jam.street|json_encode|raw }},
    city: {{ jam.city|json_encode|raw }},
    level: {{ jam.level }},
    speedKmh: {{ jam.speedKmh ?? 'null' }},
    length: {{ jam.length ?? 'null' }},
    delay: {{ jam.delay ?? 'null' }},
    blocking: {{ jam.blocking ? 'true' : 'false' }},
    line: {{ jam.line|json_encode|raw }}
  }{{ not loop.last ? ',' }}
  {% endif %}
  {% endfor %}
];

const LEVEL_COLOR = { 0:'#4caf50',1:'#4caf50',2:'#ff9800',3:'#ff9800',4:'#f44336',5:'#7b1fa2' };
const LEVEL_WEIGHT = { 0:3,1:3,2:4,3:4,4:5,5:6 };

const map = L.map('hist-map', { zoomControl: true, attributionControl: true });
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
  maxZoom: 19
}).addTo(map);

const layerMap = {};
const allBounds = [];

JAM_DATA.forEach(jam => {
  if (!jam.line || !jam.line.length) return;
  const coords = jam.line.map(p => [p.y, p.x]);
  allBounds.push(...coords);
  const color = LEVEL_COLOR[jam.level] || '#999';
  const weight = LEVEL_WEIGHT[jam.level] || 3;

  // sombra
  L.polyline(coords, { color: '#000', weight: weight + 4, opacity: 0.12 }).addTo(map);
  // linha principal
  const poly = L.polyline(coords, {
    color,
    weight,
    opacity: 0.85,
    lineJoin: 'round',
    lineCap: 'round'
  }).addTo(map);

  // seta de direção animada
  const mid = coords[Math.floor(coords.length / 2)];
  const arrowIcon = L.divIcon({
    className: '',
    html: `<div style="width:16px;height:16px;background:${color};border-radius:50%;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;">
             <svg width="8" height="8" viewBox="0 0 8 8" fill="white"><path d="M4 1L7 7H1z"/></svg>
           </div>`,
    iconSize: [16, 16],
    iconAnchor: [8, 8]
  });
  L.marker(mid, { icon: arrowIcon, interactive: false }).addTo(map);

  const speedText = jam.speedKmh != null ? `${Math.round(jam.speedKmh)} km/h` : '—';
  const lengthText = jam.length != null ? `${jam.length} m` : '—';
  const delayText = jam.delay != null ? `${jam.delay}s` : '—';
  const blockTag = jam.blocking ? '<span style="background:#f44336;color:#fff;padding:1px 5px;border-radius:3px;font-size:11px">Bloqueado</span>' : '';

  poly.bindPopup(`
    <div style="min-width:200px;font-family:Inter,sans-serif">
      <div style="font-weight:700;font-size:13px;margin-bottom:4px">${jam.street || 'Via desconhecida'}</div>
      <div style="font-size:11px;color:#666;margin-bottom:8px">${jam.city || ''}</div>
      <table style="width:100%;font-size:12px;border-collapse:collapse">
        <tr><td style="color:#888;padding:2px 0">Nível</td><td style="font-weight:600;color:${color}">${jam.level}/5</td></tr>
        <tr><td style="color:#888;padding:2px 0">Velocidade</td><td>${speedText}</td></tr>
        <tr><td style="color:#888;padding:2px 0">Extensão</td><td>${lengthText}</td></tr>
        <tr><td style="color:#888;padding:2px 0">Atraso</td><td>${delayText}</td></tr>
      </table>
      ${blockTag}
      <div style="margin-top:8px">
        <a href="/congestionamentos/${jam.id}" style="color:#01696f;font-size:12px;font-weight:500">Ver detalhes →</a>
      </div>
    </div>
  `, { maxWidth: 260 });

  layerMap[jam.id] = poly;
});

if (allBounds.length) {
  map.fitBounds(allBounds, { padding: [40, 40] });
} else {
  map.setView([-19.92, -43.94], 12);
}

window.focusJam = function(id) {
  const poly = layerMap[id];
  if (!poly) return;
  map.fitBounds(poly.getBounds(), { padding: [60, 60], maxZoom: 16 });
  poly.openPopup();
  document.querySelectorAll('tr[data-jam-id]').forEach(r => r.style.background = '');
  const row = document.querySelector(`tr[data-jam-id="${id}"]`);
  if (row) { row.style.background = 'oklch(from var(--color-primary) l c h / 0.08)'; row.scrollIntoView({ block: 'nearest' }); }
};
</script>
{% endblock %}
