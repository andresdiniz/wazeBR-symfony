{% extends 'base.html.twig' %}
{% block title %}Congestionamentos{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
.filter-card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-5);margin-bottom:var(--space-6);box-shadow:var(--shadow-sm)}
.filter-row{display:flex;flex-wrap:wrap;gap:var(--space-3);align-items:flex-end}
.filter-field{display:flex;flex-direction:column;gap:var(--space-1);min-width:130px;flex:1}
.filter-field label{font-size:var(--text-xs);font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--color-text-muted)}
.total-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-4)}
.total-bar-text{font-size:var(--text-sm);color:var(--color-text-muted)}
#jam-map{height:320px;border-radius:var(--radius-lg);border:1px solid var(--color-border);margin-bottom:var(--space-6);overflow:hidden}
.leaflet-popup-content-wrapper{border-radius:10px!important;box-shadow:0 4px 20px rgba(0,0,0,.15)!important}
.level-bar{display:flex;gap:2px;align-items:center}
.level-pip{width:10px;height:10px;border-radius:2px}
@media(max-width:700px){.filter-row{flex-direction:column}}
</style>
{% endblock %}

{% block content %}

<div class="page-header" style="margin-bottom:var(--space-5)">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-3)">
    <div>
      <h1 class="page-title">Congestionamentos</h1>
      <p class="page-subtitle">Histórico &mdash; {{ partner.name }}</p>
    </div>
    <a href="{{ path('jam_live') }}" class="btn btn-primary">
      <i data-lucide="radio" style="width:14px;height:14px"></i> Ao vivo
    </a>
  </div>
</div>

{# Mapa de polylines #}
<div id="jam-map"></div>

{# Filtros #}
<div class="filter-card">
  <form method="get" id="filter-form">
    <div class="filter-row">

      <div class="filter-field">
        <label>Nível mínimo</label>
        <select name="minLevel" class="form-select" onchange="this.form.submit()">
          <option value="">Todos</option>
          {% for lv in 1..5 %}
            <option value="{{ lv }}" {{ minLevel == lv ? 'selected' }}>
              Nível {{ lv }}{{ lv == 5 ? ' (máx)' : '' }}
            </option>
          {% endfor %}
        </select>
      </div>

      <div class="filter-field">
        <label>Tipo</label>
        <select name="type" class="form-select" onchange="this.form.submit()">
          <option value="">Todos</option>
          {% for t in types %}
            <option value="{{ t }}" {{ type == t ? 'selected' }}>{{ t|replace({'_':' '})|title }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="filter-field">
        <label>Cidade</label>
        <select name="city" class="form-select" onchange="this.form.submit()">
          <option value="">Todas</option>
          {% for c in cities %}
            <option value="{{ c }}" {{ city == c ? 'selected' }}>{{ c }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="filter-field">
        <label>De</label>
        <input type="date" name="dateFrom" class="form-input" value="{{ dateFrom }}"
               onchange="document.getElementById('filter-form').submit()">
      </div>

      <div class="filter-field">
        <label>Até</label>
        <input type="date" name="dateTo" class="form-input" value="{{ dateTo }}"
               onchange="document.getElementById('filter-form').submit()">
      </div>

      <div style="display:flex;gap:var(--space-2)">
        <button type="submit" class="btn btn-primary">
          <i data-lucide="search" style="width:14px;height:14px"></i> Filtrar
        </button>
        <a href="{{ path('jam_index') }}" class="btn btn-ghost">
          <i data-lucide="x" style="width:14px;height:14px"></i>
        </a>
      </div>

    </div>
  </form>
</div>

<div class="total-bar">
  <span class="total-bar-text">
    <strong>{{ total|number_format(0,',','.') }}</strong> congestionamento{{ total != 1 ? 's' }}
    {% if minLevel or city or type or dateFrom or dateTo %}&mdash; filtro ativo{% endif %}
  </span>
  {% if pages > 1 %}<span class="total-bar-text">Página {{ page }} de {{ pages }}</span>{% endif %}
</div>

<div class="card">
{% if jams is empty %}
  <div class="empty">
    <i data-lucide="traffic-cone"></i>
    <h3>Nenhum congestionamento encontrado</h3>
    <p>Tente ajustar os filtros.</p>
  </div>
{% else %}
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Nível</th>
        <th>Via / Cidade</th>
        <th>Extensão</th>
        <th>Atraso</th>
        <th>Vel. (km/h)</th>
        <th>Bloqueio</th>
        <th>Publicado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
    {% for j in jams %}
      {% set lv = j.level ?? 0 %}
      <tr>
        <td style="color:var(--color-text-faint);font-size:var(--text-xs)">{{ j.id }}</td>
        <td>
          <div class="level-bar" title="Nível {{ lv }}">
            {% for i in 1..5 %}
              <div class="level-pip" style="background:{{ i <= lv ? (lv >= 4 ? '#a12c7b' : (lv >= 2 ? '#da7101' : '#d19900')) : 'var(--color-surface-dynamic)' }}"></div>
            {% endfor %}
            <span style="font-size:var(--text-xs);margin-left:4px;color:var(--color-text-muted)">{{ lv }}</span>
          </div>
        </td>
        <td>
          <div style="font-size:var(--text-sm);font-weight:500">{{ j.street ?? '—' }}</div>
          {% if j.city %}<div style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ j.city }}</div>{% endif %}
        </td>
        <td style="font-size:var(--text-sm);font-variant-numeric:tabular-nums">
          {% if j.length %}{{ (j.length / 1000)|number_format(2,',','.') }} km{% else %}—{% endif %}
        </td>
        <td style="font-size:var(--text-sm)">
          {% if j.delay %}
            {% if j.delay >= 60 %}
              {{ (j.delay / 60)|round(0,'ceil') }} min
            {% else %}
              {{ j.delay }}s
            {% endif %}
          {% else %}—{% endif %}
        </td>
        <td style="font-size:var(--text-sm);font-variant-numeric:tabular-nums">
          {% if j.speedKmh is not null %}
            <span style="color:{{ j.speedKmh < 10 ? 'var(--color-error)' : (j.speedKmh < 30 ? 'var(--color-warning)' : 'var(--color-success)') }}">
              {{ j.speedKmh|number_format(1,',','.') }}
            </span>
          {% else %}—{% endif %}
        </td>
        <td style="text-align:center">
          {% if j.blocking %}
            <span class="badge badge-red">Sim</span>
          {% else %}
            <span style="color:var(--color-text-faint)">Não</span>
          {% endif %}
        </td>
        <td style="font-size:var(--text-xs);color:var(--color-text-muted);white-space:nowrap">
          {{ j.pubDate|date('d/m H:i') }}
        </td>
        <td>
          <a href="{{ path('jam_show', {id: j.id}) }}" class="btn btn-ghost btn-sm">
            <i data-lucide="eye" style="width:13px;height:13px"></i> Ver
          </a>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if pages > 1 %}
  <div style="padding:var(--space-4) var(--space-5);border-top:1px solid var(--color-divider)">
    <div class="pagination">
      {% if page > 1 %}
        <a href="?{{ app.request.query.all|merge({page: page - 1})|url_encode }}">‹</a>
      {% endif %}
      {% for p in max(1, page-2)..min(pages, page+2) %}
        {% if p == page %}<span class="current">{{ p }}</span>
        {% else %}<a href="?{{ app.request.query.all|merge({page: p})|url_encode }}">{{ p }}</a>{% endif %}
      {% endfor %}
      {% if page < pages %}
        <a href="?{{ app.request.query.all|merge({page: page + 1})|url_encode }}">›</a>
      {% endif %}
    </div>
  </div>
  {% endif %}

{% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  const jams = {{ jams|map(j => {
    id:      j.id,
    street:  j.street,
    city:    j.city,
    level:   j.level,
    speedKmh: j.speedKmh,
    length:  j.length,
    delay:   j.delay,
    blocking: j.blocking,
    line:    j.line
  })|json_encode|raw }};

  function levelColor(lv) {
    if (lv >= 5) return '#a12c7b';
    if (lv >= 4) return '#da3501';
    if (lv >= 3) return '#da7101';
    if (lv >= 2) return '#d19900';
    return '#437a22';
  }

  const map = L.map('jam-map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    {attribution:'© OpenStreetMap',maxZoom:19}).addTo(map);

  const layers = [];
  jams.forEach(j => {
    if (!j.line || !j.line.length) return;
    const latlngs = j.line.map(p => [parseFloat(p.y), parseFloat(p.x)]);
    const color = levelColor(j.level || 0);
    const delay = j.delay ? (j.delay >= 60 ? Math.ceil(j.delay/60)+'min' : j.delay+'s') : '—';
    const popup = `
      <div style="min-width:190px;font-family:inherit">
        <b style="font-size:13px;color:${color}">Nível ${j.level ?? '?'}</b>
        ${j.blocking ? '<span style="background:#a12c7b;color:#fff;border-radius:20px;padding:1px 7px;font-size:10px;margin-left:6px">Bloqueado</span>' : ''}
        <div style="font-size:12px;font-weight:500;margin-top:4px">${j.street||'Via não identificada'}</div>
        ${j.city ? '<div style="font-size:11px;opacity:.6">'+j.city+'</div>' : ''}
        <div style="display:flex;gap:8px;margin-top:6px;flex-wrap:wrap">
          ${j.speedKmh!==null ? '<span style="background:#f0f0f0;border-radius:20px;padding:2px 7px;font-size:10px">🞥 '+parseFloat(j.speedKmh).toFixed(1)+' km/h</span>' : ''}
          ${j.length ? '<span style="background:#f0f0f0;border-radius:20px;padding:2px 7px;font-size:10px">📍 '+(j.length/1000).toFixed(2)+' km</span>' : ''}
          <span style="background:#f0f0f0;border-radius:20px;padding:2px 7px;font-size:10px">⏱ ${delay}</span>
        </div>
        <a href="/congestionamentos/${j.id}" style="display:block;margin-top:8px;font-size:11px;color:#01696f;text-decoration:none;font-weight:600">🔗 Ver detalhes</a>
      </div>`;
    const pl = L.polyline(latlngs, {color, weight: 5, opacity: 0.85}).bindPopup(popup, {maxWidth:260});
    pl.addTo(map);
    layers.push(pl);
  });

  if (layers.length) {
    map.fitBounds(L.featureGroup(layers).getBounds().pad(0.1));
  } else {
    map.setView([-19.92, -43.94], 11);
  }
})();
</script>
{% endblock %}
