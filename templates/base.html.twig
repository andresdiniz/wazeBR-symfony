<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{% block title %}WazeBR{% endblock %} — Monitoramento</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%2301696f'/><path d='M8 22 L16 8 L24 22' fill='none' stroke='white' stroke-width='3' stroke-linejoin='round'/><circle cx='16' cy='25' r='2.5' fill='white'/></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ══ TOKENS ════════════════════════════════════════════════════════════════════ */
    :root,[data-theme=light]{
      /* type — fluid scale */
      --text-xs:  clamp(.7rem,  .65rem + .25vw, .8rem);
      --text-sm:  clamp(.8rem,  .75rem + .3vw,  1rem);
      --text-base:clamp(.9rem,  .85rem + .3vw,  1.1rem);
      --text-lg:  clamp(1rem,   .9rem  + .5vw,  1.35rem);
      --text-xl:  clamp(1.1rem, .9rem  + .8vw,  1.75rem);
      --text-2xl: clamp(1.4rem, 1rem   + 1.5vw, 2.5rem);
      /* spacing */
      --space-1:.25rem;--space-2:.5rem;--space-3:.75rem;--space-4:1rem;
      --space-5:1.25rem;--space-6:1.5rem;--space-8:2rem;--space-10:2.5rem;
      --space-12:3rem;--space-16:4rem;
      /* radius */
      --radius-sm:.375rem;--radius-md:.5rem;--radius-lg:.75rem;--radius-xl:1rem;--radius-full:9999px;
      /* colors — light */
      --color-bg:#f7f6f2;--color-surface:#f9f8f5;--color-surface-2:#fbfbf9;
      --color-surface-offset:#f3f0ec;--color-surface-dynamic:#e6e4df;
      --color-divider:#dcd9d5;--color-border:#d4d1ca;
      --color-text:#28251d;--color-text-muted:#7a7974;--color-text-faint:#bab9b4;
      --color-primary:#01696f;--color-primary-hover:#0c4e54;--color-primary-active:#0f3638;
      --color-primary-highlight:#cedcd8;
      --color-error:#a12c7b;--color-error-hover:#7d1e5e;
      --color-success:#437a22;--color-success-hover:#2e5c10;
      --color-warning:#964219;--color-orange:#da7101;
      --color-gold:#d19900;
      --shadow-sm:0 1px 2px oklch(0.2 0.01 80/.06);
      --shadow-md:0 4px 12px oklch(0.2 0.01 80/.08);
      --shadow-lg:0 12px 32px oklch(0.2 0.01 80/.12);
      --font-body:'Inter','Helvetica Neue',sans-serif;
      --font-display:'Space Grotesk','Helvetica Neue',sans-serif;
      /* layout */
      --sidebar-w:240px;
      --header-h:56px;
      --bottom-nav-h:60px;
      --transition:180ms cubic-bezier(.16,1,.3,1);
    }
    /* TV — scale up everything */
    @media(min-width:1800px){
      :root{
        --text-xs:.85rem;--text-sm:1rem;--text-base:1.125rem;
        --text-lg:1.375rem;--text-xl:1.75rem;--text-2xl:2.5rem;
        --space-4:1.25rem;--space-5:1.5rem;--space-6:2rem;
        --space-8:2.5rem;--space-12:4rem;--space-16:5rem;
        --sidebar-w:280px;--header-h:68px;
      }
    }
    [data-theme=dark]{
      --color-bg:#171614;--color-surface:#1c1b19;--color-surface-2:#201f1d;
      --color-surface-offset:#1d1c1a;--color-surface-dynamic:#2d2c2a;
      --color-divider:#262523;--color-border:#393836;
      --color-text:#cdccca;--color-text-muted:#797876;--color-text-faint:#5a5957;
      --color-primary:#4f98a3;--color-primary-hover:#227f8b;--color-primary-active:#1a626b;
      --color-primary-highlight:#313b3b;
      --color-error:#d163a7;--color-success:#6daa45;--color-warning:#bb653b;
      --color-orange:#fdab43;--color-gold:#e8af34;
      --shadow-sm:0 1px 2px oklch(0 0 0/.2);
      --shadow-md:0 4px 12px oklch(0 0 0/.3);
      --shadow-lg:0 12px 32px oklch(0 0 0/.4);
    }

    /* ══ RESET ════════════════════════════════════════════════════════════════════════ */
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;scroll-behavior:smooth;scroll-padding-top:var(--header-h)}
    body{
      min-height:100dvh;
      font-family:var(--font-body);
      font-size:var(--text-base);
      color:var(--color-text);
      background:var(--color-bg);
      display:grid;
      grid-template-rows:var(--header-h) 1fr;
      grid-template-columns:var(--sidebar-w) 1fr;
      grid-template-areas:'header header' 'sidebar main';
    }
    img,svg{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    button{cursor:pointer;background:none;border:none;font:inherit;color:inherit}
    :focus-visible{outline:2px solid var(--color-primary);outline-offset:3px;border-radius:var(--radius-sm)}
    @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}

    /* ══ HEADER ════════════════════════════════════════════════════════════════════ */
    .header{
      grid-area:header;
      background:var(--color-surface);
      border-bottom:1px solid var(--color-divider);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 var(--space-5);
      position:sticky;top:0;z-index:200;
      box-shadow:var(--shadow-sm);
    }
    .header-brand{display:flex;align-items:center;gap:var(--space-3)}
    .header-logo{width:32px;height:32px;flex-shrink:0}
    @media(min-width:1800px){.header-logo{width:40px;height:40px}}
    .header-title{
      font-family:var(--font-display);font-size:var(--text-lg);
      font-weight:700;color:var(--color-primary);letter-spacing:-.02em;
    }
    .header-badge{
      font-size:var(--text-xs);
      background:oklch(from var(--color-primary) l c h/.12);
      color:var(--color-primary);
      padding:2px 8px;border-radius:var(--radius-full);font-weight:600;
    }
    .header-right{display:flex;align-items:center;gap:var(--space-4)}
    .user-chip{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-text-muted)}
    .user-name{display:none}
    @media(min-width:640px){.user-name{display:inline}}
    .user-avatar{
      width:30px;height:30px;border-radius:var(--radius-full);
      background:oklch(from var(--color-primary) l c h/.15);
      color:var(--color-primary);display:grid;place-items:center;
      font-weight:700;font-size:var(--text-xs);flex-shrink:0;
    }
    @media(min-width:1800px){.user-avatar{width:38px;height:38px;font-size:var(--text-sm)}}
    .btn-icon{
      width:36px;height:36px;border-radius:var(--radius-md);
      display:grid;place-items:center;
      transition:background var(--transition);
      min-width:44px;min-height:44px; /* touch target */
    }
    .btn-icon:hover{background:var(--color-surface-offset)}
    /* hamburger — visible only on mobile */
    .btn-menu{display:grid;place-items:center;min-width:44px;min-height:44px}
    @media(min-width:768px){.btn-menu{display:none}}

    /* ══ SIDEBAR ══════════════════════════════════════════════════════════════════════════ */
    .sidebar{
      grid-area:sidebar;
      background:var(--color-surface);
      border-right:1px solid var(--color-divider);
      padding:var(--space-4) 0;
      overflow-y:auto;
      position:sticky;
      top:var(--header-h);
      height:calc(100dvh - var(--header-h));
      transition:transform var(--transition),width var(--transition);
      z-index:150;
    }
    .nav-section{margin-bottom:var(--space-2)}
    .nav-label{
      font-size:var(--text-xs);font-weight:600;text-transform:uppercase;
      letter-spacing:.06em;color:var(--color-text-faint);
      padding:var(--space-3) var(--space-4) var(--space-1);
    }
    .nav-item{
      display:flex;align-items:center;gap:var(--space-3);
      padding:var(--space-2) var(--space-4);
      font-size:var(--text-sm);color:var(--color-text-muted);
      border-radius:0;transition:all var(--transition);
      border-left:2px solid transparent;
      min-height:44px; /* touch target */
    }
    .nav-item:hover{color:var(--color-text);background:var(--color-surface-offset)}
    .nav-item.active{
      color:var(--color-primary);
      background:oklch(from var(--color-primary) l c h/.08);
      border-left-color:var(--color-primary);font-weight:500;
    }
    /* Tela Live — destaque especial com pulso */
    .nav-item-live{
      display:flex;align-items:center;gap:var(--space-3);
      padding:var(--space-2) var(--space-4);
      font-size:var(--text-sm);color:var(--color-text-muted);
      border-radius:0;transition:all var(--transition);
      border-left:2px solid transparent;
      min-height:44px;
    }
    .nav-item-live:hover{color:var(--color-text);background:var(--color-surface-offset)}
    .nav-item-live.active{
      color:var(--color-primary);
      background:oklch(from var(--color-primary) l c h/.08);
      border-left-color:var(--color-primary);font-weight:500;
    }
    .nav-live-dot{
      width:7px;height:7px;border-radius:50%;
      background:var(--color-success);
      flex-shrink:0;margin-left:auto;
      box-shadow:0 0 0 0 oklch(from var(--color-success) l c h/.4);
      animation:live-pulse 2s ease-in-out infinite;
    }
    @keyframes live-pulse{
      0%,100%{box-shadow:0 0 0 0 oklch(from var(--color-success) l c h/.4)}
      50%{box-shadow:0 0 0 5px oklch(from var(--color-success) l c h/0)}
    }
    @media(prefers-reduced-motion:reduce){.nav-live-dot{animation:none}}
    .nav-item svg,.nav-item [data-lucide]{flex-shrink:0;width:17px;height:17px}
    .nav-item-live svg,.nav-item-live [data-lucide]{flex-shrink:0;width:17px;height:17px}
    @media(min-width:1800px){
      .nav-item{font-size:var(--text-base);padding:var(--space-3) var(--space-6);min-height:52px}
      .nav-item-live{font-size:var(--text-base);padding:var(--space-3) var(--space-6);min-height:52px}
      .nav-label{padding:var(--space-4) var(--space-6) var(--space-2);font-size:var(--text-sm)}
      .nav-item svg,.nav-item [data-lucide]{width:20px;height:20px}
      .nav-item-live svg,.nav-item-live [data-lucide]{width:20px;height:20px}
      .nav-live-dot{width:9px;height:9px}
    }

    /* Mobile: sidebar off-canvas */
    @media(max-width:767px){
      body{
        grid-template-columns:1fr;
        grid-template-areas:'header' 'main';
        padding-bottom:var(--bottom-nav-h);
      }
      .sidebar{
        position:fixed;
        top:var(--header-h);
        left:0;
        width:min(280px,85vw);
        height:calc(100dvh - var(--header-h));
        transform:translateX(-110%);
        box-shadow:var(--shadow-lg);
        z-index:300;
      }
      .sidebar.open{transform:translateX(0)}
      .sidebar-overlay{
        display:none;
        position:fixed;inset:0;
        background:oklch(0.1 0 0/.45);
        z-index:290;
        backdrop-filter:blur(2px);
      }
      .sidebar-overlay.visible{display:block}
    }

    /* ══ MAIN ══════════════════════════════════════════════════════════════════════════════ */
    main{
      grid-area:main;
      padding:var(--space-6);
      overflow-y:auto;
      min-height:0;
      max-width:100%;
    }
    @media(min-width:1800px){main{padding:var(--space-8) var(--space-12)}}
    @media(max-width:480px){main{padding:var(--space-4)}}

    @media(min-width:1800px){
      .content-wrap{max-width:1600px;margin-inline:auto}
    }

    /* ══ BOTTOM NAV (mobile only) ══════════════════════════════════════════════════════════ */
    .bottom-nav{
      display:none;
      position:fixed;
      bottom:0;left:0;right:0;
      height:var(--bottom-nav-h);
      background:var(--color-surface);
      border-top:1px solid var(--color-divider);
      z-index:200;
      padding:0 var(--space-2);
      padding-bottom:env(safe-area-inset-bottom,0);
      gap:var(--space-1);
      align-items:center;justify-content:space-around;
      box-shadow:0 -4px 16px oklch(0.2 0.01 80/.08);
    }
    @media(max-width:767px){.bottom-nav{display:flex}}
    .bottom-nav-item{
      display:flex;flex-direction:column;align-items:center;
      gap:3px;flex:1;
      font-size:clamp(.6rem,.5rem + .5vw,.75rem);
      color:var(--color-text-muted);
      padding:var(--space-2) var(--space-1);
      border-radius:var(--radius-md);
      min-height:44px;min-width:44px;
      transition:color var(--transition),background var(--transition);
    }
    .bottom-nav-item:hover,.bottom-nav-item.active{
      color:var(--color-primary);
      background:oklch(from var(--color-primary) l c h/.08);
    }
    .bottom-nav-item svg,.bottom-nav-item [data-lucide]{width:20px;height:20px}
    /* Live indicator no bottom nav */
    .bottom-nav-live{position:relative}
    .bottom-nav-live::after{
      content:'';position:absolute;top:6px;right:calc(50% - 14px);
      width:7px;height:7px;border-radius:50%;
      background:var(--color-success);
      border:2px solid var(--color-surface);
    }

    /* ══ COMPONENTS ════════════════════════════════════════════════════════════════════════════════════════ */
    .page-header{margin-bottom:var(--space-6)}
    .page-title{
      font-family:var(--font-display);
      font-size:var(--text-xl);font-weight:700;
      color:var(--color-text);letter-spacing:-.02em;
    }
    .page-subtitle{font-size:var(--text-sm);color:var(--color-text-muted);margin-top:var(--space-1)}

    .card{
      background:var(--color-surface);
      border:1px solid var(--color-border);
      border-radius:var(--radius-lg);
      overflow:hidden;box-shadow:var(--shadow-sm);
    }
    .card-header{
      display:flex;align-items:center;justify-content:space-between;
      padding:var(--space-4) var(--space-5);
      border-bottom:1px solid var(--color-divider);
    }
    .card-title{font-weight:600;font-size:var(--text-sm)}

    /* responsive tables */
    .table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
    table{width:100%;border-collapse:collapse}
    th{
      font-size:var(--text-xs);font-weight:600;text-transform:uppercase;
      letter-spacing:.04em;color:var(--color-text-muted);
      padding:var(--space-2) var(--space-4);
      text-align:left;border-bottom:1px solid var(--color-divider);white-space:nowrap;
    }
    td{
      padding:var(--space-3) var(--space-4);
      font-size:var(--text-sm);
      border-bottom:1px solid oklch(from var(--color-divider) l c h/.5);
    }
    tr:last-child td{border-bottom:none}
    tr:hover td{background:var(--color-surface-offset)}
    @media(min-width:1800px){th,td{padding:var(--space-3) var(--space-6);font-size:var(--text-base)}}

    .btn{
      display:inline-flex;align-items:center;gap:var(--space-2);
      padding:var(--space-2) var(--space-4);
      font-size:var(--text-sm);font-weight:500;
      border-radius:var(--radius-md);
      border:1px solid transparent;
      transition:all var(--transition);
      text-decoration:none;cursor:pointer;
      min-height:44px; /* touch target */
    }
    .btn-primary{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
    .btn-primary:hover{background:var(--color-primary-hover)}
    .btn-ghost{color:var(--color-text-muted);border-color:var(--color-border)}
    .btn-ghost:hover{background:var(--color-surface-offset);color:var(--color-text)}
    .btn-sm{padding:var(--space-1) var(--space-3);font-size:var(--text-xs);min-height:36px}
    @media(min-width:1800px){.btn{font-size:var(--text-base);min-height:52px}}

    .badge{
      display:inline-flex;align-items:center;gap:4px;
      padding:2px 8px;font-size:var(--text-xs);
      font-weight:600;border-radius:var(--radius-full);
    }
    .badge-gray{background:var(--color-surface-offset);color:var(--color-text-muted)}
    .badge-red{background:oklch(from var(--color-error) l c h/.12);color:var(--color-error)}
    .badge-orange{background:oklch(from var(--color-orange) l c h/.12);color:var(--color-orange)}
    .badge-yellow{background:oklch(from var(--color-gold) l c h/.12);color:var(--color-gold)}
    .badge-green{background:oklch(from var(--color-success) l c h/.12);color:var(--color-success)}

    .form-group{margin-bottom:var(--space-4)}
    .form-label{display:block;font-size:var(--text-sm);font-weight:500;margin-bottom:var(--space-2)}
    .form-control{
      width:100%;padding:var(--space-2) var(--space-3);
      font-size:var(--text-sm);
      border:1px solid var(--color-border);border-radius:var(--radius-md);
      background:var(--color-surface-2);color:var(--color-text);
      transition:border-color var(--transition),box-shadow var(--transition);
      min-height:44px;
    }
    .form-control:focus{
      outline:none;border-color:var(--color-primary);
      box-shadow:0 0 0 3px oklch(from var(--color-primary) l c h/.15);
    }
    .form-hint{display:block;font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-1)}

    .flash{
      padding:var(--space-3) var(--space-4);border-radius:var(--radius-md);
      margin-bottom:var(--space-4);font-size:var(--text-sm);font-weight:500;
      display:flex;align-items:center;gap:var(--space-2);
    }
    .flash-success{background:oklch(from var(--color-success) l c h/.1);color:var(--color-success);border:1px solid oklch(from var(--color-success) l c h/.25)}
    .flash-error{background:oklch(from var(--color-error) l c h/.1);color:var(--color-error);border:1px solid oklch(from var(--color-error) l c h/.25)}
    .flash-info{background:oklch(from var(--color-primary) l c h/.1);color:var(--color-primary);border:1px solid oklch(from var(--color-primary) l c h/.25)}

    .kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:var(--space-4);margin-bottom:var(--space-6)}
    @media(min-width:1800px){.kpi-grid{grid-template-columns:repeat(auto-fill,minmax(240px,1fr))}}
    .kpi{
      background:var(--color-surface);border:1px solid var(--color-border);
      border-radius:var(--radius-lg);padding:var(--space-4);box-shadow:var(--shadow-sm);
    }
    .kpi-label{font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--color-text-muted);margin-bottom:var(--space-2)}
    .kpi-value{font-family:var(--font-display);font-size:var(--text-xl);font-weight:700;color:var(--color-text);letter-spacing:-.02em}
    .kpi-sub{font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-1)}

    .empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:var(--space-16) var(--space-8);text-align:center;color:var(--color-text-muted);gap:var(--space-4)}
    .empty h3{color:var(--color-text);font-size:var(--text-lg)}
    .empty p{font-size:var(--text-sm);max-width:36ch}
    .empty svg{width:40px;height:40px;color:var(--color-text-faint)}
  </style>
  {% block stylesheets %}{% endblock %}
</head>
<body>

  <!-- Overlay for mobile sidebar -->
  <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

  <header class="header">
    <div class="header-brand">
      <!-- Hamburger (mobile only) -->
      <button class="btn-menu btn-icon" id="btnMenu" aria-label="Abrir menu" aria-expanded="false" aria-controls="sidebar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <svg class="header-logo" viewBox="0 0 32 32" fill="none" aria-label="WazeBR Logo">
        <rect width="32" height="32" rx="8" fill="var(--color-primary)"/>
        <path d="M8 23 L16 7 L24 23" fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
        <circle cx="16" cy="26" r="2" fill="white"/>
      </svg>
      <span class="header-title">WazeBR</span>
      <span class="header-badge">Monitor</span>
    </div>
    <div class="header-right">
      <button class="btn-icon" data-theme-toggle aria-label="Alternar tema">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>
      {% if app.user %}
      <div class="user-chip">
        <div class="user-avatar">{{ app.user.name|slice(0,1)|upper }}</div>
        <span class="user-name">{{ app.user.name }}</span>
      </div>
      <a href="{{ path('auth_logout') }}" class="btn btn-ghost btn-sm">Sair</a>
      {% endif %}
    </div>
  </header>

  {% set _route = app.request.attributes.get('_route') %}

  <nav class="sidebar" id="sidebar" aria-label="Navegação principal">
    <div class="nav-section">
      <div class="nav-label">Monitoramento</div>
      <a href="{{ path('dashboard_index') }}" class="nav-item {{ _route starts with 'dashboard' ? 'active' }}">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="{{ path('operator_live') }}" class="nav-item-live {{ _route starts with 'operator' ? 'active' }}" title="Tela de operador em tempo real">
        <i data-lucide="monitor"></i> Tela Live
        <span class="nav-live-dot" aria-hidden="true"></span>
      </a>
      <a href="{{ path('alert_index') }}" class="nav-item {{ _route starts with 'alert' ? 'active' }}">
        <i data-lucide="triangle-alert"></i> Alertas
      </a>
      <a href="{{ path('jam_index') }}" class="nav-item {{ _route starts with 'jam' ? 'active' }}">
        <i data-lucide="traffic-cone"></i> Congestionamentos
      </a>
      <a href="{{ path('route_admin_index') }}" class="nav-item {{ _route starts with 'route_admin' ? 'active' }}">
        <i data-lucide="route"></i> Rotas
      </a>
      <a href="{{ path('cemaden_index') }}" class="nav-item {{ _route starts with 'cemaden' ? 'active' }}">
        <i data-lucide="cloud-rain"></i> CEMADEN
      </a>
      {# Rios Ao Vivo: ativo SOMENTE na rota exata hydro_live ou hydro_live_data #}
      <a href="{{ path('hydro_live') }}" class="nav-item-live {{ _route == 'hydro_live' or _route == 'hydro_live_data' ? 'active' }}" title="Nível dos rios em tempo real">
        <i data-lucide="waves"></i> Rios — Ao Vivo
        <span class="nav-live-dot" aria-hidden="true"></span>
      </a>
      {# Rios Histórico: ativo SOMENTE na rota hydro_historico #}
      <a href="{{ path('hydro_historico') }}" class="nav-item {{ _route == 'hydro_historico' ? 'active' }}">
        <i data-lucide="book-open"></i> Rios — Histórico
      </a>
      <a href="{{ path('notification_index') }}" class="nav-item {{ _route starts with 'notification' ? 'active' }}">
        <i data-lucide="bell"></i> Notificações
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-label">Waze — Envio</div>
      <a href="{{ path('cifs_index') }}" class="nav-item {{ _route starts with 'cifs' ? 'active' }}" title="Criar e gerenciar eventos enviados ao Waze (CIFS)">
        <i data-lucide="send"></i> Enviar Alertas
      </a>
    </div>

    {# Minha Conta — visível para ROLE_ACCOUNT_ADMIN (exceto super admin que usa painel admin) #}
    {% if is_granted('ROLE_ACCOUNT_ADMIN') and not is_granted('ROLE_ADMIN') %}
    <div class="nav-section">
      <div class="nav-label">Minha Conta</div>
      <a href="{{ path('account_link_index') }}" class="nav-item {{ _route starts with 'account_link' ? 'active' }}">
        <i data-lucide="link"></i> Meus Links
      </a>
      <a href="{{ path('account_settings') }}" class="nav-item {{ _route == 'account_settings' ? 'active' }}">
        <i data-lucide="timer"></i> Intervalo de Coleta
      </a>
      <a href="{{ path('account_logs') }}" class="nav-item {{ _route == 'account_logs' ? 'active' }}">
        <i data-lucide="file-warning"></i> Logs de Erros
      </a>
    </div>
    {% endif %}

    {% if is_granted('ROLE_ADMIN') %}
    <div class="nav-section">
      <div class="nav-label">Administração</div>
      <a href="{{ path('admin_link_index') }}" class="nav-item {{ _route starts with 'admin_link' ? 'active' }}">
        <i data-lucide="link"></i> Links Monitorados
      </a>
      <a href="{{ path('admin_city_index') }}" class="nav-item {{ _route starts with 'admin_city' ? 'active' }}">
        <i data-lucide="map-pin"></i> Cidades / Clima
      </a>
      <a href="{{ path('admin_station_index') }}" class="nav-item {{ _route starts with 'admin_station' ? 'active' }}">
        <i data-lucide="radio-tower"></i> Estações CEMADEN
      </a>
      <a href="{{ path('admin_settings_index') }}" class="nav-item {{ _route starts with 'admin_settings' ? 'active' }}">
        <i data-lucide="settings"></i> Configurações
      </a>
    </div>
    {% endif %}

    {% if is_granted('ROLE_SUPER_ADMIN') %}
    <div class="nav-section">
      <div class="nav-label">Super Admin</div>
      <a href="{{ path('admin_partner_index') }}" class="nav-item {{ _route starts with 'admin_partner' ? 'active' }}">
        <i data-lucide="building-2"></i> Parceiros
      </a>
    </div>
    {% endif %}
  </nav>

  <main>
    <div class="content-wrap">
      {% for type, messages in app.flashes %}
        {% for msg in messages %}
          <div class="flash flash-{{ type == 'success' ? 'success' : (type == 'error' ? 'error' : 'info') }}">
            <i data-lucide="{{ type == 'success' ? 'check-circle' : (type == 'error' ? 'x-circle' : 'info') }}" style="width:16px;height:16px"></i>
            {{ msg }}
          </div>
        {% endfor %}
      {% endfor %}

      {% block content %}{% endblock %}
    </div>
  </main>

  <!-- Bottom nav (mobile) -->
  <nav class="bottom-nav" aria-label="Navegação rápida">
    <a href="{{ path('dashboard_index') }}" class="bottom-nav-item {{ _route starts with 'dashboard' ? 'active' }}" aria-label="Dashboard">
      <i data-lucide="layout-dashboard"></i>
      <span>Dashboard</span>
    </a>
    <a href="{{ path('operator_live') }}" class="bottom-nav-item bottom-nav-live {{ _route starts with 'operator' ? 'active' }}" aria-label="Tela Live">
      <i data-lucide="monitor"></i>
      <span>Live</span>
    </a>
    <a href="{{ path('hydro_live') }}" class="bottom-nav-item bottom-nav-live {{ _route starts with 'hydro' ? 'active' }}" aria-label="Rios ao vivo">
      <i data-lucide="waves"></i>
      <span>Rios</span>
    </a>
    {% if is_granted('ROLE_ACCOUNT_ADMIN') and not is_granted('ROLE_ADMIN') %}
    <a href="{{ path('account_settings') }}" class="bottom-nav-item {{ _route == 'account_settings' or _route == 'account_logs' ? 'active' }}" aria-label="Minha Conta">
      <i data-lucide="settings-2"></i>
      <span>Conta</span>
    </a>
    {% else %}
    <a href="{{ path('cifs_index') }}" class="bottom-nav-item {{ _route starts with 'cifs' ? 'active' }}" aria-label="Enviar Alertas ao Waze">
      <i data-lucide="send"></i>
      <span>Alertas</span>
    </a>
    {% endif %}
    <!-- More button opens sidebar -->
    <button class="bottom-nav-item" id="btnMenuBottom" aria-label="Mais opções">
      <i data-lucide="menu"></i>
      <span>Mais</span>
    </button>
  </nav>

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    lucide.createIcons();

    /* ── Tema ── */
    (function(){
      const t=document.querySelector('[data-theme-toggle]'),r=document.documentElement;
      let d=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');
      r.setAttribute('data-theme',d);
      t&&t.addEventListener('click',()=>{
        d=d==='dark'?'light':'dark';
        r.setAttribute('data-theme',d);
        try{localStorage.setItem('theme',d)}catch(e){}
      });
    })();

    /* ── Mobile sidebar toggle ── */
    (function(){
      const sidebar  = document.getElementById('sidebar');
      const overlay  = document.getElementById('sidebarOverlay');
      const btnMenu  = document.getElementById('btnMenu');
      const btnBottom= document.getElementById('btnMenuBottom');
      if(!sidebar) return;

      function open(){
        sidebar.classList.add('open');
        overlay.classList.add('visible');
        btnMenu && btnMenu.setAttribute('aria-expanded','true');
        document.body.style.overflow='hidden';
      }
      function close(){
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
        btnMenu && btnMenu.setAttribute('aria-expanded','false');
        document.body.style.overflow='';
      }
      btnMenu   && btnMenu.addEventListener('click', ()=> sidebar.classList.contains('open') ? close() : open());
      btnBottom && btnBottom.addEventListener('click', ()=> sidebar.classList.contains('open') ? close() : open());
      overlay.addEventListener('click', close);
      /* close on nav click (mobile) */
      sidebar.querySelectorAll('.nav-item,.nav-item-live').forEach(el => el.addEventListener('click', ()=>{
        if(window.innerWidth < 768) close();
      }));
      /* ESC closes */
      document.addEventListener('keydown', e => { if(e.key==='Escape') close(); });
    })();

    /* ── WazeTZ ── */
    const WazeTZ = {
      TZ: 'America/Sao_Paulo',
      FMT_FULL: new Intl.DateTimeFormat('pt-BR', {timeZone:'America/Sao_Paulo',day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}),
      FMT_DATE: new Intl.DateTimeFormat('pt-BR', {timeZone:'America/Sao_Paulo',day:'2-digit',month:'2-digit',year:'numeric'}),
      FMT_TIME: new Intl.DateTimeFormat('pt-BR', {timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit'}),
      format:     function(v){ const d=new Date(v); return isNaN(d)?'—':this.FMT_FULL.format(d); },
      formatDate: function(v){ const d=new Date(v); return isNaN(d)?'—':this.FMT_DATE.format(d); },
      formatTime: function(v){ const d=new Date(v); return isNaN(d)?'—':this.FMT_TIME.format(d); }
    };
    document.addEventListener('DOMContentLoaded', function(){
      document.querySelectorAll('time[data-utc]').forEach(function(el){
        const iso=el.getAttribute('data-utc'), fmt=el.getAttribute('data-fmt')||'datetime';
        if(!iso) return;
        el.textContent = fmt==='date' ? WazeTZ.formatDate(iso) : fmt==='time' ? WazeTZ.formatTime(iso) : WazeTZ.format(iso);
      });
    });
  </script>
  {% block javascripts %}{% endblock %}
</body>
</html>