<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}WazeBR{% endblock %} — WazeBR Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest" defer></script>
  {% block stylesheets %}
  {% endblock %}
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;scroll-behavior:smooth}
    :root,[data-theme="light"]{
      --color-bg:#f7f6f2;--color-surface:#f9f8f5;--color-surface-2:#fbfbf9;
      --color-surface-offset:#f3f0ec;--color-surface-dynamic:#e6e4df;
      --color-divider:#dcd9d5;--color-border:#d4d1ca;
      --color-text:#28251d;--color-text-muted:#7a7974;--color-text-faint:#bab9b4;
      --color-primary:#01696f;--color-primary-hover:#0c4e54;--color-primary-highlight:#cedcd8;
      --color-error:#a12c7b;--color-success:#437a22;--color-gold:#d19900;--color-orange:#da7101;
      --color-warning:#964219;--color-blue:#006494;--color-notification:#a13544;
      --radius-sm:.375rem;--radius-md:.5rem;--radius-lg:.75rem;--radius-xl:1rem;--radius-full:9999px;
      --space-1:.25rem;--space-2:.5rem;--space-3:.75rem;--space-4:1rem;--space-5:1.25rem;
      --space-6:1.5rem;--space-8:2rem;--space-10:2.5rem;--space-12:3rem;--space-16:4rem;
      --text-xs:clamp(.75rem,.7rem + .25vw,.875rem);--text-sm:clamp(.875rem,.8rem + .35vw,1rem);
      --text-base:clamp(1rem,.95rem + .25vw,1.125rem);--text-lg:clamp(1.125rem,1rem + .75vw,1.5rem);
      --text-xl:clamp(1.5rem,1.2rem + 1.25vw,2.25rem);
      --shadow-sm:0 1px 2px oklch(.2 .01 80/.06);--shadow-md:0 4px 12px oklch(.2 .01 80/.08);
      --shadow-lg:0 12px 32px oklch(.2 .01 80/.12);
      --transition-interactive:180ms cubic-bezier(.16,1,.3,1);
      --font-body:'Inter','Helvetica Neue',sans-serif;
      --sidebar-w:240px;--header-h:56px;
    }
    [data-theme="dark"]{
      --color-bg:#171614;--color-surface:#1c1b19;--color-surface-2:#201f1d;
      --color-surface-offset:#1d1c1a;--color-surface-dynamic:#2d2c2a;
      --color-divider:#262523;--color-border:#393836;
      --color-text:#cdccca;--color-text-muted:#797876;--color-text-faint:#5a5957;
      --color-primary:#4f98a3;--color-primary-hover:#227f8b;--color-primary-highlight:#313b3b;
      --color-error:#d163a7;--color-success:#6daa45;--color-gold:#e8af34;--color-orange:#fdab43;
      --color-warning:#bb653b;--color-blue:#5591c7;--color-notification:#dd6974;
      --shadow-sm:0 1px 2px oklch(0 0 0/.2);--shadow-md:0 4px 12px oklch(0 0 0/.3);
      --shadow-lg:0 12px 32px oklch(0 0 0/.4);
    }
    body{min-height:100dvh;font-family:var(--font-body);font-size:var(--text-base);color:var(--color-text);background:var(--color-bg);line-height:1.6}
    img,picture,video,canvas,svg{display:block;max-width:100%;height:auto}
    input,button,textarea,select{font:inherit;color:inherit}
    button{cursor:pointer;background:none;border:none}
    table{border-collapse:collapse;width:100%}
    a{color:inherit;text-decoration:none}
    :focus-visible{outline:2px solid var(--color-primary);outline-offset:3px;border-radius:var(--radius-sm)}
    /* Layout */
    .app-shell{display:grid;grid-template-columns:var(--sidebar-w) 1fr;grid-template-rows:var(--header-h) 1fr;min-height:100dvh}
    /* Header */
    .app-header{grid-column:1/-1;display:flex;align-items:center;background:var(--color-surface);border-bottom:1px solid var(--color-border);padding:0 var(--space-4);gap:var(--space-4);position:sticky;top:0;z-index:100}
    .header-logo{display:flex;align-items:center;gap:var(--space-2);font-weight:700;font-size:var(--text-sm);letter-spacing:-.01em;color:var(--color-primary);width:calc(var(--sidebar-w) - var(--space-6) - var(--space-4))}
    .header-spacer{flex:1}
    .icon-btn{display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:var(--radius-md);color:var(--color-text-muted);position:relative;transition:background var(--transition-interactive),color var(--transition-interactive)}
    .icon-btn:hover{background:var(--color-surface-offset);color:var(--color-text)}
    .notif-badge{position:absolute;top:6px;right:6px;width:8px;height:8px;border-radius:var(--radius-full);background:var(--color-error);border:2px solid var(--color-surface)}
    .header-user{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-text-muted);padding:var(--space-2) var(--space-3);border-radius:var(--radius-md);transition:background var(--transition-interactive)}
    .header-user:hover{background:var(--color-surface-offset);color:var(--color-text)}
    .avatar{width:28px;height:28px;border-radius:var(--radius-full);background:var(--color-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
    /* Notif dropdown */
    .notif-wrap{position:relative}
    .notif-dropdown{position:absolute;top:calc(100% + 8px);right:0;width:320px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);z-index:200;display:none}
    .notif-dropdown.open{display:block}
    .notif-dropdown-header{display:flex;align-items:center;justify-content:space-between;padding:var(--space-3) var(--space-4);border-bottom:1px solid var(--color-divider);font-size:var(--text-sm);font-weight:600}
    .notif-item{padding:var(--space-3) var(--space-4);border-bottom:1px solid var(--color-divider);font-size:var(--text-sm)}
    .notif-item:last-child{border-bottom:none}
    .notif-item-title{font-weight:500;color:var(--color-text);margin-bottom:2px}
    .notif-item-body{color:var(--color-text-muted);font-size:var(--text-xs)}
    /* Sidebar */
    .sidebar{background:var(--color-surface);border-right:1px solid var(--color-border);padding:var(--space-4) var(--space-3);overflow-y:auto}
    .nav-section{margin-bottom:var(--space-6)}
    .nav-label{font-size:var(--text-xs);font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--color-text-faint);padding:0 var(--space-2);margin-bottom:var(--space-2)}
    .nav-item{display:flex;align-items:center;gap:var(--space-3);padding:var(--space-2) var(--space-3);border-radius:var(--radius-md);font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:2px;transition:background var(--transition-interactive),color var(--transition-interactive)}
    .nav-item:hover{background:var(--color-surface-offset);color:var(--color-text)}
    .nav-item.active{background:var(--color-primary-highlight);color:var(--color-primary);font-weight:600}
    .nav-item.active svg{color:var(--color-primary)}
    .nav-item svg{flex-shrink:0;width:16px;height:16px}
    @media(max-width:768px){.app-shell{grid-template-columns:1fr}.sidebar{display:none}.header-logo{width:auto}}
    /* Main */
    .main-content{overflow-y:auto;padding:var(--space-8);background:var(--color-bg)}
    /* Components */
    .page-header{margin-bottom:var(--space-8)}
    .page-title{font-size:var(--text-xl);font-weight:700;line-height:1.2;color:var(--color-text)}
    .page-subtitle{font-size:var(--text-sm);color:var(--color-text-muted);margin-top:var(--space-1)}
    .card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);box-shadow:var(--shadow-sm)}
    .card-header{display:flex;align-items:center;justify-content:space-between;padding:var(--space-4) var(--space-6);border-bottom:1px solid var(--color-divider)}
    .card-title{font-size:var(--text-sm);font-weight:600;color:var(--color-text)}
    .kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:var(--space-4);margin-bottom:var(--space-6)}
    .kpi-card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-5);display:flex;flex-direction:column;gap:var(--space-2);box-shadow:var(--shadow-sm)}
    .kpi-icon{width:40px;height:40px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center}
    .kpi-label{font-size:var(--text-xs);color:var(--color-text-muted);font-weight:500;text-transform:uppercase;letter-spacing:.04em}
    .kpi-value{font-size:var(--text-xl);font-weight:700;color:var(--color-text);line-height:1.1;font-variant-numeric:tabular-nums}
    table thead th{font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--color-text-muted);padding:var(--space-3) var(--space-4);border-bottom:1px solid var(--color-border);white-space:nowrap;text-align:left}
    table tbody td{padding:var(--space-3) var(--space-4);border-bottom:1px solid var(--color-divider);font-size:var(--text-sm);vertical-align:middle}
    table tbody tr:last-child td{border-bottom:none}
    .badge{display:inline-flex;align-items:center;padding:2px var(--space-2);border-radius:var(--radius-full);font-size:10px;font-weight:700;letter-spacing:.03em;text-transform:uppercase;white-space:nowrap}
    .badge-gray{background:var(--color-surface-offset);color:var(--color-text-muted)}
    .btn{display:inline-flex;align-items:center;gap:var(--space-2);padding:var(--space-2) var(--space-4);border-radius:var(--radius-md);font-size:var(--text-sm);font-weight:500;cursor:pointer;transition:background var(--transition-interactive),color var(--transition-interactive),border-color var(--transition-interactive);border:1px solid transparent}
    .btn-primary{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
    .btn-primary:hover{background:var(--color-primary-hover)}
    .btn-ghost{background:transparent;color:var(--color-text-muted);border-color:var(--color-border)}
    .btn-ghost:hover{background:var(--color-surface-offset);color:var(--color-text)}
    .btn-danger{background:var(--color-error);color:#fff;border-color:var(--color-error)}
    .btn-sm{padding:var(--space-1) var(--space-3);font-size:var(--text-xs)}
    .empty{display:flex;flex-direction:column;align-items:center;text-align:center;padding:var(--space-16) var(--space-8);color:var(--color-text-muted);gap:var(--space-4)}
    .empty h3{color:var(--color-text)}
    .flash{padding:var(--space-3) var(--space-4);border-radius:var(--radius-md);font-size:var(--text-sm);margin-bottom:var(--space-4)}
    .flash-success{background:oklch(from var(--color-success) l c h/.12);color:var(--color-success);border:1px solid oklch(from var(--color-success) l c h/.3)}
    .flash-error{background:oklch(from var(--color-error) l c h/.12);color:var(--color-error);border:1px solid oklch(from var(--color-error) l c h/.3)}
    .form-group{display:flex;flex-direction:column;gap:var(--space-2);margin-bottom:var(--space-4)}
    .form-label{font-size:var(--text-sm);font-weight:500;color:var(--color-text)}
    .form-control{padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);color:var(--color-text);font-size:var(--text-sm);transition:border-color var(--transition-interactive),box-shadow var(--transition-interactive)}
    .form-control:focus{outline:none;border-color:var(--color-primary);box-shadow:0 0 0 3px oklch(from var(--color-primary) l c h/.15)}
    select.form-control{cursor:pointer}
    .form-hint{font-size:var(--text-xs);color:var(--color-text-muted)}
  </style>
</head>
<body>
<div class="app-shell">
  <header class="app-header">
    <div class="header-logo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-label="WazeBR" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" fill="var(--color-primary)" opacity=".15"/>
        <path d="M6 12c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"/>
        <circle cx="9" cy="14" r="1.5" fill="var(--color-primary)"/>
        <circle cx="15" cy="14" r="1.5" fill="var(--color-primary)"/>
        <path d="M9 17c.8 1 1.6 1.5 3 1.5s2.2-.5 3-1.5" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      WazeBR
    </div>
    <div class="header-spacer"></div>
    <div class="notif-wrap">
      <button class="icon-btn" id="notif-btn" aria-label="Notificações">
        <i data-lucide="bell" style="width:18px;height:18px"></i>
        <span class="notif-badge" id="notif-badge" style="display:none"></span>
      </button>
      <div class="notif-dropdown" id="notif-dropdown">
        <div class="notif-dropdown-header">
          <span>Notificações</span>
          <button id="notif-clear" style="font-size:var(--text-xs);color:var(--color-text-muted)">Marcar todas lidas</button>
        </div>
        <div id="notif-list"><div class="empty" style="padding:var(--space-8)"><p>Nenhuma notificação.</p></div></div>
        <div style="padding:var(--space-3) var(--space-4);border-top:1px solid var(--color-divider);text-align:center">
          <a href="{{ path('notification_index') }}" style="font-size:var(--text-xs);color:var(--color-primary)">Ver todas</a>
        </div>
      </div>
    </div>
    <button class="icon-btn" id="theme-toggle" data-theme-toggle aria-label="Alternar tema">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <a href="{{ path('auth_logout') }}" class="header-user" title="Sair">
      <div class="avatar">{{ app.user ? app.user.email|slice(0,2)|upper : 'US' }}</div>
      <span style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ app.user ? app.user.email : '' }}</span>
      <i data-lucide="log-out" style="width:14px;height:14px;color:var(--color-text-muted)"></i>
    </a>
  </header>

  <nav class="sidebar" aria-label="Navegação principal">
    <div class="nav-section">
      <div class="nav-label">Monitoramento</div>
      <a href="{{ path('dashboard_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'dashboard' ? 'active' }}">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="{{ path('alert_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'alert' ? 'active' }}">
        <i data-lucide="triangle-alert"></i> Alertas
      </a>
      <a href="{{ path('jam_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'jam' ? 'active' }}">
        <i data-lucide="traffic-cone"></i> Congestionamentos
      </a>
      <a href="{{ path('route_admin_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'route_admin' ? 'active' }}">
        <i data-lucide="route"></i> Rotas
      </a>
      <a href="{{ path('cemaden_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'cemaden' ? 'active' }}">
        <i data-lucide="cloud-rain"></i> CEMADEN
      </a>
      <a href="{{ path('notification_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'notification' ? 'active' }}">
        <i data-lucide="bell"></i> Notificações
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-label">Administração</div>
      <a href="{{ path('admin_link_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_link' ? 'active' }}">
        <i data-lucide="link"></i> Links Monitorados
      </a>
      <a href="{{ path('admin_city_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_city' ? 'active' }}">
        <i data-lucide="map-pin"></i> Cidades / Clima
      </a>
      <a href="{{ path('admin_station_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_station' ? 'active' }}">
        <i data-lucide="radio-tower"></i> Estações CEMADEN
      </a>
      <a href="{{ path('admin_settings_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_settings' ? 'active' }}">
        <i data-lucide="settings"></i> Configurações
      </a>
    </div>

    {% if is_granted('ROLE_SUPER_ADMIN') %}
    <div class="nav-section">
      <div class="nav-label">Super Admin</div>
      <a href="{{ path('partner_admin_index') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'partner_admin' ? 'active' }}">
        <i data-lucide="building-2"></i> Parceiros
      </a>
    </div>
    {% endif %}
  </nav>

  <main class="main-content">
    {% for msg in app.flashes('success') %}
      <div class="flash flash-success">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
      <div class="flash flash-error">{{ msg }}</div>
    {% endfor %}
    {% block content %}{% endblock %}
  </main>
</div>

{% block javascripts %}{% endblock %}

<script>
// Theme toggle
(function(){
  const r=document.documentElement;
  const t=document.getElementById('theme-toggle');
  let d=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
  r.setAttribute('data-theme',d);
  if(t) t.addEventListener('click',()=>{
    d=d==='dark'?'light':'dark';
    r.setAttribute('data-theme',d);
  });
})();

// Lucide icons
if(typeof lucide!=='undefined') lucide.createIcons();
document.addEventListener('DOMContentLoaded',()=>{ if(typeof lucide!=='undefined') lucide.createIcons(); });

// WazeTZ — converte datas UTC para fuso do usuário
window.WazeTZ=(function(){
  const tz=Intl.DateTimeFormat().resolvedOptions().timeZone;
  const FMT_FULL  =new Intl.DateTimeFormat('pt-BR',{timeZone:tz,day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
  const FMT_DATE  =new Intl.DateTimeFormat('pt-BR',{timeZone:tz,day:'2-digit',month:'2-digit',year:'numeric'});
  const FMT_TIME  =new Intl.DateTimeFormat('pt-BR',{timeZone:tz,hour:'2-digit',minute:'2-digit'});
  const FMT_DTIME =new Intl.DateTimeFormat('pt-BR',{timeZone:tz,day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
  function rel(d){
    const s=Math.floor((Date.now()-d)/1000);
    if(s<60) return 'agora';
    if(s<3600) return `há ${Math.floor(s/60)} min`;
    if(s<86400) return `há ${Math.floor(s/3600)}h`;
    return FMT_DATE.format(d);
  }
  function applyAll(){
    document.querySelectorAll('time[data-utc]').forEach(el=>{
      try{
        const d=new Date(el.dataset.utc);
        const fmt=el.dataset.fmt||'datetime';
        if(fmt==='datetime') el.textContent=FMT_FULL.format(d);
        else if(fmt==='date') el.textContent=FMT_DATE.format(d);
        else if(fmt==='time') el.textContent=FMT_TIME.format(d);
        else if(fmt==='dtime') el.textContent=FMT_DTIME.format(d);
        else if(fmt==='relative'){el.textContent=rel(d);setInterval(()=>el.textContent=rel(d),30000);}
      }catch(e){}
    });
  }
  document.addEventListener('DOMContentLoaded',applyAll);
  return {tz,FMT_FULL,FMT_DATE,FMT_TIME,FMT_DTIME,rel,applyAll};
})();

// Notif dropdown
const notifBtn=document.getElementById('notif-btn');
const notifDrop=document.getElementById('notif-dropdown');
const notifBadge=document.getElementById('notif-badge');
const notifList=document.getElementById('notif-list');
if(notifBtn&&notifDrop){
  notifBtn.addEventListener('click',e=>{e.stopPropagation();notifDrop.classList.toggle('open');if(notifDrop.classList.contains('open'))loadNotifs();});
  document.addEventListener('click',()=>notifDrop.classList.remove('open'));
  notifDrop.addEventListener('click',e=>e.stopPropagation());
}
function loadNotifs(){
  fetch('/api/notifications/unread').then(r=>r.json()).then(data=>{
    if(!notifList) return;
    if(!data.length){notifList.innerHTML='<div class="empty" style="padding:var(--space-8)"><p>Tudo em dia!</p></div>';notifBadge&&(notifBadge.style.display='none');return;}
    notifBadge&&(notifBadge.style.display='block');
    notifList.innerHTML=data.slice(0,5).map(n=>`<div class="notif-item"><div class="notif-item-title">${n.title||''}</div><div class="notif-item-body">${n.body||''}</div></div>`).join('');
  }).catch(()=>{});
}
setInterval(loadNotifs,60000);
document.addEventListener('DOMContentLoaded',loadNotifs);
document.getElementById('notif-clear')?.addEventListener('click',()=>{
  fetch('/api/notifications/mark-all-read',{method:'POST'}).then(()=>{loadNotifs();}).catch(()=>{});
});
</script>
</body>
</html>
