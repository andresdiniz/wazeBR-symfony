<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Eventos CIFS — WazeBR</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
/* (Mantive o estilo existente e acrescentei regras para modal) */
:root{ --bg:#0d0e10; --surface:#14161a; --surface2:#1c1f26; --teal:#14b8a6; --muted:#8b9099; --radius:10px; --tr:180ms; }
html,body{height:100%;margin:0;background:var(--bg);color:#e2e4e8;font-family:Inter,Segoe UI,sans-serif;font-size:14px;}
.shell{display:grid;grid-template-rows:52px 1fr;height:100dvh;}
.header{display:flex;align-items:center;padding:0 14px;background:var(--surface);border-bottom:1px solid rgba(255,255,255,.06);}
.header .logo{font-weight:700;color:var(--teal);display:flex;gap:8px;align-items:center;}
.body{display:grid;grid-template-columns:1fr 360px;min-height:0;}
@media(max-width:768px){.body{grid-template-columns:1fr;grid-template-rows:50vh 1fr}}
.map-wrap{position:relative;min-height:0}
#map{width:100%;height:100%}
.panel{background:var(--surface);border-left:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;min-height:0}
.tabs{display:flex;border-bottom:1px solid rgba(255,255,255,.04)}
.tab-btn{flex:1;padding:10px 8px;background:none;border:none;color:var(--muted);font-weight:700;cursor:pointer}
.tab-btn.active{color:var(--teal);border-bottom:2px solid var(--teal)}
.tab-content{display:none;flex:1;overflow:auto;padding:12px}
.tab-content.active{display:flex;flex-direction:column;gap:10px}
.field{display:flex;flex-direction:column;gap:6px}
.field label{font-size:11px;color:var(--muted);font-weight:700}
.field input, .field select, .field textarea{background:var(--surface2);border:1px solid rgba(255,255,255,.04);padding:8px;border-radius:6px;color:inherit}
.polyline-display{background:var(--surface2);border:1px solid rgba(255,255,255,.04);padding:8px;border-radius:6px;font-size:13px;font-family:monospace}
.btn-primary{background:var(--teal);color:#081018;padding:10px;border-radius:6px;border:none;font-weight:700;cursor:pointer}
.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.6);display:none;align-items:center;justify-content:center;z-index:1200}
.modal{width:92%;max-width:980px;background:var(--surface2);border-radius:8px;padding:12px;border:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;gap:8px;min-height:320px}
.modal .map-inner{height:420px;border-radius:6px;overflow:hidden}
.modal .controls{display:flex;gap:8px;align-items:center}
.small-btn{padding:8px;border-radius:6px;background:transparent;border:1px solid rgba(255,255,255,.06);color:inherit;cursor:pointer}
.preview-json{background:#0b0c0d;border-radius:6px;padding:8px;font-family:monospace;font-size:12px;overflow:auto;max-height:240px;border:1px solid rgba(255,255,255,.04)}
.hint{font-size:12px;color:var(--muted)}
.toast{position:fixed;left:50%;transform:translateX(-50%);bottom:18px;background:var(--surface2);padding:10px 14px;border-radius:8px;border:1px solid rgba(255,255,255,.06);z-index:2000;display:none}
</style>
</head>
<body>
<div class="shell">
<header class="header">
<div class="logo">WazeBR - Eventos CIFS</div>
</header>

<div class="body">
<div class="map-wrap">
<div id="map"></div>

<!-- Controls over map -->
<div style="position:absolute;top:10px;left:10px;display:flex;flex-direction:column;gap:6px;z-index:600">
<button id="open-modal" class="small-btn">Desenhar segmento</button>
<button id="btn-toggle-points" class="small-btn">Ponto/Polilinha</button>
</div>
</div>

<div class="panel">
<div class="tabs">
<button class="tab-btn active" data-tab="form">Novo evento</button>
<button class="tab-btn" data-tab="list">Eventos</button>
</div>

<div class="tab-content active" id="tab-form">
<div class="field">
<label>Segmento selecionado</label>
<div class="polyline-display" id="polyline-display">Nenhum</div>
<div class="hint">Abra o modal e desenhe o segmento com a ferramenta dedicada. Para ROAD_CLOSED prefira >=2 pontos</div>
</div>

<div class="field">
<label>Tipo *</label>
<select id="sel-type">
<option value="">Selecione...</option>
{% for type, data in grouped %}
<option value="{{ type }}">{{ data.label ?: type }}</option>
{% endfor %}
</select>
</div>

<div class="field" id="field-subtype" style="display:none">
<label>Subtipo</label>
<select id="sel-subtype"><option value="">Nenhum</option></select>
</div>

<div class="field">
<label>Nome da via *</label>
<input type="text" id="inp-street" maxlength="150" placeholder="Use o nome conforme Waze (reverse geocode)">
<div class="hint">Se disponível, use a função de autocompletar via Reverse Geocode do Partner Hub.</div>
</div>

<div class="field">
<label>Direção</label>
<select id="sel-direction">
<option value="">Não especificada</option>
{% for dir in directions %}
<option value="{{ dir.value }}">{{ dir.label() }}</option>
{% endfor %}
</select>
</div>

<div class="field">
<label>Descrição (até 64 caracteres)</label>
<input type="text" id="inp-description" maxlength="64">
</div>

<div class="field">
<label>Início *</label>
<input type="datetime-local" id="inp-start">
</div>

<div class="field">
<label>Término (opcional)</label>
<input type="datetime-local" id="inp-end">
</div>

<div style="display:flex;gap:8px">
<button class="btn-primary" id="btn-save" disabled>Enviar para o Waze</button>
<button class="small-btn" id="btn-preview">Preview JSON</button>
</div>

</div><!-- /form -->

<div class="tab-content" id="tab-list">
{% if events|length == 0%}
<div style="padding:20px;text-align:center;color:var(--muted)">Nenhum evento cadastrado</div>
{% else %}
{% for event in events %}
<div style="padding:10px;border-bottom:1px solid rgba(255,255,255,.03)">
<div style="font-weight:700">{{ event.type.value }} - {{ event.street }}</div>
<div style="font-size:13px;color:var(--muted)">{{ event.description }}</div>
<div style="font-size:12px;color:var(--muted)">{{ event.startTime|date('d/m/Y H:i') }}{% if event.endTime %} → {{ event.endTime|date('d/m/Y H:i') }}{% endif %}</div>
</div>
{% endfor %}
{% endif %}
</div><!-- /list -->
</div><!-- /panel -->
</div><!-- /body -->
</div><!-- /shell -->

<div class="modal-backdrop" id="modal-backdrop" aria-hidden="true">
<div class="modal" role="dialog" aria-modal="true" aria-label="Desenhar segmento">
<div style="display:flex;justify-content:space-between;align-items:center">
<div style="font-weight:700">Desenhar segmento</div>
<div>
<button class="small-btn" id="btn-close-modal">Fechar</button>
</div>
</div>

<div class="map-inner" id="modal-map"></div>

<div class="controls">
<button class="small-btn" id="btn-add-point">Adicionar ponto</button>
<button class="small-btn" id="btn-undo">Desfazer último</button>
<button class="small-btn" id="btn-clear">Limpar</button>
<button class="small-btn" id="btn-finalize">Finalizar segmento</button>
<div style="margin-left:auto" class="hint">Dica: para ROAD_CLOSED, prefira 2+ pontos alinhados com a via</div>
</div>

<div>
<div style="font-weight:700;margin-bottom:6px">Preview do payload</div>
<div class="preview-json" id="preview-json">{}</div>
</div>
</div>
</div>

<div class="toast" id="toast"></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const GROUPED_TYPES = {{ grouped|json_encode|raw }};

let modalBackdrop = document.getElementById('modal-backdrop');
let modalMapEl = document.getElementById('modal-map');
let map = L.map('map',{ attributionControl:false }).setView([-23.55,-46.63],12);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:19}).addTo(map);

let modalMap, drawLayer;
let modalPoints = [];

function openModal(){
modalBackdrop.style.display='flex';
if(!modalMap){
modalMap = L.map('modal-map',{ attributionControl:false }).setView(map.getCenter(), map.getZoom());
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:19}).addTo(modalMap);
drawLayer = L.layerGroup().addTo(modalMap);

modalMap.on('click', e=> {
modalPoints.push(e.latlng);
renderDraw();
updatePreview();
});
} modalMap.invalidateSize();
}

function closeModal(){ modalBackdrop.style.display='none'; }

function renderDraw(){
drawLayer.clearLayers();
if(modalPoints.length===0) return;
modalPoints.forEach((p,i)=> {
L.circleMarker(p,{radius:5,color:'#14b8a6',fillOpacity:.9}).addTo(drawLayer);
});
if(modalPoints.length>1){
L.polyline(modalPoints,{color:'#14b8a6',weight:4,opacity:.85}).addTo(drawLayer);
} }

document.getElementById('open-modal').addEventListener('click', openModal);
document.getElementById('btn-close-modal').addEventListener('click', closeModal);
document.getElementById('btn-clear').addEventListener('click', ()=> { modalPoints=[]; renderDraw(); updatePreview(); });
document.getElementById('btn-undo').addEventListener('click', ()=> { modalPoints.pop(); renderDraw(); updatePreview(); });

document.getElementById('btn-finalize').addEventListener('click', ()=> {
if(modalPoints.length===0){ showToast('Adicione pelo menos um ponto'); return; }
// Build polyline string 'lat lon lat lon ...' for the form (existing backend accepts this)
const str = modalPoints.map(p => p.lat.toFixed(6) + ' ' + p.lng.toFixed(6)).join(' ');
document.getElementById('polyline-display').textContent = str;
closeModal();
showToast('Segmento inserido no formulário');
});

function updatePreview(){
const type = document.getElementById('sel-type').value || null;
const poly = modalPoints.length ? modalPoints.map(p => p.lat.toFixed(6) + ' ' + p.lng.toFixed(6)).join(' ') : null;
const street = document.getElementById('inp-street').value || null;
const direction = document.getElementById('sel-direction').value || null;
const desc = document.getElementById('inp-description').value || null;
const start = document.getElementById('inp-start').value ? new Date(document.getElementById('inp-start').value).toISOString() : null;
const end = document.getElementById('inp-end').value ? new Date(document.getElementById('inp-end').value).toISOString() : null;

const payload = {
type, polyline: poly, street, direction, description: desc, starttime: start, endtime: end
};
document.getElementById('preview-json').textContent = JSON.stringify(payload, null, 2);
}

document.getElementById('sel-type').addEventListener('change', updatePreview);
document.getElementById('sel-direction').addEventListener('change', updatePreview);
document.getElementById('inp-street').addEventListener('input', updatePreview);
document.getElementById('inp-description').addEventListener('input', updatePreview);
document.getElementById('inp-start').addEventListener('input', updatePreview);
document.getElementById('inp-end').addEventListener('input', updatePreview);

document.getElementById('btn-save').addEventListener('click', async ()=>{
const poly = document.getElementById('polyline-display').textContent;
if(!poly || poly==='Nenhum'){ showToast('Insira um segmento antes de enviar'); return; }
const payload = {
type: document.getElementById('sel-type').value,
subtype: document.getElementById('sel-subtype')?.value || null,
polyline: poly,
street: document.getElementById('inp-street').value,
direction: document.getElementById('sel-direction').value || null,
description: document.getElementById('inp-description').value || null,
starttime: document.getElementById('inp-start').value ? new Date(document.getElementById('inp-start').value).toISOString() : null,
endtime: document.getElementById('inp-end').value ? new Date(document.getElementById('inp-end').value).toISOString() : null,
};
try{
const res = await fetch('/cifs/api/event', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
const json = await res.json();
if(res.ok){ showToast('Evento criado: ' + (json.externalId || json.id)); setTimeout(()=>location.reload(),1200); }
else showToast('Erro: ' + (json.error || 'ver console'), 'err');
}catch(e){ showToast('Erro de conexão', 'err'); }
});

function showToast(msg, type='') {
const t = document.getElementById('toast');
t.textContent = msg; t.style.display='block';
setTimeout(()=> t.style.display='none',2500);
}

/* Inicialização simples do input starttime = agora */
(function(){
const now = new Date(); now.setSeconds(0,0);
document.getElementById('inp-start').value = now.toISOString().slice(0,16);
})();

/* Abas */
document.querySelectorAll('.tab-btn').forEach(btn=>{
btn.addEventListener('click', ()=>{
document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
btn.classList.add('active');
document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
});
});

/* Popula subtipo ao trocar tipo (usando GROUPED_TYPES) */
document.getElementById('sel-type').addEventListener('change', ()=>{
const type = document.getElementById('sel-type').value;
const sel = document.getElementById('sel-subtype');
sel.innerHTML = '<option value="">Nenhum</option>';
if(type && GROUPED_TYPES[type] && GROUPED_TYPES[type].subtypes){
Object.entries(GROUPED_TYPES[type].subtypes).forEach(([k,v])=>{
const o = document.createElement('option'); o.value=k; o.textContent=v; sel.appendChild(o);
});
document.getElementById('field-subtype').style.display = Object.keys(GROUPED_TYPES[type].subtypes).length ? 'block' : 'none';
} else {
document.getElementById('field-subtype').style.display = 'none';
} });

/* Preview button opens modal with preview of built payload */
document.getElementById('btn-preview').addEventListener('click', ()=> {
// If modal closed, open and update; else update existing preview
if(modalBackdrop.style.display!=='flex') openModal();
updatePreview();
});

</script>
</body>
</html>
