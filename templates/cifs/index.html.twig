<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Eventos CIFS — WazeBR</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
*,*::before,*::after{box-sizing:border-box}
:root{
  --bg:#0d0e10; --surface:#14161a; --surface2:#1c1f26; --surface3:#22252e;
  --border:rgba(255,255,255,.07); --border2:rgba(255,255,255,.13);
  --text:#e2e4e8; --muted:#8b9099; --faint:#464c57;
  --teal:#14b8a6; --teal-dim:rgba(20,184,166,.15);
  --red:#ef4444; --red-dim:rgba(239,68,68,.15);
  --orange:#f97316; --yellow:#eab308; --blue:#3b82f6;
  --radius:10px; --tr:160ms;
}
html,body{height:100%;margin:0;background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;font-size:14px;}
.shell{display:grid;grid-template-rows:52px 1fr;height:100dvh;}
.header{display:flex;align-items:center;gap:10px;padding:0 16px;background:var(--surface);border-bottom:1px solid var(--border);}
.header .logo{font-weight:800;color:var(--teal);display:flex;gap:8px;align-items:center;letter-spacing:-.01em}
.header .subtitle{font-size:12px;color:var(--muted);margin-left:4px;padding-left:10px;border-left:1px solid var(--border)}
.header-badge{margin-left:auto;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  background:var(--teal-dim);color:var(--teal);padding:3px 10px;border-radius:20px}

.body{display:grid;grid-template-columns:1fr 380px;min-height:0;}
@media(max-width:860px){.body{grid-template-columns:1fr;grid-template-rows:46vh 1fr}}
.map-wrap{position:relative;min-height:0}
#map{width:100%;height:100%}
.map-controls{position:absolute;top:10px;left:10px;display:flex;flex-direction:column;gap:6px;z-index:600}
.map-btn{
  display:flex;align-items:center;gap:6px;padding:8px 12px;border-radius:8px;
  background:rgba(20,22,26,.92);backdrop-filter:blur(6px);border:1px solid var(--border2);
  color:var(--text);font-size:12px;font-weight:600;cursor:pointer;transition:border-color var(--tr),background var(--tr);
}
.map-btn:hover{border-color:var(--teal);background:rgba(20,184,166,.1)}
.map-btn svg{flex-shrink:0}

.panel{background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;min-height:0}
.tabs{display:flex;border-bottom:1px solid var(--border)}
.tab-btn{flex:1;padding:12px 8px;background:none;border:none;color:var(--muted);font-weight:700;font-size:13px;cursor:pointer;
  border-bottom:2px solid transparent;transition:color var(--tr),border-color var(--tr)}
.tab-btn.active{color:var(--teal);border-bottom-color:var(--teal)}
.tab-content{display:none;flex:1;overflow:auto;padding:16px}
.tab-content.active{display:flex;flex-direction:column;gap:2px}

.form-section{display:flex;flex-direction:column;gap:12px;padding:14px 0 18px;border-bottom:1px solid var(--border)}
.form-section:last-of-type{border-bottom:none}
.form-section-title{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:.06em;
  text-transform:uppercase;color:var(--muted)}
.form-section-title .step-num{display:flex;align-items:center;justify-content:center;width:18px;height:18px;
  border-radius:50%;background:var(--teal-dim);color:var(--teal);font-size:10px;font-weight:700;flex-shrink:0}

.field{display:flex;flex-direction:column;gap:6px}
.field label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.02em}
.field input,.field select,.field textarea{
  background:var(--surface2);border:1px solid var(--border2);padding:9px 10px;border-radius:8px;
  color:var(--text);font-size:13px;font-family:inherit;transition:border-color var(--tr)
}
.field input:focus,.field select:focus{outline:none;border-color:var(--teal)}
.hint{font-size:11px;color:var(--faint);line-height:1.5}
.char-count{font-size:10px;color:var(--faint);text-align:right}

.polyline-display{background:var(--surface2);border:1px solid var(--border2);padding:9px 10px;border-radius:8px;
  font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--muted);word-break:break-all;max-height:64px;overflow:auto}
.polyline-display.filled{color:var(--teal);border-color:rgba(20,184,166,.35)}

.closure-warning{
  display:none;align-items:flex-start;gap:8px;background:var(--red-dim);
  border:1px solid rgba(239,68,68,.3);border-radius:8px;padding:9px 10px;font-size:11px;color:var(--red);line-height:1.5
}
.closure-warning.show{display:flex}

.street-suggestions{display:none;flex-wrap:wrap;gap:5px;margin-top:2px}
.street-suggestions.show{display:flex}
.suggestion-label{font-size:10px;color:var(--faint);width:100%}
.suggestion-chip{
  padding:3px 10px;font-size:11px;background:var(--surface3);border:1px solid var(--border2);
  border-radius:20px;color:var(--text);cursor:pointer;transition:border-color var(--tr),background var(--tr)
}
.suggestion-chip:hover{border-color:var(--teal);background:var(--teal-dim);color:var(--teal)}

.btn-primary{background:var(--teal);color:#04231c;padding:11px;border-radius:8px;border:none;font-weight:700;
  font-size:13px;cursor:pointer;transition:background var(--tr),opacity var(--tr);width:100%}
.btn-primary:hover:not(:disabled){background:#1ccdb8}
.btn-primary:disabled{opacity:.4;cursor:not-allowed}
.btn-secondary{background:none;border:1px solid var(--border2);color:var(--muted);padding:9px;border-radius:8px;
  font-size:12px;font-weight:600;cursor:pointer;width:100%;transition:border-color var(--tr),color var(--tr)}
.btn-secondary:hover{border-color:var(--border2);color:var(--text)}
.btn-row{display:flex;gap:8px;margin-top:8px}
.btn-row>*{flex:1}

.event-item{padding:12px;border-bottom:1px solid var(--border);transition:background var(--tr)}
.event-item:hover{background:var(--surface2)}
.event-item.inactive{opacity:.45}
.event-header{display:flex;align-items:center;gap:7px;margin-bottom:4px;flex-wrap:wrap}
.event-badge{font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:2px 8px;
  border-radius:20px;background:var(--surface3);color:var(--muted)}
.event-badge.ROAD_CLOSED{background:var(--red-dim);color:var(--red)}
.event-badge.ACCIDENT{background:rgba(249,115,22,.15);color:var(--orange)}
.event-badge.HAZARD{background:rgba(234,179,8,.15);color:var(--yellow)}
.event-badge.POLICE{background:rgba(59,130,246,.15);color:var(--blue)}
.event-badge.JAM{background:rgba(249,115,22,.12);color:var(--orange)}
.event-street{font-size:12.5px;font-weight:600;color:var(--text)}
.event-desc{font-size:11px;color:var(--muted);margin-top:2px}
.event-meta{font-size:10px;color:var(--faint);margin-top:5px;display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.event-deact{margin-left:auto;background:var(--red-dim);border:1px solid rgba(239,68,68,.3);color:var(--red);
  font-size:9px;font-weight:700;border-radius:20px;padding:2px 8px;cursor:pointer;transition:background var(--tr)}
.event-deact:hover{background:rgba(239,68,68,.25)}
.empty-state{display:flex;flex-direction:column;align-items:center;gap:6px;padding:40px 12px;color:var(--faint);
  font-size:12px;text-align:center}

.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.65);display:none;align-items:center;justify-content:center;z-index:1200}
.modal-backdrop.show{display:flex}
.modal{width:92%;max-width:960px;background:var(--surface);border-radius:var(--radius);padding:16px;
  border:1px solid var(--border2);display:flex;flex-direction:column;gap:10px;min-height:320px;
  box-shadow:0 20px 60px rgba(0,0,0,.5)}
.modal-head{display:flex;justify-content:space-between;align-items:center}
.modal-title{font-weight:700;font-size:14px}
.modal .map-inner{height:400px;border-radius:8px;overflow:hidden;border:1px solid var(--border2)}
.modal-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.small-btn{padding:8px 12px;border-radius:8px;background:var(--surface2);border:1px solid var(--border2);
  color:var(--text);cursor:pointer;font-size:12px;font-weight:600;transition:border-color var(--tr)}
.small-btn:hover{border-color:var(--teal)}
.preview-json{background:#0a0b0c;border-radius:8px;padding:10px;font-family:'JetBrains Mono',monospace;
  font-size:11px;overflow:auto;max-height:200px;border:1px solid var(--border);color:var(--muted)}
.toast{position:fixed;left:50%;transform:translateX(-50%);bottom:20px;background:var(--surface2);
  padding:11px 18px;border-radius:8px;border:1px solid var(--border2);z-index:2000;display:none;font-size:13px;
  box-shadow:0 8px 24px rgba(0,0,0,.4)}
.toast.err{border-color:rgba(239,68,68,.4);color:var(--red)}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--faint);border-radius:4px}
</style>
</head>
<body>
<div class="shell">

<header class="header">
  <div class="logo">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
    WazeBR
  </div>
  <span class="subtitle">Eventos CIFS</span>
  <span class="header-badge">Feed Waze</span>
</header>

<div class="body">
  <div class="map-wrap">
    <div id="map"></div>
    <div class="map-controls">
      <button id="open-modal" class="map-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 17 9 7 15 13 21 5"/></svg>
        Desenhar segmento
      </button>
    </div>
  </div>

  <div class="panel">
    <div class="tabs">
      <button class="tab-btn active" data-tab="form">📝 Novo evento</button>
      <button class="tab-btn" data-tab="list">📋 Eventos ({{ events|length }})</button>
    </div>

    <div class="tab-content active" id="tab-form">

      <!-- ═══ 1. CLASSIFICAÇÃO ═══ -->
      <div class="form-section">
        <div class="form-section-title"><span class="step-num">1</span>Classificação</div>

        <div class="field">
          <label>Tipo *</label>
          <select id="sel-type">
            <option value="">Selecione o tipo…</option>
            {% for type, data in grouped %}
              <option value="{{ type }}">{{ data.label ?: type }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="field" id="field-subtype" style="display:none">
          <label>Subtipo</label>
          <select id="sel-subtype"><option value="">Nenhum / genérico</option></select>
        </div>

        <div class="field">
          <label>Descrição (máx 64 chars)</label>
          <input type="text" id="inp-description" maxlength="64" placeholder="Ex: Obras na pista central">
          <div class="char-count" id="char-count">0 / 64</div>
        </div>
      </div>

      <!-- ═══ 2. LOCALIZAÇÃO ═══ -->
      <div class="form-section">
        <div class="form-section-title"><span class="step-num">2</span>Localização</div>

        <div class="field">
          <label>Segmento selecionado</label>
          <div class="polyline-display" id="polyline-display">Nenhum ponto — clique em "Desenhar segmento"</div>
          <div class="closure-warning" id="closure-warning">
            ⚠️ <span>Via Interditada exige <strong>2+ pontos</strong> (início e fim), e ambos devem estar na
            <strong>mesma via</strong> — o Waze rejeita fechamentos que cruzam nomes de rua diferentes, mesmo com
            polyline exato. Válido apenas para rodovias, vias urbanas, ramais e vias privadas.</span>
          </div>
        </div>

        <div class="field">
          <label>Nome da via *</label>
          <input type="text" id="inp-street" maxlength="150" placeholder="Ex: Av. Paulista, BR-040…">
          <span class="hint">Deve bater com o nome usado no mapa do Waze — use as sugestões abaixo quando disponíveis.</span>
          <div class="street-suggestions" id="street-suggestions">
            <span class="suggestion-label" id="suggestion-label">Nomes de via encontrados perto do ponto:</span>
          </div>
        </div>

        <div class="field">
          <label>Direção</label>
          <select id="sel-direction">
            <option value="">Não especificada</option>
            {% for dir in directions %}
              <option value="{{ dir.value }}">{{ dir.label() }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="field" id="field-lane-impact" style="display:none">
          <label>Impacto por faixa <span style="text-transform:none;font-weight:400;color:var(--faint)">(opcional)</span></label>
          <div style="display:flex;gap:6px">
            <input type="number" id="inp-lane-count" min="1" max="10" placeholder="Nº de faixas fechadas" style="flex:1">
            <select id="sel-lane-roadside" style="flex:1">
              <option value="">Lado</option>
              {% for rs in roadsides %}
                <option value="{{ rs.value }}">{{ rs.label() }}</option>
              {% endfor %}
            </select>
          </div>
          <span class="hint">Só se aplica quando a via é de sentido único e o evento não é interdição total.</span>
        </div>
      </div>

      <!-- ═══ 3. DURAÇÃO ═══ -->
      <div class="form-section">
        <div class="form-section-title"><span class="step-num">3</span>Duração</div>

        <div class="field">
          <label>Início *</label>
          <input type="datetime-local" id="inp-start">
          <span class="hint">Obrigatório para Via Interditada. Para os demais tipos, se vazio, assume-se "agora".</span>
        </div>

        <div class="field">
          <label>Término (deixe vazio = 14 dias padrão)</label>
          <input type="datetime-local" id="inp-end">
        </div>

        <div class="field">
          <label style="display:flex;align-items:center;gap:6px;cursor:pointer;text-transform:none">
            <input type="checkbox" id="chk-schedule" style="width:auto">
            Agendamento recorrente <span style="text-transform:none;font-weight:400;color:var(--faint)">(opcional)</span>
          </label>
          <div id="schedule-days" style="display:none;flex-direction:column;gap:6px;margin-top:4px">
            {% for key, name in weekdays %}
              <div style="display:flex;align-items:center;gap:6px">
                <span style="width:64px;font-size:11px;color:var(--muted)">{{ name }}</span>
                <input type="text" class="schedule-range" data-day="{{ key }}" placeholder="09:00-18:00" style="flex:1;padding:6px 8px;font-size:12px">
              </div>
            {% endfor %}
            <span class="hint">Formato HH:MM-HH:MM, múltiplos intervalos separados por vírgula.</span>
          </div>
        </div>
      </div>

      <div class="btn-row">
        <button class="btn-primary" id="btn-save" disabled>Enviar para o Waze</button>
      </div>
      <div class="btn-row">
        <button class="btn-secondary" id="btn-preview">Ver JSON</button>
        <button class="btn-secondary" id="btn-reset">Limpar</button>
      </div>

    </div><!-- /form -->

    <div class="tab-content" id="tab-list">
      {% if events|length == 0 %}
        <div class="empty-state">Nenhum evento cadastrado ainda.</div>
      {% else %}
        {% for event in events %}
          <div class="event-item {{ event.active ? '' : 'inactive' }}">
            <div class="event-header">
              <span class="event-badge {{ event.type.value }}">{{ typesMap[event.type.value] ?? event.type.value }}</span>
              {% if event.subtype %}
                <span class="event-badge">{{ subtypesMap[event.type.value ~ '|' ~ event.subtype] ?? event.subtype }}</span>
              {% endif %}
            </div>
            <div class="event-street">{{ event.street }}</div>
            {% if event.description %}<div class="event-desc">{{ event.description }}</div>{% endif %}
            <div class="event-meta">
              <span>{{ event.startTime|date('d/m/Y H:i') }}{% if event.endTime %} → {{ event.endTime|date('d/m/Y H:i') }}{% endif %}</span>
              {% if event.active %}
                <button class="event-deact" data-id="{{ event.id }}">Desativar</button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div><!-- /list -->
  </div><!-- /panel -->
</div><!-- /body -->
</div><!-- /shell -->

<!-- Modal de desenho -->
<div class="modal-backdrop" id="modal-backdrop" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-label="Desenhar segmento">
    <div class="modal-head">
      <div class="modal-title">Desenhar segmento</div>
      <button class="small-btn" id="btn-close-modal">Fechar</button>
    </div>

    <div class="map-inner" id="modal-map"></div>

    <div class="modal-controls">
      <button class="small-btn" id="btn-undo">↩ Desfazer último</button>
      <button class="small-btn" id="btn-clear">🗑 Limpar</button>
      <button class="small-btn" id="btn-finalize" style="margin-left:auto;background:var(--teal);color:#04231c;border-color:var(--teal)">Usar este segmento</button>
    </div>
    <span class="hint" id="modal-hint">Clique no mapa para adicionar pontos. Para Via Interditada, use 2+ pontos ao longo da mesma via.</span>

    <div>
      <div style="font-weight:700;margin-bottom:6px;font-size:12px;color:var(--muted)">Preview do payload</div>
      <div class="preview-json" id="preview-json">{}</div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const GROUPED_TYPES = {{ grouped|json_encode|raw }};
const REVERSE_GEOCODE_URL = "{{ path('cifs_api_geocode_reverse') }}";

let modalBackdrop = document.getElementById('modal-backdrop');
let map = L.map('map', { attributionControl: false }).setView([-19.92, -43.94], 12);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { maxZoom: 19 }).addTo(map);

let eventLayers = L.layerGroup().addTo(map);
document.querySelectorAll('.event-item').forEach(() => {}); // placeholder de futura sobreposição de eventos no mapa principal

let modalMap, drawLayer;
let modalPoints = [];
let geocodeTimer = null;

const selType   = document.getElementById('sel-type');
const selSubtype= document.getElementById('sel-subtype');
const fieldSub  = document.getElementById('field-subtype');
const inpDesc   = document.getElementById('inp-description');
const charCount = document.getElementById('char-count');
const polylineDisplay = document.getElementById('polyline-display');
const closureWarning  = document.getElementById('closure-warning');
const fieldLaneImpact = document.getElementById('field-lane-impact');
const selDirection    = document.getElementById('sel-direction');
const streetInput     = document.getElementById('inp-street');
const suggestionsBox  = document.getElementById('street-suggestions');
const suggestionLabel = document.getElementById('suggestion-label');
const chkSchedule     = document.getElementById('chk-schedule');
const scheduleDays    = document.getElementById('schedule-days');

// ── Modal de desenho ──────────────────────────────────────────
function openModal() {
  modalBackdrop.classList.add('show');
  if (!modalMap) {
    modalMap = L.map('modal-map', { attributionControl: false }).setView(map.getCenter(), map.getZoom());
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { maxZoom: 19 }).addTo(modalMap);
    drawLayer = L.layerGroup().addTo(modalMap);
    modalMap.on('click', e => {
      modalPoints.push(e.latlng);
      renderDraw();
      updatePreview();
      suggestStreetFromPoints();
    });
  }
  modalMap.invalidateSize();
}
function closeModal() { modalBackdrop.classList.remove('show'); }

function renderDraw() {
  drawLayer.clearLayers();
  modalPoints.forEach(p => L.circleMarker(p, { radius: 5, color: '#14b8a6', fillOpacity: .9, weight: 2 }).addTo(drawLayer));
  if (modalPoints.length > 1) {
    L.polyline(modalPoints, { color: '#14b8a6', weight: 4, opacity: .85 }).addTo(drawLayer);
  }
  updateClosureWarning();
}

function updateClosureWarning() {
  const isClosure = selType.value === 'ROAD_CLOSED';
  closureWarning.classList.toggle('show', isClosure);
}

document.getElementById('open-modal').addEventListener('click', openModal);
document.getElementById('btn-close-modal').addEventListener('click', closeModal);
document.getElementById('btn-clear').addEventListener('click', () => { modalPoints = []; renderDraw(); updatePreview(); });
document.getElementById('btn-undo').addEventListener('click', () => { modalPoints.pop(); renderDraw(); updatePreview(); });

document.getElementById('btn-finalize').addEventListener('click', () => {
  if (modalPoints.length === 0) { showToast('Adicione pelo menos um ponto', 'err'); return; }
  if (selType.value === 'ROAD_CLOSED' && modalPoints.length < 2) {
    showToast('Via Interditada exige 2+ pontos (início e fim do trecho)', 'err');
    return;
  }
  const str = modalPoints.map(p => p.lat.toFixed(6) + ' ' + p.lng.toFixed(6)).join(' ');
  polylineDisplay.textContent = str;
  polylineDisplay.classList.add('filled');
  closeModal();
  updateSaveBtn();
  showToast('Segmento inserido no formulário');
});

// ── Sugestão de nome de via por geocodificação reversa ────────
function suggestStreetFromPoints() {
  if (!modalPoints.length) return;
  clearTimeout(geocodeTimer);
  geocodeTimer = setTimeout(async () => {
    const mid = modalPoints[Math.floor(modalPoints.length / 2)];
    try {
      const res = await fetch(`${REVERSE_GEOCODE_URL}?lat=${mid.lat}&lon=${mid.lng}`);
      const data = await res.json();
      const candidates = data.candidates || [];
      if (!candidates.length) { suggestionsBox.classList.remove('show'); return; }
      suggestionLabel.textContent = data.source === 'waze'
        ? 'Nomes de via do mapa do Waze perto do ponto (por distância):'
        : 'Sugestão aproximada (OSM) — confira no mapa do Waze:';
      suggestionsBox.querySelectorAll('.suggestion-chip').forEach(el => el.remove());
      candidates.slice(0, 5).forEach(c => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'suggestion-chip';
        chip.textContent = c.name + (c.distance != null ? ` (${Math.round(c.distance)}m)` : '');
        chip.addEventListener('click', () => {
          streetInput.value = c.name;
          updateSaveBtn();
          suggestionsBox.classList.remove('show');
        });
        suggestionsBox.appendChild(chip);
      });
      suggestionsBox.classList.add('show');
    } catch (err) {
      suggestionsBox.classList.remove('show');
    }
  }, 600);
}

// ── Preview do payload ─────────────────────────────────────────
function buildPayload() {
  const schedule = {};
  if (chkSchedule.checked) {
    document.querySelectorAll('.schedule-range').forEach(inp => {
      const val = inp.value.trim();
      if (val) schedule[inp.dataset.day] = val;
    });
  }
  const laneCount = document.getElementById('inp-lane-count').value;
  const laneImpact = laneCount
    ? { total_closed_lanes: parseInt(laneCount, 10), roadside: document.getElementById('sel-lane-roadside').value || null }
    : null;

  const poly = modalPoints.length ? modalPoints.map(p => p.lat.toFixed(6) + ' ' + p.lng.toFixed(6)).join(' ') : null;

  return {
    type: selType.value || null,
    subtype: selSubtype.value || null,
    polyline: poly,
    street: streetInput.value.trim() || null,
    direction: selDirection.value || null,
    description: inpDesc.value.trim() || null,
    starttime: document.getElementById('inp-start').value ? new Date(document.getElementById('inp-start').value).toISOString() : null,
    endtime: document.getElementById('inp-end').value ? new Date(document.getElementById('inp-end').value).toISOString() : null,
    schedule: Object.keys(schedule).length ? schedule : null,
    lane_impact: laneImpact,
  };
}
function updatePreview() {
  document.getElementById('preview-json').textContent = JSON.stringify(buildPayload(), null, 2);
}
['sel-direction','inp-description','inp-start','inp-end'].forEach(id =>
  document.getElementById(id).addEventListener('input', updatePreview));
document.getElementById('btn-preview').addEventListener('click', () => { openModal(); updatePreview(); });

// ── Impacto por faixa: só p/ tipos != ROAD_CLOSED com direção única ──
function updateLaneImpactVisibility() {
  const show = selType.value !== 'ROAD_CLOSED' && selDirection.value === 'ONE_DIRECTION';
  fieldLaneImpact.style.display = show ? 'flex' : 'none';
  if (!show) {
    document.getElementById('inp-lane-count').value = '';
    document.getElementById('sel-lane-roadside').value = '';
  }
}
selDirection.addEventListener('change', () => { updateLaneImpactVisibility(); updateSaveBtn(); });
chkSchedule.addEventListener('change', () => { scheduleDays.style.display = chkSchedule.checked ? 'flex' : 'none'; });

// ── Tipo/subtipo ────────────────────────────────────────────────
selType.addEventListener('change', () => {
  const type = selType.value;
  selSubtype.innerHTML = '<option value="">Nenhum / genérico</option>';
  if (type && GROUPED_TYPES[type]?.subtypes) {
    const subs = GROUPED_TYPES[type].subtypes;
    Object.entries(subs).forEach(([key, label]) => {
      const opt = document.createElement('option');
      opt.value = key; opt.textContent = label;
      selSubtype.appendChild(opt);
    });
    fieldSub.style.display = Object.keys(subs).length > 0 ? 'flex' : 'none';
  } else {
    fieldSub.style.display = 'none';
  }
  updateClosureWarning();
  updateLaneImpactVisibility();
  updateSaveBtn();
});

inpDesc.addEventListener('input', () => { charCount.textContent = `${inpDesc.value.length} / 64`; });
streetInput.addEventListener('input', updateSaveBtn);

// ── Validação do botão salvar ────────────────────────────────────
function updateSaveBtn() {
  const isClosure = selType.value === 'ROAD_CLOSED';
  const ok = modalPoints.length > 0
    && (!isClosure || modalPoints.length >= 2)
    && selType.value !== ''
    && streetInput.value.trim() !== '';
  document.getElementById('btn-save').disabled = !ok;
}

// ── Salvar evento ─────────────────────────────────────────────
document.getElementById('btn-save').addEventListener('click', async () => {
  if (modalPoints.length === 0) { showToast('Desenhe um segmento antes de enviar', 'err'); return; }
  const payload = buildPayload();
  try {
    const res = await fetch('{{ path('cifs_api_save') }}', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const json = await res.json();
    if (res.ok) {
      showToast('Evento criado: ' + (json.externalId || json.id));
      setTimeout(() => location.reload(), 1200);
    } else {
      showToast('Erro: ' + (json.error || 'ver console'), 'err');
    }
  } catch (e) {
    showToast('Erro de conexão', 'err');
  }
});

document.getElementById('btn-reset').addEventListener('click', () => {
  modalPoints = [];
  polylineDisplay.textContent = 'Nenhum ponto — clique em "Desenhar segmento"';
  polylineDisplay.classList.remove('filled');
  selType.value = ''; selSubtype.innerHTML = '<option value="">Nenhum / genérico</option>';
  fieldSub.style.display = 'none';
  streetInput.value = ''; selDirection.value = '';
  inpDesc.value = ''; charCount.textContent = '0 / 64';
  document.getElementById('inp-start').value = '';
  document.getElementById('inp-end').value = '';
  document.getElementById('inp-lane-count').value = '';
  document.getElementById('sel-lane-roadside').value = '';
  chkSchedule.checked = false; scheduleDays.style.display = 'none';
  document.querySelectorAll('.schedule-range').forEach(inp => inp.value = '');
  closureWarning.classList.remove('show');
  suggestionsBox.classList.remove('show');
  fieldLaneImpact.style.display = 'none';
  updateSaveBtn();
});

// ── Desativar evento ──────────────────────────────────────────
document.querySelectorAll('.event-deact').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;
    try {
      const res = await fetch(`/cifs/api/event/${id}/deactivate`, { method: 'POST' });
      if (res.ok) { showToast('Evento desativado'); setTimeout(() => location.reload(), 800); }
    } catch (e) { showToast('Erro de conexão', 'err'); }
  });
});

function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast' + (type ? ' ' + type : ''); t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 2800);
}

/* Abas */
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

/* Início padrão = agora */
(function () {
  const now = new Date(); now.setSeconds(0, 0);
  document.getElementById('inp-start').value = now.toISOString().slice(0, 16);
})();
</script>
</body>
</html>
