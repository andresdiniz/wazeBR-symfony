{% extends 'base.html.twig' %}
{% block title %}Dashboard CEMADEN{% endblock %}
{% block content %}
<div class="page-header">
  <h1 class="page-title">Dashboard CEMADEN</h1>
</div>

<div class="card">
  <div class="card-header"><span class="card-title">Leituras recentes por estação</span></div>
  <div style="overflow-x:auto">
    <table>
      <thead><tr>
        <th>Estação</th>
        <th>Município</th>
        <th>UF</th>
        <th style="text-align:right">Acumulado (mm)</th>
        <th>Medido em</th>
      </tr></thead>
      <tbody>
      {% for s in stations %}
        <tr>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ s.codEstacao }}</td>
          <td>{{ s.nomeMunicipio }}</td>
          <td style="font-size:var(--text-xs)">{{ s.uf }}</td>
          <td style="text-align:right;font-weight:600">{{ s.valorMedida|number_format(1,',') }}</td>
          <td style="color:var(--color-text-muted)">
            <time data-utc="{{ s.measuredAt|date('c') }}" data-fmt="datetime">{{ s.measuredAt|date('d/m H:i') }}</time>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
