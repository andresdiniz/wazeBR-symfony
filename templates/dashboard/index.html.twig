{% extends 'base.html.twig' %}
{% block title %}Dashboard{% endblock %}

{% block content %}
<div class="page-header">
  <h1 class="page-title">Dashboard</h1>
  <p class="page-subtitle">Visão geral do monitoramento — {{ partner.name }}</p>
</div>

{# KPIs #}
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-icon" style="background:oklch(from var(--color-warning) l c h/.12)">
      <i data-lucide="triangle-alert" style="width:18px;height:18px;color:var(--color-warning)"></i>
    </div>
    <div class="kpi-label">Alertas</div>
    <div class="kpi-value">{{ kpis.alerts|number_format(0, ',', '.') }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-icon" style="background:oklch(from var(--color-orange) l c h/.12)">
      <i data-lucide="traffic-cone" style="width:18px;height:18px;color:var(--color-orange)"></i>
    </div>
    <div class="kpi-label">Congestionamentos</div>
    <div class="kpi-value">{{ kpis.jams|number_format(0, ',', '.') }}</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-icon" style="background:oklch(from var(--color-primary) l c h/.12)">
      <i data-lucide="cloud-rain" style="width:18px;height:18px;color:var(--color-primary)"></i>
    </div>
    <div class="kpi-label">Leituras CEMADEN</div>
    <div class="kpi-value">{{ kpis.cemaden|number_format(0, ',', '.') }}</div>
  </div>
</div>

{# Recentes #}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-6)">

  {# Alertas recentes #}
  <div class="card">
    <div class="card-header">
      <span class="card-title">Últimos alertas</span>
      <a href="{{ path('alert_index') }}" class="btn btn-ghost btn-sm">Ver todos</a>
    </div>
    {% if recentAlerts is empty %}
      <div class="empty"><i data-lucide="check-circle"></i><h3>Sem alertas recentes</h3></div>
    {% else %}
      <table>
        <thead><tr><th>Tipo</th><th>Local</th><th>Conf.</th></tr></thead>
        <tbody>
        {% for a in recentAlerts %}
          <tr>
            <td>
              <span class="badge {{ a.type in ['ACCIDENT','HAZARD'] ? 'badge-red' : 'badge-orange' }}">
                {{ a.type }}
              </span>
            </td>
            <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
              {{ a.street ?? a.city ?? '—' }}
            </td>
            <td>{{ a.confidence }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

  {# Congestionamentos recentes #}
  <div class="card">
    <div class="card-header">
      <span class="card-title">Últimos congestionamentos</span>
      <a href="{{ path('traffic_jam_index') }}" class="btn btn-ghost btn-sm">Ver todos</a>
    </div>
    {% if recentJams is empty %}
      <div class="empty"><i data-lucide="check-circle"></i><h3>Sem congestionamentos</h3></div>
    {% else %}
      <table>
        <thead><tr><th>Nível</th><th>Via</th><th>km/h</th></tr></thead>
        <tbody>
        {% for j in recentJams %}
          <tr>
            <td>
              <span class="badge {{ j.level >= 4 ? 'badge-red' : (j.level >= 2 ? 'badge-orange' : 'badge-yellow') }}">
                {{ j.level }}
              </span>
            </td>
            <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
              {{ j.street ?? j.city ?? '—' }}
            </td>
            <td>{{ j.speedKmh|number_format(1, ',') }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

</div>
{% endblock %}
