{% extends 'base.html.twig' %}
{% block title %}Dashboard — WazeBR{% endblock %}
{% block content %}
<div class="topbar">
    <h1>📊 Dashboard</h1>
    <span style="font-size:var(--text-sm);color:var(--color-text-muted)">
        Última coleta:
        {% if summary.last_collection %}
            {{ summary.last_collection|date('d/m/Y H:i') }}
        {% else %}
            Aguardando...
        {% endif %}
    </span>
    <button class="theme-toggle" data-theme-toggle title="Alternar tema">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    </button>
</div>

<div class="kpi-grid">
    <div class="kpi">
        <div class="kpi-value">{{ summary.alerts_today }}</div>
        <div class="kpi-label">🚨 Alertas hoje</div>
    </div>
    <div class="kpi">
        <div class="kpi-value">{{ summary.jams_today }}</div>
        <div class="kpi-label">🚗 Congestionamentos hoje</div>
    </div>
    <div class="kpi">
        <div class="kpi-value">{{ summary.cemaden_active }}</div>
        <div class="kpi-label">🌧️ Alertas CEMADEN ativos</div>
    </div>
    <div class="kpi">
        <div class="kpi-value">{{ summary.unread_notifications }}</div>
        <div class="kpi-label">🔔 Notificações não lidas</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">
    <div class="card">
        <h2 style="font-size:var(--text-base);font-weight:600;margin-bottom:1rem">Alertas por Tipo (hoje)</h2>
        {% if summary.alerts_by_type %}
        <table>
            <thead><tr><th>Tipo</th><th>Total</th></tr></thead>
            <tbody>
            {% for row in summary.alerts_by_type %}
                <tr><td>{{ row.type }}</td><td style="font-variant-numeric:tabular-nums">{{ row.total }}</td></tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="color:var(--color-text-muted);font-size:var(--text-sm)">Nenhum alerta coletado hoje.</p>
        {% endif %}
    </div>

    <div class="card">
        <h2 style="font-size:var(--text-base);font-weight:600;margin-bottom:1rem">Congestionamentos por Nível (hoje)</h2>
        {% if summary.jams_by_level %}
        <table>
            <thead><tr><th>Nível</th><th>Total</th></tr></thead>
            <tbody>
            {% for row in summary.jams_by_level %}
                <tr>
                    <td>
                        {% if row.level >= 4 %}<span class="badge badge-danger">{% elseif row.level >= 2 %}<span class="badge badge-warning">{% else %}<span class="badge badge-success">{% endif %}
                        Nível {{ row.level }}</span>
                    </td>
                    <td style="font-variant-numeric:tabular-nums">{{ row.total }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="color:var(--color-text-muted);font-size:var(--text-sm)">Nenhum congestionamento hoje.</p>
        {% endif %}
    </div>
</div>
{% endblock %}
