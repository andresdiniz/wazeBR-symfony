{% extends 'base.html.twig' %}
{% block title %}Rotas Monitoradas{% endblock %}
{% block content %}
<div class="page-header">
  <h1>Rotas Monitoradas</h1>
  <a href="{{ path('route_admin_new') }}" class="btn btn-primary">+ Nova Rota</a>
</div>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Descrição</th>
        <th>Ativa</th>
        <th>Links</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      {% for route in routes %}
      <tr>
        <td>{{ route.name }}</td>
        <td>{{ route.description ?? '—' }}</td>
        <td>{{ route.isActive ? 'Sim' : 'Não' }}</td>
        <td>{{ route.links|length }}</td>
        <td>
          <a href="{{ path('route_admin_show', {id: route.id}) }}" class="btn btn-sm">Ver</a>
          <a href="{{ path('route_admin_edit', {id: route.id}) }}" class="btn btn-sm">Editar</a>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="5" class="empty-cell">Nenhuma rota cadastrada.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
