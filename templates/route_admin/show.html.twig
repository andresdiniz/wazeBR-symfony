{% extends 'base.html.twig' %}
{% block title %}Rota #{{ route.id }}{% endblock %}
{% block content %}
<div class="page-header">
  <h1 class="page-title">Rota #{{ route.id }}</h1>
  <a href="{{ path('route_admin_index') }}" class="btn btn-ghost btn-sm">Voltar</a>
</div>

<div class="card">
  <div class="card-body">
    <dl style="display:grid;grid-template-columns:max-content 1fr;gap:var(--space-2) var(--space-6)">
      <dt>Nome</dt><dd>{{ route.name }}</dd>
      <dt>Origem</dt><dd>{{ route.origin }}</dd>
      <dt>Destino</dt><dd>{{ route.destination }}</dd>
      <dt>Criada em</dt><dd><time data-utc="{{ route.createdAt|date('c') }}" data-fmt="datetime">{{ route.createdAt|date('d/m/Y H:i') }}</time></dd>
      {% if route.updatedAt %}
        <dt>Atualizada em</dt><dd><time data-utc="{{ route.updatedAt|date('c') }}" data-fmt="datetime">{{ route.updatedAt|date('d/m/Y H:i') }}</time></dd>
      {% endif %}
    </dl>
  </div>
</div>
{% endblock %}
