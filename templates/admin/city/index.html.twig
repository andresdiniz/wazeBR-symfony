{% extends 'base.html.twig' %}
{% block title %}Cidades Monitoradas{% endblock %}
{% block content %}
<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Cidades Monitoradas</h1>
    <div class="page-subtitle">Cidades para busca de clima e monitoramento</div>
  </div>
  <a href="{{ path('admin_city_new') }}" class="btn btn-primary">
    <i data-lucide="plus" style="width:14px;height:14px"></i> Nova Cidade
  </a>
</div>

<div class="card">
  <div style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>Cidade</th>
          <th>Estado</th>
          <th>Parceiro</th>
          <th>Clima Atual</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
      {% for city in cities %}
        <tr style="opacity:{{ city.isActive ? 1 : 0.55 }}">
          <td style="font-weight:500">{{ city.name }}</td>
          <td><span class="badge badge-gray">{{ city.state }}</span></td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ city.partner.name }}</td>
          <td>
            <button class="btn btn-ghost btn-sm fetch-weather"
              data-city="{{ city.name|e('html_attr') }}"
              data-state="{{ city.state|e('html_attr') }}"
              style="font-size:var(--text-xs)">
              <i data-lucide="cloud" style="width:12px;height:12px"></i> Ver clima
            </button>
            <span class="weather-result" style="font-size:var(--text-xs);color:var(--color-text-muted);margin-left:var(--space-2)"></span>
          </td>
          <td>
            {% if city.isActive %}
              <span class="badge" style="background:oklch(from var(--color-success) l c h/.12);color:var(--color-success)">Ativa</span>
            {% else %}
              <span class="badge badge-gray">Inativa</span>
            {% endif %}
          </td>
          <td style="display:flex;gap:var(--space-2);white-space:nowrap">
            <a href="{{ path('admin_city_edit', {id: city.id}) }}" class="btn btn-ghost btn-sm">
              <i data-lucide="pencil" style="width:12px;height:12px"></i>
            </a>
            <form method="post" action="{{ path('admin_city_toggle', {id: city.id}) }}">
              <button class="btn btn-ghost btn-sm" title="{{ city.isActive ? 'Desativar' : 'Ativar' }}">
                <i data-lucide="{{ city.isActive ? 'pause' : 'play' }}" style="width:12px;height:12px"></i>
              </button>
            </form>
            <form method="post" action="{{ path('admin_city_delete', {id: city.id}) }}" onsubmit="return confirm('Excluir cidade?')">
              <input type="hidden" name="_token" value="{{ csrf_token('del_city_' ~ city.id) }}">
              <button class="btn btn-sm" style="color:var(--color-error);border-color:oklch(from var(--color-error) l c h/.3)">
                <i data-lucide="trash-2" style="width:12px;height:12px"></i>
              </button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="6" style="text-align:center;padding:var(--space-16);color:var(--color-text-muted)">
          Nenhuma cidade cadastrada. <a href="{{ path('admin_city_new') }}" style="color:var(--color-primary)">Adicionar</a>
        </td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
{% block javascripts %}
<script>
document.querySelectorAll('.fetch-weather').forEach(btn => {
  btn.addEventListener('click', async () => {
    const city  = btn.dataset.city;
    const state = btn.dataset.state;
    const out   = btn.nextElementSibling;
    out.textContent = 'Buscando…';
    try {
      // Geocodifica cidade via Open-Meteo Geocoding API (grátis, sem key)
      const geo = await fetch(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city+' '+state)}&count=1&language=pt&format=json`);
      const gd  = await geo.json();
      if (!gd.results?.length) { out.textContent = 'Cidade não encontrada'; return; }
      const { latitude, longitude, name } = gd.results[0];
      // Busca clima atual
      const wx = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,weathercode,windspeed_10m,precipitation&timezone=auto&forecast_days=1`);
      const wd = await wx.json();
      const cur = wd.current;
      const codes = {0:'Céu limpo',1:'Quase limpo',2:'Parcialmente nublado',3:'Nublado',45:'Névoa',48:'Névoa com geada',51:'Garoa leve',53:'Garoa moderada',55:'Garoa intensa',61:'Chuva leve',63:'Chuva moderada',65:'Chuva forte',71:'Neve leve',73:'Neve moderada',75:'Neve forte',80:'Pancadas leves',81:'Pancadas moderadas',82:'Pancadas fortes',95:'Trovoada',96:'Trovoada c/ granizo',99:'Trovoada forte c/ granizo'};
      const desc = codes[cur.weathercode] ?? `Código ${cur.weathercode}`;
      out.textContent = `${name}: ${cur.temperature_2m}°C — ${desc} — Vento ${cur.windspeed_10m} km/h — Chuva ${cur.precipitation} mm`;
    } catch(e) {
      out.textContent = 'Erro ao buscar clima';
    }
  });
});
</script>
{% endblock %}
