{% extends 'base.html.twig' %}
{% block title %}Editar Cidade{% endblock %}
{% block content %}
<div class="page-header" style="display:flex;align-items:center;gap:var(--space-4)">
  <a href="{{ path('admin_city_index') }}" class="btn btn-ghost btn-sm">
    <i data-lucide="arrow-left" style="width:14px;height:14px"></i> Voltar
  </a>
  <h1 class="page-title">Editar Cidade</h1>
</div>
<div class="card" style="max-width:520px">
  <div style="padding:var(--space-6)">
    <form method="post">
      <div class="form-group">
        <label class="form-label" for="name">Nome da Cidade</label>
        <input class="form-control" id="name" name="name" required value="{{ city.name }}">
      </div>
      <div class="form-group">
        <label class="form-label" for="state">Estado (UF)</label>
        <input class="form-control" id="state" name="state" maxlength="2" required value="{{ city.state }}">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%">Salvar Alterações</button>
    </form>
  </div>
</div>
{% endblock %}
