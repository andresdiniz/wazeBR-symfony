{% extends 'base.html.twig' %}
{% block title %}Rota: {{ route.name }}{% endblock %}
{% block content %}
<div class="page-header">
  <a href="{{ path('route_admin_index') }}" class="btn btn-ghost">&larr; Voltar</a>
  <h1>{{ route.name }}</h1>
  <span class="badge {{ route.isActive ? 'badge-success' : 'badge-neutral' }}">
    {{ route.isActive ? 'Ativa' : 'Inativa' }}
  </span>
</div>

{% for msg in app.flashes('success') %}
  <div class="alert alert-success">{{ msg }}</div>
{% endfor %}

<div class="detail-card">
  <dl>
    <dt>Descrição</dt><dd>{{ route.description ?? '—' }}</dd>
    <dt>Criada em</dt><dd>{{ route.createdAt|date('d/m/Y H:i') }}</dd>
  </dl>
  <form method="post" action="{{ path('route_admin_toggle', {id: route.id}) }}" style="margin-top:1rem">
    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ route.id) }}">
    <button type="submit" class="btn {{ route.isActive ? 'btn-ghost' : 'btn-primary' }}">
      {{ route.isActive ? 'Desativar Rota' : 'Ativar Rota' }}
    </button>
  </form>
</div>

<h2 style="margin-top:2rem">Sub-rotas ({{ route.subRoutes|length }})</h2>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>De</th>
        <th>Para</th>
        <th>Tempo (s)</th>
        <th>Tempo Hist. (s)</th>
        <th>Extensão (m)</th>
        <th>Congestionamento</th>
      </tr>
    </thead>
    <tbody>
      {% for sub in route.subRoutes %}
      <tr>
        <td>{{ sub.fromName ?? '—' }}</td>
        <td>{{ sub.toName ?? '—' }}</td>
        <td>{{ sub.time ?? '—' }}</td>
        <td>{{ sub.historicTime ?? '—' }}</td>
        <td>{{ sub.length ?? '—' }}</td>
        <td>
          {% if sub.jamLevel is not null %}
            <span class="badge
              {% if sub.jamLevel == 0 %}badge-success
              {% elseif sub.jamLevel <= 2 %}badge-warning
              {% else %}badge-danger{% endif %}">
              {{ sub.jamLevel }}
            </span>
          {% else %}
            —
          {% endif %}
        </td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="empty-cell">Nenhuma sub-rota coletada ainda. Rode <code>app:waze:collect-tvt</code> para popular.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
