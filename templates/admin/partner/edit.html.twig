{% extends 'base.html.twig' %}
{% block title %}Editar: {{ partner.name }}{% endblock %}
{% block content %}
<div class="page-header">
  <a href="{{ path('partner_admin_index') }}" class="btn btn-ghost">&larr; Voltar</a>
  <h1>Editar: {{ partner.name }}</h1>
</div>
<div class="form-card">
  <form method="post" action="{{ path('partner_admin_edit', {id: partner.id}) }}">
    <input type="hidden" name="_method" value="PUT">
    <div class="form-group">
      <label for="name">Nome <span class="required">*</span></label>
      <input type="text" id="name" name="name" required class="form-control" value="{{ partner.name }}">
    </div>
    <div class="form-group">
      <label for="slug">Slug</label>
      <input type="text" id="slug" name="slug" class="form-control" value="{{ partner.slug }}" readonly>
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" class="form-control" value="{{ partner.email ?? '' }}">
    </div>
    <div class="form-group">
      <label for="bbox">BBox</label>
      <input type="text" id="bbox" name="bbox" class="form-control" value="{{ partner.bbox ?? '' }}">
    </div>
    <div class="form-group">
      <label>
        <input type="checkbox" name="isActive" value="1" {{ partner.isActive ? 'checked' : '' }}>
        Parceiro ativo
      </label>
    </div>
    <div class="form-actions">
      <a href="{{ path('partner_admin_index') }}" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
  </form>
</div>
{% endblock %}
