{% extends 'base.html.twig' %}

{% block title %}Editar {{ partner.name }}{% endblock %}

{% block content %}
<div style="max-width:680px">

    <nav aria-label="breadcrumb" style="margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-text-muted)">
        <a href="{{ path('admin_partner_index') }}" style="color:var(--color-primary)">Parceiros</a>
        <span style="margin:0 var(--space-2)">›</span>
        <a href="{{ path('admin_partner_show', {id: partner.id}) }}" style="color:var(--color-primary)">{{ partner.name }}</a>
        <span style="margin:0 var(--space-2)">›</span>
        <span>Editar</span>
    </nav>

    <div class="page-header">
        <h1 class="page-title">Editar: {{ partner.name }}</h1>
    </div>

    <form method="post" action="{{ path('admin_partner_edit', {id: partner.id}) }}" novalidate>

        <div class="card" style="padding:var(--space-6);margin-bottom:var(--space-4)">
            <h2 style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--color-text-muted);margin-bottom:var(--space-5)">Dados do parceiro</h2>

            <div class="form-group">
                <label class="form-label" for="name">Nome</label>
                <input class="form-control" type="text" id="name" name="name" value="{{ partner.name }}" required>
            </div>

            <div class="form-group">
                <label class="form-label" for="slug">Slug</label>
                <input class="form-control" type="text" id="slug" name="slug" value="{{ partner.slug }}" required pattern="[a-z0-9\-]+">
                <span class="form-hint">Apenas letras minúsculas, números e hífens.</span>
            </div>

            <div class="form-group">
                <label class="form-label" for="email">E-mail</label>
                <input class="form-control" type="email" id="email" name="email" value="{{ partner.email }}" required>
            </div>

            <div class="form-group">
                <label class="form-label" for="bbox">Bounding Box (bbox)</label>
                <input class="form-control" type="text" id="bbox" name="bbox" value="{{ partner.bbox }}" style="font-family:monospace" placeholder="minLng,minLat,maxLng,maxLat">
                <span class="form-hint">Coordenadas delimitadoras da área de cobertura.</span>
            </div>

            <div class="form-group">
                <label class="form-label" for="cemaden_states">Estados CEMADEN</label>
                <input class="form-control" type="text" id="cemaden_states" name="cemaden_states"
                    value="{{ partner.cemadenStates|join(', ') }}" placeholder="SP, RJ, MG">
                <span class="form-hint">Siglas dos estados separadas por vírgula.</span>
            </div>

            <div style="display:flex;align-items:center;gap:var(--space-3);margin-top:var(--space-2)">
                <input type="checkbox" id="isActive" name="isActive" value="1"
                    {{ partner.isActive ? 'checked' : '' }}
                    style="width:18px;height:18px;cursor:pointer;accent-color:var(--color-primary)">
                <label for="isActive" class="form-label" style="margin:0;cursor:pointer">Parceiro ativo</label>
            </div>
        </div>

        <div class="card" style="padding:var(--space-5);margin-bottom:var(--space-6)">
            <h2 style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--color-text-muted);margin-bottom:var(--space-3)">API Token</h2>
            <div style="display:flex;align-items:center;gap:var(--space-3);flex-wrap:wrap">
                <code style="flex:1;min-width:0;font-size:var(--text-xs);background:var(--color-surface-offset);padding:var(--space-2) var(--space-3);border-radius:var(--radius-md);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ partner.apiToken }}</code>
                <form method="post" action="{{ path('admin_partner_regenerate_token', {id: partner.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('regen_token_' ~ partner.id) }}">
                    <button type="submit" class="btn btn-ghost btn-sm"
                            onclick="return confirm('Atenção: o token atual deixará de funcionar imediatamente. Confirmar?')">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        Regenerar
                    </button>
                </form>
            </div>
        </div>

        <div style="display:flex;gap:var(--space-3)">
            <button type="submit" class="btn btn-primary">Salvar alterações</button>
            <a href="{{ path('admin_partner_show', {id: partner.id}) }}" class="btn btn-ghost">Cancelar</a>
        </div>

    </form>

</div>
{% endblock %}
