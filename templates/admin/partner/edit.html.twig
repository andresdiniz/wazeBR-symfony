{% extends 'base.html.twig' %}

{% block title %}Editar {{ partner.name }}{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 680px">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin_partner_index') }}">Parceiros</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin_partner_show', {id: partner.id}) }}">{{ partner.name }}</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    <h1 class="h3 mb-4">Editar: {{ partner.name }}</h1>

    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

        <div class="card shadow-sm p-4 mb-3">
            <h2 class="h6 text-muted text-uppercase mb-3">Dados do parceiro</h2>

            <div class="mb-3">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.slug) }}
                {{ form_widget(form.slug, {attr: {class: 'form-control'}}) }}
                {{ form_help(form.slug) }}
                {{ form_errors(form.slug) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.bbox) }}
                {{ form_widget(form.bbox, {attr: {class: 'form-control font-monospace'}}) }}
                {{ form_help(form.bbox) }}
                {{ form_errors(form.bbox) }}
            </div>

            <div class="form-check">
                {{ form_widget(form.isActive, {attr: {class: 'form-check-input'}}) }}
                {{ form_label(form.isActive, null, {label_attr: {class: 'form-check-label'}}) }}
            </div>
        </div>

        <div class="card shadow-sm p-4 mb-4">
            <h2 class="h6 text-muted text-uppercase mb-2">API Token</h2>
            <div class="d-flex align-items-center gap-2">
                <code class="flex-grow-1 bg-light px-3 py-2 rounded small">{{ partner.apiToken }}</code>
                <form method="post" action="{{ path('admin_partner_regenerate_token', {id: partner.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('regen_token_' ~ partner.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-warning"
                            onclick="return confirm('Atenção: o token atual deixará de funcionar imediatamente. Confirmar?')">
                        <i class="bi bi-arrow-repeat"></i> Regenerar
                    </button>
                </form>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">Salvar alterações</button>
            <a href="{{ path('admin_partner_show', {id: partner.id}) }}" class="btn btn-outline-secondary">Cancelar</a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
