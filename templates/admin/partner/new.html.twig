{% extends 'base.html.twig' %}
{% block title %}Novo Parceiro{% endblock %}
{% block content %}
<div class="page-header">
  <a href="{{ path('partner_admin_index') }}" class="btn btn-ghost">&larr; Voltar</a>
  <h1>Novo Parceiro</h1>
</div>
<div class="form-card">
  <form method="post" action="{{ path('partner_admin_new') }}">
    <div class="form-group">
      <label for="name">Nome <span class="required">*</span></label>
      <input type="text" id="name" name="name" required class="form-control">
    </div>
    <div class="form-group">
      <label for="slug">Slug <span class="required">*</span></label>
      <input type="text" id="slug" name="slug" required class="form-control" placeholder="ex: pbh">
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" class="form-control">
    </div>
    <div class="form-group">
      <label for="bbox">BBox (lat_min,lon_min,lat_max,lon_max)</label>
      <input type="text" id="bbox" name="bbox" class="form-control" placeholder="-20.1,-44.1,-19.7,-43.8">
    </div>
    <div class="form-actions">
      <a href="{{ path('partner_admin_index') }}" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary">Criar Parceiro</button>
    </div>
  </form>
</div>
{% endblock %}
