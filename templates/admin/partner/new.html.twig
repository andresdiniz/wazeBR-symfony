{% extends 'base.html.twig' %}

{% block title %}Novo Parceiro{% endblock %}

{% macro error(errors, key) %}
  {% if errors[key] is defined %}
    <span class="form-error">{{ errors[key] }}</span>
  {% endif %}
{% endmacro %}

{% import _self as f %}

{% block content %}
<div style="max-width:760px">

  <nav aria-label="breadcrumb" style="margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-text-muted)">
    <a href="{{ path('admin_partner_index') }}" style="color:var(--color-primary)">Parceiros</a>
    <span style="margin:0 var(--space-2)">›</span>
    <span>Novo parceiro</span>
  </nav>

  <div class="page-header">
    <h1 class="page-title">Novo parceiro</h1>
  </div>

  <form method="post" action="{{ path('admin_partner_new') }}" novalidate id="partnerForm">

    {# ═══════════════════════════════ DADOS DO PARCEIRO ═══════════════════ #}
    <div class="card" style="padding:var(--space-6);margin-bottom:var(--space-4)">
      <h2 style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--color-text-muted);margin-bottom:var(--space-5)">Dados do parceiro</h2>

      <div class="form-group">
        <label class="form-label" for="name">Nome</label>
        <input class="form-control" type="text" id="name" name="name"
               value="{{ old.name ?? '' }}" required autofocus>
        {{ f.error(errors, 'name') }}
      </div>

      <div class="form-group">
        <label class="form-label" for="slug">Slug</label>
        <input class="form-control" type="text" id="slug" name="slug"
               value="{{ old.slug ?? '' }}" required pattern="[a-z0-9\-]+">
        <span class="form-hint">Apenas letras minúsculas, números e hífens. Ex: prefeitura-sp</span>
        {{ f.error(errors, 'slug') }}
      </div>

      <div class="form-group">
        <label class="form-label" for="email">E-mail do parceiro</label>
        <input class="form-control" type="email" id="email" name="email"
               value="{{ old.email ?? '' }}" required>
        {{ f.error(errors, 'email') }}
      </div>

      <div class="form-group">
        <label class="form-label" for="cemaden_states">Estados CEMADEN</label>
        <input class="form-control" type="text" id="cemaden_states" name="cemaden_states"
               value="{{ old.cemaden_states ?? '' }}" placeholder="SP, RJ, MG">
        <span class="form-hint">Siglas separadas por vírgula.</span>
      </div>

      <div style="display:flex;align-items:center;gap:var(--space-3);margin-top:var(--space-2)">
        <input type="checkbox" id="isActive" name="isActive" value="1"
               {{ (old.isActive ?? true) ? 'checked' : '' }}
               style="width:18px;height:18px;cursor:pointer;accent-color:var(--color-primary)">
        <label for="isActive" class="form-label" style="margin:0;cursor:pointer">Parceiro ativo</label>
      </div>
    </div>

    {# ═══════════════════════════════ DELIMITAÇÃO GEOGRÁFICA ═════════════ #}
    <div class="card" style="padding:var(--space-6);margin-bottom:var(--space-4)">
      <h2 style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--color-text-muted);margin-bottom:var(--space-4)">Delimitação geográfica</h2>
      <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
        Desenhe o polígono de cobertura no mapa ou cole um WKT manualmente.
      </p>

      <div id="map" style="height:400px;border-radius:var(--radius-lg);border:1px solid var(--color-border);margin-bottom:var(--space-3);overflow:hidden"></div>

      <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-3);flex-wrap:wrap">
        <button type="button" id="btnDraw" class="btn btn-ghost btn-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
          Desenhar polígono
        </button>
        <button type="button" id="btnClear" class="btn btn-ghost btn-sm" style="color:var(--color-error)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          Limpar
        </button>
      </div>

      <div class="form-group" style="margin-bottom:0">
        <label class="form-label" for="bbox">WKT do polígono</label>
        <textarea class="form-control" id="bbox" name="bbox" rows="3"
          style="font-family:monospace;font-size:var(--text-xs);resize:vertical"
          placeholder="POLYGON((-43.8 -20.6, ...))">{{ old.bbox ?? '' }}</textarea>
        <span class="form-hint">Preenchido automaticamente ao desenhar, ou cole um WKT.</span>
      </div>
    </div>

    {# ═══════════════════════════════ ADMIN DO PARCEIRO ═══════════════════ #}
    <div class="card" style="padding:var(--space-6);margin-bottom:var(--space-4)" id="adminCard">

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-4)">
        <h2 style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--color-text-muted);margin:0">Administrador do parceiro</h2>
        <label style="display:flex;align-items:center;gap:var(--space-2);cursor:pointer;font-size:var(--text-sm)">
          <input type="checkbox" id="toggleAdmin" name="create_admin" value="1"
                 {{ old.create_admin is defined ? 'checked' : '' }}
                 style="width:16px;height:16px;accent-color:var(--color-primary);cursor:pointer">
          Criar agora
        </label>
      </div>

      <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)" id="adminHint">
        Opcional. Cria automaticamente um usuário com <strong>ROLE_ACCOUNT_ADMIN</strong> vinculado a este parceiro.
      </p>

      <div id="adminFields" style="display:none">

        <div class="form-group">
          <label class="form-label" for="admin_name">Nome do administrador</label>
          <input class="form-control" type="text" id="admin_name" name="admin_name"
                 value="{{ old.admin_name ?? '' }}">
          {{ f.error(errors, 'admin_name') }}
        </div>

        <div class="form-group">
          <label class="form-label" for="admin_email">E-mail de acesso</label>
          <input class="form-control" type="email" id="admin_email" name="admin_email"
                 value="{{ old.admin_email ?? '' }}">
          {{ f.error(errors, 'admin_email') }}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4)">
          <div class="form-group">
            <label class="form-label" for="admin_password">Senha</label>
            <div style="position:relative">
              <input class="form-control" type="password" id="admin_password"
                     name="admin_password" autocomplete="new-password"
                     style="padding-right:var(--space-10)">
              <button type="button" class="toggle-pw" data-target="admin_password"
                aria-label="Mostrar senha"
                style="position:absolute;right:var(--space-3);top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--color-text-muted);padding:0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
            <span class="form-hint">Mínimo 8 caracteres.</span>
            {{ f.error(errors, 'admin_password') }}
          </div>

          <div class="form-group">
            <label class="form-label" for="admin_password_confirm">Confirmar senha</label>
            <div style="position:relative">
              <input class="form-control" type="password" id="admin_password_confirm"
                     name="admin_password_confirm" autocomplete="new-password"
                     style="padding-right:var(--space-10)">
              <button type="button" class="toggle-pw" data-target="admin_password_confirm"
                aria-label="Mostrar senha"
                style="position:absolute;right:var(--space-3);top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--color-text-muted);padding:0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
            {{ f.error(errors, 'admin_password_confirm') }}
          </div>
        </div>

        <div style="background:oklch(from var(--color-primary) l c h / .08);border:1px solid oklch(from var(--color-primary) l c h / .18);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);font-size:var(--text-sm);color:var(--color-text-muted)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:4px;color:var(--color-primary)"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          O usuário receberá a role <strong>ROLE_ACCOUNT_ADMIN</strong> e ficará vinculado a este parceiro.
        </div>

      </div>
    </div>

    <div style="display:flex;gap:var(--space-3)">
      <button type="submit" class="btn btn-primary">Criar parceiro</button>
      <a href="{{ path('admin_partner_index') }}" class="btn btn-ghost">Cancelar</a>
    </div>

  </form>
</div>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  .leaflet-container { background: var(--color-bg); }
  #btnDraw.drawing { background: oklch(from var(--color-primary) l c h / .12); color: var(--color-primary); border-color: var(--color-primary); }
  .form-error { display:block; font-size:var(--text-xs); color:var(--color-error); margin-top:var(--space-1); }
</style>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  /* ── Toggle admin fields ─────────────────────────────────── */
  const toggle = document.getElementById('toggleAdmin');
  const fields = document.getElementById('adminFields');
  const hint   = document.getElementById('adminHint');

  function applyToggle() {
    const on = toggle.checked;
    fields.style.display = on ? 'block' : 'none';
    hint.style.display   = on ? 'none'  : 'block';
    fields.querySelectorAll('input').forEach(i => i.required = on && i.id !== 'admin_password_confirm');
  }

  toggle.addEventListener('change', applyToggle);
  applyToggle(); // estado inicial (reaberto após erro)

  /* ── Mostrar/ocultar senha ───────────────────────────────── */
  document.querySelectorAll('.toggle-pw').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = document.getElementById(btn.dataset.target);
      input.type = input.type === 'password' ? 'text' : 'password';
    });
  });

  /* ── Auto-slug a partir do nome ──────────────────────────── */
  const nameInput = document.getElementById('name');
  const slugInput = document.getElementById('slug');
  nameInput.addEventListener('input', () => {
    if (slugInput.dataset.edited) return;
    slugInput.value = nameInput.value
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  });
  slugInput.addEventListener('input', () => { slugInput.dataset.edited = '1'; });

  /* ── Mapa Leaflet ────────────────────────────────────────── */
  const map = L.map('map').setView([-15.8, -47.9], 5);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors', maxZoom: 19
  }).addTo(map);

  const textarea = document.getElementById('bbox');
  let points = [], polyline = null, polygon = null, drawing = false;
  const btnDraw = document.getElementById('btnDraw');
  const btnClear = document.getElementById('btnClear');

  function toWkt(pts) {
    if (pts.length < 3) return '';
    const coords = [...pts, pts[0]].map(p => p.lng.toFixed(10) + ' ' + p.lat.toFixed(10)).join(',');
    return 'POLYGON((' + coords + '))';
  }

  function renderPreview() {
    if (polyline) { map.removeLayer(polyline); polyline = null; }
    if (polygon)  { map.removeLayer(polygon);  polygon  = null; }
    if (!points.length) return;
    if (points.length < 3) {
      polyline = L.polyline(points, {color:'#01696f',weight:2,dashArray:'6 4'}).addTo(map);
    } else {
      polygon = L.polygon(points, {color:'#01696f',weight:2,fillColor:'#01696f',fillOpacity:.12}).addTo(map);
    }
    textarea.value = toWkt(points);
  }

  function loadWkt(wkt) {
    if (!wkt) return;
    const m = wkt.match(/POLYGON\s*\(\((.+?)\)\)/i);
    if (!m) return;
    const pts = m[1].split(',').map(p=>{ const [lng,lat]=p.trim().split(/\s+/); return L.latLng(+lat,+lng); });
    if (pts.length > 1) pts.pop();
    points = pts; renderPreview();
    if (polygon) map.fitBounds(polygon.getBounds(),{padding:[24,24]});
  }

  btnDraw.addEventListener('click', () => {
    drawing = !drawing;
    btnDraw.classList.toggle('drawing', drawing);
    btnDraw.innerHTML = drawing
      ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg> Parar desenho'
      : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg> Desenhar polígono';
    map.getContainer().style.cursor = drawing ? 'crosshair' : '';
  });

  btnClear.addEventListener('click', () => {
    points=[]; renderPreview(); textarea.value='';
    drawing=false; btnDraw.classList.remove('drawing');
    btnDraw.innerHTML='<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg> Desenhar polígono';
    map.getContainer().style.cursor='';
  });

  map.on('click', e => { if (!drawing) return; points.push(e.latlng); renderPreview(); });
  textarea.addEventListener('change', () => { points=[]; loadWkt(textarea.value.trim()); });
  loadWkt(textarea.value.trim());
})();
</script>
{% endblock %}
