{% extends 'base.html.twig' %}

{% block title %}Novo Parceiro{% endblock %}

{% block content %}
<div style="max-width:680px">

    <nav aria-label="breadcrumb" style="margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-text-muted)">
        <a href="{{ path('admin_partner_index') }}" style="color:var(--color-primary)">Parceiros</a>
        <span style="margin:0 var(--space-2)">›</span>
        <span>Novo parceiro</span>
    </nav>

    <div class="page-header">
        <h1 class="page-title">Novo parceiro</h1>
    </div>

    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

        <div class="card" style="padding:var(--space-6);margin-bottom:var(--space-4)">
            <h2 style="font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--color-text-muted);margin-bottom:var(--space-4)">Dados do parceiro</h2>

            <div class="form-group">
                {{ form_label(form.name, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.name, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.slug, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.slug, {attr: {class: 'form-control'}}) }}
                {{ form_help(form.slug) }}
                {{ form_errors(form.slug) }}
            </div>

            <div class="form-group">
                {{ form_label(form.email, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.email, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group">
                {{ form_label(form.bbox, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.bbox, {attr: {class: 'form-control', style: 'font-family:monospace'}}) }}
                {{ form_help(form.bbox) }}
                {{ form_errors(form.bbox) }}
            </div>

            <div style="display:flex;align-items:center;gap:var(--space-3);margin-top:var(--space-2)">
                {{ form_widget(form.isActive) }}
                {{ form_label(form.isActive, null, {label_attr: {class: 'form-label', style: 'margin:0;cursor:pointer'}}) }}
            </div>
        </div>

        <div style="display:flex;gap:var(--space-3)">
            <button type="submit" class="btn btn-primary">Criar parceiro</button>
            <a href="{{ path('admin_partner_index') }}" class="btn btn-ghost">Cancelar</a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
