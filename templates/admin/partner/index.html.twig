{% extends 'base.html.twig' %}

{% block title %}Parceiros — Admin{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Parceiros</h1>
            <p class="text-muted mb-0">Gerencie órgãos públicos e concessionárias cadastrados na plataforma.</p>
        </div>
        <a href="{{ path('admin_partner_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Novo parceiro
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Slug</th>
                        <th>E-mail</th>
                        <th class="text-center">Usuários</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Criado em</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for partner in partners %}
                    <tr>
                        <td>
                            <a href="{{ path('admin_partner_show', {id: partner.id}) }}" class="fw-semibold text-decoration-none">
                                {{ partner.name }}
                            </a>
                        </td>
                        <td><code class="small">{{ partner.slug }}</code></td>
                        <td class="text-muted small">{{ partner.email }}</td>
                        <td class="text-center">{{ partner.users|length }}</td>
                        <td class="text-center">
                            {% if partner.isActive %}
                                <span class="badge bg-success">Ativo</span>
                            {% else %}
                                <span class="badge bg-secondary">Inativo</span>
                            {% endif %}
                        </td>
                        <td class="text-center text-muted small">{{ partner.createdAt|date('d/m/Y') }}</td>
                        <td class="text-end">
                            <a href="{{ path('admin_partner_show', {id: partner.id}) }}" class="btn btn-sm btn-outline-secondary me-1" title="Ver detalhes">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('admin_partner_edit', {id: partner.id}) }}" class="btn btn-sm btn-outline-primary" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-building fs-2 d-block mb-2"></i>
                            Nenhum parceiro cadastrado ainda.
                            <a href="{{ path('admin_partner_new') }}">Criar o primeiro</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
