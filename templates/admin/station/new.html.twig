{% extends 'admin/layout.html.twig' %}

{% block title %}Nova Estação CEMADEN{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Nova Estação CEMADEN</h1>
        <p class="page-subtitle">Cadastre uma estação pluviométrica ou hidrológica para monitoramento.</p>
    </div>
    <a href="{{ path('admin_station_index') }}" class="btn btn-secondary">← Voltar</a>
</div>

{% if errors is defined and errors|length > 0 %}
    <div class="alert alert-error">
        <ul>{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
    </div>
{% endif %}

<div class="card">
    <div class="card-body">
        <form method="POST">
            <div class="form-grid">

                <div class="form-group">
                    <label for="cod_estacao">Código da Estação</label>
                    <input type="text" id="cod_estacao" name="cod_estacao"
                           class="form-control" required
                           placeholder="Ex: 311830410H">
                    <small class="form-hint">Código CEMADEN. Pluviométrica: alfanumérico simples. Hidrológica: geralmente mais dígitos.</small>
                </div>

                <div class="form-group">
                    <label for="nome">Nome da Estação</label>
                    <input type="text" id="nome" name="nome"
                           class="form-control" required
                           placeholder="Ex: Rio Bananeiras">
                </div>

                <div class="form-group">
                    <label for="municipio">Município</label>
                    <input type="text" id="municipio" name="municipio"
                           class="form-control" required
                           placeholder="Ex: Conselheiro Lafaiete">
                </div>

                <div class="form-group">
                    <label for="uf">UF</label>
                    <input type="text" id="uf" name="uf"
                           class="form-control" maxlength="2" required
                           placeholder="MG">
                </div>

                <div class="form-group">
                    <label for="station_type">Tipo da Estação</label>
                    <select id="station_type" name="station_type" class="form-control"
                            onchange="toggleHydroUrl(this.value)">
                        {% for value, label in station_types %}
                            <option value="{{ value }}">{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="partner_slug">Parceiro</label>
                    <select id="partner_slug" name="partner_slug" class="form-control">
                        {% for partner in partners %}
                            <option value="{{ partner.slug }}">{{ partner.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="lat">Latitude (opcional)</label>
                    <input type="number" id="lat" name="lat" step="0.000001"
                           class="form-control" placeholder="Ex: -20.656400">
                    <small class="form-hint">Deixe vazio — será preenchida automaticamente na 1ª coleta pluviométrica.</small>
                </div>

                <div class="form-group">
                    <label for="lng">Longitude (opcional)</label>
                    <input type="number" id="lng" name="lng" step="0.000001"
                           class="form-control" placeholder="Ex: -43.793700">
                </div>

            </div>

            <div id="hydro-url-section" style="display:none">
                <div class="form-group" style="margin-top:1rem">
                    <label for="hydro_url">URL da API Hidrológica CEMADEN</label>
                    <input type="url" id="hydro_url" name="hydro_url"
                           class="form-control"
                           placeholder="https://resources.cemaden.gov.br/graficos/cemaden/hidro/resources/json/MedidaResource.php?est=XXXX&sen=20&pag=24">
                    <small class="form-hint">
                        URL completa retornando JSON com campos: <code>datahora</code>, <code>valor</code>, <code>offset</code>.
                    </small>
                </div>
            </div>

            <div class="form-actions" style="margin-top:1.5rem">
                <button type="submit" class="btn btn-primary">✚ Criar Estação</button>
                <a href="{{ path('admin_station_index') }}" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<script>
function toggleHydroUrl(type) {
    document.getElementById('hydro-url-section').style.display =
        type === 'hydrological' ? '' : 'none';
}
</script>
{% endblock %}
