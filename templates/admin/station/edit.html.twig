{% extends 'base.html.twig' %}

{% block title %}Editar Estação CEMADEN{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 800px">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1">Editar Estação</h1>
            <p class="text-muted small mb-0">{{ station.nome }} — {{ station.municipio starts with '{' ? '(município corrompido)' : station.municipio }}/{{ station.uf }}</p>
        </div>
        <a href="{{ path('admin_station_index') }}" class="btn btn-outline-secondary btn-sm">← Voltar</a>
    </div>

    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('success') %}
        <div class="alert alert-success">{{ msg }}</div>
    {% endfor %}

    {% if municipio_warning %}
        <div class="alert alert-warning">⚠️ {{ municipio_warning }}</div>
    {% endif %}

    {% if errors is defined and errors|length > 0 %}
        <div class="alert alert-danger">
            <ul class="mb-0">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
        </div>
    {% endif %}

    <form method="POST">
        <div class="row g-3">

            <div class="col-md-6">
                <label class="form-label fw-semibold">Código da Estação</label>
                <input type="text" name="cod_estacao" class="form-control"
                       value="{{ station.cod_estacao }}" required
                       placeholder="Ex: 311830410H">
                <div class="form-text">Pluviométrica: 9 dígitos+letra &nbsp;|&nbsp; Hidrológica: geralmente 10 dígitos+letra</div>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Nome da Estação</label>
                <input type="text" name="nome" class="form-control"
                       value="{{ station.nome }}" required>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Município</label>
                <input type="text" name="municipio" class="form-control{% if municipio_warning %} is-warning border-warning{% endif %}"
                       value="{% if station.municipio starts with '{' %}{% else %}{{ station.municipio }}{% endif %}"
                       required placeholder="Ex: Conselheiro Lafaiete">
                {% if municipio_warning %}
                    <div class="form-text text-warning">O valor atual está corrompido. Digite o nome correto.</div>
                {% endif %}
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">UF</label>
                <input type="text" name="uf" class="form-control"
                       value="{{ station.uf }}" maxlength="2" required>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Tipo da Estação</label>
                <select name="station_type" class="form-select" id="station-type-select"
                        onchange="toggleHydroUrl(this.value)">
                    {% for value, label in station_types %}
                        <option value="{{ value }}"
                            {% if station.station_type == value %}selected{% endif %}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Parceiro</label>
                <select name="partner_slug" class="form-select">
                    {% for partner in partners %}
                        <option value="{{ partner.slug }}"
                            {% if station.partner_slug == partner.slug %}selected{% endif %}>
                            {{ partner.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Latitude <span class="text-muted fw-normal">(opcional)</span></label>
                <input type="number" name="lat" class="form-control" step="0.000001"
                       value="{{ station.lat ?? '' }}" placeholder="-20.656400">
                <div class="form-text">Preenchida automaticamente na 1ª coleta pluviométrica.</div>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Longitude <span class="text-muted fw-normal">(opcional)</span></label>
                <input type="number" name="lng" class="form-control" step="0.000001"
                       value="{{ station.lng ?? '' }}" placeholder="-43.793700">
            </div>

        </div>

        {# hydro_url — visível apenas para hidrológicas #}
        <div id="hydro-url-section" class="mt-3"
             style="{{ station.station_type != 'hydrological' ? 'display:none' : '' }}">
            <label class="form-label fw-semibold">URL da API Hidrológica CEMADEN</label>
            <input type="url" name="hydro_url" class="form-control font-monospace"
                   value="{{ station.hydro_url ?? '' }}"
                   placeholder="https://resources.cemaden.gov.br/graficos/cemaden/hidro/resources/json/MedidaResource.php?est=XXXX&sen=20&pag=24">
            <div class="form-text">URL completa retornando JSON com campos: <code>datahora</code>, <code>valor</code>, <code>offset</code>.</div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">💾 Salvar alterações</button>
            <a href="{{ path('admin_station_index') }}" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

<script>
function toggleHydroUrl(type) {
    document.getElementById('hydro-url-section').style.display =
        type === 'hydrological' ? '' : 'none';
}
</script>
{% endblock %}
