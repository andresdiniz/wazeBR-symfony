{% extends 'base.html.twig' %}

{% block title %}Editar Estação CEMADEN{% endblock %}

{% block content %}
<div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem">
    <div>
        <h1 class="page-title">Editar Estação</h1>
        <p class="page-subtitle">
            {{ station.nome }} —
            {% if station.municipio starts with '{' %}
                <span style="color:var(--color-warning)">(município corrompido)</span>
            {% else %}
                {{ station.municipio }}
            {% endif %}
            / {{ station.uf }}
        </p>
    </div>
    <a href="{{ path('admin_station_index') }}" class="btn btn-ghost btn-sm">← Voltar</a>
</div>

{% if municipio_warning %}
    <div class="flash flash-error" style="margin-bottom:var(--space-4)">
        <i data-lucide="alert-triangle" style="width:16px;height:16px"></i>
        {{ municipio_warning }}
    </div>
{% endif %}

{% if errors is defined and errors|length > 0 %}
    <div class="flash flash-error">
        <div>{% for e in errors %}<div>{{ e }}</div>{% endfor %}</div>
    </div>
{% endif %}

<div class="card" style="padding:var(--space-6)">
    <form method="POST">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-4)">

            <div class="form-group">
                <label class="form-label">Código da Estação</label>
                <input type="text" name="cod_estacao" class="form-control"
                       value="{{ station.cod_estacao }}" required
                       placeholder="Ex: 311830410H">
                <span class="form-hint">Pluviométrica: 9 dígitos+letra &nbsp;|&nbsp; Hidrológica: 10+ dígitos+letra</span>
            </div>

            <div class="form-group">
                <label class="form-label">Nome da Estação</label>
                <input type="text" name="nome" class="form-control"
                       value="{{ station.nome }}" required>
            </div>

            <div class="form-group">
                <label class="form-label">Município</label>
                <input type="text" name="municipio" class="form-control"
                       value="{% if station.municipio starts with '{' %}{% else %}{{ station.municipio }}{% endif %}"
                       required placeholder="Ex: Conselheiro Lafaiete"
                       style="{% if municipio_warning %}border-color:var(--color-warning){% endif %}">
                {% if municipio_warning %}
                    <span class="form-hint" style="color:var(--color-warning)">Dado corrompido. Digite o nome correto do município.</span>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label">UF</label>
                <input type="text" name="uf" class="form-control"
                       value="{{ station.uf }}" maxlength="2" required
                       placeholder="MG">
            </div>

            <div class="form-group">
                <label class="form-label">Tipo da Estação</label>
                <select name="station_type" class="form-control"
                        onchange="toggleHydroUrl(this.value)">
                    {% for value, label in station_types %}
                        <option value="{{ value }}"
                            {% if station.station_type == value %}selected{% endif %}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Parceiro</label>
                <select name="partner_slug" class="form-control">
                    {% for partner in partners %}
                        <option value="{{ partner.slug }}"
                            {% if station.partner_slug == partner.slug %}selected{% endif %}>
                            {{ partner.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Latitude <span style="color:var(--color-text-muted);font-weight:400">(opcional)</span></label>
                <input type="number" name="lat" class="form-control" step="0.000001"
                       value="{{ station.lat ?? '' }}" placeholder="-20.656400">
                <span class="form-hint">Preenchida automaticamente na 1ª coleta pluviométrica.</span>
            </div>

            <div class="form-group">
                <label class="form-label">Longitude <span style="color:var(--color-text-muted);font-weight:400">(opcional)</span></label>
                <input type="number" name="lng" class="form-control" step="0.000001"
                       value="{{ station.lng ?? '' }}" placeholder="-43.793700">
            </div>

        </div>

        <div id="hydro-url-section"
             style="margin-top:var(--space-4);{{ station.station_type != 'hydrological' ? 'display:none' : '' }}">
            <div class="form-group">
                <label class="form-label">URL da API Hidrológica CEMADEN</label>
                <input type="url" name="hydro_url" class="form-control"
                       value="{{ station.hydro_url ?? '' }}"
                       placeholder="https://resources.cemaden.gov.br/graficos/cemaden/hidro/resources/json/MedidaResource.php?est=XXXX&sen=20&pag=24"
                       style="font-family:monospace;font-size:var(--text-xs)">
                <span class="form-hint">Retorna JSON com campos: <code>datahora</code>, <code>valor</code>, <code>offset</code>.</span>
            </div>
        </div>

        <div style="display:flex;gap:var(--space-3);margin-top:var(--space-6)">
            <button type="submit" class="btn btn-primary">💾 Salvar alterações</button>
            <a href="{{ path('admin_station_index') }}" class="btn btn-ghost">Cancelar</a>
        </div>
    </form>
</div>

<script>
function toggleHydroUrl(type) {
    document.getElementById('hydro-url-section').style.display =
        type === 'hydrological' ? '' : 'none';
}
</script>
{% endblock %}
