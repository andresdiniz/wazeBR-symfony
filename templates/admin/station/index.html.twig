{% extends 'base.html.twig' %}

{% block title %}Estações CEMADEN{% endblock %}

{% block content %}
<div class="page-header" style="display:flex;justify-content:space-between;align-items:center">
    <div>
        <h1 class="page-title">Estações CEMADEN</h1>
        <p class="page-subtitle">Estações pluviométricas e hidrológicas monitoradas.</p>
    </div>
    <a href="{{ path('admin_station_new') }}" class="btn btn-primary btn-sm">✚ Nova Estação</a>
</div>

{% if by_partner is empty %}
    <div class="empty">
        <i data-lucide="radio-tower"></i>
        <h3>Nenhuma estação cadastrada</h3>
        <p>Adicione uma estação CEMADEN para começar o monitoramento pluviométrico.</p>
        <a href="{{ path('admin_station_new') }}" class="btn btn-primary">✚ Nova Estação</a>
    </div>
{% else %}
    {% for slug, stations in by_partner %}
        <div style="margin-bottom:var(--space-2)">
            <p class="form-hint" style="text-transform:uppercase;letter-spacing:.06em;font-weight:600">Parceiro: {{ slug }}</p>
        </div>
        <div class="card" style="margin-bottom:var(--space-6)">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Código</th>
                            <th>Nome</th>
                            <th>Município / UF</th>
                            <th>Tipo</th>
                            <th>Lat / Lng</th>
                            <th>Ativo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in stations %}
                        <tr>
                            <td style="color:var(--color-text-faint)">{{ s.id }}</td>
                            <td><code style="font-size:var(--text-xs)">{{ s.cod_estacao }}</code></td>
                            <td>{{ s.nome }}</td>
                            <td>
                                {% if s.municipio starts with '{' %}
                                    <span class="badge badge-orange" title="Dado corrompido">⚠️ corrompido</span>
                                {% else %}
                                    {{ s.municipio }}
                                {% endif %}
                                / {{ s.uf }}
                            </td>
                            <td>
                                <span class="badge badge-gray">{{ station_types[s.station_type] ?? s.station_type }}</span>
                                {% if s.station_type == 'hydrological' and s.hydro_url %}
                                    <a href="{{ s.hydro_url }}" target="_blank" title="Ver API" style="margin-left:4px;color:var(--color-primary)">🔗</a>
                                {% endif %}
                            </td>
                            <td style="color:var(--color-text-muted);font-size:var(--text-xs)">
                                {% if s.lat and s.lng %}
                                    {{ s.lat|number_format(4) }}, {{ s.lng|number_format(4) }}
                                {% else %}
                                    <span style="color:var(--color-text-faint)">—</span>
                                {% endif %}
                            </td>
                            <td>
                                <form method="POST" action="{{ path('admin_station_toggle', {id: s.id}) }}" style="display:inline">
                                    <button class="btn btn-sm {{ s.is_active ? 'btn-primary' : 'btn-ghost' }}"
                                            title="{{ s.is_active ? 'Ativo — clique para desativar' : 'Inativo — clique para ativar' }}">
                                        {{ s.is_active ? '✅' : '⏸️' }}
                                    </button>
                                </form>
                            </td>
                            <td style="text-align:right;white-space:nowrap">
                                <a href="{{ path('admin_station_edit', {id: s.id}) }}"
                                   class="btn btn-ghost btn-sm">Editar</a>
                                <form method="POST" action="{{ path('admin_station_delete', {id: s.id}) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Remover esta estação?')">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('del_station_' ~ s.id) }}">
                                    <button class="btn btn-ghost btn-sm"
                                            style="color:var(--color-error)">Remover</button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endfor %}
{% endif %}
{% endblock %}
