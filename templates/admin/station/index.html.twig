{% extends 'base.html.twig' %}
{% block title %}Estações CEMADEN{% endblock %}
{% block content %}
<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Estações CEMADEN</h1>
    <div class="page-subtitle">Estações pluviométricas e fluviométricas monitoradas</div>
  </div>
  <a href="{{ path('admin_station_new') }}" class="btn btn-primary">
    <i data-lucide="plus" style="width:14px;height:14px"></i> Nova Estação
  </a>
</div>

<div class="card">
  <div style="padding:var(--space-4);border-bottom:1px solid var(--color-divider)">
    <input class="form-control" id="station-search" placeholder="Filtrar por nome, município ou código…" style="max-width:360px">
  </div>
  <div style="overflow-x:auto">
    <table id="station-table">
      <thead>
        <tr>
          <th>Código</th>
          <th>Nome da Estação</th>
          <th>Município / UF</th>
          <th>Lat / Long</th>
          <th>Parceiro</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
      {% for s in stations %}
        <tr>
          <td style="font-family:monospace;font-size:var(--text-xs)">{{ s.stationCode }}</td>
          <td style="font-weight:500">{{ s.stationName }}</td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ s.municipality }} / {{ s.state }}</td>
          <td style="font-size:var(--text-xs);font-family:monospace">{{ s.latitude }}, {{ s.longitude }}</td>
          <td style="font-size:var(--text-xs)">{{ s.partner ? s.partner.name : '—' }}</td>
          <td style="display:flex;gap:var(--space-2)">
            <a href="{{ path('admin_station_edit', {id: s.id}) }}" class="btn btn-ghost btn-sm">
              <i data-lucide="pencil" style="width:12px;height:12px"></i>
            </a>
            <form method="post" action="{{ path('admin_station_delete', {id: s.id}) }}" onsubmit="return confirm('Excluir estação?')">
              <input type="hidden" name="_token" value="{{ csrf_token('del_station_' ~ s.id) }}">
              <button class="btn btn-sm" style="color:var(--color-error);border-color:oklch(from var(--color-error) l c h/.3)">
                <i data-lucide="trash-2" style="width:12px;height:12px"></i>
              </button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="6" style="text-align:center;padding:var(--space-16);color:var(--color-text-muted)">
          Nenhuma estação. <a href="{{ path('admin_station_new') }}" style="color:var(--color-primary)">Adicionar</a>
        </td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
{% block javascripts %}
<script>
const inp = document.getElementById('station-search');
const rows = document.querySelectorAll('#station-table tbody tr');
inp?.addEventListener('input', () => {
  const q = inp.value.toLowerCase();
  rows.forEach(r => {
    r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});
</script>
{% endblock %}
