{% extends 'base.html.twig' %}

{% block title %}Estações CEMADEN{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Estações CEMADEN</h1>
        <a href="{{ path('admin_station_new') }}" class="btn btn-primary btn-sm">✚ Nova Estação</a>
    </div>

    {% for msg in app.flashes('success') %}
        <div class="alert alert-success">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger">{{ msg }}</div>
    {% endfor %}

    {% if by_partner is empty %}
        <div class="alert alert-info">Nenhuma estação cadastrada ainda.</div>
    {% else %}
        {% for slug, stations in by_partner %}
            <h5 class="mt-4 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em">Parceiro: {{ slug }}</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Código</th>
                            <th>Nome</th>
                            <th>Município/UF</th>
                            <th>Tipo</th>
                            <th>Lat/Lng</th>
                            <th>Ativo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in stations %}
                        <tr>
                            <td class="text-muted">{{ s.id }}</td>
                            <td><code>{{ s.cod_estacao }}</code></td>
                            <td>{{ s.nome }}</td>
                            <td>
                                {% if s.municipio starts with '{' %}
                                    <span class="badge bg-warning text-dark" title="Dado corrompido">⚠️ corrompido</span>
                                {% else %}
                                    {{ s.municipio }}
                                {% endif %}
                                /{{ s.uf }}
                            </td>
                            <td>
                                <span class="badge bg-secondary">{{ station_types[s.station_type] ?? s.station_type }}</span>
                                {% if s.station_type == 'hydrological' and s.hydro_url %}
                                    <a href="{{ s.hydro_url }}" target="_blank" class="small ms-1" title="API">&#x1f517;</a>
                                {% endif %}
                            </td>
                            <td class="small text-muted">
                                {% if s.lat and s.lng %}
                                    {{ s.lat|number_format(4) }}, {{ s.lng|number_format(4) }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                <form method="POST" action="{{ path('admin_station_toggle', {id: s.id}) }}" class="d-inline">
                                    <button class="btn btn-sm {{ s.is_active ? 'btn-success' : 'btn-outline-secondary' }}"
                                            title="{{ s.is_active ? 'Ativo — clique para desativar' : 'Inativo — clique para ativar' }}">
                                        {{ s.is_active ? '✅' : '⏸️' }}
                                    </button>
                                </form>
                            </td>
                            <td class="text-end">
                                <a href="{{ path('admin_station_edit', {id: s.id}) }}"
                                   class="btn btn-sm btn-outline-primary">Editar</a>
                                <form method="POST" action="{{ path('admin_station_delete', {id: s.id}) }}"
                                      class="d-inline"
                                      onsubmit="return confirm('Remover esta estação?')">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('del_station_' ~ s.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Remover</button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}
