{% extends 'base.html.twig' %}
{% block title %}Links Monitorados{% endblock %}
{% block content %}
<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Links Monitorados</h1>
    <div class="page-subtitle">Feeds de dados Waze por parceiro</div>
  </div>
  <a href="{{ path('admin_link_new') }}" class="btn btn-primary">
    <i data-lucide="plus" style="width:14px;height:14px"></i> Novo Link
  </a>
</div>

{% if by_partner is empty %}
  <div class="empty">
    <i data-lucide="link" style="width:40px;height:40px"></i>
    <h3>Nenhum link cadastrado</h3>
    <p>Adicione o primeiro feed de dados.</p>
    <a href="{{ path('admin_link_new') }}" class="btn btn-primary">Novo Link</a>
  </div>
{% else %}
  {% for group in by_partner %}
    <div class="card" style="margin-bottom:var(--space-6)">
      <div class="card-header">
        <div style="display:flex;align-items:center;gap:var(--space-3)">
          <i data-lucide="building-2" style="width:16px;height:16px;color:var(--color-text-muted)"></i>
          <span class="card-title">{{ group.partner ? group.partner.name : 'Sem parceiro' }}</span>
          {% if group.partner %}<span class="badge badge-gray">{{ group.partner.slug }}</span>{% endif %}
        </div>
        <span style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ group.links|length }} link(s)</span>
      </div>
      <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>Rótulo</th>
              <th>URL</th>
              <th>Formato</th>
              <th>Última Coleta</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
          {% for link in group.links %}
            <tr style="opacity:{{ link.isActive ? 1 : 0.5 }}">
              <td style="font-weight:500">{{ link.label ?? '—' }}</td>
              <td style="font-size:var(--text-xs);color:var(--color-text-muted);max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                <a href="{{ link.url }}" target="_blank" rel="noopener" title="{{ link.url }}">{{ link.url|length > 50 ? link.url|slice(0,50) ~ '…' : link.url }}</a>
              </td>
              <td><span class="badge badge-gray">Feed {{ link.feedFormat }}</span></td>
              <td style="font-size:var(--text-xs);font-variant-numeric:tabular-nums">
                {% if link.lastCollectedAt %}
                  <time data-utc="{{ link.lastCollectedAt|date('c') }}" data-fmt="dtime">{{ link.lastCollectedAt|date('d/m H:i') }}</time>
                {% else %}
                  <span style="color:var(--color-text-faint)">Nunca</span>
                {% endif %}
              </td>
              <td>
                {% if link.isActive %}
                  <span class="badge" style="background:oklch(from var(--color-success) l c h/.12);color:var(--color-success)">Ativo</span>
                {% else %}
                  <span class="badge badge-gray">Inativo</span>
                {% endif %}
              </td>
              <td style="white-space:nowrap;display:flex;gap:var(--space-2)">
                <a href="{{ path('admin_link_edit', {id: link.id}) }}" class="btn btn-ghost btn-sm" title="Editar">
                  <i data-lucide="pencil" style="width:12px;height:12px"></i>
                </a>
                <form method="post" action="{{ path('admin_link_toggle', {id: link.id}) }}">
                  <button class="btn btn-ghost btn-sm" title="{{ link.isActive ? 'Desativar' : 'Ativar' }}">
                    <i data-lucide="{{ link.isActive ? 'pause' : 'play' }}" style="width:12px;height:12px"></i>
                  </button>
                </form>
                <form method="post" action="{{ path('admin_link_delete', {id: link.id}) }}" onsubmit="return confirm('Excluir este link?')">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_link_' ~ link.id) }}">
                  <button class="btn btn-sm" style="color:var(--color-error);border-color:oklch(from var(--color-error) l c h/.3)" title="Excluir">
                    <i data-lucide="trash-2" style="width:12px;height:12px"></i>
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endfor %}
{% endif %}
{% endblock %}
