{% extends 'base.html.twig' %}

{% block title %}Novo Link Monitorado{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 640px">

    <h1 class="h4 mb-4">Novo Link Monitorado</h1>

    {% for flash in app.flashes('error') %}
        <div class="alert alert-danger">{{ flash }}</div>
    {% endfor %}

    <form method="post" action="{{ path('admin_link_new') }}">

        <div class="mb-3">
            <label class="form-label fw-semibold">Parceiro <span class="text-danger">*</span></label>
            <select name="partner_id" class="form-select" required>
                <option value="">Selecione o parceiro...</option>
                {% for partner in partners %}
                    <option value="{{ partner.id }}">{{ partner.name }} ({{ partner.slug }})</option>
                {% endfor %}
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Nome do link <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" required
                   placeholder="Ex: PBH \u2014 Alertas Centro-Sul">
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Tipo <span class="text-danger">*</span></label>
            <select name="type" class="form-select" required id="type-select">
                {% for type in types %}
                    <option value="{{ type }}">
                        {% if type == 'feed' %}\ud83d\udea8 Alertas Waze
                        {% elseif type == 'traffic' %}\ud83d\ude97 Tr\u00e1fego TVT
                        {% elseif type == 'cemaden' %}\ud83c\udf27 CEMADEN
                        {% elseif type == 'camera' %}\ud83d\udcf7 C\u00e2mera
                        {% elseif type == 'sensor' %}\ud83d\udcf1 Sensor
                        {% else %}\ud83d\udd17 Gen\u00e9rico{% endif %}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">URL do feed <span class="text-danger">*</span></label>
            <input type="url" name="url" class="form-control font-monospace" required
                   placeholder="https://www.waze.com/row-partnerhub-api/..."
                   id="url-input">
            <div class="form-text" id="url-hint">
                O feedUuid e o partnerId ser\u00e3o extra\u00eddos automaticamente da URL.
            </div>
        </div>

        {# Dicas din\u00e2micas por tipo #}
        <div id="hint-feed" class="alert alert-secondary small d-none">
            <strong>Formato esperado (Alertas):</strong><br>
            <code>https://www.waze.com/row-partnerhub-api/partners/{ID}/waze-feeds/{UUID}?format=1</code>
        </div>
        <div id="hint-traffic" class="alert alert-secondary small d-none">
            <strong>Formato esperado (Tr\u00e1fego TVT):</strong><br>
            <code>https://www.waze.com/row-partnerhub-api/feeds-tvt/{UUID}?id={partnerID}</code>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a href="{{ path('admin_link_index') }}" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

<script>
(function() {
    const typeSelect = document.getElementById('type-select');
    const hintFeed   = document.getElementById('hint-feed');
    const hintTraffic = document.getElementById('hint-traffic');

    function updateHint() {
        hintFeed.classList.add('d-none');
        hintTraffic.classList.add('d-none');
        if (typeSelect.value === 'feed')    hintFeed.classList.remove('d-none');
        if (typeSelect.value === 'traffic') hintTraffic.classList.remove('d-none');
    }

    typeSelect.addEventListener('change', updateHint);
    updateHint();
})();
</script>
{% endblock %}
