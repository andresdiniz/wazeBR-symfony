<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WazeBR — Monitoramento de Tráfego em Tempo Real</title>
    <meta name="description" content="Plataforma de monitoramento de tráfego urbano em tempo real para órgãos públicos e concessionárias de rodovias. Alertas Waze, congestionamentos, chuva e muito mais.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Overpass:wght@500;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --asphalt:   #0c0e12;
            --panel:     #14181f;
            --panel-2:   #1a1f28;
            --line:      rgba(255,255,255,0.08);
            --paper:     #eef1f0;
            --dim:       #838c99;
            --faint:     #454e5c;
            --signal:    #ffb400;
            --signal-dim:#8a6300;
            --flow:      #35d0a0;
            --jam:       #ff4d6a;
            --font-body:    'Inter', sans-serif;
            --font-display: 'Overpass', sans-serif;
            --font-mono:    'JetBrains Mono', monospace;
            --radius-sm: 6px;
            --radius-md: 10px;
            --radius-lg: 16px;
            --radius-xl: 22px;
        }
        html { scroll-behavior: smooth; }
        body {
            font-family: var(--font-body);
            background: var(--asphalt);
            color: var(--paper);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }
        img { display: block; max-width: 100%; }
        a { color: inherit; text-decoration: none; }
        button { cursor: pointer; font: inherit; border: none; }
        a:focus-visible, button:focus-visible {
            outline: 2px solid var(--signal); outline-offset: 3px; border-radius: 4px;
        }
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                scroll-behavior: auto !important;
            }
        }

        /* ── NAV ── */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 clamp(1.25rem, 5vw, 4rem);
            height: 64px;
            background: rgba(12,14,18,0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--line);
        }
        .nav-logo {
            display: flex; align-items: center; gap: 10px;
            font-family: var(--font-display); font-size: 1.15rem; font-weight: 800;
            letter-spacing: 0.01em; color: var(--paper); text-transform: uppercase;
        }
        .nav-logo svg { color: var(--signal); flex-shrink: 0; }
        .nav-status {
            display: flex; align-items: center; gap: 6px;
            font-family: var(--font-mono); font-size: 0.7rem; color: var(--dim);
            margin-left: 14px; padding-left: 14px; border-left: 1px solid var(--line);
        }
        .nav-status span { width: 6px; height: 6px; border-radius: 50%; background: var(--flow); animation: pulse 2s ease-in-out infinite; flex-shrink: 0; }
        @media (max-width: 560px) { .nav-status { display: none; } }
        .nav-cta {
            background: var(--signal); color: #1a1300;
            padding: 8px 18px; border-radius: var(--radius-sm);
            font-size: 0.85rem; font-weight: 700;
            transition: background 0.18s, transform 0.18s;
        }
        .nav-cta:hover { background: #ffc633; transform: translateY(-1px); }

        /* ── HERO ── */
        .hero {
            padding: clamp(6.5rem, 14vw, 9rem) clamp(1.25rem, 5vw, 4rem) clamp(3.5rem, 7vw, 5rem);
            display: grid; grid-template-columns: 1.15fr 0.85fr;
            gap: clamp(2rem, 5vw, 4rem);
            max-width: 1280px; margin: 0 auto;
            align-items: center;
        }
        @media (max-width: 980px) { .hero { grid-template-columns: 1fr; } }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(255,180,0,0.08); border: 1px solid rgba(255,180,0,0.25);
            color: var(--signal); border-radius: 999px;
            padding: 6px 14px; font-size: 0.72rem; font-weight: 700;
            letter-spacing: 0.08em; text-transform: uppercase;
            margin-bottom: 1.75rem; font-family: var(--font-mono);
        }
        .hero-badge span { width: 6px; height: 6px; border-radius: 50%; background: var(--signal); animation: pulse 2s ease-in-out infinite; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.25} }
        .hero h1 {
            font-family: var(--font-display);
            font-size: clamp(2.3rem, 5.2vw, 4.2rem);
            font-weight: 800; line-height: 1.04;
            letter-spacing: -0.01em; text-transform: uppercase;
            margin-bottom: 1.4rem;
        }
        .hero h1 em { font-style: normal; color: var(--signal); }
        .hero p {
            font-size: clamp(1rem, 1.4vw, 1.15rem);
            color: var(--dim); max-width: 520px;
            margin-bottom: 2.25rem; line-height: 1.7;
        }
        .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
        .btn-primary {
            background: var(--signal); color: #1a1300;
            padding: 14px 30px; border-radius: var(--radius-sm);
            font-weight: 700; font-size: 0.95rem;
            transition: background 0.18s, transform 0.18s;
        }
        .btn-primary:hover { background: #ffc633; transform: translateY(-1px); }
        .btn-ghost {
            border: 1px solid var(--line); color: var(--paper);
            padding: 14px 30px; border-radius: var(--radius-sm);
            font-weight: 500; font-size: 0.95rem;
            transition: border-color 0.18s, background 0.18s;
        }
        .btn-ghost:hover { border-color: var(--signal); background: rgba(255,180,0,0.06); }

        /* ── LIVE TICKER (feed simulado) ── */
        .ticker {
            margin-top: 2.5rem; max-width: 520px;
            border: 1px solid var(--line); border-radius: var(--radius-md);
            background: var(--panel); overflow: hidden; position: relative;
            height: 118px;
        }
        .ticker::after {
            content: ''; position: absolute; inset: 0; pointer-events: none;
            background: linear-gradient(var(--panel), transparent 18%, transparent 82%, var(--panel));
        }
        .ticker-head {
            font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.08em;
            text-transform: uppercase; color: var(--faint);
            padding: 10px 14px 0;
        }
        .ticker-track {
            display: flex; flex-direction: column; gap: 9px;
            padding: 8px 14px 14px;
            animation: ticker-scroll 16s linear infinite;
        }
        .ticker-track div {
            font-family: var(--font-mono); font-size: 0.76rem; color: var(--dim);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .ticker-track time { color: var(--signal); margin-right: 8px; }
        .ticker-track .tag { color: var(--faint); margin-right: 6px; }
        @keyframes ticker-scroll { from { transform: translateY(0); } to { transform: translateY(-50%); } }

        /* ── RADAR PANEL (elemento assinatura) ── */
        .radar-panel {
            position: relative; aspect-ratio: 1 / 1; width: 100%; max-width: 460px;
            margin: 0 auto; border-radius: var(--radius-xl);
            border: 1px solid var(--line);
            background: radial-gradient(circle at 50% 50%, #171e28 0%, #0c1218 72%);
            overflow: hidden;
        }
        .radar-grid {
            position: absolute; inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.045) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.045) 1px, transparent 1px);
            background-size: 34px 34px;
        }
        .radar-road-h, .radar-road-v {
            position: absolute; background: rgba(255,180,0,0.14);
        }
        .radar-road-h { left: 0; right: 0; top: 50%; height: 2px; }
        .radar-road-v { top: 0; bottom: 0; left: 50%; width: 2px; }
        .radar-ring {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
            border: 1px solid rgba(255,255,255,0.08); border-radius: 50%;
        }
        .radar-ring.r1 { width: 34%; height: 34%; }
        .radar-ring.r2 { width: 62%; height: 62%; }
        .radar-ring.r3 { width: 90%; height: 90%; }
        .radar-sweep {
            position: absolute; inset: 0; border-radius: 50%;
            background: conic-gradient(from 0deg, rgba(255,180,0,0.4), transparent 30%);
            animation: radar-spin 4.5s linear infinite;
            mix-blend-mode: screen;
        }
        @keyframes radar-spin { to { transform: rotate(360deg); } }
        .radar-blip {
            position: absolute; width: 9px; height: 9px; border-radius: 50%;
            background: var(--c, var(--signal));
            animation: radar-blip 2.2s ease-out infinite;
        }
        @keyframes radar-blip {
            0%   { box-shadow: 0 0 0 0 rgba(255,180,0,0.45); }
            70%  { box-shadow: 0 0 0 14px transparent; }
            100% { box-shadow: 0 0 0 0 transparent; }
        }
        .radar-coord {
            position: absolute; font-family: var(--font-mono); font-size: 0.62rem;
            color: var(--faint); letter-spacing: 0.03em;
        }
        .radar-coord.tl { top: 14px; left: 16px; }
        .radar-coord.br { bottom: 14px; right: 16px; }
        .radar-caption {
            position: absolute; bottom: 14px; left: 16px;
            font-family: var(--font-mono); font-size: 0.62rem; color: var(--faint);
        }

        /* ── STATS BAR ── */
        .stats-bar {
            background: var(--panel);
            border-top: 1px solid var(--line);
            border-bottom: 1px solid var(--line);
            padding: 2rem clamp(1.25rem, 5vw, 4rem);
        }
        .stats-grid {
            max-width: 1100px; margin: 0 auto;
            display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 2rem; text-align: center;
        }
        .stat-val {
            font-family: var(--font-mono);
            font-size: clamp(1.5rem, 2.6vw, 2.1rem);
            font-weight: 500; color: var(--signal);
        }
        .stat-label { font-size: 0.8rem; color: var(--dim); margin-top: 4px; }

        /* ── SECTIONS ── */
        section { padding: clamp(3.5rem, 8vw, 6.5rem) clamp(1.25rem, 5vw, 4rem); }
        .section-inner { max-width: 1100px; margin: 0 auto; }
        .section-tag {
            font-family: var(--font-mono);
            font-size: 0.72rem; font-weight: 500; letter-spacing: 0.1em;
            text-transform: uppercase; color: var(--signal);
            margin-bottom: 0.75rem;
        }
        .section-title {
            font-family: var(--font-display);
            font-size: clamp(1.7rem, 3.2vw, 2.5rem);
            font-weight: 800; line-height: 1.12; text-transform: uppercase;
            letter-spacing: -0.005em; margin-bottom: 1rem;
        }
        .section-sub {
            font-size: 1rem; color: var(--dim);
            max-width: 540px; line-height: 1.7;
        }

        /* ── FEATURES ── */
        .features-grid {
            margin-top: 3rem;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5px;
            background: var(--line);
            border: 1px solid var(--line);
            border-radius: var(--radius-lg); overflow: hidden;
        }
        .feature-card {
            background: var(--panel); padding: 1.75rem 1.75rem 1.75rem 1.6rem;
            border-left: 2px solid transparent;
            transition: background 0.18s, border-color 0.18s;
        }
        .feature-card:hover { background: var(--panel-2); border-left-color: var(--signal); }
        .feature-code {
            font-family: var(--font-mono); font-size: 0.72rem; font-weight: 500;
            color: var(--signal); letter-spacing: 0.05em; margin-bottom: 0.6rem; display: block;
        }
        .feature-card h3 {
            font-family: var(--font-display); text-transform: uppercase;
            font-size: 1rem; font-weight: 700; letter-spacing: 0.01em; margin-bottom: 0.5rem;
        }
        .feature-card p { font-size: 0.88rem; color: var(--dim); line-height: 1.6; }

        /* ── AUDIENCE SPLIT ── */
        .audience-grid {
            margin-top: 3rem;
            display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
        }
        @media (max-width: 768px) { .audience-grid { grid-template-columns: 1fr; } }
        .audience-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: var(--radius-lg); padding: clamp(1.5rem, 4vw, 2.5rem);
        }
        .audience-card.highlight { border-color: rgba(255,180,0,0.3); }
        .audience-card h3 {
            font-family: var(--font-display); text-transform: uppercase;
            font-size: 1.2rem; font-weight: 700; margin-bottom: 1rem;
        }
        .audience-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
        .audience-list li {
            display: flex; align-items: flex-start; gap: 10px;
            font-size: 0.88rem; color: var(--dim);
        }
        .audience-list li::before {
            content: '';
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--signal); flex-shrink: 0; margin-top: 7px;
        }
        .audience-label {
            display: inline-flex; align-items: center; gap: 6px;
            font-family: var(--font-mono);
            font-size: 0.72rem; font-weight: 500; letter-spacing: 0.05em;
            text-transform: uppercase; padding: 4px 12px;
            border-radius: 999px; margin-bottom: 1.25rem;
        }
        .label-public { background: rgba(53,208,160,0.1); color: var(--flow); }
        .label-concess { background: rgba(255,180,0,0.1); color: var(--signal); }

        /* ── DASHBOARD PREVIEW ── */
        .preview-wrap {
            margin-top: 3rem;
            border: 1px solid var(--line); border-radius: var(--radius-xl);
            overflow: hidden; background: var(--panel);
            padding: clamp(1.25rem, 4vw, 2rem);
        }
        .preview-bar { display: flex; gap: 6px; margin-bottom: 1.5rem; }
        .preview-dot { width: 12px; height: 12px; border-radius: 50%; }
        .dot-red   { background: var(--jam); }
        .dot-amber { background: var(--signal); }
        .dot-green { background: var(--flow); }
        .preview-kpis {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .kpi-box {
            background: var(--panel-2); border: 1px solid var(--line);
            border-radius: var(--radius-md); padding: 1rem 1.15rem;
        }
        .kpi-val { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 500; }
        .kpi-lbl { font-size: 0.72rem; color: var(--dim); margin-top: 2px; }
        .kpi-val.green { color: var(--flow); }
        .kpi-val.amber { color: var(--signal); }
        .kpi-val.red   { color: var(--jam); }
        .kpi-val.blue  { color: var(--paper); }
        .preview-map {
            height: 220px; border-radius: var(--radius-md);
            background: radial-gradient(circle at 50% 40%, #171e28 0%, #0c1218 75%);
            display: flex; align-items: center; justify-content: center;
            position: relative; overflow: hidden;
        }
        .map-grid {
            position: absolute; inset: 0;
            background-image:
                linear-gradient(rgba(255,180,0,0.045) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,180,0,0.045) 1px, transparent 1px);
            background-size: 36px 36px;
        }
        .map-road-h { position: absolute; left: 0; right: 0; height: 2px; background: rgba(255,180,0,0.16); }
        .map-road-v { position: absolute; top: 0; bottom: 0; width: 2px; background: rgba(255,180,0,0.13); }
        .map-alert {
            position: absolute;
            width: 11px; height: 11px; border-radius: 50%;
            animation: blink 2s ease-in-out infinite;
        }
        @keyframes blink { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.5);opacity:0.6} }
        .map-label {
            position: relative; z-index: 2;
            font-family: var(--font-mono); font-size: 0.76rem; color: var(--dim);
        }

        /* ── CTA SECTION ── */
        .cta-section {
            background: var(--panel);
            border-top: 1px solid var(--line);
            border-bottom: 1px solid var(--line);
            text-align: center;
        }
        .cta-section h2 {
            font-family: var(--font-display); text-transform: uppercase;
            font-size: clamp(1.7rem, 3.2vw, 2.5rem);
            font-weight: 800; letter-spacing: -0.005em;
            margin-bottom: 1rem;
        }
        .cta-section p { color: var(--dim); font-size: 1rem; margin-bottom: 2rem; }
        .cta-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        .contact-info { margin-top: 2rem; font-size: 0.88rem; color: var(--faint); }
        .contact-info a { color: var(--dim); transition: color 0.18s; }
        .contact-info a:hover { color: var(--signal); }

        /* ── FOOTER ── */
        footer {
            padding: 2.25rem clamp(1.25rem, 5vw, 4rem);
            border-top: 1px solid var(--line);
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 1rem;
        }
        footer p { font-size: 0.78rem; color: var(--faint); font-family: var(--font-mono); }
        .footer-login { font-size: 0.85rem; color: var(--dim); display: flex; align-items: center; gap: 8px; }
        .footer-login a { color: var(--signal); font-weight: 600; transition: color 0.18s; }
        .footer-login a:hover { color: #ffc633; }

        /* ── RESPONSIVE ── */
        @media (max-width: 640px) {
            .hero-actions { flex-direction: column; align-items: stretch; }
            .btn-primary, .btn-ghost { text-align: center; }
            .ticker { max-width: 100%; }
            .radar-panel { max-width: 340px; }
            footer { flex-direction: column; align-items: flex-start; text-align: left; }
        }
        @media (max-width: 420px) {
            .hero-badge { font-size: 0.65rem; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem 1rem; }
            .preview-kpis { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

<!-- NAV -->
<nav>
    <a href="/" class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="2"/>
            <path d="M8 14c0-3.314 2.686-6 6-6s6 2.686 6 6-2.686 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="14" cy="14" r="3" fill="currentColor"/>
            <path d="M14 8v2M14 18v2M8 14H6M22 14h-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        WazeBR
        <span class="nav-status"><span></span>Coleta ativa</span>
    </a>
    <a href="{{ path('auth_login') }}" class="nav-cta">Acessar plataforma</a>
</nav>

<!-- HERO -->
<section class="hero">
    <div>
        <div class="hero-badge"><span></span> Plataforma ativa em tempo real</div>
        <h1>Monitoramento de tráfego<br>para <em>gestão pública</em><br>e rodovias</h1>
        <p>Centralize alertas do Waze, congestionamentos, dados pluviométricos e eventos de tráfego em um único painel operacional para sua equipe.</p>
        <div class="hero-actions">
            <a href="mailto:contato@wazebr.com.br" class="btn-primary">Solicitar demonstração</a>
            <a href="#funcionalidades" class="btn-ghost">Ver funcionalidades</a>
        </div>

        <div class="ticker" aria-hidden="true">
            <div class="ticker-head">Feed de ocorrências — ilustrativo</div>
            <div class="ticker-track">
                <div><time>14:32:07</time><span class="tag">ALT</span>Colisão sem vítimas — Av. Rebouças, SP</div>
                <div><time>14:31:44</time><span class="tag">JAM</span>Nível 4 — Marginal Tietê, sentido leste</div>
                <div><time>14:30:59</time><span class="tag">RAIN</span>12,4mm/h — Estação CEMADEN Guarulhos</div>
                <div><time>14:29:12</time><span class="tag">ALT</span>Bloqueio de pista — BR-101, km 224</div>
                <div><time>14:28:03</time><span class="tag">JAM</span>Nível 2 — Radial Leste, sentido centro</div>
                <div><time>14:32:07</time><span class="tag">ALT</span>Colisão sem vítimas — Av. Rebouças, SP</div>
                <div><time>14:31:44</time><span class="tag">JAM</span>Nível 4 — Marginal Tietê, sentido leste</div>
                <div><time>14:30:59</time><span class="tag">RAIN</span>12,4mm/h — Estação CEMADEN Guarulhos</div>
                <div><time>14:29:12</time><span class="tag">ALT</span>Bloqueio de pista — BR-101, km 224</div>
                <div><time>14:28:03</time><span class="tag">JAM</span>Nível 2 — Radial Leste, sentido centro</div>
            </div>
        </div>
    </div>

    <div class="radar-panel" aria-hidden="true">
        <div class="radar-grid"></div>
        <div class="radar-road-h"></div>
        <div class="radar-road-v"></div>
        <div class="radar-ring r1"></div>
        <div class="radar-ring r2"></div>
        <div class="radar-ring r3"></div>
        <div class="radar-sweep"></div>
        <div class="radar-blip" style="top:30%; left:26%; --c:var(--jam);"></div>
        <div class="radar-blip" style="top:62%; left:57%; --c:var(--signal); animation-delay:.6s;"></div>
        <div class="radar-blip" style="top:40%; left:64%; --c:var(--jam); animation-delay:1.1s;"></div>
        <div class="radar-blip" style="top:70%; left:32%; --c:var(--flow); animation-delay:1.6s;"></div>
        <div class="radar-coord tl">23°33'S</div>
        <div class="radar-coord br">46°38'W</div>
        <div class="radar-caption">Varredura contínua de eventos</div>
    </div>
</section>

<!-- STATS -->
<div class="stats-bar">
    <div class="stats-grid">
        <div>
            <div class="stat-val">24/7</div>
            <div class="stat-label">Coleta contínua de dados</div>
        </div>
        <div>
            <div class="stat-val">&lt; 5min</div>
            <div class="stat-label">Latência de atualização</div>
