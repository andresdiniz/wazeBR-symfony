{% extends 'base.html.twig' %}
{% block title %}Rotas monitoradas{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
{% endblock %}

{% block content %}
<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Rotas monitoradas</h1>
    <div class="page-subtitle">
      Snapshot mais recente
      {% if lastSnapshot %}
        &mdash; coletado <time data-utc="{{ lastSnapshot.collectedAt|date('c') }}" data-fmt="relative">{{ lastSnapshot.collectedAt|date('d/m/Y H:i') }}</time>
      {% else %}
        &mdash; nenhum snapshot encontrado
      {% endif %}
    </div>
  </div>
  <a href="{{ path('route_admin_index') }}" class="btn btn-ghost btn-sm">
    <i data-lucide="refresh-cw" style="width:14px;height:14px"></i> Atualizar
  </a>
</div>

{% if not lastSnapshot %}
  <div class="card"><div class="card-body" style="text-align:center;padding:var(--space-16);color:var(--color-text-muted)">Nenhum snapshot de rota encontrado. Execute <code>app:waze:collect-tvt</code> para coletar.</div></div>
{% else %}

{# KPIs #}
<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-label">Rotas</div>
    <div class="kpi-value">{{ routes|length }}</div>
  </div>
  {% set usersTotal = lastSnapshot.totalUsersOnJams %}
  <div class="kpi-card">
    <div class="kpi-label">Usuários em jams</div>
    <div class="kpi-value">{{ usersTotal }}</div>
  </div>
  {% set jamLevels = routes|map(r => r.jamLevel)|filter(j => j is not null) %}
  {% if jamLevels|length %}
  <div class="kpi-card">
    <div class="kpi-label">Jam médio</div>
    <div class="kpi-value">{{ (jamLevels|reduce((acc, j) => acc + j, 0) / jamLevels|length)|round(1) }}</div>
  </div>
  {% endif %}
</div>

{# Filtro por jam #}
<div style="display:flex;gap:var(--space-2);margin-bottom:var(--space-6);flex-wrap:wrap">
  {% for lvl in ['', '0','1','2','3','4','5'] %}
    <a href="?jam={{ lvl }}" class="btn btn-sm {{ (app.request.query.get('jam') ?? '') == lvl ? 'btn-primary' : 'btn-ghost' }}">
      {{ lvl == '' ? 'Todos' : 'Jam ' ~ lvl }}
    </a>
  {% endfor %}
</div>

{# Mapa #}
<div class="card" style="margin-bottom:var(--space-6)">
  <div class="card-header"><span class="card-title">Rotas no mapa</span></div>
  <div id="route-map" style="height:400px;border-radius:0 0 var(--radius-lg) var(--radius-lg)"></div>
</div>

{# Tabela #}
<div class="card">
  <div class="card-header"><span class="card-title">Rotas do snapshot</span></div>
  <div style="overflow-x:auto">
    <table id="routes-table">
      <thead><tr>
        <th>Rota</th>
        <th>De → Para</th>
        <th style="text-align:right">Distância</th>
        <th style="text-align:right">Tempo</th>
        <th style="text-align:right">Histórico</th>
        <th style="text-align:center">Jam</th>
        <th></th>
      </tr></thead>
      <tbody>
      {% for r in routes %}
        {% set jamFilter = app.request.query.get('jam') %}
        {% if jamFilter == '' or jamFilter is null or r.jamLevel|default(0)|string == jamFilter %}
        <tr style="cursor:pointer" data-route-id="{{ r.wazeRouteId }}">
          <td style="font-weight:500">{{ r.name ?? r.wazeRouteId ?? '—' }}</td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted)">
            {{ r.fromName ?? '—' }} → {{ r.toName ?? '—' }}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {% if r.length is not null %}{{ (r.length/1000)|round(1) }} km{% else %}—{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {% if r.time is not null %}{{ (r.time/60)|round(1) }} min{% else %}—{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums;color:var(--color-text-muted)">
            {% if r.historicTime is not null %}{{ (r.historicTime/60)|round(1) }} min{% else %}—{% endif %}
          </td>
          <td style="text-align:center">
            <span class="badge jam-{{ r.jamLevel ?? 0 }}">{{ r.jamLevel ?? '—' }}</span>
          </td>
          <td>
            {% if r.wazeRouteId %}
            <a href="{{ path('route_admin_history', {wazeRouteId: r.wazeRouteId}) }}" class="btn btn-ghost btn-sm"
               onclick="event.stopPropagation()">
              <i data-lucide="chart-line" style="width:13px;height:13px"></i> Histórico
            </a>
            {% endif %}
          </td>
        </tr>
        {% endif %}
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  const routeData = {{ routes is defined ? routes|map(r => {
    id:   r.wazeRouteId,
    name: r.name,
    jam:  r.jamLevel,
    line: r.line
  })|json_encode|raw : '[]' }};

  const JAM_COLOR = ['#437a22','#6daa45','#d19900','#da7101','#a12c7b','#7a39bb'];

  const map = L.map('route-map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    {attribution:'© OpenStreetMap',maxZoom:19}).addTo(map);

  const allLayers = [];
  routeData.forEach(r => {
    if (!r.line || !r.line.length) return;
    const coords = r.line.map(p => [p.y ?? p.lat, p.x ?? p.lng]);
    const color  = JAM_COLOR[Math.min(r.jam ?? 0, JAM_COLOR.length-1)];
    const poly   = L.polyline(coords, {color, weight:4, opacity:.8})
      .bindTooltip(r.name || r.id, {sticky:true});
    poly.addTo(map);
    allLayers.push(poly);
  });

  if (allLayers.length) {
    map.fitBounds(L.featureGroup(allLayers).getBounds().pad(0.1));
  } else {
    map.setView([-19.92,-43.94], 10);
  }

  // Clicar na linha da tabela destaca no mapa
  document.querySelectorAll('#routes-table tbody tr[data-route-id]').forEach(tr => {
    tr.addEventListener('click', e => {
      if (e.target.closest('a')) return;
      const id = tr.dataset.routeId;
      const idx = routeData.findIndex(r => r.id === id);
      if (idx >= 0 && allLayers[idx]) {
        map.fitBounds(allLayers[idx].getBounds().pad(0.2));
        allLayers[idx].openTooltip();
      }
    });
  });
})();
</script>
{% endblock %}
