{% extends 'base.html.twig' %}
{% block title %}Rotas{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  /* ── Jam badges ─────────────────────────────────────────── */
  .jam-0{background:oklch(from var(--color-success) l c h/.12);color:var(--color-success)}
  .jam-1{background:oklch(from var(--color-gold)    l c h/.12);color:var(--color-gold)}
  .jam-2{background:oklch(from var(--color-orange)  l c h/.15);color:var(--color-orange)}
  .jam-3{background:oklch(from var(--color-error)   l c h/.12);color:var(--color-error)}
  .jam-4{background:oklch(from var(--color-error)   l c h/.2) ;color:var(--color-error)}
  .jam-5{background:var(--color-error);color:#fff}

  /* ── KPI grid ───────────────────────────────────────────── */
  .route-kpi-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
    gap:var(--space-4);
    margin-bottom:var(--space-6);
  }
  .route-kpi-card{
    background:var(--color-surface);
    border:1px solid var(--color-border);
    border-radius:var(--radius-lg);
    padding:var(--space-5);
    display:flex;
    flex-direction:column;
    gap:var(--space-2);
    box-shadow:var(--shadow-sm);
    transition:box-shadow var(--transition-interactive);
  }
  .route-kpi-card:hover{box-shadow:var(--shadow-md)}
  .route-kpi-card.span2{grid-column:span 2}
  .route-kpi-card.span3{grid-column:span 3}
  .rkpi-top{
    display:flex;
    align-items:center;
    justify-content:space-between;
  }
  .rkpi-icon{
    width:36px;height:36px;
    border-radius:var(--radius-md);
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .rkpi-badge{
    font-size:var(--text-xs);
    font-weight:600;
    padding:2px var(--space-2);
    border-radius:var(--radius-full);
    letter-spacing:.02em;
  }
  .rkpi-label{
    font-size:var(--text-xs);
    color:var(--color-text-muted);
    font-weight:500;
    text-transform:uppercase;
    letter-spacing:.06em;
    margin-top:var(--space-3);
  }
  .rkpi-value{
    font-size:var(--text-2xl);
    font-weight:700;
    line-height:1;
    color:var(--color-text);
    font-variant-numeric:tabular-nums;
  }
  .rkpi-sub{
    font-size:var(--text-xs);
    color:var(--color-text-muted);
    margin-top:var(--space-1);
  }

  /* ── Health bar ─────────────────────────────────────────── */
  .health-bar-wrap{
    display:flex;
    height:6px;
    border-radius:var(--radius-full);
    overflow:hidden;
    gap:2px;
    margin-top:var(--space-3);
  }
  .health-seg{height:100%;border-radius:2px;transition:width .5s ease}
  .hs-0{background:var(--color-success)}
  .hs-1{background:var(--color-gold)}
  .hs-2{background:var(--color-orange)}
  .hs-3,.hs-4,.hs-5{background:var(--color-error)}

  /* ── Donut SVG ──────────────────────────────────────────── */
  .donut-wrap{
    display:flex;
    align-items:center;
    gap:var(--space-4);
    margin-top:var(--space-3);
  }
  .donut-legend{
    display:flex;
    flex-direction:column;
    gap:var(--space-2);
    flex:1;
  }
  .donut-leg-item{
    display:flex;
    align-items:center;
    gap:var(--space-2);
    font-size:var(--text-xs);
    color:var(--color-text-muted);
  }
  .donut-dot{
    width:8px;height:8px;
    border-radius:50%;
    flex-shrink:0;
  }
  .donut-leg-val{
    margin-left:auto;
    font-variant-numeric:tabular-nums;
    font-weight:600;
    color:var(--color-text);
  }

  /* ── Map / table / chips ────────────────────────────────── */
  #tvt-map{height:420px;border-radius:var(--radius-lg);z-index:1;border:1px solid var(--color-border)}
  .chip-group{display:flex;flex-wrap:wrap;gap:var(--space-2)}
  .chip{display:inline-flex;align-items:center;gap:4px;padding:4px var(--space-3);border-radius:var(--radius-full);font-size:var(--text-xs);font-weight:600;border:1px solid var(--color-border);color:var(--color-text-muted);background:var(--color-surface);text-decoration:none;transition:all var(--transition-interactive)}
  .chip:hover{background:var(--color-surface-offset);color:var(--color-text)}
  .chip.active{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
  .delay-pos{color:var(--color-error)}
  .delay-neg{color:var(--color-success)}
  .delay-zero{color:var(--color-text-faint)}
  tr.row-hover:hover td{background:oklch(from var(--color-primary) l c h/.04)}
  tr.row-selected td{background:oklch(from var(--color-primary) l c h/.08)}
  .leaflet-popup-content-wrapper{border-radius:var(--radius-md)!important;box-shadow:var(--shadow-lg)!important;font-family:var(--font-body)!important;font-size:var(--text-xs)!important}
</style>
{% endblock %}

{% block content %}
<div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Rotas monitoradas</h1>
    <div class="page-subtitle">
      Snapshot mais recente
      {% if lastSnapshot %}
        &mdash; coletado <time data-utc="{{ lastSnapshot.collectedAt|date('c') }}" data-fmt="relative">{{ lastSnapshot.collectedAt|date('d/m/Y H:i') }}</time>
      {% else %}
        &mdash; nenhum snapshot encontrado
      {% endif %}
    </div>
  </div>
  <a href="{{ path('route_admin_index') }}" class="btn btn-ghost btn-sm">
    <i data-lucide="refresh-cw" style="width:14px;height:14px"></i> Atualizar
  </a>
</div>

{# ── Compute derived KPIs ────────────────────────────────────────────────── #}
{% set free      = kpi.levels[0] ?? 0 %}
{% set slow      = kpi.levels[1] ?? 0 %}
{% set moderate  = kpi.levels[2] ?? 0 %}
{% set heavy     = kpi.levels[3] ?? 0 %}
{% set vheavy    = kpi.levels[4] ?? 0 %}
{% set stopped   = kpi.levels[5] ?? 0 %}
{% set total     = kpi.total %}
{% set congPct   = total > 0 ? ((kpi.congested / total) * 100)|round(0) : 0 %}
{% set freePct   = total > 0 ? ((free / total) * 100)|round(0) : 0 %}

{# Health score: 100 - weighted penalty (stopped=100, vheavy=80, heavy=50, moderate=20, slow=5) #}
{% if total > 0 %}
  {% set penalty = (stopped * 100 + vheavy * 80 + heavy * 50 + moderate * 20 + slow * 5) / total %}
  {% set healthScore = max(0, (100 - penalty)|round(0)) %}
  {% set healthScore = min(100, healthScore) %}
{% else %}
  {% set healthScore = 100 %}
{% endif %}

{# Health label #}
{% if healthScore >= 80 %}
  {% set healthLabel = 'Bom' %}
  {% set healthColor = 'var(--color-success)' %}
  {% set healthBg    = 'oklch(from var(--color-success) l c h/.1)' %}
{% elseif healthScore >= 50 %}
  {% set healthLabel = 'Moderado' %}
  {% set healthColor = 'var(--color-gold)' %}
  {% set healthBg    = 'oklch(from var(--color-gold) l c h/.1)' %}
{% else %}
  {% set healthLabel = 'Crítico' %}
  {% set healthColor = 'var(--color-error)' %}
  {% set healthBg    = 'oklch(from var(--color-error) l c h/.1)' %}
{% endif %}

{# Donut SVG — 5 segments (join levels 3-4-5 as congested) #}
{# cx=40,cy=40,r=28 → circ=175.9 #}
{% set circ = 175.93 %}
{% set donutData = [
  {lv: '0', cnt: free,     color: 'var(--color-success)', label: 'Livre'},
  {lv: '1', cnt: slow,     color: 'var(--color-gold)',    label: 'Lento'},
  {lv: '2', cnt: moderate, color: 'var(--color-orange)',  label: 'Moderado'},
  {lv: '3', cnt: heavy,    color: 'oklch(0.55 0.2 25)',   label: 'Pesado'},
  {lv: '4', cnt: vheavy,   color: 'oklch(0.48 0.22 25)',  label: 'Muito pesado'},
  {lv: '5', cnt: stopped,  color: 'var(--color-error)',   label: 'Parado'}
] %}

{# ── KPI grid ─────────────────────────────────────────────────────────────── #}
<div class="route-kpi-grid">

  {# 1 — Total de rotas #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-primary) l c h/.1);color:var(--color-primary)">
        <i data-lucide="route" style="width:18px;height:18px"></i>
      </div>
    </div>
    <div class="rkpi-label">Total de Rotas</div>
    <div class="rkpi-value">{{ total }}</div>
    <div class="rkpi-sub">no snapshot atual</div>
  </div>

  {# 2 — Saúde geral #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:{{ healthBg }};color:{{ healthColor }}">
        <i data-lucide="{% if healthScore >= 80 %}shield-check{% elseif healthScore >= 50 %}shield-alert{% else %}shield-x{% endif %}" style="width:18px;height:18px"></i>
      </div>
      <span class="rkpi-badge" style="background:{{ healthBg }};color:{{ healthColor }}">{{ healthLabel }}</span>
    </div>
    <div class="rkpi-label">Sa&uacute;de da Rede</div>
    <div class="rkpi-value" style="color:{{ healthColor }}">{{ healthScore }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">%</span></div>
    <div style="height:6px;border-radius:var(--radius-full);background:var(--color-surface-offset);margin-top:var(--space-2);overflow:hidden">
      <div style="height:100%;width:{{ healthScore }}%;background:{{ healthColor }};border-radius:var(--radius-full);transition:width .6s ease"></div>
    </div>
  </div>

  {# 3 — Congestionadas #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-error) l c h/.1);color:var(--color-error)">
        <i data-lucide="traffic-cone" style="width:18px;height:18px"></i>
      </div>
      {% if total > 0 %}
      <span class="rkpi-badge" style="background:oklch(from var(--color-error) l c h/.1);color:var(--color-error)">{{ congPct }}%</span>
      {% endif %}
    </div>
    <div class="rkpi-label">Congestionadas (&ge;3)</div>
    <div class="rkpi-value" style="color:var(--color-error)">{{ kpi.congested }}</div>
    <div class="rkpi-sub">{{ stopped }} parada{{ stopped != 1 ? 's' }}, {{ vheavy }} muito pesada{{ vheavy != 1 ? 's' }}</div>
  </div>

  {# 4 — Livres #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-success) l c h/.1);color:var(--color-success)">
        <i data-lucide="check-circle" style="width:18px;height:18px"></i>
      </div>
      {% if total > 0 %}
      <span class="rkpi-badge" style="background:oklch(from var(--color-success) l c h/.1);color:var(--color-success)">{{ freePct }}%</span>
      {% endif %}
    </div>
    <div class="rkpi-label">Livres (n&iacute;vel 0)</div>
    <div class="rkpi-value" style="color:var(--color-success)">{{ free }}</div>
    <div class="rkpi-sub">sem congestionamento</div>
  </div>

  {# 5 — Atraso médio #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-gold) l c h/.1);color:var(--color-gold)">
        <i data-lucide="clock" style="width:18px;height:18px"></i>
      </div>
    </div>
    <div class="rkpi-label">Atraso M&eacute;dio</div>
    <div class="rkpi-value">
      {% if kpi.avgDelaySec == 0 %}&mdash;
      {% elseif kpi.avgDelaySec < 60 %}{{ kpi.avgDelaySec }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">s</span>
      {% else %}{{ (kpi.avgDelaySec / 60)|round(1) }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">min</span>
      {% endif %}
    </div>
    <div class="rkpi-sub">em relação ao tempo histórico</div>
  </div>

  {# 6 — Distribuição (donut + legenda) — span 2 #}
  <div class="route-kpi-card span2">
    <div class="rkpi-label">Distribui&ccedil;&atilde;o por N&iacute;vel</div>
    {% if total > 0 %}
    <div class="donut-wrap">
      {# SVG donut — r=28, cx=cy=40, circ≈175.93 #}
      <svg width="80" height="80" viewBox="0 0 80 80" aria-hidden="true" style="flex-shrink:0;transform:rotate(-90deg)">
        <circle cx="40" cy="40" r="28" fill="none" stroke="var(--color-surface-offset)" stroke-width="10"/>
        {% set offset = 0 %}
        {% for seg in donutData %}
          {% if seg.cnt > 0 %}
            {% set dash = (seg.cnt / total * circ)|round(2) %}
            <circle cx="40" cy="40" r="28" fill="none"
              stroke="{{ seg.color }}"
              stroke-width="10"
              stroke-dasharray="{{ dash }} {{ circ - dash }}"
              stroke-dashoffset="{{ (circ - offset)|round(2) }}"
              stroke-linecap="butt"/>
            {% set offset = offset + dash %}
          {% endif %}
        {% endfor %}
        {# center text — counter-rotate #}
        <text x="40" y="44" text-anchor="middle" font-size="13" font-weight="700"
          fill="var(--color-text)" style="transform:rotate(90deg);transform-origin:40px 40px">{{ total }}</text>
      </svg>
      <div class="donut-legend">
        {% for seg in donutData %}
          {% if seg.cnt > 0 %}
          <div class="donut-leg-item">
            <span class="donut-dot" style="background:{{ seg.color }}"></span>
            <span>{{ seg.label }}</span>
            <span class="donut-leg-val">{{ seg.cnt }}</span>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {# stacked bar #}
    <div class="health-bar-wrap" style="margin-top:var(--space-4)">
      {% for seg in donutData %}
        {% if seg.cnt > 0 %}
          <div class="health-seg hs-{{ seg.lv }}"
               style="width:{{ (seg.cnt / total * 100)|round(1) }}%"
               title="{{ seg.label }}: {{ seg.cnt }}"></div>
        {% endif %}
      {% endfor %}
    </div>
    {% else %}
      <div class="rkpi-sub" style="margin-top:var(--space-3)">Nenhuma rota no snapshot.</div>
    {% endif %}
  </div>

</div>{# /route-kpi-grid #}

{% if routes is not empty %}
<div class="card" style="margin-bottom:var(--space-6)">
  <div class="card-header">
    <span class="card-title"><i data-lucide="map" style="width:14px;height:14px;display:inline"></i> Mapa de Rotas</span>
    <span style="font-size:var(--text-xs);color:var(--color-text-muted)">Clique numa rota para destacar na tabela</span>
  </div>
  <div style="padding:var(--space-4)">
    <div id="tvt-map"></div>
  </div>
</div>
{% endif %}

<div style="margin-bottom:var(--space-4);display:flex;align-items:center;gap:var(--space-4);flex-wrap:wrap">
  <div class="chip-group">
    <a href="{{ path('route_admin_index') }}" class="chip {{ jamFilter is null or jamFilter == '' ? 'active' }}">Todos</a>
    <a href="{{ path('route_admin_index', {jam: 0}) }}" class="chip {{ jamFilter == '0' ? 'active' }}">&#x1F7E2; Livre</a>
    <a href="{{ path('route_admin_index', {jam: 1}) }}" class="chip {{ jamFilter == '1' ? 'active' }}">&#x1F7E1; Lento</a>
    <a href="{{ path('route_admin_index', {jam: 2}) }}" class="chip {{ jamFilter == '2' ? 'active' }}">&#x1F7E0; Moderado</a>
    <a href="{{ path('route_admin_index', {jam: 3}) }}" class="chip {{ jamFilter == '3' ? 'active' }}">&#x1F534; Pesado</a>
    <a href="{{ path('route_admin_index', {jam: 4}) }}" class="chip {{ jamFilter == '4' ? 'active' }}">&#x1F534; Muito Pesado</a>
    <a href="{{ path('route_admin_index', {jam: 5}) }}" class="chip {{ jamFilter == '5' ? 'active' }}">&#x26D4; Parado</a>
  </div>
  <span style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ routes|length }} rota(s)</span>
</div>

{% if routes is empty %}
  <div class="empty">
    <i data-lucide="route" style="width:40px;height:40px"></i>
    <h3>Nenhuma rota encontrada</h3>
    <p>Aguarde a pr&oacute;xima coleta do feed TVT ou remova os filtros.</p>
  </div>
{% else %}
<div class="card">
  <div class="card-header">
    <span class="card-title">Rotas do Snapshot</span>
  </div>
  <div style="overflow-x:auto">
    <table id="routes-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Origem &rarr; Destino</th>
          <th>Jam</th>
          <th style="text-align:right">Ext. (m)</th>
          <th style="text-align:right">Atual</th>
          <th style="text-align:right">Hist&oacute;rico</th>
          <th style="text-align:right">Atraso</th>
          <th>Tipo</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
      {% for r in routes %}
        {% set delay = r.delaySeconds %}
        <tr class="row-hover route-row" data-waze-id="{{ r.wazeRouteId }}" style="cursor:pointer">
          <td style="font-weight:500;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ r.name }}">{{ r.name ?? '&mdash;' }}</td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ r.fromName }} &rarr; {{ r.toName }}">
            {{ r.fromName ?? '&mdash;' }} &rarr; {{ r.toName ?? '&mdash;' }}
          </td>
          <td><span class="badge jam-{{ r.jamLevel ?? 0 }}">{{ r.jamLevelLabel }}</span></td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">{{ r.length ?? '&mdash;' }}</td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {% if r.time is not null %}
              {% if r.time < 60 %}{{ r.time }}s{% else %}{{ (r.time / 60)|round(1) }} min{% endif %}
            {% else %}&mdash;{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums;color:var(--color-text-muted)">
            {% if r.historicTime is not null %}
              {% if r.historicTime < 60 %}{{ r.historicTime }}s{% else %}{{ (r.historicTime / 60)|round(1) }} min{% endif %}
            {% else %}&mdash;{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums" class="{% if delay is not null %}{% if delay > 0 %}delay-pos{% elseif delay < 0 %}delay-neg{% else %}delay-zero{% endif %}{% endif %}">
            {% if delay is null %}&mdash;
            {% elseif delay == 0 %}0s
            {% elseif delay > 0 %}+{{ delay < 60 ? delay ~ 's' : (delay/60)|round(1) ~ ' min' }}
            {% else %}{{ delay < -60 ? (delay/60)|round(1) ~ ' min' : delay ~ 's' }}{% endif %}
          </td>
          <td><span class="badge badge-gray" style="font-size:10px">{{ r.type ?? '&mdash;' }}</span></td>
          <td>
            <a href="{{ path('route_admin_history', {wazeRouteId: r.wazeRouteId}) }}" class="btn btn-ghost btn-sm" title="Hist&oacute;rico">
              <i data-lucide="history" style="width:13px;height:13px"></i>
            </a>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
{% set routesData = [] %}
{% for r in routes %}
  {% set routesData = routesData|merge([{
    id:   r.wazeRouteId,
    name: r.name,
    from: r.fromName,
    to:   r.toName,
    jam:  r.jamLevel,
    time: r.time,
    hist: r.historicTime,
    line: r.line
  }]) %}
{% endfor %}
  var routes = {{ routesData|json_encode|raw }};

  var mapEl = document.getElementById('tvt-map');
  if (!mapEl || !routes.length) return;

  var map = L.map('tvt-map', { zoomControl: true });
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors', maxZoom: 18
  }).addTo(map);

  var jamColors = ['#437a22','#d19900','#da7101','#a12c7b','#a13544','#dc2626'];
  var layers = {};
  var bounds = L.latLngBounds();

  routes.forEach(function(r) {
    if (!r.line || !r.line.length) return;
    var latlngs = r.line.map(function(p) { return [p.y, p.x]; });
    var color   = jamColors[r.jam != null ? r.jam : 0] || '#888';
    var pl = L.polyline(latlngs, { color: color, weight: 4, opacity: 0.8 });
    pl.bindPopup('<strong>' + (r.name || '\u2014') + '</strong><br>' + (r.from || '') + ' \u2192 ' + (r.to || '') + '<br>Jam: ' + (r.jam != null ? r.jam : 0));
    pl.addTo(map);
    if (r.id) layers[r.id] = pl;
    latlngs.forEach(function(ll) { bounds.extend(ll); });
  });

  if (bounds.isValid()) map.fitBounds(bounds, { padding: [24, 24] });

  Object.keys(layers).forEach(function(wid) {
    var pl = layers[wid];
    pl.on('click', function() {
      document.querySelectorAll('.route-row').forEach(function(tr) { tr.classList.remove('row-selected'); });
      var row = document.querySelector('.route-row[data-waze-id="' + wid + '"]');
      if (row) { row.classList.add('row-selected'); row.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    });
  });

  document.querySelectorAll('.route-row').forEach(function(tr) {
    tr.addEventListener('click', function(e) {
      if (e.target.closest('a')) return;
      var wid = tr.dataset.wazeId;
      var pl  = layers[wid];
      if (pl) {
        var lls = pl.getLatLngs();
        pl.openPopup();
        map.panTo(lls[Math.floor(lls.length / 2)]);
      }
      document.querySelectorAll('.route-row').forEach(function(r) { r.classList.remove('row-selected'); });
      tr.classList.add('row-selected');
    });
  });

  document.querySelectorAll('time[data-utc]').forEach(function(el) {
    var d = new Date(el.dataset.utc);
    var diff = Math.floor((Date.now() - d) / 1000);
    if (diff < 60) el.textContent = 'agora';
    else if (diff < 3600) el.textContent = 'h\u00e1 ' + Math.floor(diff/60) + ' min';
    else if (diff < 86400) el.textContent = 'h\u00e1 ' + Math.floor(diff/3600) + 'h';
  });
})();
</script>
{% endblock %}
