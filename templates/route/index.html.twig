{% extends 'base.html.twig' %}
{% block title %}Rotas{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  /* ── Jam badges ─────────────────────────────────────────── */
  .jam-0{background:oklch(from var(--color-success) l c h/.12);color:var(--color-success)}
  .jam-1{background:oklch(from var(--color-gold)    l c h/.12);color:var(--color-gold)}
  .jam-2{background:oklch(from var(--color-orange)  l c h/.15);color:var(--color-orange)}
  .jam-3{background:oklch(from var(--color-error)   l c h/.12);color:var(--color-error)}
  .jam-4{background:oklch(from var(--color-error)   l c h/.2) ;color:var(--color-error)}
  .jam-5{background:var(--color-error);color:#fff}

  /* ── KPI grid principal — 4 colunas no desktop ──────────── */
  .route-kpi-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:var(--space-4);
    margin-bottom:var(--space-4);
  }
  @media(max-width:1024px){.route-kpi-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.route-kpi-grid{grid-template-columns:1fr}}

  /* ── KPI grid secundário — 3 colunas (distribuição ocupa 2) */
  .route-kpi-grid-2{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:var(--space-4);
    margin-bottom:var(--space-6);
  }
  @media(max-width:1024px){.route-kpi-grid-2{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.route-kpi-grid-2{grid-template-columns:1fr}}
  .span2{grid-column:span 2}
  @media(max-width:600px){.span2{grid-column:span 1}}

  .route-kpi-card{
    background:var(--color-surface);
    border:1px solid var(--color-border);
    border-radius:var(--radius-lg);
    padding:var(--space-5);
    display:flex;
    flex-direction:column;
    gap:var(--space-2);
    box-shadow:var(--shadow-sm);
    transition:box-shadow var(--transition-interactive);
  }
  .route-kpi-card:hover{box-shadow:var(--shadow-md)}
  .rkpi-top{display:flex;align-items:center;justify-content:space-between}
  .rkpi-icon{width:36px;height:36px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .rkpi-badge{font-size:var(--text-xs);font-weight:600;padding:2px var(--space-2);border-radius:var(--radius-full);letter-spacing:.02em}
  .rkpi-label{font-size:var(--text-xs);color:var(--color-text-muted);font-weight:500;text-transform:uppercase;letter-spacing:.06em;margin-top:var(--space-3)}
  .rkpi-value{font-size:var(--text-2xl);font-weight:700;line-height:1;color:var(--color-text);font-variant-numeric:tabular-nums}
  .rkpi-sub{font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-1)}
  .rkpi-divider{height:1px;background:var(--color-divider);margin:var(--space-2) 0}
  .rkpi-critical-row{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);padding:var(--space-2) var(--space-3);border-radius:var(--radius-md);background:oklch(from var(--color-error) l c h/.07);border:1px solid oklch(from var(--color-error) l c h/.18);margin-top:var(--space-1)}
  .rkpi-bar-split{display:flex;height:6px;border-radius:var(--radius-full);overflow:hidden;gap:1px;margin-top:var(--space-2)}
  .rkpi-bar-seg{height:100%;border-radius:2px;transition:width .5s ease}

  /* ── Nível de serviço badge ──────────────────────────────── */
  .los-badge{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:var(--radius-md);font-size:var(--text-xl);font-weight:800;letter-spacing:-.02em;line-height:1}

  /* ── Health / stacked bar ───────────────────────────────── */
  .health-bar-wrap{display:flex;height:6px;border-radius:var(--radius-full);overflow:hidden;gap:2px;margin-top:var(--space-3)}
  .health-seg{height:100%;border-radius:2px;transition:width .5s ease}
  .hs-0{background:var(--color-success)}
  .hs-1{background:var(--color-gold)}
  .hs-2{background:var(--color-orange)}
  .hs-3,.hs-4,.hs-5{background:var(--color-error)}

  /* ── Donut SVG ──────────────────────────────────────────── */
  .donut-wrap{display:flex;align-items:center;gap:var(--space-4);margin-top:var(--space-3)}
  .donut-legend{display:flex;flex-direction:column;gap:var(--space-2);flex:1}
  .donut-leg-item{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-muted)}
  .donut-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .donut-leg-val{margin-left:auto;font-variant-numeric:tabular-nums;font-weight:600;color:var(--color-text)}
  .donut-leg-pct{font-variant-numeric:tabular-nums;color:var(--color-text-faint);min-width:2.8em;text-align:right}

  /* ── Map / table / chips ────────────────────────────────── */
  #tvt-map{height:420px;border-radius:var(--radius-lg);z-index:1;border:1px solid var(--color-border)}
  .chip-group{display:flex;flex-wrap:wrap;gap:var(--space-2)}
  .chip{display:inline-flex;align-items:center;gap:4px;padding:4px var(--space-3);border-radius:var(--radius-full);font-size:var(--text-xs);font-weight:600;border:1px solid var(--color-border);color:var(--color-text-muted);background:var(--color-surface);text-decoration:none;transition:all var(--transition-interactive)}
  .chip:hover{background:var(--color-surface-offset);color:var(--color-text)}
  .chip.active{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
  .delay-pos{color:var(--color-error)}
  .delay-neg{color:var(--color-success)}
  .delay-zero{color:var(--color-text-faint)}
  tr.row-hover:hover td{background:oklch(from var(--color-primary) l c h/.04)}
  tr.row-selected td{background:oklch(from var(--color-primary) l c h/.08)}
  .leaflet-popup-content-wrapper{border-radius:var(--radius-md)!important;box-shadow:var(--shadow-lg)!important;font-family:var(--font-body)!important;font-size:var(--text-xs)!important}
</style>
{% endblock %}

{% block content %}
<div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <h1 class="page-title">Rotas monitoradas</h1>
    <div class="page-subtitle">
      Snapshot mais recente
      {% if lastSnapshot %}
        &mdash; coletado <time data-utc="{{ lastSnapshot.collectedAt|date('c') }}" data-fmt="relative">{{ lastSnapshot.collectedAt|date('d/m/Y H:i') }}</time>
      {% else %}
        &mdash; nenhum snapshot encontrado
      {% endif %}
    </div>
  </div>
  <a href="{{ path('route_admin_index') }}" class="btn btn-ghost btn-sm">
    <i data-lucide="refresh-cw" style="width:14px;height:14px"></i> Atualizar
  </a>
</div>

{# ── Compute derived KPIs ─────────────────────────────────────────────────── #}
{% set free     = kpi.levels[0] ?? 0 %}
{% set slow     = kpi.levels[1] ?? 0 %}
{% set moderate = kpi.levels[2] ?? 0 %}
{% set heavy    = kpi.levels[3] ?? 0 %}
{% set vheavy   = kpi.levels[4] ?? 0 %}
{% set stopped  = kpi.levels[5] ?? 0 %}
{% set total    = kpi.total %}
{% set congPct  = total > 0 ? ((kpi.congested / total) * 100)|round(0) : 0 %}
{% set freePct  = total > 0 ? ((free / total) * 100)|round(0) : 0 %}
{% set slowPct  = total > 0 ? ((slow / total) * 100)|round(0) : 0 %}
{% set modPct   = total > 0 ? ((moderate / total) * 100)|round(0) : 0 %}

{# Extensão + rota crítica + atrasos + velocidade #}
{% set totalExtM       = 0 %}
{% set congExtM        = 0 %}
{% set maxDelayRoute   = null %}
{% set maxDelaySec     = 0 %}
{% set congDelaySumSec = 0 %}
{% set congDelayCount  = 0 %}
{% set delayedCount    = 0 %}
{% set totalDelaySumSec = 0 %}
{% set timeSumSec      = 0 %}
{% set timeCount       = 0 %}
{% set normalCount     = 0 %}
{% set totalTimeLostSec = 0 %}

{% for r in routes %}
  {% if r.length is not null %}
    {% set totalExtM = totalExtM + r.length %}
    {% if r.jamLevel is not null and r.jamLevel >= 3 %}
      {% set congExtM = congExtM + r.length %}
    {% endif %}
  {% endif %}
  {% if r.delaySeconds is not null %}
    {% if r.delaySeconds > maxDelaySec %}
      {% set maxDelaySec = r.delaySeconds %}
      {% set maxDelayRoute = r %}
    {% endif %}
    {% if r.delaySeconds > 0 %}
      {% set delayedCount = delayedCount + 1 %}
      {% set totalTimeLostSec = totalTimeLostSec + r.delaySeconds %}
    {% else %}
      {% set normalCount = normalCount + 1 %}
    {% endif %}
    {% if r.jamLevel is not null and r.jamLevel >= 3 %}
      {% set congDelaySumSec = congDelaySumSec + r.delaySeconds %}
      {% set congDelayCount = congDelayCount + 1 %}
    {% endif %}
  {% endif %}
  {% if r.time is not null %}
    {% set timeSumSec = timeSumSec + r.time %}
    {% set timeCount  = timeCount + 1 %}
  {% endif %}
{% endfor %}

{% set totalExtKm    = (totalExtM / 1000)|round(1) %}
{% set congExtKm     = (congExtM / 1000)|round(1) %}
{% set congAvgDelaySec = congDelayCount > 0 ? (congDelaySumSec / congDelayCount)|round(0) : 0 %}
{% set delayedPct    = total > 0 ? ((delayedCount / total) * 100)|round(0) : 0 %}
{% set normalPct     = total > 0 ? (((total - delayedCount) / total) * 100)|round(0) : 100 %}
{% set timeLostMin   = (totalTimeLostSec / 60)|round(1) %}

{# Velocidade média da rede: extensão total / tempo médio #}
{% set avgSpeedKmh = 0 %}
{% if timeCount > 0 and totalExtM > 0 %}
  {% set avgTimeSec  = timeSumSec / timeCount %}
  {% set avgExtM     = totalExtM / timeCount %}
  {% set avgSpeedKmh = (avgExtM / avgTimeSec * 3.6)|round(1) %}
{% endif %}

{# Health score #}
{% if total > 0 %}
  {% set penalty     = (stopped * 100 + vheavy * 80 + heavy * 50 + moderate * 20 + slow * 5) / total %}
  {% set healthScore = max(0, min(100, (100 - penalty)|round(0))) %}
{% else %}
  {% set healthScore = 100 %}
{% endif %}

{% if healthScore >= 80 %}
  {% set healthLabel = 'Bom' %}{% set healthColor = 'var(--color-success)' %}{% set healthBg = 'oklch(from var(--color-success) l c h/.1)' %}
{% elseif healthScore >= 50 %}
  {% set healthLabel = 'Moderado' %}{% set healthColor = 'var(--color-gold)' %}{% set healthBg = 'oklch(from var(--color-gold) l c h/.1)' %}
{% else %}
  {% set healthLabel = 'Crítico' %}{% set healthColor = 'var(--color-error)' %}{% set healthBg = 'oklch(from var(--color-error) l c h/.1)' %}
{% endif %}

{# Nível de Serviço predominante (HCM A-F) baseado no jam médio ponderado #}
{% if total > 0 %}
  {% set jamSum = (free * 0 + slow * 1 + moderate * 2 + heavy * 3 + vheavy * 4 + stopped * 5) %}
  {% set avgJam = (jamSum / total)|round(1) %}
{% else %}
  {% set avgJam = 0 %}
{% endif %}
{% if avgJam < 0.5 %}{% set losLevel = 'A' %}{% set losColor = 'var(--color-success)' %}{% set losBg = 'oklch(from var(--color-success) l c h/.1)' %}
{% elseif avgJam < 1.5 %}{% set losLevel = 'B' %}{% set losColor = 'var(--color-success)' %}{% set losBg = 'oklch(from var(--color-success) l c h/.08)' %}
{% elseif avgJam < 2.5 %}{% set losLevel = 'C' %}{% set losColor = 'var(--color-gold)' %}{% set losBg = 'oklch(from var(--color-gold) l c h/.1)' %}
{% elseif avgJam < 3.5 %}{% set losLevel = 'D' %}{% set losColor = 'var(--color-orange)' %}{% set losBg = 'oklch(from var(--color-orange) l c h/.1)' %}
{% elseif avgJam < 4.5 %}{% set losLevel = 'E' %}{% set losColor = 'var(--color-error)' %}{% set losBg = 'oklch(from var(--color-error) l c h/.12)' %}
{% else %}{% set losLevel = 'F' %}{% set losColor = 'var(--color-error)' %}{% set losBg = 'var(--color-error)' %}{% endif %}

{# Donut data #}
{% set circ = 175.93 %}
{% set donutData = [
  {lv:'0', cnt:free,     pct:freePct, color:'var(--color-success)', label:'Livre'},
  {lv:'1', cnt:slow,     pct:slowPct, color:'var(--color-gold)',    label:'Lento'},
  {lv:'2', cnt:moderate, pct:modPct,  color:'var(--color-orange)',  label:'Moderado'},
  {lv:'3', cnt:heavy,    pct:total>0?((heavy/total)*100)|round(0):0,   color:'oklch(0.55 0.2 25)',  label:'Pesado'},
  {lv:'4', cnt:vheavy,   pct:total>0?((vheavy/total)*100)|round(0):0,  color:'oklch(0.48 0.22 25)', label:'Muito pesado'},
  {lv:'5', cnt:stopped,  pct:total>0?((stopped/total)*100)|round(0):0, color:'var(--color-error)',  label:'Parado'}
] %}

{# ────────────────────────────────────────────────────────────────────────── #}
{# GRID SUPERIOR — 4 KPIs principais (linha 1) #}
{# ────────────────────────────────────────────────────────────────────────── #}
<div class="route-kpi-grid">

  {# 1 — Nível de Serviço (A-F) #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="los-badge" style="background:{{ losBg }};color:{{ losLevel == 'F' ? '#fff' : losColor }}">{{ losLevel }}</div>
      <span class="rkpi-badge" style="background:{{ losBg }};color:{{ losLevel == 'F' ? '#fff' : losColor }}">
        {% if losLevel == 'A' %}Livre
        {% elseif losLevel == 'B' %}Fluindo
        {% elseif losLevel == 'C' %}Moderado
        {% elseif losLevel == 'D' %}Pesado
        {% elseif losLevel == 'E' %}Crítico
        {% else %}Colapsado{% endif %}
      </span>
    </div>
    <div class="rkpi-label">N&iacute;vel de Servi&ccedil;o (HCM)</div>
    <div class="rkpi-value" style="color:{{ losLevel == 'F' ? 'var(--color-error)' : losColor }};font-size:var(--text-xl)">Nível {{ losLevel }}</div>
    <div class="rkpi-sub">jam médio ponderado: {{ avgJam }}/5</div>
  </div>

  {# 2 — Saúde da Rede #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:{{ healthBg }};color:{{ healthColor }}">
        <i data-lucide="{% if healthScore >= 80 %}shield-check{% elseif healthScore >= 50 %}shield-alert{% else %}shield-x{% endif %}" style="width:18px;height:18px"></i>
      </div>
      <span class="rkpi-badge" style="background:{{ healthBg }};color:{{ healthColor }}">{{ healthLabel }}</span>
    </div>
    <div class="rkpi-label">Sa&uacute;de da Rede</div>
    <div class="rkpi-value" style="color:{{ healthColor }}">{{ healthScore }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">%</span></div>
    <div style="height:6px;border-radius:var(--radius-full);background:var(--color-surface-offset);margin-top:var(--space-2);overflow:hidden">
      <div style="height:100%;width:{{ healthScore }}%;background:linear-gradient(to right,var(--color-error),var(--color-gold) 50%,var(--color-success));border-radius:var(--radius-full);transition:width .6s ease"></div>
    </div>
  </div>

  {# 3 — Índice de Normalidade #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-primary) l c h/.1);color:var(--color-primary)">
        <i data-lucide="check-circle-2" style="width:18px;height:18px"></i>
      </div>
      <span class="rkpi-badge" style="background:oklch(from var(--color-primary) l c h/.1);color:var(--color-primary)">{{ normalPct }}%</span>
    </div>
    <div class="rkpi-label">&Iacute;ndice de Normalidade</div>
    <div class="rkpi-value" style="color:var(--color-primary)">{{ total - delayedCount }}<span style="font-size:var(--text-lg);font-weight:400;color:var(--color-text-muted)">/{{ total }}</span></div>
    <div class="rkpi-sub">rotas dentro do tempo hist&oacute;rico</div>
    <div style="height:6px;border-radius:var(--radius-full);background:var(--color-surface-offset);margin-top:var(--space-2);overflow:hidden">
      <div style="height:100%;width:{{ normalPct }}%;background:var(--color-primary);border-radius:var(--radius-full);transition:width .6s ease"></div>
    </div>
  </div>

  {# 4 — Velocidade Média da Rede #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-blue) l c h/.1);color:var(--color-blue)">
        <i data-lucide="gauge" style="width:18px;height:18px"></i>
      </div>
      {% if avgSpeedKmh > 0 %}
        {% if avgSpeedKmh >= 50 %}
          <span class="rkpi-badge" style="background:oklch(from var(--color-success) l c h/.1);color:var(--color-success)">boa</span>
        {% elseif avgSpeedKmh >= 25 %}
          <span class="rkpi-badge" style="background:oklch(from var(--color-gold) l c h/.1);color:var(--color-gold)">lenta</span>
        {% else %}
          <span class="rkpi-badge" style="background:oklch(from var(--color-error) l c h/.1);color:var(--color-error)">crítica</span>
        {% endif %}
      {% endif %}
    </div>
    <div class="rkpi-label">Velocidade M&eacute;dia</div>
    <div class="rkpi-value" style="color:var(--color-blue)">
      {% if avgSpeedKmh > 0 %}{{ avgSpeedKmh }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">km/h</span>
      {% else %}&mdash;{% endif %}
    </div>
    <div class="rkpi-sub">m&eacute;dia geral da rede monitorada</div>
  </div>

</div>{# /route-kpi-grid #}

{# ────────────────────────────────────────────────────────────────────────── #}
{# GRID INFERIOR — 3 colunas (Tempo perdido | Congestionadas+ext | Donut×2) #}
{# ────────────────────────────────────────────────────────────────────────── #}
<div class="route-kpi-grid-2">

  {# 5 — Tempo Total Perdido + rota mais crítica #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-gold) l c h/.1);color:var(--color-gold)">
        <i data-lucide="clock" style="width:18px;height:18px"></i>
      </div>
      {% if delayedCount > 0 %}
      <span class="rkpi-badge" style="background:oklch(from var(--color-warning) l c h/.12);color:var(--color-warning)">{{ delayedPct }}% em atraso</span>
      {% endif %}
    </div>
    <div class="rkpi-label">Tempo Total Perdido na Rede</div>
    <div class="rkpi-value">
      {% if timeLostMin > 0 %}
        {% if timeLostMin >= 60 %}{{ (timeLostMin / 60)|round(1) }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">h</span>
        {% else %}{{ timeLostMin }}<span style="font-size:var(--text-lg);font-weight:500;color:var(--color-text-muted)">min</span>{% endif %}
      {% else %}&mdash;{% endif %}
    </div>
    <div class="rkpi-sub">soma dos atrasos de {{ delayedCount }} rota{{ delayedCount != 1 ? 's' }}</div>
    {% if maxDelayRoute is not null and maxDelaySec > 0 %}
    <div class="rkpi-divider"></div>
    <div class="rkpi-sub" style="color:var(--color-text-muted)">Rota mais cr&iacute;tica:</div>
    <div class="rkpi-critical-row">
      <i data-lucide="alert-triangle" style="width:12px;height:12px;flex-shrink:0;color:var(--color-error)"></i>
      <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;color:var(--color-text)" title="{{ maxDelayRoute.name }}">{{ maxDelayRoute.name }}</span>
      <span style="font-weight:700;color:var(--color-error);flex-shrink:0">+{% if maxDelaySec < 60 %}{{ maxDelaySec }}s{% else %}{{ (maxDelaySec / 60)|round(1) }}min{% endif %}</span>
    </div>
    {% endif %}
    {% if kpi.avgDelaySec > 0 %}
    <div class="rkpi-divider"></div>
    <div class="rkpi-sub">Atraso m&eacute;dio geral:
      <strong>{% if kpi.avgDelaySec < 60 %}{{ kpi.avgDelaySec }}s{% else %}{{ (kpi.avgDelaySec / 60)|round(1) }}min{% endif %}</strong>
    </div>
    {% endif %}
  </div>

  {# 6 — Congestionadas + Extensão monitorada #}
  <div class="route-kpi-card">
    <div class="rkpi-top">
      <div class="rkpi-icon" style="background:oklch(from var(--color-error) l c h/.1);color:var(--color-error)">
        <i data-lucide="traffic-cone" style="width:18px;height:18px"></i>
      </div>
      {% if total > 0 %}
      <span class="rkpi-badge" style="background:oklch(from var(--color-error) l c h/.1);color:var(--color-error)">{{ congPct }}%</span>
      {% endif %}
    </div>
    <div class="rkpi-label">Congestionadas (&ge;3) &amp; Extens&atilde;o</div>
    <div class="rkpi-value" style="color:var(--color-error)">{{ kpi.congested }}
      <span style="font-size:var(--text-sm);font-weight:400;color:var(--color-text-muted)">rotas</span>
    </div>
    {% if kpi.congested > 0 %}
    <div class="rkpi-bar-split">
      {% if stopped > 0 %}<div class="rkpi-bar-seg" style="width:{{ (stopped/kpi.congested*100)|round(1) }}%;background:var(--color-error)" title="Parado: {{ stopped }}"></div>{% endif %}
      {% if vheavy > 0 %}<div class="rkpi-bar-seg" style="width:{{ (vheavy/kpi.congested*100)|round(1) }}%;background:oklch(0.48 0.22 25)" title="Muito pesado: {{ vheavy }}"></div>{% endif %}
      {% if heavy > 0 %}<div class="rkpi-bar-seg" style="width:{{ (heavy/kpi.congested*100)|round(1) }}%;background:oklch(0.55 0.2 25)" title="Pesado: {{ heavy }}"></div>{% endif %}
    </div>
    <div class="rkpi-sub">
      {% if stopped > 0 %}<span style="color:var(--color-error)">{{ stopped }} parada{{ stopped!=1?'s' }}</span>{% if vheavy>0 %}, {% endif %}{% endif %}
      {% if vheavy > 0 %}{{ vheavy }} muito pesada{{ vheavy!=1?'s' }}{% endif %}
    </div>
    {% if congAvgDelaySec > 0 %}
    <div class="rkpi-divider"></div>
    <div class="rkpi-sub">Atraso m&eacute;dio congestionadas: <strong style="color:var(--color-error)">{% if congAvgDelaySec < 60 %}{{ congAvgDelaySec }}s{% else %}{{ (congAvgDelaySec/60)|round(1) }}min{% endif %}</strong></div>
    {% endif %}
    {% endif %}
    <div class="rkpi-divider"></div>
    <div style="display:flex;justify-content:space-between;align-items:center">
      <div>
        <div class="rkpi-sub" style="margin-top:0">Extens&atilde;o total: <strong style="color:var(--color-text)">{{ totalExtKm }} km</strong></div>
        {% if congExtKm > 0 %}
        <div class="rkpi-sub"><span style="color:var(--color-error)">{{ congExtKm }} km</span> congestionados
          {% if totalExtKm > 0 %}({{ ((congExtKm/totalExtKm)*100)|round(0) }}%){% endif %}
        </div>
        {% endif %}
      </div>
      <div class="rkpi-icon" style="background:oklch(from var(--color-blue) l c h/.1);color:var(--color-blue)">
        <i data-lucide="ruler" style="width:18px;height:18px"></i>
      </div>
    </div>
    {% if slow > 0 or moderate > 0 %}
    <div class="rkpi-divider"></div>
    <div class="rkpi-sub">
      Livres: <span style="color:var(--color-success)">{{ free }}</span> &nbsp;|
      {% if slow > 0 %} Lentas: <span style="color:var(--color-gold)">{{ slow }}</span>{% endif %}
      {% if moderate > 0 %} Moderadas: <span style="color:var(--color-orange)">{{ moderate }}</span>{% endif %}
    </div>
    {% endif %}
  </div>

  {# 7 — Distribuição (donut) ocupa span 1 neste grid de 3 #}
  <div class="route-kpi-card">
    <div class="rkpi-label">Distribui&ccedil;&atilde;o por N&iacute;vel</div>
    {% if total > 0 %}
    <div class="donut-wrap">
      <svg width="80" height="80" viewBox="0 0 80 80" aria-hidden="true" style="flex-shrink:0;transform:rotate(-90deg)">
        <circle cx="40" cy="40" r="28" fill="none" stroke="var(--color-surface-offset)" stroke-width="10"/>
        {% set offset = 0 %}
        {% for seg in donutData %}
          {% if seg.cnt > 0 %}
            {% set dash = (seg.cnt / total * circ)|round(2) %}
            <circle cx="40" cy="40" r="28" fill="none"
              stroke="{{ seg.color }}" stroke-width="10"
              stroke-dasharray="{{ dash }} {{ circ - dash }}"
              stroke-dashoffset="{{ (circ - offset)|round(2) }}"
              stroke-linecap="butt"/>
            {% set offset = offset + dash %}
          {% endif %}
        {% endfor %}
        <text x="40" y="44" text-anchor="middle" font-size="13" font-weight="700"
          fill="var(--color-text)" style="transform:rotate(90deg);transform-origin:40px 40px">{{ total }}</text>
      </svg>
      <div class="donut-legend">
        {% for seg in donutData %}{% if seg.cnt > 0 %}
        <div class="donut-leg-item">
          <span class="donut-dot" style="background:{{ seg.color }}"></span>
          <span>{{ seg.label }}</span>
          <span class="donut-leg-pct">{{ seg.pct }}%</span>
          <span class="donut-leg-val">{{ seg.cnt }}</span>
        </div>
        {% endif %}{% endfor %}
      </div>
    </div>
    <div class="health-bar-wrap" style="margin-top:var(--space-4)">
      {% for seg in donutData %}{% if seg.cnt > 0 %}
        <div class="health-seg hs-{{ seg.lv }}" style="width:{{ (seg.cnt/total*100)|round(1) }}%" title="{{ seg.label }}: {{ seg.cnt }} ({{ seg.pct }}%)"></div>
      {% endif %}{% endfor %}
    </div>
    {% if maxDelayRoute is not null and maxDelaySec > 0 %}
    <div style="margin-top:var(--space-3)">
      <div class="rkpi-critical-row">
        <i data-lucide="alert-triangle" style="width:12px;height:12px;flex-shrink:0;color:var(--color-error)"></i>
        <span style="font-size:var(--text-xs);color:var(--color-text-muted)">Mais cr&iacute;tica:</span>
        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;font-size:var(--text-xs);font-weight:600;color:var(--color-text)" title="{{ maxDelayRoute.name }}">{{ maxDelayRoute.name }}</span>
        <span style="font-size:var(--text-xs);font-weight:700;color:var(--color-error);flex-shrink:0">+{% if maxDelaySec < 60 %}{{ maxDelaySec }}s{% else %}{{ (maxDelaySec/60)|round(1) }}min{% endif %}</span>
      </div>
    </div>
    {% endif %}
    {% else %}
      <div class="rkpi-sub" style="margin-top:var(--space-3)">Nenhuma rota no snapshot.</div>
    {% endif %}
  </div>

</div>{# /route-kpi-grid-2 #}

{# Mapa #}
{% if routes is not empty %}
<div class="card" style="margin-bottom:var(--space-6)">
  <div class="card-header">
    <span class="card-title"><i data-lucide="map" style="width:14px;height:14px;display:inline"></i> Mapa de Rotas</span>
    <span style="font-size:var(--text-xs);color:var(--color-text-muted)">Clique numa rota para destacar na tabela</span>
  </div>
  <div style="padding:var(--space-4)"><div id="tvt-map"></div></div>
</div>
{% endif %}

<div style="margin-bottom:var(--space-4);display:flex;align-items:center;gap:var(--space-4);flex-wrap:wrap">
  <div class="chip-group">
    <a href="{{ path('route_admin_index') }}" class="chip {{ jamFilter is null or jamFilter == '' ? 'active' }}">Todos</a>
    <a href="{{ path('route_admin_index', {jam: 0}) }}" class="chip {{ jamFilter == '0' ? 'active' }}">&#x1F7E2; Livre</a>
    <a href="{{ path('route_admin_index', {jam: 1}) }}" class="chip {{ jamFilter == '1' ? 'active' }}">&#x1F7E1; Lento</a>
    <a href="{{ path('route_admin_index', {jam: 2}) }}" class="chip {{ jamFilter == '2' ? 'active' }}">&#x1F7E0; Moderado</a>
    <a href="{{ path('route_admin_index', {jam: 3}) }}" class="chip {{ jamFilter == '3' ? 'active' }}">&#x1F534; Pesado</a>
    <a href="{{ path('route_admin_index', {jam: 4}) }}" class="chip {{ jamFilter == '4' ? 'active' }}">&#x1F534; Muito Pesado</a>
    <a href="{{ path('route_admin_index', {jam: 5}) }}" class="chip {{ jamFilter == '5' ? 'active' }}">&#x26D4; Parado</a>
  </div>
  <span style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ routes|length }} rota(s)</span>
</div>

{% if routes is empty %}
  <div class="empty">
    <i data-lucide="route" style="width:40px;height:40px"></i>
    <h3>Nenhuma rota encontrada</h3>
    <p>Aguarde a pr&oacute;xima coleta do feed TVT ou remova os filtros.</p>
  </div>
{% else %}
<div class="card">
  <div class="card-header"><span class="card-title">Rotas do Snapshot</span></div>
  <div style="overflow-x:auto">
    <table id="routes-table">
      <thead>
        <tr>
          <th>Nome</th><th>Origem &rarr; Destino</th><th>Jam</th>
          <th style="text-align:right">Ext. (m)</th><th style="text-align:right">Atual</th>
          <th style="text-align:right">Hist&oacute;rico</th><th style="text-align:right">Atraso</th>
          <th style="text-align:right">Veloc.</th><th>Tipo</th><th></th>
        </tr>
      </thead>
      <tbody>
      {% for r in routes %}
        {% set delay = r.delaySeconds %}
        {% set veloc = (r.length is not null and r.time is not null and r.time > 0) ? (r.length / r.time * 3.6)|round(0) : null %}
        <tr class="row-hover route-row" data-waze-id="{{ r.wazeRouteId }}" style="cursor:pointer">
          <td style="font-weight:500;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ r.name }}">{{ r.name ?? '&mdash;' }}</td>
          <td style="font-size:var(--text-xs);color:var(--color-text-muted);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ r.fromName }} &rarr; {{ r.toName }}">{{ r.fromName ?? '&mdash;' }} &rarr; {{ r.toName ?? '&mdash;' }}</td>
          <td><span class="badge jam-{{ r.jamLevel ?? 0 }}">{{ r.jamLevelLabel }}</span></td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">{{ r.length ?? '&mdash;' }}</td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">{% if r.time is not null %}{% if r.time < 60 %}{{ r.time }}s{% else %}{{ (r.time/60)|round(1) }} min{% endif %}{% else %}&mdash;{% endif %}</td>
          <td style="text-align:right;font-variant-numeric:tabular-nums;color:var(--color-text-muted)">{% if r.historicTime is not null %}{% if r.historicTime < 60 %}{{ r.historicTime }}s{% else %}{{ (r.historicTime/60)|round(1) }} min{% endif %}{% else %}&mdash;{% endif %}</td>
          <td style="text-align:right;font-variant-numeric:tabular-nums" class="{% if delay is not null %}{% if delay > 0 %}delay-pos{% elseif delay < 0 %}delay-neg{% else %}delay-zero{% endif %}{% endif %}">
            {% if delay is null %}&mdash;
            {% elseif delay == 0 %}0s
            {% elseif delay > 0 %}+{{ delay < 60 ? delay~'s' : (delay/60)|round(1)~' min' }}
            {% else %}{{ delay < -60 ? (delay/60)|round(1)~' min' : delay~'s' }}{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums;color:var(--color-blue)">
            {% if veloc is not null %}{{ veloc }} <span style="color:var(--color-text-muted)">km/h</span>{% else %}&mdash;{% endif %}
          </td>
          <td><span class="badge badge-gray" style="font-size:10px">{{ r.type ?? '&mdash;' }}</span></td>
          <td>
            <a href="{{ path('route_admin_history', {wazeRouteId: r.wazeRouteId}) }}" class="btn btn-ghost btn-sm" title="Hist&oacute;rico">
              <i data-lucide="history" style="width:13px;height:13px"></i>
            </a>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
{% set routesData = [] %}
{% for r in routes %}
  {% set routesData = routesData|merge([{id:r.wazeRouteId,name:r.name,from:r.fromName,to:r.toName,jam:r.jamLevel,time:r.time,hist:r.historicTime,line:r.line}]) %}
{% endfor %}
  var routes = {