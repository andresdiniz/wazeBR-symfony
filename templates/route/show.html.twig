{% extends 'base.html.twig' %}
{% block title %}{{ route.name ?? 'Rota' }}{% endblock %}

{% block stylesheets %}
<style>
  .hist-table td { font-size: var(--text-xs); padding: var(--space-2) var(--space-3); }
  .hist-table th { font-size: var(--text-xs); padding: var(--space-2) var(--space-3); }
  .jam-dot { display:inline-block; width:10px; height:10px; border-radius:var(--radius-full); margin-right:4px; }
  .chart-wrap { position:relative; height:200px; }
  .tab-bar { display:flex; gap:var(--space-1); border-bottom:1px solid var(--color-border); margin-bottom:var(--space-5); }
  .tab-btn { padding:var(--space-2) var(--space-4); font-size:var(--text-sm); color:var(--color-text-muted); border-bottom:2px solid transparent; cursor:pointer; background:none; border-left:none; border-right:none; border-top:none; }
  .tab-btn.active { color:var(--color-primary); border-bottom-color:var(--color-primary); font-weight:600; }
  .tab-panel { display:none; }
  .tab-panel.active { display:block; }
</style>
{% endblock %}

{% block content %}
{% set jc   = ['badge-green','badge-yellow','badge-orange','badge-red','badge-red'] %}
{% set jl   = ['Livre','Lento','Moderado','Pesado','Parado'] %}
{% set jdot = ['#437a22','#d19900','#da7101','#a12c7b','#a12c7b'] %}

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div style="display:flex;align-items:center;gap:var(--space-4)">
    <a href="{{ path('route_admin_index') }}" class="icon-btn"><i data-lucide="arrow-left"></i></a>
    <div>
      <h1 class="page-title">{{ route.name ?? 'Rota sem nome' }}</h1>
      <p class="page-subtitle">
        {% if route.fromName %}{{ route.fromName }} → {{ route.toName }}{% else %}{{ route.description ?? 'Sem descrição' }}{% endif %}
      </p>
    </div>
  </div>
  <div style="display:flex;gap:var(--space-2);align-items:center">
    {% if route.isActive %}
      <span class="badge badge-green">Ativa</span>
    {% else %}
      <span class="badge badge-gray">Inativa</span>
    {% endif %}
    <form method="post" action="{{ path('route_admin_toggle', {id: route.id}) }}" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">
        <i data-lucide="{{ route.isActive ? 'pause' : 'play' }}" style="width:13px;height:13px"></i>
        {{ route.isActive ? 'Desativar' : 'Ativar' }}
      </button>
    </form>
  </div>
</div>

{# ─ KPIs: dados atuais da rota (campo direto da entity) + último snapshot ─ #}
{% set last = snapshots|first %}
<div class="kpi-grid" style="margin-bottom:var(--space-6)">
  <div class="kpi-card">
    <div class="kpi-label">Tempo atual</div>
    <div class="kpi-value">
      {% if route.time is not null %}{{ (route.time / 60)|round(1) }} min{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Tempo histórico</div>
    <div class="kpi-value">
      {% if route.historicTime is not null %}{{ (route.historicTime / 60)|round(1) }} min{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Extensão</div>
    <div class="kpi-value">
      {% if route.length is not null %}{{ (route.length / 1000)|round(2) }} km{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Congestionamento</div>
    <div class="kpi-value">
      {% if route.jamLevel is not null %}
        <span class="badge {{ jc[route.jamLevel] }}">{{ jl[route.jamLevel] }}</span>
      {% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Última coleta</div>
    <div class="kpi-value" style="font-size:var(--text-sm)">
      {% if route.collectedAt %}
        <time data-utc="{{ route.collectedAt|date('Y-m-d\\TH:i:s\\Z') }}" data-fmt="relative"></time>
      {% else %}Sem dados{% endif %}
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Snapshots salvos</div>
    <div class="kpi-value">{{ snapshots|length }}</div>
  </div>
</div>

{# ─ Tabs ─ #}
<div class="tab-bar">
  <button class="tab-btn active" data-tab="history">
    <i data-lucide="history" style="width:13px;height:13px;vertical-align:middle;margin-right:4px"></i>Histórico
  </button>
  <button class="tab-btn" data-tab="chart">
    <i data-lucide="trending-up" style="width:13px;height:13px;vertical-align:middle;margin-right:4px"></i>Gráfico
  </button>
  <button class="tab-btn" data-tab="links">
    <i data-lucide="link" style="width:13px;height:13px;vertical-align:middle;margin-right:4px"></i>Sub-rotas ({{ route.routeLinks|length }})
  </button>
</div>

{# Tab: Histórico #}
<div id="tab-history" class="tab-panel active">
  {% if snapshots is empty %}
    <div class="empty">
      <i data-lucide="database" style="width:36px;height:36px"></i>
      <h3>Nenhum dado coletado ainda</h3>
      <p>Os snapshots aparecerão aqui após cada busca automática.</p>
    </div>
  {% else %}
    <div class="card">
      <div class="card-header">
        <span class="card-title">Registro de buscas</span>
        <span style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ snapshots|length }} registros — mais recentes primeiro</span>
      </div>
      <div style="overflow-x:auto">
        <table class="hist-table">
          <thead>
            <tr>
              <th>Data/hora</th>
              <th>Tempo atual</th>
              <th>Tempo hist.</th>
              <th>Extensão</th>
              <th>Congestionamento</th>
            </tr>
          </thead>
          <tbody>
            {% for s in snapshots %}
            <tr>
              <td>
                <time data-utc="{{ s.collectedAt|date('Y-m-d\\TH:i:s\\Z') }}" data-fmt="datetime"></time>
              </td>
              <td style="font-variant-numeric:tabular-nums">
                {% if s.time is not null %}{{ (s.time / 60)|round(1) }} min{% else %}—{% endif %}
              </td>
              <td style="font-variant-numeric:tabular-nums;color:var(--color-text-muted)">
                {% if s.historicTime is not null %}{{ (s.historicTime / 60)|round(1) }} min{% else %}—{% endif %}
              </td>
              <td style="font-variant-numeric:tabular-nums">
                {% if s.length is not null %}{{ (s.length / 1000)|round(2) }} km{% else %}—{% endif %}
              </td>
              <td>
                {% if s.jamLevel is not null %}
                  <span class="badge {{ jc[s.jamLevel] }}">
                    <span class="jam-dot" style="background:{{ jdot[s.jamLevel] }}"></span>
                    {{ jl[s.jamLevel] }}
                  </span>
                {% else %}
                  <span style="color:var(--color-text-faint)">—</span>
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endif %}
</div>

{# Tab: Gráfico #}
<div id="tab-chart" class="tab-panel">
  {% if snapshots|length < 2 %}
    <div class="empty">
      <i data-lucide="trending-up" style="width:36px;height:36px"></i>
      <h3>Dados insuficientes</h3>
      <p>São necessários ao menos 2 registros para exibir o gráfico.</p>
    </div>
  {% else %}
    <div class="card">
      <div class="card-header">
        <span class="card-title">Tempo de percurso ao longo do tempo</span>
      </div>
      <div class="card-body">
        <div class="chart-wrap"><canvas id="chart-route"></canvas></div>
      </div>
    </div>
    <script>
    window.__routeSnapshots = [
      {% for s in snapshots|reverse %}
      { t:"{{ s.collectedAt|date('Y-m-d\\TH:i:s\\Z') }}", time:{{ s.time is not null ? (s.time/60)|round(2) : 'null' }}, hist:{{ s.historicTime is not null ? (s.historicTime/60)|round(2) : 'null' }} }{{ not loop.last ? ',' }}
      {% endfor %}
    ];
    </script>
  {% endif %}
</div>

{# Tab: Sub-rotas #}
<div id="tab-links" class="tab-panel">
  {% if route.routeLinks is empty %}
    <div class="empty">
      <i data-lucide="link" style="width:36px;height:36px"></i>
      <h3>Nenhuma sub-rota</h3>
      <p>Sub-rotas são os segmentos que compõem a rota principal.</p>
    </div>
  {% else %}
    <div class="card">
      <table>
        <thead>
          <tr><th>#</th><th>Nome</th><th>Ordem</th></tr>
        </thead>
        <tbody>
          {% for link in route.routeLinks %}
          <tr>
            <td style="color:var(--color-text-muted)">{{ link.id }}</td>
            <td>{{ link.name }}</td>
            <td>{{ link.sortOrder }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  /* Tabs */
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      if (btn.dataset.tab === 'chart') initChart();
    });
  });

  /* Gráfico */
  let chartInited = false;
  function initChart() {
    if (chartInited) return;
    const data = window.__routeSnapshots;
    if (!data || data.length < 2) return;
    chartInited = true;
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const gridColor = isDark ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.06)';
    const textColor = isDark ? '#797876' : '#7a7974';
    const labels = data.map(s => {
      const d = new Date(s.t);
      return d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}) + ' ' + d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
    });
    new Chart(document.getElementById('chart-route'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label:'Tempo atual (min)', data:data.map(s=>s.time), borderColor:'#01696f', backgroundColor:'rgba(1,105,111,.12)', tension:.35, fill:true, pointRadius:3, spanGaps:true },
          { label:'Tempo histórico (min)', data:data.map(s=>s.hist), borderColor:'#da7101', backgroundColor:'rgba(218,113,1,.08)', tension:.35, fill:false, borderDash:[5,4], pointRadius:2, spanGaps:true }
        ]
      },
      options: {
        responsive:true, maintainAspectRatio:false,
        interaction:{ mode:'index', intersect:false },
        plugins:{
          legend:{ labels:{ color:textColor, font:{size:11} } },
          tooltip:{ callbacks:{ label:ctx => ctx.dataset.label+': '+(ctx.parsed.y!==null ? ctx.parsed.y.toFixed(1)+' min' : '—') } }
        },
        scales:{
          x:{ ticks:{ color:textColor, font:{size:10}, maxTicksLimit:10 }, grid:{ color:gridColor } },
          y:{ ticks:{ color:textColor, font:{size:10}, callback:v=>v+' min' }, grid:{ color:gridColor } }
        }
      }
    });
  }
});
</script>
{% endblock %}
