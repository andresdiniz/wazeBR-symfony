{% extends 'base.html.twig' %}
{% block title %}Histórico — {{ routeName }}{% endblock %}

{% block content %}
<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4)">
  <div>
    <a href="{{ path('route_admin_index') }}" style="font-size:var(--text-sm);color:var(--color-text-muted);display:inline-flex;align-items:center;gap:4px;margin-bottom:var(--space-2)">
      <i data-lucide="arrow-left" style="width:14px;height:14px"></i> Voltar
    </a>
    <h1 class="page-title">{{ routeName }}</h1>
    <p class="page-subtitle">Histórico de snapshots &mdash; últimos {{ history|length }} registros</p>
  </div>
</div>

{# Gráfico #}
<div class="card" style="margin-bottom:var(--space-6)">
  <div class="card-header"><span class="card-title">Evolução do tempo de percurso</span></div>
  <div class="card-body"><canvas id="chart-history" style="max-height:320px"></canvas></div>
</div>

{# Tabela #}
<div class="card">
  <div class="card-header"><span class="card-title">Registros</span></div>
  <div style="overflow-x:auto">
    <table>
      <thead><tr>
        <th>Coletado em</th>
        <th>Jam</th>
        <th style="text-align:right">Tempo atual</th>
        <th style="text-align:right">Histórico</th>
        <th style="text-align:right">Atraso</th>
      </tr></thead>
      <tbody>
      {% for r in history %}
        {% set delay = r.delaySeconds %}
        <tr>
          <td style="font-variant-numeric:tabular-nums;font-size:var(--text-xs)">
            <time data-utc="{{ r.snapshot.collectedAt|date('c') }}" data-fmt="datetime">{{ r.snapshot.collectedAt|date('d/m/Y H:i') }}</time>
          </td>
          <td><span class="badge jam-{{ r.jamLevel ?? 0 }}">{{ r.jamLevelLabel }}</span></td>
          <td style="text-align:right;font-variant-numeric:tabular-nums">
            {% if r.time is not null %}{{ (r.time/60)|round(1) }} min{% else %}&mdash;{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums;color:var(--color-text-muted)">
            {% if r.historicTime is not null %}{{ (r.historicTime/60)|round(1) }} min{% else %}&mdash;{% endif %}
          </td>
          <td style="text-align:right;font-variant-numeric:tabular-nums" class="{% if delay is not null %}{% if delay > 0 %}delay-pos{% elseif delay < 0 %}delay-neg{% else %}delay-zero{% endif %}{% endif %}">
            {% if delay is null %}&mdash;
            {% elseif delay == 0 %}0s
            {% elseif delay > 0 %}+{{ delay < 60 ? delay ~ 's' : (delay/60)|round(1) ~ ' min' }}
            {% else %}{{ delay < -60 ? (delay/60)|round(1) ~ ' min' : delay ~ 's' }}{% endif %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function(){
  const FMT = WazeTZ.FMT_DATE; // dd/mm/yyyy no fuso do usuário

  const raw = {{ history|map(r => {
    iso:  r.snapshot.collectedAt|date('c'),
    time: r.time,
    hist: r.historicTime,
    jam:  r.jamLevel
  })|json_encode|raw }};

  const sorted  = [...raw].reverse();
  const labels  = sorted.map(r => FMT.format(new Date(r.iso)));
  const times   = sorted.map(r => r.time  !== null ? +(r.time /60).toFixed(1) : null);
  const hists   = sorted.map(r => r.hist  !== null ? +(r.hist /60).toFixed(1) : null);

  new Chart(document.getElementById('chart-history'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'Tempo atual (min)', data: times, borderColor: '#a12c7b', backgroundColor: 'oklch(0.5 0.2 330 / 0.08)', tension: 0.3, fill: true, pointRadius: 2 },
        { label: 'Histórico (min)',   data: hists, borderColor: '#437a22', borderDash: [4,3], tension: 0.3, pointRadius: 2 }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { position: 'top' } },
      scales: {
        x: { ticks: { maxTicksLimit: 12, maxRotation: 45 } },
        y: { beginAtZero: true, title: { display: true, text: 'minutos' } }
      }
    }
  });
})();
</script>
{% endblock %}
