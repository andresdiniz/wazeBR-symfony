        <div class="map-legend-row">
          <div class="map-legend-line" style="background:#eab308"></div>
          <span class="map-legend-label">Jam leve (1–2)</span>
        </div>
        <div class="legend-sep"></div>
        <div class="map-legend-row">
          <span class="map-legend-emoji" style="filter:hue-rotate(160deg)">🌧️</span>
          <span class="map-legend-label">CEMADEN normal</span>
        </div>
        <div class="map-legend-row">
          <span class="map-legend-emoji" style="filter:hue-rotate(320deg) saturate(2)">🌧️</span>
          <span class="map-legend-label">CEMADEN crítico</span>
        </div>
        </div>{# /legend-body #}
      </div>
    </div>

    <!-- ─── Feed de eventos ───────────────────────── -->
    <aside class="op-feed">
      <div class="feed-header">
        <div class="feed-title">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Eventos Recentes
          <span class="feed-count-badge" id="feedCount">0</span>
        </div>
      </div>
      <div class="feed-list" id="feed-list"></div>
    </aside>

  </div><!-- /op-body -->

  <!-- ═══ BOTTOM BAR ════════════════════════════════════════ -->
  <div class="op-bar">
    <div class="op-bar-item">
      <div class="op-bar-dot" style="background:#ef4444"></div>
      <b id="barJams">0</b> jams
    </div>
    <div class="op-bar-item">
      <div class="op-bar-dot" style="background:#eab308"></div>
      <b id="barAlerts">0</b> alertas
    </div>
    <div class="op-bar-item">
      <div class="op-bar-dot" style="background:#3b82f6"></div>
      <b id="barCemaden">0</b> estações CEMADEN
    </div>
    <div class="op-bar-spacer"></div>
    <div class="op-bar-sources">
      <div class="op-bar-src" id="srcWaze">
        <div class="op-bar-dot" style="background:#14b8a6"></div>
        Waze
      </div>
      <div class="op-bar-src" id="srcCemaden">
        <div class="op-bar-dot" style="background:#3b82f6"></div>
        CEMADEN
      </div>
      <div class="op-bar-src" id="srcAlerts">
        <div class="op-bar-dot" style="background:#eab308"></div>
        Alertas
      </div>
    </div>
  </div>

</div><!-- /op-shell -->

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── Dados do servidor (Twig) ──────────────────────────────────
const FALLBACK_LAT  = {{ partner.lat  ?? -20.66 }};
const FALLBACK_LNG  = {{ partner.lng  ?? -43.78 }};
const FALLBACK_ZOOM = {{ partner.zoom ?? 13 }};
const API_URL       = '{{ path('operator_live_data') }}';
const REFRESH_MS    = {{ refreshMs ?? 30000 }};

// ── Camadas do mapa ───────────────────────────────────────────
const mapLayers = {
  jams:    L.layerGroup(),
  alerts:  L.layerGroup(),
  cemaden: L.layerGroup(),
};

// ── Sound ─────────────────────────────────────────────────────
let soundEnabled = false;
const btnSound   = document.getElementById('btnSound');
const soundIcon  = document.getElementById('soundIcon');
btnSound.addEventListener('click', () => {
  soundEnabled = !soundEnabled;
  btnSound.style.color    = soundEnabled ? '#14b8a6' : '';
  btnSound.style.borderColor = soundEnabled ? 'rgba(20,184,166,.35)' : '';
  soundIcon.innerHTML = soundEnabled
    ? '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>'
    : '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>';
});

function playAlert() {
  if (!soundEnabled) return;
  try {
    const ctx  = new (window.AudioContext || window.webkitAudioContext)();
    const osc  = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.type      = 'sine';
    osc.frequency.setValueAtTime(880, ctx.currentTime);
    gain.gain.setValueAtTime(.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(.001, ctx.currentTime + .4);
    osc.start(); osc.stop(ctx.currentTime + .4);
  } catch (_) {}
}

// ── Mapa — CartoDB DarkMatter (vias em cinza neutro) ──────────────
const map = L.map('op-map', { zoomControl: false, attributionControl: false });
L.control.zoom({ position: 'bottomright' }).addTo(map);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
  subdomains: 'abcd', maxZoom: 19,
  opacity: 0.85,
}).addTo(map);
// Labels acima dos overlays de trânsito
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png', {
  subdomains: 'abcd', maxZoom: 19, pane: 'shadowPane',
  opacity: 0.9,
}).addTo(map);
map.setView([FALLBACK_LAT, FALLBACK_LNG], FALLBACK_ZOOM);
Object.values(mapLayers).forEach(l => l.addTo(map));

// ── Cores dos jams ────────────────────────────────────────────────
function jamColor(level) {
  if (level >= 5) return '#ef4444';
  if (level >= 3) return '#f97316';
  if (level >= 1) return '#eab308';
  return '#22c55e';
}

// ── Ícones emoji por tipo de alerta ──────────────────────────────
function makeAlertIcon(type) {
  type = (type || '').toUpperCase();
  let emoji = '📍';
  let size  = 28;
  if (type.includes('ACCIDENT'))                              { emoji = '🚨'; size = 30; }
  else if (type.includes('JAM'))                             { emoji = '🚗'; size = 28; }
  else if (type.includes('CONSTRUCTION'))                    { emoji = '🚧'; size = 28; }
  else if (type.includes('POT_HOLE'))                        { emoji = '🕳️'; size = 26; }
  else if (type.includes('HAZARD') || type.includes('OBJECT')) { emoji = '⚠️'; size = 28; }
  else if (type.includes('ROAD') || type.includes('CLOSED')) { emoji = '🚫'; size = 28; }
  else if (type.includes('WEATHER') || type.includes('FLOOD')) { emoji = '🌊'; size = 28; }
  const half = Math.round(size / 2);
  return L.divIcon({
    html: `<span class="map-emoji-marker" style="font-size:${size}px;width:${size}px;height:${size}px;">${emoji}</span>`,
    className: '',
    iconSize:   [size, size],
    iconAnchor: [half, half],
  });
}

// ── CEMADEN marker ────────────────────────────────────────────────
function makeCemadenIcon(critical) {
  const color = critical ? '#ef4444' : '#3b82f6';
  const emoji = '🌧️';
  return L.divIcon({
    html: `<span class="map-emoji-marker" style="font-size:22px;width:22px;height:22px;filter:drop-shadow(0 0 4px ${color})">${emoji}</span>`,
    className: '',
    iconSize:   [22, 22],
    iconAnchor: [11, 11],
  });
}

// ── Relógio ───────────────────────────────────────────────────────
const clockEl = document.getElementById('op-clock');
function tickClock() {
  const now = new Date();
  const h = String(now.getHours()).padStart(2,'0');
  const m = String(now.getMinutes()).padStart(2,'0');
  const s = String(now.getSeconds()).padStart(2,'0');
  clockEl.textContent = `${h}:${m}:${s}`;
}
tickClock();
setInterval(tickClock, 1000);

// ── Wake Lock ─────────────────────────────────────────────────────
let wakeLock = null;
async function requestWakeLock() {
  if (!('wakeLock' in navigator)) return;
  try {
    wakeLock = await navigator.wakeLock.request('screen');
    document.getElementById('wakelockIndicator').classList.add('active');
    document.getElementById('wakelockLabel').textContent = 'ativa';
    wakeLock.addEventListener('release', () => {
      document.getElementById('wakelockIndicator').classList.remove('active');
      document.getElementById('wakelockLabel').textContent = 'tela';
    });
  } catch (_) {}
}
requestWakeLock();
document.addEventListener('visibilitychange', async () => {
  if (document.visibilityState === 'visible') await requestWakeLock();
});

// ── Fullscreen ────────────────────────────────────────────────────
document.getElementById('btnFullscreen').addEventListener('click', () => {
  if (!document.fullscreenElement) {
    document.documentElement.requestFullscreen().catch(() => {});
  } else {
    document.exitFullscreen().catch(() => {});
  }
});
document.addEventListener('fullscreenchange', () => {
  const btn = document.getElementById('btnFullscreen');
  btn.innerHTML = document.fullscreenElement
    ? '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg> Sair'
    : '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg> Fullscreen';
});

// ── Pulse / ago ───────────────────────────────────────────────────
const pulseEl = document.getElementById('op-pulse');
const agoEl   = document.getElementById('op-ago');
let lastFetch = null;

// FIX: updateAgo usa requestAnimationFrame para evitar forced reflow
// ao ler Date.now() e escrever no DOM no mesmo tick do setInterval
let _agoRafId = null;
function updateAgo() {
  if (_agoRafId) cancelAnimationFrame(_agoRafId);
  _agoRafId = requestAnimationFrame(() => {
    if (!lastFetch) { agoEl.textContent = '—'; return; }
    const sec = Math.round((Date.now() - lastFetch) / 1000);
    if (sec < 60)  { agoEl.textContent = `atualizado ${sec}s`; return; }
    const min = Math.floor(sec / 60);
    agoEl.textContent = `atualizado ${min}min`;
  });
}
setInterval(updateAgo, 5000);

// ── KPI builder ───────────────────────────────────────────────────
function alertClass(val, t1, t2, t3) {
  if (val >= t3) return 'alert-red';
  if (val >= t2) return 'alert-orange';
  if (val >= t1) return 'alert-yellow';
  return '';
}

function buildKpis(d) {
  const jams    = d.jams    || [];
  const alerts  = d.alerts  || [];
  const cemaden = d.cemaden || [];

  const jamCount   = jams.length;
  const alertCount = alerts.length;
  const critJams   = jams.filter(j => (j.level || 0) >= 5).length;
  const avgSpd     = jams.length ? Math.round(jams.reduce((s,j)=>s+(j.speedKMH||0),0)/jams.length) : 0;
  const totalLen   = jams.reduce((s,j)=>s+(j.length||0),0);
  const avgDelay   = jams.length ? Math.round(jams.reduce((s,j)=>s+(j.delay||0),0)/jams.length/60) : 0;

  const cemadenCrit  = cemaden.filter(c => c.critical).length;
  const alertByType  = {};
  alerts.forEach(a => {
    const t = (a.type||'OTHER').split('_')[0];
    alertByType[t] = (alertByType[t]||0) + 1;
  });

  function kpiCard(icon, label, value, unit, sub, alertCls, barPct, barCls) {
    return `<div class="kpi-card ${alertCls||''}">
      <div class="kpi-header">
        <div class="kpi-icon">${icon}</div>
        <div class="kpi-label">${label}</div>
      </div>
      <div class="kpi-body">
        <span class="kpi-value">${value}</span>
        ${unit ? `<span class="kpi-unit">${unit}</span>` : ''}
      </div>
      ${sub ? `<div class="kpi-sub">${sub}</div>` : ''}
      ${barPct !== undefined ? `<div class="kpi-bar-wrap"><div class="kpi-bar ${barCls||''}" style="width:${Math.min(100,barPct)}%"></div></div>` : ''}
    </div>`;
  }

  const trafficIcon = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 17H5a2 2 0 0 0-2 2v2"/><path d="M21 17h-4a2 2 0 0 0-2 2v2"/><circle cx="9" cy="9" r="2"/><circle cx="15" cy="9" r="2"/><path d="M12 3v4"/><path d="M3 9h18"/><path d="M5 9v8"/><path d="M19 9v8"/></svg>`;
  const alertIcon   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`;
  const speedIcon   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12l4-4"/><circle cx="12" cy="12" r="1"/></svg>`;
  const routeIcon   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M3 17.5A4.5 4.5 0 0 0 7.5 22H10"/><path d="M10 14H7.5a4.5 4.5 0 0 1 0-9H10"/></svg>`;
  const cloudIcon   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25"/><line x1="8" y1="19" x2="8" y2="21"/><line x1="8" y1="13" x2="8" y2="15"/><line x1="16" y1="19" x2="16" y2="21"/><line x1="16" y1="13" x2="16" y2="15"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="12" y1="15" x2="12" y2="17"/></svg>`;
  const delayIcon   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;

  const jamCls  = alertClass(jamCount, 5, 10, 20);
  const aluCls  = alertClass(alertCount, 3, 7, 15);
  const critCls = alertClass(critJams, 1, 3, 6);
  const spdCls  = avgSpd < 10 ? 'alert-red' : avgSpd < 20 ? 'alert-orange' : avgSpd < 30 ? 'alert-yellow' : '';

  const kpisHtml = [
    `<div class="kpi-section-label">${trafficIcon} Tráfego — últimas 3h</div>`,
    kpiCard(trafficIcon, 'Jams ativos', jamCount, '', `nível mín. ${jams.length ? Math.min(...jams.map(j=>j.level||0)) : '—'}`, jamCls, jamCount/30*100, jamCls==='alert-red'?'red':jamCls==='alert-orange'?'orange':'yellow'),
    kpiCard(speedIcon, 'Velocidade média', avgSpd, 'km/h', '', spdCls, avgSpd/60*100, spdCls==='alert-red'?'red':spdCls==='alert-orange'?'orange':'teal'),
    kpiCard(delayIcon, 'Atraso médio', avgDelay, 'min', '', alertClass(avgDelay,2,5,10), avgDelay/15*100, 'orange'),
    kpiCard(routeIcon, 'Extensão congestionada', (totalLen/1000).toFixed(1), 'km', '', alertClass(totalLen/1000,2,8,15), totalLen/1000/20*100, 'red'),
    `<div class="kpi-section-label">${alertIcon} Alertas</div>`,
    kpiCard(alertIcon, 'Alertas — última hora', alertCount, '', `68 nas últimas 24h`, aluCls, alertCount/15*100, 'yellow'),
    `<div class="kpi-section-label">${cloudIcon} CEMADEN — estação próxima</div>`,
    kpiCard(cloudIcon, 'Monitoramento fluvial', cemaden.length > 0 ? '—' : '—', '', 'aguardando dados…', '', undefined),
    kpiCard(cloudIcon, 'Chuva acum. — 1h (REDE)', '—', 'mm', '', '', undefined),
    `<div class="kpi-section-label"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg> Infraestrutura</div>`,
    kpiCard(`<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`, 'Monitorados', `0 <span style="font-size:10px;font-weight:400;color:var(--faint)">câm.</span> 2 <span style="font-size:10px;font-weight:400;color:var(--faint)">links</span> ${jamCount} <span style="font-size:10px;font-weight:400;color:var(--faint)">rotas</span>`, '', '', '', undefined),
  ].join('');

  document.getElementById('op-kpis').innerHTML = kpisHtml;
}

// ── Render Jams ───────────────────────────────────────────────────
function renderJams(jams) {
  mapLayers.jams.clearLayers();
  jams.forEach(j => {
    if (!j.line || !j.line.length) return;
    const coords = j.line.map(p => [p.y ?? p[1], p.x ?? p[0]]);
    const color  = jamColor(j.level ?? 0);
    const w      = j.level >= 5 ? 6 : j.level >= 3 ? 5 : 4;
    L.polyline(coords, {
      color, weight: w, opacity: .85,
      lineCap: 'round', lineJoin: 'round',
    }).bindPopup(`<b>${j.street || '—'}</b><br>Nível ${j.level ?? '?'} — ${j.speedKMH ?? '?'} km/h<br>Atraso: ${j.delay ? Math.round(j.delay/60)+'min' : '—'}`)
      .addTo(mapLayers.jams);
  });
}

// ── Render Alerts ─────────────────────────────────────────────────
function renderAlerts(alerts) {
  mapLayers.alerts.clearLayers();
  alerts.forEach(a => {
    if (!a.lat || !a.lng) return;
    L.marker([a.lat, a.lng], { icon: makeAlertIcon(a.type) })
      .bindPopup(`<b>${a.type || 'Alerta'}</b><br>${a.street || '—'}<br>Conf. ${a.confidence ?? '?'}`)
      .addTo(mapLayers.alerts);
  });
}

// ── Render CEMADEN ────────────────────────────────────────────────
function renderCemaden(stations) {
  mapLayers.cemaden.clearLayers();
  stations.forEach(s => {
    if (!s.lat || !s.lng) return;
    L.marker([s.lat, s.lng], { icon: makeCemadenIcon(s.critical) })
      .bindPopup(`<b>${s.name || 'Estação'}</b><br>Chuva 1h: ${s.rain1h ?? '—'} mm`)
      .addTo(mapLayers.cemaden);
  });
}

// ── Feed builder ──────────────────────────────────────────────────
const MAX_FEED = 30;
let feedItems  = [];
const feedEl   = document.getElementById('feed-list');
const feedCnt  = document.getElementById('feedCount');

function feedBadgeClass(type) {
  if (!type) return 'feed-badge-other';
  const t = type.toUpperCase();
  if (t.includes('JAM'))           return 'feed-badge-jam';
  if (t.includes('ACCIDENT'))      return 'feed-badge-jam';
  if (t.includes('CLOSED') || t.includes('ROAD')) return 'feed-badge-closed';
  if (t.includes('HAZARD') || t.includes('OBJECT')) return 'feed-badge-hazard';
  return 'feed-badge-alert';
}
function feedLabel(type) {
  if (!type) return 'ALERTA';
  const t = type.toUpperCase();
  if (t.includes('JAM'))       return 'TRÂNSITO INTENSO';
  if (t.includes('ACCIDENT'))  return 'ACIDENTE';
  if (t.includes('ROAD'))      return 'VIA FECHADA';
  if (t.includes('HAZARD'))    return 'PERIGO NA VIA';
  if (t.includes('BUMP') || t.includes('POT')) return 'BURACO NA VIA';
  if (t.includes('STOPPED'))   return 'VEÍCULO PARADO';
  if (t.includes('OBJECT'))    return 'OBJETO NA VIA';
  return type.replace(/_/g,' ').substring(0,20);
}
function timeAgo(ts) {
  if (!ts) return '—';
  const sec = Math.round((Date.now() - new Date(ts * 1000)) / 1000);
  if (sec < 60) return `${sec}s atrás`;
  if (sec < 3600) return `${Math.floor(sec/60)}min atrás`;
  return `${Math.floor(sec/3600)}h atrás`;
}

function mergeIntoFeed(items) {
  const existing = new Set(feedItems.map(i => i._id));
  let added = 0;
  items.forEach(item => {
    const id = item.uuid || item.id || (item.street + item.type);
    if (!existing.has(id)) {
      feedItems.unshift({ ...item, _id: id, _ts: Date.now() });
      added++;
    }
  });
  if (added) {
    feedItems = feedItems.slice(0, MAX_FEED);
    renderFeed();
  }
  feedCnt.textContent = feedItems.length;
}

function renderFeed() {
  feedEl.innerHTML = feedItems.map(item => `
    <div class="feed-item">
      <div class="feed-item-header">
        <span class="feed-badge ${feedBadgeClass(item.type)}">${feedLabel(item.type)}</span>
        <span class="feed-time">${timeAgo(item.pubMillis ? item.pubMillis/1000 : null)}</span>
      </div>
      <div class="feed-street">${item.street || '—'}</div>
      <div class="feed-city">${item.city || ''}</div>
      <div class="feed-conf">conf. ${item.confidence ?? 0}</div>
    </div>
  `).join('');
}

// ── Update bar counts ─────────────────────────────────────────────
function updateBar(d) {
  const jc = (d.jams||[]).length;
  const ac = (d.alerts||[]).length;
  const cc = (d.cemaden||[]).length;
  document.getElementById('barJams').textContent    = jc;
  document.getElementById('barAlerts').textContent  = ac;
  document.getElementById('barCemaden').textContent = cc;
  document.getElementById('lblJams').textContent    = `${jc} jams`;
  document.getElementById('lblAlerts').textContent  = `${ac} alertas`;
  document.getElementById('lblCemaden').textContent = `${cc} estações CEMADEN`;
  document.getElementById('dotJams').style.background = jc > 15 ? '#ef4444' : jc > 5 ? '#f97316' : '#ef4444';

  document.getElementById('srcWaze').className    = 'op-bar-src ' + (jc > 0 || ac > 0 ? 'on' : 'off');
  document.getElementById('srcCemaden').className = 'op-bar-src ' + (cc > 0 ? 'on' : 'off');
  document.getElementById('srcAlerts').className  = 'op-bar-src ' + (ac > 0 ? 'on' : 'off');
}

// ── Main fetch loop ───────────────────────────────────────────────
// FIX: usa setTimeout recursivo em vez de setInterval para evitar
// sobreposição de ciclos quando o fetch demora mais que REFRESH_MS,
// eliminando o violation 'setInterval handler took Xms'.
let prevAlertCount = 0;
let _fetchTimer    = null;

async function fetchData() {
  try {
    const res  = await fetch(API_URL);
    if (!res.ok) throw new Error(res.status);
    const data = await res.json();

    lastFetch = Date.now();
    pulseEl.className = 'op-pulse ok';
    updateAgo();

    // FIX: operações leves de DOM primeiro (KPIs, bar, feed)
    buildKpis(data);
    updateBar(data);
    mergeIntoFeed([...(data.alerts||[]), ...(data.jams||[])]);

    // FIX: renderização pesada do mapa adiada via setTimeout para liberar
    // a thread principal e evitar 'Forced reflow while executing JavaScript'
    setTimeout(() => renderJams(data.jams       || []), 0);
    setTimeout(() => renderAlerts(data.alerts   || []), 0);
    setTimeout(() => renderCemaden(data.cemaden || []), 0);

    const newAlerts = (data.alerts||[]).length;
    if (newAlerts > prevAlertCount) playAlert();
    prevAlertCount = newAlerts;

  } catch (e) {
    pulseEl.className = 'op-pulse err';
    console.error('[LiveOp] fetch error', e);
  } finally {
    // Agenda próximo ciclo somente após o atual terminar
    _fetchTimer = setTimeout(fetchData, REFRESH_MS);
  }
}

fetchData();

// ── Legend toggle ──────────────────────────────────────────────
(function() {
  const btn = document.getElementById('legendToggle');
  const legend = btn && btn.closest('.map-legend');
  if (!btn || !legend) return;
  btn.addEventListener('click', () => {
    const collapsed = legend.classList.toggle('collapsed');
    btn.textContent = collapsed ? '+' : '−';
    btn.title = collapsed ? 'Expandir legenda' : 'Minimizar legenda';
  });
})();
</script>
</body>
</html>
