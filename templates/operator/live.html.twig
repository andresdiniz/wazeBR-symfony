<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
'use strict';

// ── Config ────────────────────────────────────────────────────────
const POLL_MS    = 30_000;
const API_URL    = '/api/live-summary';
const RAIN_WARN  = 10,  RAIN_CRIT  = 30;
const JAM_WARN   = 10,  JAM_CRIT   = 30;
const DELAY_WARN = 60,  DELAY_CRIT = 180;
const FALLBACK_LAT  = -19.92;
const FALLBACK_LNG  = -43.94;
const FALLBACK_ZOOM = 12;

// ── Wake Lock ─────────────────────────────────────────────────────
let wakeLock = null;
const wakeLockEl   = document.getElementById('wakelock-indicator');
const wakeLockText = document.getElementById('wakelock-text');

async function requestWakeLock() {
  if (!('wakeLock' in navigator)) { if (wakeLockEl) wakeLockEl.style.display = 'none'; return; }
  try {
    wakeLock = await navigator.wakeLock.request('screen');
    if (wakeLockText) wakeLockText.textContent = 'ativa';
    wakeLockEl.classList.add('active');
    wakeLock.addEventListener('release', () => {
      if (wakeLockText) wakeLockText.textContent = 'livre';
      wakeLockEl.classList.remove('active');
    });
  } catch (_) { if (wakeLockEl) wakeLockEl.style.display = 'none'; }
}
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible') requestWakeLock();
});
requestWakeLock();

// ── Estado ────────────────────────────────────────────────────────
let soundEnabled = false;
let lastTs       = null;
let mapFitted    = false;
let history      = { jams: [], alerts: [], upd: [] };
let mapLayers    = { jams: L.layerGroup(), alerts: L.layerGroup(), cemaden: L.layerGroup() };

// ── Relógio ───────────────────────────────────────────────────────
function tickClock() {
  document.getElementById('op-clock').textContent =
    new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}
setInterval(tickClock, 1000); tickClock();

// ── Fullscreen ────────────────────────────────────────────────────
document.getElementById('op-fs-btn').addEventListener('click', () => {
  if (!document.fullscreenElement) document.documentElement.requestFullscreen();
  else document.exitFullscreen();
});

// ── Som ───────────────────────────────────────────────────────────
const soundBtn   = document.getElementById('op-sound-btn');
const soundLabel = document.getElementById('sound-label');
soundBtn.addEventListener('click', function () {
  soundEnabled = !soundEnabled;
  soundLabel.textContent = soundEnabled ? 'Som on' : 'Som';
  this.style.color = soundEnabled ? 'var(--teal)' : '';
  this.style.borderColor = soundEnabled ? 'rgba(20,184,166,.4)' : '';
});
function beep() {
  if (!soundEnabled) return;
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator(), gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.value = 880;
    gain.gain.setValueAtTime(.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(.001, ctx.currentTime + .4);
    osc.start(); osc.stop(ctx.currentTime + .4);
  } catch (_) {}
}

// ── Mapa ──────────────────────────────────────────────────────────
const map = L.map('op-map', { zoomControl: true, attributionControl: false });
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  subdomains: 'abcd', maxZoom: 19,
}).addTo(map);
map.setView([FALLBACK_LAT, FALLBACK_LNG], FALLBACK_ZOOM);
Object.values(mapLayers).forEach(l => l.addTo(map));

// ── Cores dos jams ────────────────────────────────────────────────
function jamColor(level) {
  if (level >= 5) return '#ef4444';
  if (level >= 3) return '#f97316';
  if (level >= 1) return '#eab308';
  return '#22c55e';
}

// ── Ícones SVG por tipo de alerta ─────────────────────────────────
function makeAlertIcon(type) {
  type = (type || '').toUpperCase();

  if (type.includes('ACCIDENT')) {
    // Círculo vermelho com "!"
    return L.divIcon({
      html: `<svg width="22" height="22" viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="10" fill="#ef4444" stroke="rgba(255,255,255,.4)" stroke-width="1.5"/>
        <text x="11" y="15.5" text-anchor="middle" font-size="13" font-weight="bold" font-family="Arial,sans-serif" fill="#fff">!</text>
      </svg>`,
      className: '', iconSize: [22, 22], iconAnchor: [11, 11],
    });
  }

  if (type.includes('JAM')) {
    // Círculo laranja com ícone de carro simplificado
    return L.divIcon({
      html: `<svg width="22" height="22" viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="10" fill="#f97316" stroke="rgba(255,255,255,.4)" stroke-width="1.5"/>
        <rect x="5" y="9" width="12" height="5" rx="1.5" fill="#fff" opacity=".9"/>
        <rect x="6" y="7.5" width="10" height="3" rx="1" fill="#fff" opacity=".7"/>
        <circle cx="7.5" cy="14.5" r="1.5" fill="#f97316" stroke="#fff" stroke-width=".8"/>
        <circle cx="14.5" cy="14.5" r="1.5" fill="#f97316" stroke="#fff" stroke-width=".8"/>
      </svg>`,
      className: '', iconSize: [22, 22], iconAnchor: [11, 11],
    });
  }

  if (type.includes('HAZARD') || type.includes('CONSTRUCTION') || type.includes('POT_HOLE') || type.includes('OBJECT')) {
    // Triângulo amarelo com "!"
    return L.divIcon({
      html: `<svg width="24" height="22" viewBox="0 0 24 22" xmlns="http://www.w3.org/2000/svg">
        <polygon points="12,1 23,21 1,21" fill="#eab308" stroke="rgba(255,255,255,.4)" stroke-width="1.5"/>
        <text x="12" y="17.5" text-anchor="middle" font-size="12" font-weight="bold" font-family="Arial,sans-serif" fill="#fff">!</text>
      </svg>`,
      className: '', iconSize: [24, 22], iconAnchor: [12, 11],
    });
  }

  if (type.includes('ROAD') || type.includes('CLOSED')) {
    // Quadrado azul com X
    return L.divIcon({
      html: `<svg width="22" height="22" viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="1" width="20" height="20" rx="5" fill="#3b82f6" stroke="rgba(255,255,255,.4)" stroke-width="1.5"/>
        <line x1="6" y1="6" x2="16" y2="16" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="16" y1="6" x2="6" y2="16" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
      </svg>`,
      className: '', iconSize: [22, 22], iconAnchor: [11, 11],
    });
  }

  // Genérico — círculo cinza com ponto
  return L.divIcon({
    html: `<svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
      <circle cx="9" cy="9" r="8" fill="#8b9099" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/>
      <circle cx="9" cy="9" r="3" fill="#fff" opacity=".8"/>
    </svg>`,
    className: '', iconSize: [18, 18], iconAnchor: [9, 9],
  });
}

// ── Ícone CEMADEN por nível de alerta ─────────────────────────────
function makeCemadenIcon(alertLevel, rainVal) {
  const col = alertLevel === 'RED'    ? '#ef4444'
             : alertLevel === 'ORANGE' ? '#f97316'
             : alertLevel === 'YELLOW' ? '#eab308'
             : '#14b8a6';
  const label = rainVal !== undefined && rainVal !== null ? String(Math.round(rainVal)) : 'mm';
  return L.divIcon({
    html: `<svg width="28" height="28" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">
      <rect x="1" y="1" width="26" height="26" rx="6" fill="${col}" stroke="rgba(255,255,255,.35)" stroke-width="1.5"/>
      <!-- nuvem + chuva -->
      <path d="M7 13a4 4 0 0 1 7.42-2.1A3 3 0 1 1 18 16H8a3 3 0 0 1-1-5.83" fill="none" stroke="#fff" stroke-width="1.3" opacity=".9"/>
      <line x1="9" y1="18" x2="9" y2="21" stroke="#fff" stroke-width="1.3" stroke-linecap="round" opacity=".85"/>
      <line x1="13" y1="18" x2="13" y2="21" stroke="#fff" stroke-width="1.3" stroke-linecap="round" opacity=".85"/>
      <line x1="17" y1="18" x2="17" y2="21" stroke="#fff" stroke-width="1.3" stroke-linecap="round" opacity=".85"/>
    </svg>`,
    className: '', iconSize: [28, 28], iconAnchor: [14, 14],
  });
}

// ── Render do mapa ─────────────────────────────────────────────────
function calcBounds(data) {
  const pts = [];
  (data.jams   || []).forEach(j => {
    if (j.line?.length > 0) j.line.forEach(p => pts.push([p.y ?? p[1], p.x ?? p[0]]));
    else if (j.lat && j.lng) pts.push([j.lat, j.lng]);
  });
  (data.alerts || []).forEach(a => { if (a.lat && a.lng) pts.push([a.lat, a.lng]); });
  (data.cemaden|| []).forEach(c => { if (c.lat && c.lng) pts.push([c.lat, c.lng]); });
  return pts.length > 0 ? L.latLngBounds(pts) : null;
}

function renderMap(data) {
  mapLayers.jams.clearLayers();
  mapLayers.alerts.clearLayers();
  mapLayers.cemaden.clearLayers();

  // Jams — polylines coloridas por nível
  (data.jams || []).forEach(j => {
    if (j.line?.length > 1) {
      const coords = j.line.map(p => [p.y ?? p[1], p.x ?? p[0]]);
      L.polyline(coords, { color: jamColor(j.level), weight: 4, opacity: .85 })
        .bindPopup(`<b>${j.street || 'Via'}</b><br>Nível ${j.level} · ${j.speed} km/h · ${Math.round(j.delay/60)} min atraso`)
        .addTo(mapLayers.jams);
    } else if (j.lat && j.lng) {
      L.circleMarker([j.lat, j.lng], { radius: 8, color: jamColor(j.level), fillOpacity: .7 })
        .bindPopup(`<b>${j.street || 'Via'}</b><br>Nível ${j.level}`)
        .addTo(mapLayers.jams);
    }
  });

  // Alertas — ícones SVG por tipo
  (data.alerts || []).forEach(a => {
    if (!a.lat || !a.lng) return;
    L.marker([a.lat, a.lng], { icon: makeAlertIcon(a.type) })
      .bindPopup(`<b>${a.type || 'Alerta'}</b>${a.subtype ? ' — ' + a.subtype : ''}<br>${a.street || ''} ${a.city || ''}`)
      .addTo(mapLayers.alerts);
  });

  // CEMADEN — ícone com símbolo de chuva, cor por nível
  (data.cemaden || []).forEach(c => {
    if (!c.lat || !c.lng) return;
    L.marker([c.lat, c.lng], { icon: makeCemadenIcon(c.alertLevel, c.rain) })
      .bindPopup(`<b>${c.station}</b><br>${c.city}<br>Chuva: ${c.rain} mm · ${c.alertLevel}`)
      .addTo(mapLayers.cemaden);
  });

  const jCount = (data.jams   || []).length;
  const aCount = (data.alerts || []).length;
  const cCount = (data.cemaden|| []).length;
  document.getElementById('map-info-text').textContent =
    `${jCount} jams · ${aCount} alertas · ${cCount} estações CEMADEN`;

  if (!mapFitted) {
    const bounds = calcBounds(data);
    if (bounds?.isValid()) { map.fitBounds(bounds, { padding: [40, 40], maxZoom: 14 }); mapFitted = true; }
  }
}

// ── KPIs ──────────────────────────────────────────────────────────
function levelClass(val, warn, crit) {
  if (val >= crit) return 'red';
  if (val >= warn) return 'orange';
  return 'green';
}
function setKpi(elId, value, colorClass) {
  const el = document.getElementById(elId);
  if (!el) return;
  el.textContent = value;
  el.className = 'kpi-value' + (colorClass ? ' val-' + colorClass : '');
}
function setCard(elId, colorClass) {
  const el = document.getElementById(elId);
  if (!el) return;
  el.className = 'kpi-card alert-' + (colorClass || 'green');
}
function fmtDelay(secs) {
  if (!secs) return '0';
  if (secs < 60) return secs + ' s';
  return Math.round(secs / 60) + ' min';
}
function fmtLen(m) {
  if (!m) return '0';
  if (m < 1000) return m + ' m';
  return (m / 1000).toFixed(1);
}
function renderKpis(k) {
  const jamCls = levelClass(k.liveJams, JAM_WARN, JAM_CRIT);
  setKpi('v-live-jams', k.liveJams ?? '—', jamCls);
  setCard('kpi-live-jams', jamCls);
  document.getElementById('s-live-jams').innerHTML = 'nível máx: <strong>' + (k.maxJamLevel ?? '—') + '</strong>';

  const spd = k.liveAvgSpeed ? Math.round(k.liveAvgSpeed) : 0;
  const spdCls = spd < 15 ? 'red' : spd < 30 ? 'orange' : 'green';
  const spdEl = document.getElementById('v-speed');
  if (spdEl) { spdEl.textContent = spd || '—'; spdEl.className = 'kpi-value' + (spd ? ' val-' + spdCls : ''); }
  setCard('kpi-speed', spdCls);

  const del = k.liveAvgDelay ?? 0;
  const delCls = levelClass(del, DELAY_WARN, DELAY_CRIT);
  setKpi('v-delay', fmtDelay(del), delCls);
  setCard('kpi-delay', delCls);

  const lenEl = document.getElementById('v-len');
  if (lenEl) lenEl.textContent = fmtLen(k.liveTotalLen);

  setKpi('v-alerts-hour', k.alertsHour ?? '—');
  document.getElementById('s-alerts24').textContent = (k.alerts24h ?? '—') + ' nas últimas 24h';

  const rain = k.rainLastHour;
  const rainCls = rain >= RAIN_CRIT ? 'red' : rain >= RAIN_WARN ? 'orange' : 'teal';
  const rainEl = document.getElementById('v-rain');
  if (rainEl) { rainEl.textContent = (rain !== null && rain !== undefined) ? rain : '—'; rainEl.className = 'kpi-value val-' + rainCls; }
  setCard('kpi-rain', rain >= RAIN_CRIT ? 'red' : rain >= RAIN_WARN ? 'orange' : 'teal');

  const ci = document.getElementById('v-cities'),
        li = document.getElementById('v-links'),
        ri = document.getElementById('v-routes');
  if (ci) ci.textContent = k.cities ?? '—';
  if (li) li.textContent = k.links  ?? '—';
  if (ri) ri.textContent = k.routes ?? '—';
}

// ── Feed ──────────────────────────────────────────────────────────
const ALERT_TYPES = {
  ACCIDENT:    { label: 'Acidente',        css: 'type-accident',    color: 'var(--red)'    },
  JAM:         { label: 'Engarrafamento',  css: 'type-jam',         color: 'var(--orange)' },
  HAZARD:      { label: 'Perigo',          css: 'type-hazard',      color: 'var(--yellow)' },
  ROAD_CLOSED: { label: 'Via fechada',     css: 'type-road-closed', color: 'var(--blue)'   },
};
function alertMeta(a) {
  const t = (a.type || '').toUpperCase();
  for (const [k, v] of Object.entries(ALERT_TYPES)) {
    if (t.includes(k)) return v;
  }
  return { label: a.type || 'Alerta', css: '', color: 'var(--muted)' };
}
function timeAgo(isoStr) {
  if (!isoStr) return '';
  const diff = Math.floor((Date.now() - new Date(isoStr)) / 1000);
  if (diff < 60)   return 'agora';
  if (diff < 3600) return Math.floor(diff / 60) + ' min atrás';
  return Math.floor(diff / 3600) + 'h atrás';
}
const CRITICAL_TYPES = ['ACCIDENT_MAJOR', 'ACCIDENT', 'ROAD_CLOSED'];
let prevAlertIds = new Set();

function renderFeed(alerts) {
  const list = document.getElementById('feed-list');
  document.getElementById('feed-count').textContent = alerts.length;
  let hasNewCritical = false;
  alerts.forEach(a => {
    if (!prevAlertIds.has(a.id) && CRITICAL_TYPES.some(t => (a.type || '').toUpperCase().includes(t))) hasNewCritical = true;
    prevAlertIds.add(a.id);
  });
  if (hasNewCritical) beep();

  if (alerts.length === 0) {
    list.innerHTML = `<div class="feed-empty">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      Nenhum evento recente
    </div>`;
    return;
  }

  list.innerHTML = alerts.map(a => {
    const meta  = alertMeta(a);
    const isCrit = CRITICAL_TYPES.some(t => (a.type || '').toUpperCase().includes(t));
    return `<div class="feed-item ${meta.css} ${isCrit ? 'feed-critical' : ''}">
      <div class="feed-item-top">
        <div class="feed-type-badge" style="color:${meta.color}">${meta.label}${a.subtype ? ' · ' + a.subtype : ''}</div>
        <div class="feed-time">${timeAgo(a.reportedAt)}</div>
      </div>
      <div class="feed-street">${a.street || 'Via não identificada'}</div>
      <div class="feed-meta">
        <span>${a.city || '—'}</span>
        <span class="feed-meta-sep">·</span>
        <span>conf. ${a.confidence ?? '?'}</span>
      </div>
    </div>`;
  }).join('');
}

// ── Sparklines ────────────────────────────────────────────────────
function drawSparkline(canvasId, values, color) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth || 180, H = canvas.offsetHeight || 22;
  canvas.width = W; canvas.height = H;
  ctx.clearRect(0, 0, W, H);
  if (!values || values.length < 2) return;
  const max  = Math.max(...values) || 1;
  const step = W / (values.length - 1);

  ctx.beginPath();
  values.forEach((v, i) => {
    const x = i * step, y = H - (v / max) * (H - 2) - 1;
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.lineTo((values.length - 1) * step, H);
  ctx.lineTo(0, H);
  ctx.closePath();
  ctx.fillStyle = color + '22';
  ctx.fill();

  ctx.beginPath();
  values.forEach((v, i) => {
    const x = i * step, y = H - (v / max) * (H - 2) - 1;
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.strokeStyle = color;
  ctx.lineWidth   = 1.5;
  ctx.lineJoin    = 'round';
  ctx.stroke();
}

// ── Polling ───────────────────────────────────────────────────────
async function poll() {
  try {
    const resp = await fetch(API_URL);
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const data = await resp.json();

    const pulse = document.getElementById('op-pulse');
    pulse.className = 'op-pulse ok';
    setTimeout(() => { pulse.className = 'op-pulse'; }, 1500);

    lastTs = new Date(data.ts);
    document.getElementById('op-ago').textContent =
      'atualizado ' + lastTs.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });

    ['waze','cemaden','api'].forEach(s => {
      const el = document.getElementById('pill-' + s);
      if (el) { el.className = 'source-pill ok'; }
    });

    renderKpis(data.kpis);
    renderMap(data);
    renderFeed(data.alerts || []);

    history.jams.push(data.kpis.liveJams ?? 0);
    history.alerts.push(data.kpis.alertsHour ?? 0);
    history.upd.push(1);
    if (history.jams.length   > 48) history.jams.shift();
    if (history.alerts.length > 48) history.alerts.shift();
    if (history.upd.length    > 48) history.upd.shift();

    drawSparkline('spark-jams',          history.jams,   '#f97316');
    drawSparkline('spark-alerts',        history.alerts, '#ef4444');
    drawSparkline('footer-spark-jams',   history.jams,   '#f97316');
    drawSparkline('footer-spark-alerts', history.alerts, '#ef4444');
    drawSparkline('footer-spark-upd',    history.upd,    '#22c55e');

  } catch (e) {
    document.getElementById('op-pulse').className = 'op-pulse err';
    document.getElementById('op-ago').textContent = 'erro na atualização';
    ['waze','cemaden','api'].forEach(s => {
      const el = document.getElementById('pill-' + s);
      if (el) el.className = 'source-pill err';
    });
    console.error('LiveSummary poll error:', e);
  }
}

poll();
setInterval(poll, POLL_MS);
</script>
