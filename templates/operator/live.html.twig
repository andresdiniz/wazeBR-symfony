<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Operador — {{ partnerName }}</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
/* ── Reset & tokens ───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; font-family: 'Inter', 'Segoe UI', sans-serif; background: #0d0e10; color: #e2e4e8; }
:root {
  --bg:        #0d0e10;
  --surface:   #14161a;
  --surface2:  #1c1f26;
  --surface3:  #22252e;
  --border:    rgba(255,255,255,.07);
  --border2:   rgba(255,255,255,.12);
  --text:      #e2e4e8;
  --muted:     #8b9099;
  --faint:     #464c57;
  --green:     #22c55e;
  --green-dim: rgba(34,197,94,.15);
  --yellow:    #eab308;
  --yellow-dim:rgba(234,179,8,.15);
  --orange:    #f97316;
  --orange-dim:rgba(249,115,22,.15);
  --red:       #ef4444;
  --red-dim:   rgba(239,68,68,.15);
  --blue:      #3b82f6;
  --blue-dim:  rgba(59,130,246,.15);
  --teal:      #14b8a6;
  --teal-dim:  rgba(20,184,166,.15);
  --radius:    8px;
  --radius-sm: 5px;
  --transition: 200ms cubic-bezier(.16,1,.3,1);
}

/* ── Layout principal ─────────────────────────────────────────── */
.op-shell {
  display: grid;
  grid-template-rows: 56px 1fr 52px;
  height: 100vh;
  width: 100vw;
}
.op-body {
  display: grid;
  grid-template-columns: 230px 1fr 296px;
  overflow: hidden;
  min-height: 0;
}

/* ── Header ───────────────────────────────────────────────────── */
.op-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 16px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  position: relative;
  z-index: 100;
}
.op-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 700;
  font-size: 15px;
  color: var(--teal);
  letter-spacing: .02em;
  flex-shrink: 0;
}
.op-logo-icon {
  width: 28px; height: 28px;
  background: var(--teal);
  border-radius: 7px;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}
.op-logo-icon svg { color: #0d0e10; }
.op-divider {
  width: 1px; height: 20px;
  background: var(--border2);
  flex-shrink: 0;
}
.op-city {
  font-size: 12px;
  color: var(--muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200px;
}
.op-spacer { flex: 1; }
.op-status-group {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 5px 10px;
}
.op-pulse {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--faint);
  transition: background .3s, box-shadow .3s;
  flex-shrink: 0;
}
.op-pulse.ok  {
  background: var(--green);
  box-shadow: 0 0 0 3px var(--green-dim);
  animation: pulse-ring 2s ease-in-out infinite;
}
.op-pulse.err { background: var(--red); box-shadow: 0 0 6px var(--red); }
@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
  50%       { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
}
.op-ago {
  font-size: 11px;
  color: var(--muted);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}
.op-clock {
  font-size: 20px;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  letter-spacing: .04em;
  color: var(--text);
  flex-shrink: 0;
}
.op-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 5px 10px;
  font-size: 12px;
  color: var(--muted);
  cursor: pointer;
  transition: color var(--transition), border-color var(--transition), background var(--transition);
  white-space: nowrap;
  flex-shrink: 0;
  text-decoration: none;
}
.op-btn:hover { color: var(--text); border-color: var(--border2); background: var(--surface3); }
.op-btn svg { flex-shrink: 0; }

.op-btn-back {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(20,184,166,.08);
  border: 1px solid rgba(20,184,166,.25);
  border-radius: var(--radius-sm);
  padding: 5px 11px;
  font-size: 12px;
  font-weight: 600;
  color: var(--teal);
  cursor: pointer;
  transition: color var(--transition), border-color var(--transition), background var(--transition);
  white-space: nowrap;
  flex-shrink: 0;
  text-decoration: none;
}
.op-btn-back:hover {
  background: rgba(20,184,166,.18);
  border-color: rgba(20,184,166,.5);
  color: #5eead4;
}
.op-btn-back svg { flex-shrink: 0; }

.op-wakelock-indicator {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: var(--faint);
  white-space: nowrap;
  flex-shrink: 0;
}
.op-wakelock-indicator.active { color: var(--teal); }

/* ── KPI Sidebar ──────────────────────────────────────────────── */
.op-kpis {
  background: var(--surface);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  overflow-x: hidden;
  padding: 10px 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.op-kpis::-webkit-scrollbar { width: 3px; }
.op-kpis::-webkit-scrollbar-track { background: transparent; }
.op-kpis::-webkit-scrollbar-thumb { background: var(--faint); border-radius: 4px; }

.kpi-section-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--faint);
  padding: 8px 6px 2px;
  border-top: 1px solid var(--border);
  margin-top: 2px;
}
.kpi-section-label:first-child { border-top: none; margin-top: 0; padding-top: 2px; }
.kpi-section-label svg { flex-shrink: 0; }

.kpi-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 10px 11px;
  position: relative;
  overflow: hidden;
  transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
  cursor: default;
}
.kpi-card:hover { border-color: var(--border2); background: var(--surface3); }

.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  border-radius: var(--radius) var(--radius) 0 0;
  background: transparent;
  transition: background var(--transition);
}
.kpi-card.alert-red::before    { background: var(--red); }
.kpi-card.alert-orange::before { background: var(--orange); }
.kpi-card.alert-yellow::before { background: var(--yellow); }
.kpi-card.alert-green::before  { background: var(--green); }
.kpi-card.alert-teal::before   { background: var(--teal); }

/* ── KPI glow states (active alerts) ─────────────────────────── */
.kpi-card.alert-red    {
  background: color-mix(in srgb, var(--surface2), rgba(239,68,68,.10));
  box-shadow: 0 0 0 1px rgba(239,68,68,.22), inset 0 0 20px rgba(239,68,68,.04);
}
.kpi-card.alert-orange {
  background: color-mix(in srgb, var(--surface2), rgba(249,115,22,.08));
  box-shadow: 0 0 0 1px rgba(249,115,22,.18);
}
.kpi-card.alert-green  { background: color-mix(in srgb, var(--surface2), rgba(34,197,94,.04)); }
.kpi-card.alert-teal   { background: color-mix(in srgb, var(--surface2), rgba(20,184,166,.04)); }

.kpi-header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}
.kpi-icon {
  width: 26px; height: 26px;
  border-radius: 6px;
  background: var(--surface3);
  display: grid;
  place-items: center;
  flex-shrink: 0;
  transition: background var(--transition);
}
.kpi-icon svg {
  width: 13px; height: 13px;
  display: block;
}
.kpi-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--muted);
  line-height: 1.2;
}

.kpi-body {
  display: flex;
  align-items: baseline;
  gap: 4px;
}
.kpi-value {
  font-size: 26px;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  color: var(--text);
  transition: color var(--transition);
  letter-spacing: -.02em;
}
.kpi-unit {
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  line-height: 1;
}
.kpi-sub {
  font-size: 10px;
  color: var(--faint);
  margin-top: 5px;
  line-height: 1.3;
}
.kpi-bar-wrap {
  height: 3px;
  background: var(--surface3);
  border-radius: 2px;
  margin-top: 7px;
  overflow: hidden;
}
.kpi-bar {
  height: 100%;
  border-radius: 2px;
  background: var(--teal);
  transition: width .6s cubic-bezier(.16,1,.3,1);
}
.kpi-bar.red    { background: var(--red);    }
.kpi-bar.orange { background: var(--orange); }
.kpi-bar.yellow { background: var(--yellow); }
.kpi-bar.green  { background: var(--green);  }
.kpi-bar.teal   { background: var(--teal);   }

/* ── Mapa ─────────────────────────────────────────────────────── */
.op-map-container {
  position: relative;
  overflow: hidden;
  min-height: 0;
}
#op-map {
  width: 100%;
  height: 100%;
  filter: contrast(1.05) brightness(0.97);
}
.map-overlay-info {
  position: absolute;
  bottom: 12px;
  left: 12px;
  background: rgba(13,14,16,.88);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 5px 10px;
  font-size: 11px;
  color: var(--muted);
  pointer-events: none;
  z-index: 500;
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  gap: 8px;
}
.map-overlay-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Legenda do mapa — canto inferior direito ─────────────────── */
.map-legend {
  position: absolute;
  bottom: 48px;
  right: 12px;
  background: rgba(13,14,16,.92);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 7px 9px;
  z-index: 500;
  backdrop-filter: blur(8px);
  display: flex;
  flex-direction: column;
  gap: 4px;
  pointer-events: auto;
  min-width: 148px;
  box-shadow: 0 4px 16px rgba(0,0,0,.5);
}
.map-legend.collapsed .map-legend-body { display: none; }
.map-legend-toggle {
  position: absolute;
  top: 5px; right: 7px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--faint);
  font-size: 13px;
  font-weight: 700;
  line-height: 1;
  padding: 0 2px;
  transition: color var(--transition);
}
.map-legend-toggle:hover { color: var(--muted); }
.map-legend-title {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--faint);
  margin-bottom: 2px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 3px;
  padding-right: 18px;
}
.map-legend-body {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.map-legend-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.map-legend-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.map-legend-line {
  width: 22px; height: 4px;
  border-radius: 2px;
  flex-shrink: 0;
}
.map-legend-emoji {
  font-size: 14px;
  line-height: 1;
  width: 18px;
  text-align: center;
  flex-shrink: 0;
}
.map-legend-label {
  font-size: 9px;
  color: var(--muted);
  white-space: nowrap;
}
.legend-sep {
  height: 1px;
  background: var(--border);
  margin: 2px 0;
}

/* ── Ícones emoji do mapa (divIcon) ─────────────────────────── */
.map-emoji-marker {
  display: flex;
  align-items: center;
  justify-content: center;
  font-style: normal;
  line-height: 1;
  filter: drop-shadow(0 1px 3px rgba(0,0,0,.7));
}

/* ── Feed de eventos ──────────────────────────────────────────── */
.op-feed {
  background: var(--surface);
  border-left: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  min-height: 0;
}
.op-feed::-webkit-scrollbar { width: 3px; }
.op-feed::-webkit-scrollbar-track { background: transparent; }
.op-feed::-webkit-scrollbar-thumb { background: var(--faint); border-radius: 4px; }

.feed-header {
  position: sticky;
  top: 0;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 10px 12px 8px;
  z-index: 10;
}
.feed-title {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--faint);
  display: flex;
  align-items: center;
  gap: 6px;
}
.feed-count-badge {
  background: var(--surface3);
  border: 1px solid var(--border2);
  color: var(--muted);
  font-size: 10px;
  font-weight: 600;
  padding: 1px 6px;
  border-radius: 20px;
  font-variant-numeric: tabular-nums;
}
.feed-list {
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  flex: 1;
}
.feed-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 8px 12px;
  border-bottom: 1px solid var(--border);
  cursor: default;
  transition: background var(--transition);
  animation: feed-in .25s cubic-bezier(.16,1,.3,1) both;
}
@keyframes feed-in {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.feed-item:hover { background: var(--surface2); }
.feed-item-header {
  display: flex;
  align-items: center;
  gap: 6px;
}
.feed-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  padding: 2px 6px;
  border-radius: 4px;
  flex-shrink: 0;
}
.feed-badge-jam    { background: rgba(239,68,68,.15);  color: #ef4444; }
.feed-badge-alert  { background: rgba(234,179,8,.15);  color: #eab308; }
.feed-badge-hazard { background: rgba(249,115,22,.15); color: #f97316; }
.feed-badge-closed { background: rgba(239,68,68,.2);   color: #f87171; }
.feed-badge-other  { background: var(--surface3);       color: var(--muted); }
.feed-time {
  font-size: 9px;
  color: var(--faint);
  font-variant-numeric: tabular-nums;
  margin-left: auto;
  flex-shrink: 0;
}
.feed-street {
  font-size: 12px;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.feed-city {
  font-size: 10px;
  color: var(--faint);
}
.feed-conf {
  font-size: 9px;
  color: var(--faint);
}

/* ── Bottom status bar ────────────────────────────────────────── */
.op-bar {
  background: var(--surface);
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 16px;
  font-size: 11px;
  color: var(--faint);
  overflow: hidden;
}
.op-bar-item {
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
  flex-shrink: 0;
}
.op-bar-item b { color: var(--muted); font-variant-numeric: tabular-nums; }
.op-bar-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  flex-shrink: 0;
}
.op-bar-spacer { flex: 1; }
.op-bar-sources {
  display: flex;
  align-items: center;
  gap: 8px;
}
.op-bar-src {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 4px;
  border: 1px solid var(--border);
  color: var(--faint);
  transition: border-color var(--transition), color var(--transition);
}
.op-bar-src.on  { border-color: rgba(20,184,166,.3); color: var(--teal); }
.op-bar-src.off { opacity: .4; }

/* ── Leaflet overrides ────────────────────────────────────────── */
.leaflet-pane,
.leaflet-tile,
.leaflet-marker-icon,
.leaflet-marker-shadow,
.leaflet-tile-container,
.leaflet-pane > svg,
.leaflet-pane > canvas,
.leaflet-zoom-box,
.leaflet-image-layer,
.leaflet-layer { position: absolute; left: 0; top: 0; }
.leaflet-container { overflow: hidden; }
.leaflet-tile { user-select: none; -webkit-user-drag: none; display: block; }
.leaflet-tile-loaded { visibility: inherit; }
.leaflet-zoom-animated { -webkit-transform-origin: 0 0; transform-origin: 0 0; }
.leaflet-pan-anim .leaflet-tile,
.leaflet-zoom-anim .leaflet-zoom-animated { will-change: transform; }
.leaflet-zoom-anim .leaflet-zoom-hide { visibility: hidden; }
.leaflet-interactive { cursor: pointer; }
.leaflet-grab { cursor: -webkit-grab; cursor:    grab; }
.leaflet-crosshair,.leaflet-crosshair .leaflet-interactive { cursor: crosshair; }
.leaflet-popup-pane,.leaflet-control { cursor: auto; }
.leaflet-dragging .leaflet-grab,
.leaflet-dragging .leaflet-grab .leaflet-interactive,
.leaflet-dragging .leaflet-marker-draggable { cursor: move; cursor: -webkit-grabbing; cursor: grabbing; }
.leaflet-marker-icon,.leaflet-marker-shadow,.leaflet-image-layer,
.leaflet-pane > svg path,.leaflet-tile-container { pointer-events: none; }
.leaflet-marker-icon.leaflet-interactive,.leaflet-image-layer.leaflet-interactive,
.leaflet-pane > svg path.leaflet-interactive,svg.leaflet-image-layer.leaflet-interactive path { pointer-events: visiblePainted; pointer-events: auto; }
.leaflet-vml-shape { width: 1px; height: 1px; }
.lvml { behavior:url(#default#VML); display:inline-block; position:absolute; }
.leaflet-control { position: relative; z-index: 800; pointer-events: visiblePainted; pointer-events: auto; float: left; clear: both; }
.leaflet-top,.leaflet-bottom { position: absolute; z-index: 1000; pointer-events: none; }
.leaflet-top    { top: 0;    }
.leaflet-right  { right: 0;  }
.leaflet-bottom { bottom: 0; }
.leaflet-left   { left: 0;   }
.leaflet-control { float: left;  margin: 0 0 8px 8px; }
.leaflet-right .leaflet-control  { float: right; margin: 0 8px 8px 0; }
.leaflet-top .leaflet-control    { margin-top: 8px; }
.leaflet-bottom .leaflet-control { margin-bottom: 8px; }

.leaflet-popup {
  position: absolute;
  text-align: center;
  margin-bottom: 20px;
}
.leaflet-popup-content-wrapper {
  background: #1c1f26;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,.5);
}
.leaflet-popup-tip { background: #1c1f26; }
.leaflet-popup-content { margin: 8px 12px; color: #e2e4e8; font-size: 12px; }
.leaflet-control-zoom {
  border: 1px solid var(--border2) !important;
  border-radius: var(--radius) !important;
  overflow: hidden;
  margin-bottom: 12px !important;
  margin-right: 12px !important;
}
.leaflet-control-zoom a {
  background: var(--surface2) !important;
  color: var(--muted) !important;
  border-bottom: 1px solid var(--border) !important;
}
.leaflet-control-zoom a:hover { background: var(--surface3) !important; color: var(--text) !important; }

/* ── Scrollbar global ─────────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--faint); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }

/* ── Telas grandes / TV ───────────────────────────────────────── */
@media (min-width: 2560px) {
  .op-body { grid-template-columns: 290px 1fr 380px; }
  .kpi-value { font-size: 34px; }
  .op-clock  { font-size: 26px; }
  .feed-street { font-size: 14px; }
  .op-shell { grid-template-rows: 64px 1fr 56px; }
  .kpi-icon { width: 32px; height: 32px; border-radius: 8px; }
  .kpi-icon svg { width: 16px; height: 16px; }
}
@media (min-width: 3840px) {
  .op-body { grid-template-columns: 360px 1fr 480px; }
  .kpi-value { font-size: 48px; }
  .kpi-label, .kpi-sub { font-size: 13px; }
  .op-clock  { font-size: 36px; }
}
</style>
</head>
<body>
<div class="op-shell">

  <!-- ═══ HEADER ════════════════════════════════════════════ -->
  <header class="op-header">
    <div class="op-logo">
      <div class="op-logo-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="3 11 22 2 13 21 11 13 3 11"/>
        </svg>
      </div>
      WazeBR
    </div>
    <div class="op-divider"></div>
    <span class="op-city">{{ partnerName }}</span>
    <div class="op-spacer"></div>
    <div class="op-status-group">
      <div class="op-pulse" id="op-pulse"></div>
      <span class="op-ago" id="op-ago">—</span>
    </div>
    <span class="op-clock" id="op-clock">--:--:--</span>
    <div class="op-wakelock-indicator" id="wakelockIndicator" title="Wake Lock — mantém a tela ligada">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
      <span id="wakelockLabel">tela</span>
    </div>
    <a href="{{ path('dashboard_index') }}" class="op-btn-back">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Dashboard
    </a>
    <button class="op-btn" id="btnFullscreen" title="Fullscreen">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
      Fullscreen
    </button>
    <button class="op-btn" id="btnSound" title="Alertas sonoros">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="soundIcon"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
      Som
    </button>
  </header>

  <!-- ═══ BODY ══════════════════════════════════════════════ -->
  <div class="op-body">

    <!-- ─── KPI Sidebar ──────────────────────────── -->
    <aside class="op-kpis" id="op-kpis">
      <!-- KPIs are injected by JS -->
    </aside>

    <!-- ─── Mapa ─────────────────────────────────── -->
    <div class="op-map-container">
      <div id="op-map"></div>

      <!-- Info bar bottom-left -->
      <div class="map-overlay-info" id="mapOverlayInfo">
        <div class="map-overlay-dot" style="background:#ef4444" id="dotJams"></div>
        <span id="lblJams">0 jams</span>
        <div class="map-overlay-dot" style="background:#eab308" id="dotAlerts"></div>
        <span id="lblAlerts">0 alertas</span>
        <div class="map-overlay-dot" style="background:#3b82f6" id="dotCemaden"></div>
        <span id="lblCemaden">0 estações CEMADEN</span>
      </div>

      <!-- Legenda — canto inferior direito, acima do zoom -->
      <div class="map-legend" id="map-legend">
        <div class="map-legend-title">Legenda
          <button class="map-legend-toggle" id="legendToggle" title="Minimizar legenda">−</button>
        </div>
        <div class="map-legend-body">
        <div class="map-legend-row">
          <span class="map-legend-emoji">🚨</span>
          <span class="map-legend-label">Acidente</span>
        </div>
        <div class="map-legend-row">
          <span class="map-legend-emoji">🚗</span>
          <span class="map-legend-label">Engarrafamento</span>
        </div>
        <div class="map-legend-row">
          <span class="map-legend-emoji">⚠️</span>
          <span class="map-legend-label">Perigo / Obra</span>
        </div>
        <div class="map-legend-row">
          <span class="map-legend-emoji">🚫</span>
          <span class="map-legend-label">Via fechada</span>
        </div>
        <div class="legend-sep"></div>
        <div class="map-legend-row">
          <div class="map-legend-line" style="background:#ef4444"></div>
          <span class="map-legend-label">Jam crítico (5+)</span>
