<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Operador — {{ partnerName }}</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
/* ── Reset & tokens ───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; font-family: 'Inter', 'Segoe UI', sans-serif; background: #0d0e10; color: #e2e4e8; }
:root {
  --bg:        #0d0e10;
  --surface:   #14161a;
  --surface2:  #1c1f26;
  --surface3:  #22252e;
  --border:    rgba(255,255,255,.07);
  --border2:   rgba(255,255,255,.12);
  --text:      #e2e4e8;
  --muted:     #8b9099;
  --faint:     #464c57;
  --green:     #22c55e;
  --green-dim: rgba(34,197,94,.15);
  --yellow:    #eab308;
  --yellow-dim:rgba(234,179,8,.15);
  --orange:    #f97316;
  --orange-dim:rgba(249,115,22,.15);
  --red:       #ef4444;
  --red-dim:   rgba(239,68,68,.15);
  --blue:      #3b82f6;
  --blue-dim:  rgba(59,130,246,.15);
  --teal:      #14b8a6;
  --teal-dim:  rgba(20,184,166,.15);
  --radius:    8px;
  --radius-sm: 5px;
  --transition: 200ms cubic-bezier(.16,1,.3,1);
}

/* ── Layout principal ─────────────────────────────────────────── */
.op-shell {
  display: grid;
  grid-template-rows: 56px 1fr 52px;
  height: 100vh;
  width: 100vw;
}
.op-body {
  display: grid;
  grid-template-columns: 230px 1fr 296px;
  overflow: hidden;
  min-height: 0;
}

/* ── Header ───────────────────────────────────────────────────── */
.op-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 16px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  position: relative;
  z-index: 100;
}
.op-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 700;
  font-size: 15px;
  color: var(--teal);
  letter-spacing: .02em;
  flex-shrink: 0;
}
.op-logo-icon {
  width: 28px; height: 28px;
  background: var(--teal);
  border-radius: 7px;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}
.op-logo-icon svg { color: #0d0e10; }
.op-divider {
  width: 1px; height: 20px;
  background: var(--border2);
  flex-shrink: 0;
}
.op-city {
  font-size: 12px;
  color: var(--muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200px;
}
.op-spacer { flex: 1; }
.op-status-group {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 5px 10px;
}
.op-pulse {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--faint);
  transition: background .3s, box-shadow .3s;
  flex-shrink: 0;
}
.op-pulse.ok  {
  background: var(--green);
  box-shadow: 0 0 0 3px var(--green-dim);
  animation: pulse-ring 2s ease-in-out infinite;
}
.op-pulse.err { background: var(--red); box-shadow: 0 0 6px var(--red); }
@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
  50%       { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
}
.op-ago {
  font-size: 11px;
  color: var(--muted);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}
.op-clock {
  font-size: 20px;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  letter-spacing: .04em;
  color: var(--text);
  flex-shrink: 0;
}
.op-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 5px 10px;
  font-size: 12px;
  color: var(--muted);
  cursor: pointer;
  transition: color var(--transition), border-color var(--transition), background var(--transition);
  white-space: nowrap;
  flex-shrink: 0;
  text-decoration: none;
}
.op-btn:hover { color: var(--text); border-color: var(--border2); background: var(--surface3); }
.op-btn svg { flex-shrink: 0; }

/* Botão voltar — destaque sutil em teal */
.op-btn-back {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(20,184,166,.08);
  border: 1px solid rgba(20,184,166,.25);
  border-radius: var(--radius-sm);
  padding: 5px 11px;
  font-size: 12px;
  font-weight: 600;
  color: var(--teal);
  cursor: pointer;
  transition: color var(--transition), border-color var(--transition), background var(--transition);
  white-space: nowrap;
  flex-shrink: 0;
  text-decoration: none;
}
.op-btn-back:hover {
  background: rgba(20,184,166,.18);
  border-color: rgba(20,184,166,.5);
  color: #5eead4;
}
.op-btn-back svg { flex-shrink: 0; }

.op-wakelock-indicator {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: var(--faint);
  white-space: nowrap;
  flex-shrink: 0;
}
.op-wakelock-indicator.active { color: var(--teal); }

/* ── KPI Sidebar ──────────────────────────────────────────────── */
.op-kpis {
  background: var(--surface);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  overflow-x: hidden;
  padding: 10px 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.op-kpis::-webkit-scrollbar { width: 3px; }
.op-kpis::-webkit-scrollbar-track { background: transparent; }
.op-kpis::-webkit-scrollbar-thumb { background: var(--faint); border-radius: 4px; }

.kpi-section-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--faint);
  padding: 8px 6px 2px;
  border-top: 1px solid var(--border);
  margin-top: 2px;
}
.kpi-section-label:first-child { border-top: none; margin-top: 0; padding-top: 2px; }
.kpi-section-label svg { flex-shrink: 0; }

.kpi-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 10px 11px;
  position: relative;
  overflow: hidden;
  transition: border-color var(--transition), background var(--transition);
  cursor: default;
}
.kpi-card:hover { border-color: var(--border2); background: var(--surface3); }

.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  border-radius: var(--radius) var(--radius) 0 0;
  background: transparent;
  transition: background var(--transition);
}
.kpi-card.alert-red::before    { background: var(--red); }
.kpi-card.alert-orange::before { background: var(--orange); }
.kpi-card.alert-yellow::before { background: var(--yellow); }
.kpi-card.alert-green::before  { background: var(--green); }
.kpi-card.alert-teal::before   { background: var(--teal); }

.kpi-card.alert-red    { background: color-mix(in srgb, var(--surface2), rgba(239,68,68,.06)); }
.kpi-card.alert-orange { background: color-mix(in srgb, var(--surface2), rgba(249,115,22,.06)); }
.kpi-card.alert-green  { background: color-mix(in srgb, var(--surface2), rgba(34,197,94,.04)); }
.kpi-card.alert-teal   { background: color-mix(in srgb, var(--surface2), rgba(20,184,166,.04)); }

.kpi-header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}
.kpi-icon {
  width: 26px; height: 26px;
  border-radius: 6px;
  background: var(--surface3);
  display: grid;
  place-items: center;
  flex-shrink: 0;
  transition: background var(--transition);
}
.kpi-icon svg {
  width: 13px; height: 13px;
  display: block;
}
.kpi-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--muted);
  line-height: 1.2;
}

.kpi-body {
  display: flex;
  align-items: baseline;
  gap: 4px;
}
.kpi-value {
  font-size: 26px;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  color: var(--text);
  transition: color var(--transition);
  letter-spacing: -.02em;
}
.kpi-unit {
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  line-height: 1;
}
.kpi-value.val-red    { color: var(--red); }
.kpi-value.val-orange { color: var(--orange); }
.kpi-value.val-yellow { color: var(--yellow); }
.kpi-value.val-green  { color: var(--green); }
.kpi-value.val-teal   { color: var(--teal); }

.kpi-sub {
  font-size: 10px;
  color: var(--muted);
  margin-top: 4px;
  line-height: 1.3;
}
.kpi-sub strong { color: var(--text); font-weight: 600; }

.kpi-spark {
  width: 100%;
  height: 22px;
  margin-top: 7px;
  display: block;
}

.kpi-card.alert-red    .kpi-icon { background: var(--red-dim); }
.kpi-card.alert-orange .kpi-icon { background: var(--orange-dim); }
.kpi-card.alert-yellow .kpi-icon { background: var(--yellow-dim); }
.kpi-card.alert-green  .kpi-icon { background: var(--green-dim); }
.kpi-card.alert-teal   .kpi-icon { background: var(--teal-dim); }

.kpi-card.alert-red    .kpi-icon svg { color: var(--red); }
.kpi-card.alert-orange .kpi-icon svg { color: var(--orange); }
.kpi-card.alert-yellow .kpi-icon svg { color: var(--yellow); }
.kpi-card.alert-green  .kpi-icon svg { color: var(--green); }
.kpi-card.alert-teal   .kpi-icon svg { color: var(--teal); }

.kpi-infra-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
  margin-top: 2px;
}
.kpi-infra-item {
  flex: 1;
  text-align: center;
  background: var(--surface3);
  border-radius: var(--radius-sm);
  padding: 5px 4px;
}
.kpi-infra-val {
  font-size: 17px;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--text);
  line-height: 1;
}
.kpi-infra-key {
  font-size: 8.5px;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--faint);
  margin-top: 2px;
}

/* ── Card estação CEMADEN ────────────────────────────────────── */
.cemaden-station-name {
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
}
.cemaden-station-city {
  font-size: 10px;
  color: var(--muted);
  margin-bottom: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cemaden-level-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}
.cemaden-level-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  border-radius: 20px;
  padding: 3px 8px;
  background: var(--surface3);
  color: var(--muted);
  flex-shrink: 0;
}
.cemaden-level-badge.lvl-normal  { background: var(--teal-dim);   color: var(--teal); }
.cemaden-level-badge.lvl-atencao { background: var(--yellow-dim); color: var(--yellow); }
.cemaden-level-badge.lvl-alerta  { background: var(--orange-dim); color: var(--orange); }
.cemaden-level-badge.lvl-critico { background: var(--red-dim);    color: var(--red); }

/* Barra de nível de cota */
.cemaden-quota-wrap {
  margin-top: 4px;
}
.cemaden-quota-label {
  display: flex;
  justify-content: space-between;
  font-size: 9px;
  color: var(--muted);
  margin-bottom: 3px;
}
.cemaden-quota-label span:last-child {
  font-weight: 700;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.cemaden-quota-track {
  width: 100%;
  height: 6px;
  background: var(--surface3);
  border-radius: 3px;
  overflow: hidden;
  position: relative;
}
.cemaden-quota-fill {
  height: 100%;
  border-radius: 3px;
  transition: width .5s ease, background .3s;
  min-width: 3px;
}
/* Marcadores de cota de alerta e transbordamento */
.cemaden-quota-markers {
  position: relative;
  height: 10px;
  margin-top: 2px;
}
.cemaden-quota-marker {
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  font-size: 8px;
  white-space: nowrap;
}
.cemaden-quota-marker::before {
  content: '';
  display: block;
  width: 1px;
  height: 5px;
  margin: 0 auto 1px;
}
.cemaden-quota-marker.mk-alerta {
  color: var(--yellow);
}
.cemaden-quota-marker.mk-alerta::before { background: var(--yellow); }
.cemaden-quota-marker.mk-transbordamento {
  color: var(--red);
}
.cemaden-quota-marker.mk-transbordamento::before { background: var(--red); }

.cemaden-rain-row {
  display: flex;
  gap: 5px;
  margin-top: 6px;
}
.cemaden-rain-item {
  flex: 1;
  background: var(--surface3);
  border-radius: var(--radius-sm);
  padding: 5px 4px;
  text-align: center;
}
.cemaden-rain-val {
  font-size: 14px;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--text);
  line-height: 1;
}
.cemaden-rain-key {
  font-size: 8px;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--faint);
  margin-top: 2px;
}

/* ── Mapa ─────────────────────────────────────────────────────── */
.op-map-container {
  position: relative;
  overflow: hidden;
  min-height: 0;
}
#op-map {
  width: 100%;
  height: 100%;
}
.map-overlay-info {
  position: absolute;
  bottom: 12px;
  left: 12px;
  background: rgba(13,14,16,.88);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 5px 10px;
  font-size: 11px;
  color: var(--muted);
  pointer-events: none;
  z-index: 500;
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  gap: 8px;
}
.map-overlay-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Legenda do mapa — só ícones ────────────────────────────── */
.map-legend {
  position: absolute;
  top: 12px;
  right: 12px;
  background: rgba(13,14,16,.9);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 7px 9px;
  z-index: 500;
  backdrop-filter: blur(6px);
  display: flex;
  flex-direction: column;
  gap: 4px;
  pointer-events: none;
}
.map-legend-title {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--faint);
  margin-bottom: 2px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 3px;
}
/* Grupos de ícones numa linha */
.map-legend-group {
  display: flex;
  gap: 5px;
  align-items: center;
}
/* Cada célula de ícone com tooltip via title */
.map-legend-cell {
  width: 26px; height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  line-height: 1;
  cursor: default;
}
.legend-sep {
  height: 1px;
  background: var(--border);
  margin: 2px 0;
}
/* Linha de jams: amostras coloridas */
.map-legend-jams {
  display: flex;
  gap: 5px;
  align-items: center;
}
.legend-jam-line {
  width: 24px; height: 4px;
  border-radius: 2px;
  flex-shrink: 0;
  cursor: default;
}

/* ── Ícones emoji do mapa (divIcon) ─────────────────────────── */
.map-emoji-marker {
  display: flex;
  align-items: center;
  justify-content: center;
  font-style: normal;
  line-height: 1;
  filter: drop-shadow(0 1px 3px rgba(0,0,0,.7));
}

/* ── Feed de eventos ──────────────────────────────────────────── */
.op-feed {
  background: var(--surface);
  border-left: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  min-height: 0;
}
.op-feed::-webkit-scrollbar { width: 3px; }
.op-feed::-webkit-scrollbar-track { background: transparent; }
.op-feed::-webkit-scrollbar-thumb { background: var(--faint); border-radius: 4px; }

.feed-header {
  position: sticky;
  top: 0;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 10px 12px;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.feed-header-title {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
}
.feed-header-title svg { color: var(--faint); }
#feed-count {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2px 8px;
  font-size: 10px;
  font-weight: 600;
  color: var(--teal);
  font-variant-numeric: tabular-nums;
}

.feed-list { flex: 1; padding: 8px; display: flex; flex-direction: column; gap: 5px; }

.feed-item {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-left: 3px solid var(--faint);
  border-radius: var(--radius);
  padding: 9px 10px;
  animation: slideIn .2s ease;
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition), transform var(--transition);
}
.feed-item:hover { background: var(--surface3); transform: translateX(2px); }
.feed-item.type-accident    { border-left-color: var(--red); }
.feed-item.type-jam         { border-left-color: var(--orange); }
.feed-item.type-hazard      { border-left-color: var(--yellow); }
.feed-item.type-road-closed { border-left-color: var(--blue); }
.feed-item.type-cemaden     { border-left-color: var(--teal); }

.feed-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  margin-bottom: 3px;
}
.feed-type-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
}
.feed-time {
  font-size: 9px;
  color: var(--faint);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}
.feed-street { font-size: 12px; font-weight: 600; color: var(--text); line-height: 1.3; }
.feed-meta   { font-size: 10px; color: var(--muted); margin-top: 2px; display: flex; align-items: center; gap: 4px; }
.feed-meta-sep { color: var(--faint); }
.feed-critical { background: rgba(239,68,68,.07); }

.feed-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 40px 16px;
  color: var(--faint);
  font-size: 12px;
  text-align: center;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: none; }
}

/* ── Barra inferior ───────────────────────────────────────────── */
.op-footer {
  background: var(--surface);
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 8px;
  overflow: hidden;
}
.footer-block {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5px 12px;
  border-right: 1px solid var(--border);
  min-width: 0;
}
.footer-block:last-child { border-right: none; }
.footer-label {
  font-size: 8.5px;
  color: var(--faint);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: 2px;
  white-space: nowrap;
}
.footer-spark { display: block; }
.footer-sources {
  display: flex;
  gap: 12px;
  padding: 0 12px;
  align-items: center;
  flex-shrink: 0;
  margin-left: auto;
}
.source-pill {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  color: var(--muted);
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 3px 8px;
  transition: border-color var(--transition);
}
.source-pill.ok  { border-color: rgba(34,197,94,.3); color: var(--green); }
.source-pill.err { border-color: rgba(239,68,68,.3); color: var(--red); }
.source-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--faint);
  flex-shrink: 0;
  transition: background var(--transition);
}
.source-pill.ok  .source-dot { background: var(--green); }
.source-pill.err .source-dot { background: var(--red); }

/* ── Leaflet custom ───────────────────────────────────────────── */
.leaflet-container { background: #1a1d22; }
.leaflet-popup-content-wrapper {
  background: #1c1f26;
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,.5);
}
.leaflet-popup-tip { background: #1c1f26; }
.leaflet-popup-content { margin: 8px 12px; color: #e2e4e8; font-size: 12px; }
.leaflet-control-zoom {
  border: 1px solid var(--border2) !important;
  border-radius: var(--radius) !important;
  overflow: hidden;
}
.leaflet-control-zoom a {
  background: var(--surface2) !important;
  color: var(--muted) !important;
  border-bottom: 1px solid var(--border) !important;
}
.leaflet-control-zoom a:hover { background: var(--surface3) !important; color: var(--text) !important; }

/* ── Scrollbar global ─────────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--faint); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }

/* ── Telas grandes / TV ───────────────────────────────────────── */
@media (min-width: 2560px) {
  .op-body { grid-template-columns: 290px 1fr 380px; }
  .kpi-value { font-size: 34px; }
  .op-clock  { font-size: 26px; }
  .feed-street { font-size: 14px; }
  .op-shell { grid-template-rows: 64px 1fr 56px; }
  .kpi-icon { width: 32px; height: 32px; border-radius: 8px; }
  .kpi-icon svg { width: 16px; height: 16px; }
}
@media (min-width: 3840px) {
  .op-body { grid-template-columns: 360px 1fr 480px; }
  .kpi-value { font-size: 48px; }
  .kpi-label, .kpi-sub { font-size: 13px; }
  .op-clock  { font-size: 36px; }
}
</style>
</head>
