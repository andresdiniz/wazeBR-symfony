{% extends 'base.html.twig' %}

{% block title %}Configurações — {{ partner.name }}{% endblock %}

{% block content %}
<div style="max-width:var(--content-narrow)">

  <div style="margin-bottom:var(--space-8)">
    <h1 class="page-title" style="margin-bottom:var(--space-1)">Configurações</h1>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted)">{{ partner.name }}</p>
  </div>

  {% for flash in app.flashes('success') %}
    <div style="background:oklch(from var(--color-success) l c h / .1);border:1px solid oklch(from var(--color-success) l c h / .25);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-success)">
      {{ flash }}
    </div>
  {% endfor %}
  {% for flash in app.flashes('error') %}
    <div style="background:oklch(from var(--color-error) l c h / .1);border:1px solid oklch(from var(--color-error) l c h / .25);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-error)">
      {{ flash }}
    </div>
  {% endfor %}

  {# ── Intervalo de atualização ─────────────────────────────────────── #}
  <div class="card" style="padding:var(--space-6)">
    <h2 style="font-size:var(--text-base);font-weight:600;margin-bottom:var(--space-1)">Intervalo de atualização de dados</h2>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-6);max-width:60ch">
      Define a frequência mínima de coleta dos seus feeds. Deixe em <strong>Padrão do sistema</strong>
      para usar o intervalo global (5 minutos). Intervalos maiores reduzem o volume de dados coletados.
    </p>

    <form method="post" action="{{ path('account_settings') }}">
      <input type="hidden" name="_token" value="{{ csrf_token('account_settings') }}">

      <div style="margin-bottom:var(--space-6)">
        <label for="refresh_interval" style="display:block;font-size:var(--text-sm);font-weight:500;margin-bottom:var(--space-2)">Intervalo de coleta</label>

        <select id="refresh_interval" name="refresh_interval"
                style="width:100%;max-width:280px;padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);color:var(--color-text);font-size:var(--text-sm);appearance:none;cursor:pointer"
                {% if errors.refresh_interval is defined %}style="border-color:var(--color-error)"{% endif %}>

          <option value="" {{ partner.refreshIntervalMinutes is null ? 'selected' : '' }}>
            Padrão do sistema (5 min)
          </option>

          {% for option in intervalOptions %}
            <option value="{{ option }}" {{ partner.refreshIntervalMinutes == option ? 'selected' : '' }}>
              {% if option < 60 %}
                A cada {{ option }} minuto{{ option > 1 ? 's' : '' }}
              {% else %}
                A cada 1 hora
              {% endif %}
            </option>
          {% endfor %}
        </select>

        {% if errors.refresh_interval is defined %}
          <p style="font-size:var(--text-xs);color:var(--color-error);margin-top:var(--space-1)">{{ errors.refresh_interval }}</p>
        {% endif %}

        <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-2)">
          {% if partner.refreshIntervalMinutes is null %}
            Usando o padrão do sistema. Nenhum intervalo personalizado configurado.
          {% else %}
            Intervalo personalizado ativo: a cada <strong>{{ partner.refreshIntervalMinutes }} min</strong>.
          {% endif %}
        </p>
      </div>

      <button type="submit" class="btn btn-primary">Salvar configurações</button>
    </form>
  </div>

  {# ── Atalhos úteis ────────────────────────────────────────────────── #}
  <div style="margin-top:var(--space-6);display:flex;gap:var(--space-3);flex-wrap:wrap">
    <a href="{{ path('account_link_index') }}" class="btn btn-ghost btn-sm">← Meus Links</a>
    <a href="{{ path('account_logs') }}" class="btn btn-ghost btn-sm">Ver logs de erro →</a>
  </div>

</div>
{% endblock %}
