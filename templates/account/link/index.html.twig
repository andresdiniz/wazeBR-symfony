{% extends 'base.html.twig' %}

{% block title %}Meus Links — {{ partner.name }}{% endblock %}

{% block content %}
<div style="max-width:var(--content-wide)">

  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--space-4);margin-bottom:var(--space-8)">
    <div>
      <h1 class="page-title" style="margin-bottom:var(--space-1)">Links monitorados</h1>
      <p style="font-size:var(--text-sm);color:var(--color-text-muted)">{{ partner.name }}</p>
    </div>
    <a href="{{ path('account_link_new') }}" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:var(--space-2)"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Novo link
    </a>
  </div>

  {% for flash in app.flashes('success') %}
    <div style="background:oklch(from var(--color-success) l c h / .1);border:1px solid oklch(from var(--color-success) l c h / .25);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-success)">
      {{ flash }}
    </div>
  {% endfor %}
  {% for flash in app.flashes('error') %}
    <div style="background:oklch(from var(--color-error) l c h / .1);border:1px solid oklch(from var(--color-error) l c h / .25);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);font-size:var(--text-sm);color:var(--color-error)">
      {{ flash }}
    </div>
  {% endfor %}

  {% if grouped is empty %}
    <div style="text-align:center;padding:var(--space-20) var(--space-8);color:var(--color-text-muted)">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto var(--space-4);color:var(--color-text-faint)"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <p style="font-size:var(--text-base);font-weight:500;color:var(--color-text);margin-bottom:var(--space-2)">Nenhum link cadastrado</p>
      <p style="margin-bottom:var(--space-6);max-width:36ch;margin-inline:auto">Adicione os feeds do Waze, TVT, CEMADEN ou câmeras para começar o monitoramento.</p>
      <div style="display:flex;gap:var(--space-3);justify-content:center;flex-wrap:wrap">
        {% for type in types %}
          <a href="{{ path('account_link_new', {type: type.value}) }}" class="btn btn-ghost btn-sm">+ {{ type.label() }}</a>
        {% endfor %}
      </div>
    </div>

  {% else %}

    {# Atalhos rápidos para tipos sem nenhum link ainda #}
    {% set missingTypes = [] %}
    {% for g in allGrouped %}
      {% if g.links|length == 0 %}
        {% set missingTypes = missingTypes|merge([g.type]) %}
      {% endif %}
    {% endfor %}
    {% if missingTypes|length > 0 %}
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-6)">
        <span style="font-size:var(--text-xs);color:var(--color-text-muted);align-self:center">Adicionar:</span>
        {% for type in missingTypes %}
          <a href="{{ path('account_link_new', {type: type.value}) }}" class="btn btn-ghost btn-sm">+ {{ type.label() }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% for g in grouped %}
      <div style="margin-bottom:var(--space-8)">
        <h2 style="font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--color-text-muted);margin-bottom:var(--space-3);display:flex;align-items:center;gap:var(--space-2)">
          {{ g.type.label() }}
          <span style="background:var(--color-surface-offset);border-radius:var(--radius-full);padding:1px 8px;font-size:var(--text-xs);">{{ g.links|length }}</span>
        </h2>

        <div class="card" style="overflow:hidden;padding:0">
          <table style="width:100%;border-collapse:collapse">
            <thead>
              <tr style="background:var(--color-surface-offset);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--color-text-muted)">
                <th style="padding:var(--space-3) var(--space-4);text-align:left">Rótulo / URL</th>
                <th style="padding:var(--space-3) var(--space-4);text-align:center">Formato</th>
                <th style="padding:var(--space-3) var(--space-4);text-align:center">Status</th>
                <th style="padding:var(--space-3) var(--space-4);text-align:center">Última coleta</th>
                <th style="padding:var(--space-3) var(--space-4);text-align:right">Ações</th>
              </tr>
            </thead>
            <tbody>
              {% for link in g.links %}
                <tr style="border-top:1px solid var(--color-divider);font-size:var(--text-sm){% if not link.isActive() %};opacity:.55{% endif %}">

                  <td style="padding:var(--space-3) var(--space-4);max-width:340px">
                    {% if link.label %}
                      <span style="font-weight:500;display:block">{{ link.label }}</span>
                    {% endif %}
                    <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                       style="color:var(--color-primary);font-size:var(--text-xs);word-break:break-all;display:block"
                       title="{{ link.url }}">{{ link.url|length > 70 ? link.url|slice(0,70) ~ '…' : link.url }}</a>
                  </td>

                  <td style="padding:var(--space-3) var(--space-4);text-align:center;white-space:nowrap">
                    <span style="background:var(--color-surface-offset);border-radius:var(--radius-sm);padding:2px 8px;font-size:var(--text-xs)">
                      {% if link.feedFormat == 1 %}JSON{% elseif link.feedFormat == 2 %}TVT{% else %}{{ link.feedFormat }}{% endif %}
                    </span>
                  </td>

                  <td style="padding:var(--space-3) var(--space-4);text-align:center">
                    {% if link.isActive() %}
                      <span style="color:var(--color-success);font-size:var(--text-xs);font-weight:600">● Ativo</span>
                    {% else %}
                      <span style="color:var(--color-text-faint);font-size:var(--text-xs)">○ Inativo</span>
                    {% endif %}
                  </td>

                  <td style="padding:var(--space-3) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-muted)">
                    {{ link.lastCollectedAt ? link.lastCollectedAt|date('d/m/Y H:i') : '—' }}
                  </td>

                  <td style="padding:var(--space-3) var(--space-4);text-align:right;white-space:nowrap">
                    <a href="{{ path('account_link_edit', {id: link.id}) }}"
                       class="btn btn-ghost btn-sm" style="font-size:var(--text-xs)">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      Editar
                    </a>

                    <form method="post" action="{{ path('account_link_toggle', {id: link.id}) }}" style="display:inline">
                      <input type="hidden" name="_token" value="{{ csrf_token('toggle_link_' ~ link.id) }}">
                      <button type="submit" class="btn btn-ghost btn-sm" style="font-size:var(--text-xs)">
                        {{ link.isActive() ? 'Pausar' : 'Ativar' }}
                      </button>
                    </form>

                    <form method="post" action="{{ path('account_link_delete', {id: link.id}) }}" style="display:inline"
                          onsubmit="return confirm('Remover este link?')">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete_link_' ~ link.id) }}">
                      <button type="submit" class="btn btn-ghost btn-sm" style="font-size:var(--text-xs);color:var(--color-error)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                      </button>
                    </form>
                  </td>

                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endfor %}

  {% endif %}
</div>
{% endblock %}
